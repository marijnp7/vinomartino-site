# Astro dev-preview environment
# Copy to .env and fill in values

# ── Directus CMS ──────────────────────────────────────
# When set, content is loaded from Directus instead of local fallback
# DIRECTUS_URL=http://directus:8055
# DIRECTUS_TOKEN=

# Directus database (used by docker-compose.directus.yml)
# DIRECTUS_DB_NAME=directus
# DIRECTUS_DB_USER=directus
# DIRECTUS_DB_PASSWORD=directus_secret
# DIRECTUS_SECRET=change-me-to-a-random-string
# DIRECTUS_ADMIN_EMAIL=admin@reisplatform.nl
# DIRECTUS_ADMIN_PASSWORD=admin_secret

# ��─ Paperclip ─────────────────────────────────────────
PAPERCLIP_API_URL=http://paperclip:3100

# ── Analytics (LAT-1755) ──────────────────────────────
# Cookieless analytics (Plausible-compatible). Leave PUBLIC_ANALYTICS_DOMAIN empty to
# fully disable (no script is emitted) — keep it empty on preview/dev.
# PUBLIC_ANALYTICS_DOMAIN=vinomartino.com
# Optional: override the script URL for self-hosted Plausible or a compatible alternative.
# PUBLIC_ANALYTICS_SRC=https://plausible.io/js/script.outbound-links.tagged-events.js
# Optional kill-switch even when a domain is set: "false" disables.
# PUBLIC_ANALYTICS_ENABLED=true

# ── Deploy ──────────────────────────────────────────���─
# DOMAIN=reisplatform.nl
# ACME_EMAIL=admin@reisplatform.nl
# SITE_URL=https://preview.reisplatform.nl
