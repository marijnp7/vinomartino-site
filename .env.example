# Astro dev-preview environment
# Copy to .env and fill in values

# Directus CMS connection (multi-brand)
# When set, brands are loaded from Directus instead of static data
# DIRECTUS_URL=http://directus:8055
# DIRECTUS_TOKEN=

# Paperclip API (used by cos-bridge; must match Docker service name)
PAPERCLIP_API_URL=http://paperclip:3100

# Public site URL for Traefik
# SITE_URL=https://preview.reisplatform.nl
