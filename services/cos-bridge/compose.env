# Wordt door .github/workflows/deploy-cos.yml gersynct naar
# /opt/paperclip-cos/.env — dus BRON hier, artefact daar. Handmatige edits op
# de VPS verdwijnen bij de eerstvolgende bridge-deploy.
#
# LAT-2811. Zonder COMPOSE_FILE laadt een kale `docker compose` in
# /opt/paperclip-cos alleen docker-compose.cos.yml, en zijn de services uit de
# overlays orphans. Met COMPOSE_FILE laadt hij alle 8 services die het label
# com.docker.compose.project=paperclip-cos dragen, en is `--remove-orphans`
# ongevaarlijk in plaats van fataal.
#
# Deze file wordt door compose alleen gebruikt voor variabele-interpolatie en
# compose-eigen instellingen; hij injecteert niets in containers (dat doet
# env_file:). Geen van de vier compose-files gebruikt ${VAR}-interpolatie, dus
# het toevoegen van deze file verandert geen enkele container-env.
#
# Uitbreiden? Voeg een nieuwe overlay hier toe in dezelfde commit waarin je hem
# aanmaakt, anders is zijn container per definitie een orphan.

COMPOSE_PROJECT_NAME=paperclip-cos
COMPOSE_FILE=docker-compose.cos.yml:docker-compose.monitoring.yml:lat920/docker-compose.publish-dispatcher.yml:docker-compose.vinomartino-nl-redirect.yml
