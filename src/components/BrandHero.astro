---
import type { Brand } from '../lib/brands';

interface Props {
  brand: Brand;
}

const { brand } = Astro.props;
---

<section class="hero" aria-label="Hero">
  <div class="hero-bg">
    <img
      src="https://images.unsplash.com/photo-1558618666-fcd25c85f82e?w=1920&h=1080&fit=crop&q=85"
      alt=""
      class="hero-bg-img"
      loading="eager"
      fetchpriority="high"
    />
    <div class="hero-overlay"></div>
  </div>

  <div class="hero-inner container">
    <div class="hero-eyebrow">
      <span class="hero-label">Wijnreizen &amp; verhalen</span>
    </div>
    <h1>
      De wereld ontdekken,<br />
      <em>glas voor glas</em>
    </h1>
    <p class="hero-subtitle">
      Persoonlijke wijnreisverhalen, proefnotities en routes
      door de mooiste wijnstreken ter wereld.
    </p>
    <div class="hero-cta">
      <a href="#artikelen" class="btn btn-primary">Lees artikelen</a>
      <a href="#bestemmingen" class="btn btn-ghost-light">Bekijk bestemmingen</a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="hero-scroll" aria-hidden="true">
    <div class="hero-scroll-line"></div>
  </div>
</section>

<section class="featured-strip">
  <div class="container featured-inner">
    <div class="featured-item">
      <span class="featured-num">7+</span>
      <span class="featured-label">Wijnstreken</span>
    </div>
    <div class="featured-divider" aria-hidden="true"></div>
    <div class="featured-item">
      <span class="featured-num">6+</span>
      <span class="featured-label">Artikelen</span>
    </div>
    <div class="featured-divider" aria-hidden="true"></div>
    <div class="featured-item">
      <span class="featured-num">4</span>
      <span class="featured-label">Reisroutes</span>
    </div>
    <div class="featured-divider" aria-hidden="true"></div>
    <div class="featured-item">
      <span class="featured-num">100%</span>
      <span class="featured-label">Eigen ervaring</span>
    </div>
  </div>
</section>

<style>
  /* ── Hero ─────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 88vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(108%) brightness(98%);
    transition: transform 8s linear;
    will-change: transform;
  }
  .hero:hover .hero-bg-img {
    transform: scale(1.025);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        105deg,
        rgba(13, 10, 7, 0.72) 0%,
        rgba(13, 10, 7, 0.48) 55%,
        rgba(13, 10, 7, 0.22) 100%
      );
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    padding: 8rem 0 7rem;
    max-width: 56rem;
  }

  /* Eyebrow label */
  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.75rem;
  }
  .hero-eyebrow::before {
    content: '';
    display: block;
    width: 2rem;
    height: 1px;
    background: var(--rule);
    opacity: 0.8;
  }

  .hero-label {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--rule);
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 2rem + 3.5vw, 4.5rem);
    font-weight: 400;
    line-height: 1.06;
    color: #FBFAF7;
    letter-spacing: -0.025em;
    margin-bottom: 1.75rem;
  }

  h1 em {
    color: var(--rule);
    font-style: italic;
  }

  .hero-subtitle {
    font-family: var(--font-body);
    font-size: 1.1875rem;
    color: rgba(251, 250, 247, 0.78);
    max-width: 32rem;
    line-height: 1.65;
    margin-bottom: 2.75rem;
    font-weight: 300;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Scroll indicator */
  .hero-scroll {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .hero-scroll-line {
    width: 1px;
    height: 3rem;
    background: linear-gradient(to bottom, transparent, rgba(196, 164, 85, 0.7));
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.4; transform: scaleY(1); transform-origin: top; }
    50% { opacity: 1; transform: scaleY(1.1); transform-origin: top; }
  }

  /* ── Featured strip ──────────────────────────────── */
  .featured-strip {
    background: var(--deep-night);
    padding: 2.25rem 0;
    border-top: 1px solid rgba(196, 164, 85, 0.15);
  }

  .featured-inner {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 3.5rem;
  }

  .featured-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.375rem;
  }

  .featured-num {
    font-family: var(--font-display);
    font-size: 1.875rem;
    font-weight: 400;
    font-style: italic;
    color: var(--rule);
    line-height: 1;
  }

  .featured-label {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: rgba(138, 122, 108, 0.8);
  }

  .featured-divider {
    width: 1px;
    height: 2.75rem;
    background: linear-gradient(to bottom, transparent, rgba(196, 164, 85, 0.25), transparent);
  }

  /* ── Responsive ──────────────────────────────────── */
  @media (max-width: 900px) {
    .hero { min-height: 72vh; }
    .hero-inner { padding: 6rem 0 5rem; }
    .hero-scroll { display: none; }
  }

  @media (max-width: 640px) {
    .hero { min-height: 65vh; }
    .hero-inner { padding: 5rem 0 4rem; }
    h1 { font-size: clamp(2.25rem, 1.8rem + 3vw, 3rem); }
    .hero-subtitle { font-size: 1rem; }
    .featured-inner { gap: 1.5rem; }
    .featured-num { font-size: 1.5rem; }
  }

  @media (max-width: 420px) {
    .featured-inner { flex-wrap: wrap; gap: 1.25rem 2rem; }
    .featured-divider { display: none; }
  }
</style>
