---
import type { Brand } from '../lib/brands';

interface Props {
  brand: Brand;
}

const { brand } = Astro.props;
---

<section class="hero" aria-label="Hero">
  <div class="hero-bg">
    <img
      src="https://images.unsplash.com/photo-1506377247377-2a5b3b417ebb?w=1920&h=1080&fit=crop&q=85"
      alt=""
      class="hero-bg-img"
      loading="eager"
      fetchpriority="high"
    />
    <div class="hero-overlay"></div>
  </div>

  <div class="hero-content container">
    <div class="hero-eyebrow">Het startpunt van jouw wijnreis</div>
    <h1>
      Hand-picked wijnstreken,<br /><em>eerlijk getest</em>
    </h1>
    <p class="hero-subtitle">
      Met onze tips ontdek je per streek de wijnhuizen waar de wijnmaker zelf inschenkt,
      de routes die de bussen nooit halen, en de proeverijen die de moeite waard zijn.
    </p>
    <div class="hero-cta">
      <a href="#streken" class="btn-hero-primary">Bekijk alle streken →</a>
      <a href="#routes" class="btn-hero-outline">De ultieme routes</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 540px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(31, 26, 22, 0.85) 0%,
      rgba(31, 26, 22, 0.2) 60%,
      rgba(31, 26, 22, 0.4) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding: 64px 0;
    color: var(--paper);
    width: 100%;
  }

  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 16px;
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 2rem + 3.5vw, 4.5rem);
    font-weight: 500;
    line-height: 0.95;
    letter-spacing: -0.02em;
    margin: 0 0 20px;
    max-width: 15ch;
    color: var(--paper);
  }

  h1 em {
    font-style: italic;
    color: var(--paper);
  }

  .hero-subtitle {
    font-family: var(--font-body);
    font-size: 1.1875rem;
    line-height: 1.5;
    color: rgba(250, 245, 233, 0.9);
    max-width: 50ch;
    margin: 0 0 28px;
  }

  .hero-cta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn-hero-primary {
    background: var(--paper);
    color: var(--ink);
    padding: 14px 24px;
    text-decoration: none;
    font-family: var(--font-ui);
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: var(--radius-sm);
    transition: background var(--duration-fast) var(--ease-out);
  }

  .btn-hero-primary:hover {
    background: var(--paperDeep);
    color: var(--ink);
  }

  .btn-hero-outline {
    background: transparent;
    color: var(--paper);
    padding: 14px 24px;
    text-decoration: none;
    font-family: var(--font-ui);
    font-size: 0.875rem;
    font-weight: 600;
    border: 1px solid var(--paper);
    border-radius: var(--radius-sm);
    transition: background var(--duration-fast) var(--ease-out);
  }

  .btn-hero-outline:hover {
    background: rgba(250, 245, 233, 0.12);
    color: var(--paper);
  }

  @media (max-width: 768px) {
    .hero { min-height: 440px; }
    .hero-content { padding: 48px 0; }
    h1 { font-size: clamp(2.25rem, 1.8rem + 3vw, 3rem); }
    .hero-subtitle { font-size: 1rem; }
  }

  @media (max-width: 480px) {
    .hero { min-height: 380px; }
    .hero-cta { flex-direction: column; align-items: flex-start; }
  }
</style>
