---
import SmartImg from '../SmartImg.astro';

interface Props {
  slug: string;
}

const { slug } = Astro.props;

interface RegionData {
  name: string;
  country: string;
  subTitle: string;
  heroImage: string;
  stats: { label: string; value: string }[];
  dropCapLetter: string;
  intro: string;
  subRegions: { id: number; name: string; badge: string; desc: string; img: string }[];
  subRegionsHeadline: string;
  grapes: { id: number; name: string; desc: string; wines: string[] }[];
  routes: { id: number; title: string; badge: string; mode: string; desc: string; img: string }[];
  wineries: { id: number; name: string; village: string; type: string }[];
  practical: { label: string; items: string[] }[];
}

const regions: Record<string, RegionData> = {
  piemonte: {
    name: 'Piemonte',
    country: 'Italië',
    subTitle: 'Noordwest',
    heroImage: '',
    stats: [
      { label: 'Beste tijd', value: 'Apr–mei · Sep–okt' },
      { label: 'Vliegen op', value: 'Turijn, Milaan' },
      { label: 'Druiven', value: 'Nebbiolo, Barbera, Dolcetto' },
      { label: 'Wijnstijl', value: 'Tannineus · Krachtig · Complex' },
    ],
    dropCapLetter: 'P',
    intro: 'iemonte — de voetheuvels van de Alpen — is het koninkrijk van Nebbiolo. Barolo en Barbaresco zijn hier geboren: tannineuze, veelgelaagde wijnen die geduld vragen maar oneindig belonen. Buiten de wijn: truffels, hazelnoten en een keuken zo sterk dat de streek om de tafel is gebouwd.',
    subRegionsHeadline: 'De vier gezichten van Piemonte',
    subRegions: [
      { id: 1, name: 'Langhe', badge: 'Barolo & Barbaresco', desc: 'Het hart van de Nebbiolo — steile heuvels, oude kelders en de meest bewonderde rode wijnen van Italië.', img: '' },
      { id: 2, name: 'Monferrato', badge: 'Barbera & Grignolino', desc: 'Zachter landschap, vriendelijkere wijnen. Barbaresco ligt hier in de schaduw van Barolo — ten onrechte.', img: '' },
      { id: 3, name: 'Asti', badge: 'Moscato & Dolcetto', desc: "Muscetkruiden en bruisend fruit. Moscato d'Asti is het tegenwicht: licht, aromatisch en misleidend complex.", img: '' },
      { id: 4, name: 'Alto Piemonte', badge: 'Gattinara & Ghemme', desc: 'Bijna vergeten, maar terug van weggeweest. Vulkanische bodems en verouderde Nebbiolo-klonen produceren wijnen die velen verrassen.', img: '' },
    ],
    grapes: [
      { id: 1, name: 'Nebbiolo', desc: 'De koningin van het noorden. Hoge tannines, hoge zuurgraad — transformeert na jaren in iets transcendents.', wines: ['Barolo', 'Barbaresco', 'Gattinara'] },
      { id: 2, name: 'Barbera', desc: 'De alledaagse held. Laag tannine, levendige zuurgraad, donker fruit. Vroeg drinkbaar, brede productie.', wines: ["Barbera d'Asti", "Barbera d'Alba"] },
      { id: 3, name: 'Dolcetto', desc: 'Bitterzoet fruit met een bitteramandel finish. Geen lange houdbaarheid maar veel karakter op jonge leeftijd.', wines: ["Dolcetto d'Alba", 'Dolcetto di Dogliani'] },
      { id: 4, name: 'Moscato', desc: 'Aromatisch, muskusachtig, semi-sprankelend in zijn meest bekende vorm. Licht en sierlijk.', wines: ["Moscato d'Asti", 'Asti Spumante'] },
    ],
    routes: [
      { id: 1, title: 'Langhe 4-daagse', badge: '4 dagen', mode: 'Auto', desc: 'Barolo, Barbaresco en de beste trattoria van de Langhe. Een klassieke route voor de wijnliefhebber die diep wil gaan.', img: '' },
      { id: 2, title: 'Barolo & Barbaresco circuit', badge: '3 dagen', mode: 'Fiets', desc: 'Per fiets door de heuvels — moeizaam maar onvergetelijk. Overnacht in Barolo, bezoek Castiglione Falletto.', img: '' },
      { id: 3, title: 'Buon Gusto route', badge: '5 dagen', mode: 'Trein', desc: 'Wijn én eten: van Asti via Alba naar Cuneo. Wittruffel in de herfst, hazelnoten het hele jaar.', img: '' },
    ],
    wineries: [
      { id: 1, name: 'Gaja', village: 'Barbaresco', type: 'Iconic' },
      { id: 2, name: 'Giacomo Conterno', village: "Serralunga d'Alba", type: 'Traditioneel' },
      { id: 3, name: 'Cordero di Montezemolo', village: 'La Morra', type: 'Klassiek' },
      { id: 4, name: 'Bruno Giacosa', village: 'Neive', type: 'Legendarisch' },
      { id: 5, name: 'Vietti', village: 'Castiglione Falletto', type: 'Modern-klassiek' },
      { id: 6, name: 'Roberto Voerzio', village: 'La Morra', type: 'Boutique' },
    ],
    practical: [
      { label: 'Beste reistijd', items: ['April – mei (voor de wijn)', 'September – oktober (oogst)', 'Vermijd augustus (drukte)'] },
      { label: 'Vliegvelden', items: ['Turijn Caselle (TRN)', 'Milaan Malpensa (MXP)', '±90 min naar Alba'] },
      { label: 'Praktisch', items: ['Reserveer wijnhuizen vooraf', 'Huurauto aanbevolen', 'Italiaans is een pluspunt'] },
    ],
  },
};

const defaultData: RegionData = {
  name: slug ? slug.charAt(0).toUpperCase() + slug.slice(1) : 'Wijnstreek',
  country: 'Europa',
  subTitle: 'Europa',
  heroImage: '',
  stats: [
    { label: 'Beste tijd', value: 'Lente & herfst' },
    { label: 'Wijnstijl', value: 'Verschilt per deelregio' },
  ],
  dropCapLetter: 'D',
  intro: 'eze streek wordt binnenkort verder uitgewerkt met uitgebreide gidsen, routes en wijnhuis-portretten.',
  subRegionsHeadline: 'Deelregio\'s',
  subRegions: [],
  grapes: [],
  routes: [],
  wineries: [],
  practical: [],
};

const data: RegionData = regions[slug] ?? defaultData;
---

<!-- ── HERO ──────────────────────────────────────────── -->
<section class="region-hero">
  <div class="region-hero-bg">
    <SmartImg src={data.heroImage} alt={data.name} theme="region" class="region-hero-img" loading="eager" />
  </div>
  <div class="region-hero-overlay"></div>
  <div class="region-hero-inner">
    <div class="region-hero-title-col">
      <div class="region-hero-eyebrow">Streek · {data.country} · {data.subTitle}</div>
      <h1 class="region-hero-h1">{data.name}</h1>
    </div>
    <div class="region-hero-stats">
      {data.stats.map(stat => (
        <div class="region-stat">
          <span class="region-stat-label">{stat.label}</span>
          <span class="region-stat-value">{stat.value}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ── INTRO ─────────────────────────────────────────── -->
<section class="region-intro">
  <div class="region-intro-inner">
    <div class="region-intro-label">§ De streek in het kort</div>
    <p class="region-intro-body">
      <span class="region-drop-cap">{data.dropCapLetter}</span>{data.intro}
    </p>
  </div>
</section>

<!-- ── SUB-REGIONS ───────────────────────────────────── -->
{data.subRegions.length > 0 && (
  <section class="region-subregions">
    <div class="container">
      <div class="section-header">
        <div class="section-label">Deelregio's</div>
        <h2>{data.subRegionsHeadline}</h2>
      </div>
      <div class="subregions-grid">
        {data.subRegions.map(sr => (
          <a href="#" class="subregion-card">
            <div class="subregion-img-wrap">
              <SmartImg src={sr.img} alt={sr.name} theme="vineyard" class="subregion-img" />
            </div>
            <div class="subregion-body">
              <div class="subregion-badge">{sr.badge}</div>
              <div class="subregion-name">{sr.name}</div>
              <div class="subregion-desc">{sr.desc}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<!-- ── GRAPE PROFILES ────────────────────────────────── -->
{data.grapes.length > 0 && (
  <section class="region-grapes">
    <div class="container">
      <div class="section-header">
        <div class="section-label">Druiven</div>
        <h2>De karakters van {data.name}</h2>
      </div>
      <div class="grapes-grid">
        {data.grapes.map((grape, i) => (
          <div class:list={['grape-cell', i > 0 && 'grape-cell--border-left']}>
            <div class="grape-index">Druif · {String(i + 1).padStart(2, '0')}</div>
            <div class="grape-name">{grape.name}</div>
            <p class="grape-desc">{grape.desc}</p>
            <div class="grape-wines">{grape.wines.join(' · ')}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<!-- ── ROUTES ────────────────────────────────────────── -->
{data.routes.length > 0 && (
  <section class="region-routes">
    <div class="container">
      <div class="section-header">
        <div class="section-label">Routes</div>
        <h2>Reis door {data.name}</h2>
        <p class="section-desc">Hand-picked reisroutes — samengesteld door Martin & Sophie na meerdere bezoeken.</p>
      </div>
      <div class="routes-grid">
        {data.routes.map(route => (
          <a href="/routes/" class="route-card">
            <div class="route-img-wrap">
              <SmartImg src={route.img} alt={route.title} theme="vineyard" class="route-img" />
              <div class="route-badges">
                <span class="route-badge">{route.badge}</span>
                <span class="route-badge route-badge--mode">{route.mode}</span>
              </div>
            </div>
            <div class="route-body">
              <div class="route-title">{route.title}</div>
              <p class="route-desc">{route.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<!-- ── WINERIES ──────────────────────────────────────── -->
{data.wineries.length > 0 && (
  <section class="region-wineries">
    <div class="container">
      <div class="section-header">
        <div class="section-label">Wijnhuizen</div>
        <h2>Bezoek waardige in {data.name}</h2>
      </div>
      <div class="wineries-grid">
        {data.wineries.map((w, i) => (
          <a href="/wijnhuizen/" class:list={['winery-cell', i % 3 !== 0 && 'winery-cell--border-left', i >= 3 && 'winery-cell--border-top']}>
            <div class="winery-type">{w.type}</div>
            <div class="winery-name">{w.name}</div>
            <div class="winery-village">{w.village}</div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<!-- ── PRACTICAL ─────────────────────────────────────── -->
{data.practical.length > 0 && (
  <section class="region-practical">
    <div class="container">
      <div class="section-header region-practical-header">
        <div class="section-label section-label--light">Reisinformatie</div>
        <h2 class="region-practical-h2">Praktisch voor {data.name}</h2>
      </div>
      <div class="practical-grid">
        {data.practical.map(col => (
          <div class="practical-col">
            <div class="practical-label">{col.label}</div>
            <ul class="practical-list">
              {col.items.map(item => (
                <li class="practical-item">{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  /* ── Hero ──────────────────────────────────────────── */
  .region-hero {
    position: relative;
    min-height: 520px;
    background: var(--ink);
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .region-hero-bg {
    position: absolute;
    inset: 0;
    opacity: 0.55;
  }

  .region-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .region-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(31, 26, 22, 0.85) 0%, rgba(31, 26, 22, 0.2) 60%);
  }

  .region-hero-inner {
    position: relative;
    z-index: 1;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-16) var(--gutter);
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: end;
    gap: var(--space-16);
  }

  .region-hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--gold);
    margin-bottom: var(--space-4);
  }

  .region-hero-h1 {
    font-family: var(--font-display);
    font-size: clamp(4rem, 7.5vw, 7.5rem);
    font-weight: 300;
    font-style: italic;
    color: var(--paper);
    line-height: 0.9;
    letter-spacing: -0.03em;
    margin: 0;
  }

  .region-hero-stats {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding-bottom: var(--space-2);
  }

  .region-stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .region-stat-label {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--gold);
    opacity: 0.7;
  }

  .region-stat-value {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--paper);
  }

  /* ── Intro ─────────────────────────────────────────── */
  .region-intro {
    padding: var(--space-16) 0;
  }

  .region-intro-inner {
    max-width: var(--max-width-narrow);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  .region-intro-label {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--rust);
    margin-bottom: var(--space-6);
  }

  .region-intro-body {
    font-family: var(--font-display);
    font-size: 1.375rem;
    line-height: 1.5;
    color: var(--ink);
    font-style: italic;
    position: relative;
  }

  .region-drop-cap {
    float: left;
    font-family: var(--font-display);
    font-size: 6rem;
    font-style: normal;
    font-weight: 400;
    line-height: 0.85;
    padding-right: 0.5rem;
    color: var(--burgundy);
    margin-top: 0.25rem;
  }

  /* ── Sub-regions ───────────────────────────────────── */
  .region-subregions {
    background: var(--paperDeep);
    padding: var(--space-16) 0;
  }

  .subregions-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
  }

  .subregion-card {
    display: block;
    text-decoration: none;
    background: var(--paper);
    border: 1px solid var(--rule);
    overflow: hidden;
    transition: transform var(--duration-base) var(--ease-out),
                box-shadow var(--duration-base) var(--ease-out);
  }

  .subregion-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card-hover);
  }

  .subregion-img-wrap {
    aspect-ratio: 4 / 5;
    overflow: hidden;
  }

  .subregion-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-image) var(--ease-out);
  }

  .subregion-card:hover .subregion-img {
    transform: scale(1.03);
  }

  .subregion-body {
    padding: var(--space-4) var(--space-5) var(--space-5);
  }

  .subregion-badge {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--rust);
    margin-bottom: var(--space-2);
  }

  .subregion-name {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-style: italic;
    color: var(--ink);
    margin-bottom: var(--space-2);
  }

  .subregion-desc {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    color: var(--inkSoft);
    line-height: 1.55;
  }

  /* ── Grapes ────────────────────────────────────────── */
  .region-grapes {
    background: var(--paper);
    padding: var(--space-16) 0;
  }

  .grapes-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--rule);
  }

  .grape-cell {
    padding: var(--space-8) var(--space-7);
  }

  .grape-cell--border-left {
    border-left: 1px solid var(--rule);
  }

  .grape-index {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--rust);
    margin-bottom: var(--space-3);
  }

  .grape-name {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-style: italic;
    color: var(--burgundy);
    margin-bottom: var(--space-2);
    line-height: 1.1;
  }

  .grape-desc {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    color: var(--inkSoft);
    line-height: 1.6;
    margin-bottom: var(--space-4);
  }

  .grape-wines {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    color: var(--rule);
    letter-spacing: 0.05em;
  }

  /* ── Routes ────────────────────────────────────────── */
  .region-routes {
    background: var(--paperDeep);
    padding: var(--space-16) 0;
  }

  .routes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .route-card {
    display: block;
    text-decoration: none;
    background: var(--paper);
    border: 1px solid var(--rule);
    overflow: hidden;
    transition: transform var(--duration-base) var(--ease-out),
                box-shadow var(--duration-base) var(--ease-out);
  }

  .route-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card-hover);
  }

  .route-img-wrap {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .route-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-image) var(--ease-out);
  }

  .route-card:hover .route-img {
    transform: scale(1.03);
  }

  .route-badges {
    position: absolute;
    bottom: var(--space-3);
    left: var(--space-3);
    display: flex;
    gap: var(--space-2);
  }

  .route-badge {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    background: var(--burgundy);
    color: var(--paper);
    padding: 3px 8px;
  }

  .route-badge--mode {
    background: var(--vine);
  }

  .route-body {
    padding: var(--space-5) var(--space-5) var(--space-6);
  }

  .route-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-style: italic;
    color: var(--ink);
    margin-bottom: var(--space-2);
  }

  .route-desc {
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    color: var(--inkSoft);
    line-height: 1.6;
    margin: 0;
  }

  /* ── Wineries ──────────────────────────────────────── */
  .region-wineries {
    background: var(--paper);
    padding: var(--space-16) 0;
  }

  .wineries-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--rule);
  }

  .winery-cell {
    padding: var(--space-8) var(--space-7);
    text-decoration: none;
    transition: background var(--duration-fast) var(--ease-out);
  }

  .winery-cell:hover {
    background: var(--paperDeep);
  }

  .winery-cell--border-left {
    border-left: 1px solid var(--rule);
  }

  .winery-cell--border-top {
    border-top: 1px solid var(--rule);
  }

  .winery-type {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--rust);
    margin-bottom: var(--space-2);
  }

  .winery-name {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-style: italic;
    color: var(--ink);
    margin-bottom: var(--space-1);
  }

  .winery-village {
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    color: var(--inkSoft);
  }

  /* ── Practical ─────────────────────────────────────── */
  .region-practical {
    background: var(--burgundyDeep);
    padding: var(--space-16) 0;
  }

  .region-practical-header {
    margin-bottom: var(--space-12);
  }

  .region-practical-h2 {
    color: var(--paper) !important;
  }

  .section-label--light {
    color: var(--gold) !important;
  }

  .practical-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-12);
  }

  .practical-label {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--gold);
    margin-bottom: var(--space-4);
  }

  .practical-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .practical-item {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--paperDeep);
    line-height: 1.5;
    padding-left: var(--space-4);
    position: relative;
  }

  .practical-item::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--rule);
    opacity: 0.6;
  }

  /* ── Responsive ────────────────────────────────────── */
  @media (max-width: 1024px) {
    .region-hero-inner {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .region-hero-stats {
      flex-direction: row;
      flex-wrap: wrap;
      gap: var(--space-6);
    }

    .subregions-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .grapes-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .grape-cell:nth-child(3) {
      border-top: 1px solid var(--rule);
    }

    .grape-cell:nth-child(4) {
