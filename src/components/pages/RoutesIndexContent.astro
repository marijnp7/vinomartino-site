---
interface RouteCard {
  title: string;
  country: string;
  region: string;
  days: number;
  transport: string;
  style: string;
  href: string;
  image?: string;
}

interface Props {
  routes?: RouteCard[];
}

const defaultRoutes: RouteCard[] = [
  { title: 'Drie dagen Langhe', country: 'Italië', region: 'Piemonte', days: 3, transport: 'Auto', style: 'Klassiek', href: '/routes/drie-dagen-langhe/' },
  { title: 'Mosel per trein', country: 'Duitsland', region: 'Mosel', days: 5, transport: 'Trein', style: 'Zonder auto', href: '/routes/mosel-per-trein/' },
  { title: 'Rioja oogst-ronde', country: 'Spanje', region: 'Rioja', days: 7, transport: 'Auto', style: 'Lange route', href: '/routes/rioja-oogst-ronde/' },
  { title: 'Douro stroomopwaarts', country: 'Portugal', region: 'Douro', days: 4, transport: 'Auto+Boot', style: 'Klassiek', href: '/routes/douro-stroomopwaarts/' },
  { title: 'Etna-rondrit', country: 'Italië', region: 'Sicilië', days: 3, transport: 'Auto', style: 'Vulkaan', href: '/routes/etna-rondrit/' },
  { title: 'Bourgogne van Chablis tot Beaujolais', country: 'Frankrijk', region: 'Bourgogne', days: 6, transport: 'Auto', style: 'Lange route', href: '/routes/bourgogne-van-chablis/' },
  { title: 'Roero op de fiets', country: 'Italië', region: 'Piemonte', days: 2, transport: 'Fiets', style: 'Actief', href: '/routes/roero-op-de-fiets/' },
  { title: 'Schuimwijn-tour Asti', country: 'Italië', region: 'Piemonte', days: 2, transport: 'Auto', style: 'Bubbels', href: '/routes/schuimwijn-tour-asti/' },
  { title: 'Wachau langs de Donau', country: 'Oostenrijk', region: 'Wachau', days: 3, transport: 'Fiets', style: 'Actief', href: '/routes/wachau-langs-de-donau/' },
];

const { routes = defaultRoutes } = Astro.props;
---

<!-- ── HEADER ─────────────────────────────────────────── -->
<section class="ri-header">
  <div class="container">
    <div class="ri-eyebrow">Reisroutes</div>
    <h1 class="ri-title">Onze kant-en-klare wijnroutes</h1>
    <p class="ri-subtitle">
      {routes.length} routes, allemaal zelf gereden. Met dagindeling, slaapadressen en de wijnhuizen die je écht moet bezoeken.
    </p>
  </div>
</section>

<!-- ── FILTER BAR ─────────────────────────────────────── -->
<div class="ri-filters" role="navigation" aria-label="Filters">
  <div class="container">
    <div class="ri-filter-group">
      <span class="ri-filter-label">Land</span>
      <button class="ri-filter-btn" aria-pressed="true">Alle landen</button>
    </div>
    <div class="ri-filter-group">
      <span class="ri-filter-label">Dagen</span>
      <button class="ri-filter-btn">Alle</button>
    </div>
    <div class="ri-filter-group">
      <span class="ri-filter-label">Vervoer</span>
      <button class="ri-filter-btn">Alle</button>
    </div>
    <div class="ri-filter-group">
      <span class="ri-filter-label">Stijl</span>
      <button class="ri-filter-btn">Alle</button>
    </div>
    <span class="ri-count">{routes.length} routes</span>
  </div>
</div>

<!-- ── GRID ───────────────────────────────────────────── -->
<section class="ri-grid-section">
  <div class="container">
    <div class="ri-grid">
      {routes.map((route, i) => (
        <a href={route.href} class="ri-card">
          <div class="ri-card__img-wrap">
            <div class="ri-card__img-placeholder">
              <span class="ri-card__num">§{i + 1}</span>
            </div>
            <div class="ri-card__badges">
              <span class="ri-badge ri-badge--days">{route.days}d</span>
              <span class="ri-badge ri-badge--transport">{route.transport}</span>
            </div>
          </div>
          <div class="ri-card__body">
            <div class="ri-card__region">{route.country} · {route.region}</div>
            <h3 class="ri-card__title">{route.title}</h3>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  /* ── Header ── */
  .ri-header {
    padding: 4.5rem 0 2rem;
    border-bottom: 1px solid var(--rule);
  }

  .ri-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rust);
    margin-bottom: 0.75rem;
  }

  .ri-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 1.5rem + 5vw, 4.5rem);
    font-weight: 500;
    color: var(--ink);
    line-height: 0.95;
    margin: 0;
  }

  .ri-subtitle {
    font-family: var(--font-body);
    font-size: 1.25rem;
    line-height: 1.5;
    color: var(--inkSoft);
    margin: 1.5rem 0 0;
    max-width: 56ch;
    font-style: italic;
  }

  /* ── Filters ── */
  .ri-filters {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--rule);
    background: var(--paperDeep);
    position: sticky;
    top: 0;
    z-index: 5;
  }

  .ri-filters .container {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .ri-filter-group {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .ri-filter-label {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--inkSoft);
  }

  .ri-filter-btn {
    background: var(--paper);
    border: 1px solid var(--rule);
    padding: 0.5rem 0.875rem;
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--ink);
    cursor: pointer;
    transition: border-color 0.15s;
  }
  .ri-filter-btn:hover,
  .ri-filter-btn[aria-pressed="true"] { border-color: var(--burgundy); }

  .ri-count {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--inkSoft);
  }

  /* ── Grid ── */
  .ri-grid-section { padding: 3rem 0 5rem; }

  .ri-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .ri-card {
    text-decoration: none;
    color: inherit;
    display: block;
    transition: transform 0.15s;
  }
  .ri-card:hover { transform: translateY(-2px); }

  .ri-card__img-wrap {
    aspect-ratio: 3 / 2;
    background: var(--paperShade);
    position: relative;
    overflow: hidden;
    margin-bottom: 0.75rem;
  }

  .ri-card__img-placeholder {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--paperDeep), var(--paperShade));
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    padding: 0.75rem;
  }

  .ri-card__num {
    font-family: var(--font-display);
    font-size: 3rem;
    font-style: italic;
    color: var(--inkFaint);
    opacity: 0.5;
    line-height: 1;
  }

  .ri-card__badges {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    display: flex;
    gap: 0.375rem;
  }

  .ri-badge {
    padding: 0.25rem 0.625rem;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .ri-badge--days {
    background: var(--paper);
    color: var(--ink);
  }

  .ri-badge--transport {
    background: var(--burgundy);
    color: var(--paper);
  }

  .ri-card__region {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--rust);
    margin-bottom: 0.375rem;
  }

  .ri-card__title {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 500;
    line-height: 1.2;
    margin: 0;
    color: var(--ink);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .ri-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .ri-grid { grid-template-columns: 1fr; }
    .ri-filters .container { gap: 0.75rem; }
  }
</style>
