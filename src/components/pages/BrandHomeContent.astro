---
import BrandLayout from '../../layouts/BrandLayout.astro';
import BrandHero from '../../components/BrandHero.astro';
import type { Brand } from '../../lib/brands';
import type { Article } from '../../lib/articles';

interface Props {
  brand: Brand;
  locale: string;
  articles: Article[];
}

const { brand, locale, articles } = Astro.props;
const base = `/${brand.slug}/${locale}`;

const CATEGORY_LABELS: Record<string, string> = {
  'culture-history': 'Cultuur & Geschiedenis',
  'wine-regions': "Wijnregio's",
  'travel-tips': 'Reistips',
  'food-pairing': 'Spijs & Wijn',
  'tasting-notes': 'Proefnotities',
  'winery-portraits': 'Wijnhuizen',
  'sustainable-travel': 'Duurzaam Reizen',
  'digital-nomads': 'Digital Nomads',
};

const FALLBACK_IMAGES = [
  'https://images.unsplash.com/photo-1506377247377-2a5b3b417ebb?w=600&h=750&fit=crop&q=80',
  'https://images.unsplash.com/photo-1558618666-fcd25c85f82e?w=600&h=750&fit=crop&q=80',
  'https://images.unsplash.com/photo-1543783207-ec64e4d95325?w=600&h=750&fit=crop&q=80',
  'https://images.unsplash.com/photo-1504279577054-acfeccf8fc52?w=600&h=750&fit=crop&q=80',
  'https://images.unsplash.com/photo-1502602898657-3e91760cbb34?w=600&h=750&fit=crop&q=80',
];

const recentArticles = articles.slice(0, 5);

const spotlight = {
  region: 'Piemonte',
  label: 'Uitgelicht · Lente-editie',
  headline: ['Piemonte: het ', 'Bourgogne', ' van Italië'],
  body: 'Volg de mist die om acht uur oplost door Barolo\'s heuvels, drink Nebbiolo bij familiehuizen waar de wijnmaker zelf inschenkt, en eet taralli zoals de moeder ze maakt.',
  image: 'https://images.unsplash.com/photo-1523906834658-6e24ef2386f9?w=1920&h=1080&fit=crop&q=85',
  href: '#',
};

const favoriteRegions = [
  { name: 'Piemonte', tag: 'Mist, Nebbiolo en familietafels', image: 'https://images.unsplash.com/photo-1506377247377-2a5b3b417ebb?w=800&h=1200&fit=crop&q=80' },
  { name: 'Mosel', tag: 'Riesling op steile leihellingen', image: 'https://images.unsplash.com/photo-1504279577054-acfeccf8fc52?w=800&h=1200&fit=crop&q=80' },
  { name: 'Rioja', tag: 'Tempranillo onder herfstzon', image: 'https://images.unsplash.com/photo-1543783207-ec64e4d95325?w=800&h=1200&fit=crop&q=80' },
  { name: 'Douro', tag: 'Terraswijngaarden langs de rivier', image: 'https://images.unsplash.com/photo-1555881400-74d7acaacd8b?w=800&h=1200&fit=crop&q=80' },
  { name: 'Etna', tag: 'Vulkanische bodem, zoute wind', image: 'https://images.unsplash.com/photo-1533105079780-92b9be482077?w=800&h=1200&fit=crop&q=80' },
  { name: 'Mendoza', tag: 'Malbec op hoogte, in de Andes', image: 'https://images.unsplash.com/photo-1612294037637-ec328d0e075e?w=800&h=1200&fit=crop&q=80' },
];

const routes = [
  { title: 'Drie dagen Langhe (Barolo & Barbaresco)', days: '3 dagen', mode: 'Auto', country: 'Piemonte, IT', image: 'https://images.unsplash.com/photo-1506377247377-2a5b3b417ebb?w=800&h=600&fit=crop&q=80' },
  { title: 'Mosel per trein van Trier naar Koblenz', days: '5 dagen', mode: 'Trein', country: 'Mosel, DE', image: 'https://images.unsplash.com/photo-1504279577054-acfeccf8fc52?w=800&h=600&fit=crop&q=80' },
  { title: 'Rioja oogst-ronde door de Sierra de Cantabria', days: '7 dagen', mode: 'Auto', country: 'Rioja, ES', image: 'https://images.unsplash.com/photo-1543783207-ec64e4d95325?w=800&h=600&fit=crop&q=80' },
  { title: 'Douro stroomopwaarts: Porto naar Pinhão', days: '4 dagen', mode: 'Auto + Boot', country: 'Douro, PT', image: 'https://images.unsplash.com/photo-1555881400-74d7acaacd8b?w=800&h=600&fit=crop&q=80' },
  { title: 'Etna-rondrit: zwarte aarde, zoute wind', days: '3 dagen', mode: 'Auto', country: 'Sicilië, IT', image: 'https://images.unsplash.com/photo-1533105079780-92b9be482077?w=800&h=600&fit=crop&q=80' },
  { title: 'Bourgogne-route: Chablis naar Beaujolais', days: '6 dagen', mode: 'Auto', country: 'Bourgogne, FR', image: 'https://images.unsplash.com/photo-1502602898657-3e91760cbb34?w=800&h=600&fit=crop&q=80' },
];

const themes = [
  { label: 'Weekendjes proeven', desc: '2–3 dagen, één streek', count: 12 },
  { label: 'Lange routes', desc: '5+ dagen, auto of trein', count: 9 },
  { label: 'Wijnhuis-portretten', desc: 'Mensen achter de wijn', count: 24 },
  { label: 'Druif-deepdives', desc: 'Eén druif, vele percelen', count: 8 },
  { label: 'Spijs & wijn', desc: 'Combinaties die werken', count: 15 },
  { label: 'Per trein', desc: 'Wijngebieden zonder huurauto', count: 6 },
  { label: 'Oogst-tijd', desc: 'Wat te bezoeken in sept–okt', count: 7 },
  { label: 'Voorbereidingen', desc: 'Praktisch: visum, valuta, taal', count: 11 },
];

const atlasEuropa = ['Piemonte', 'Toscane', 'Etna', 'Bourgogne', 'Rhône', 'Champagne', 'Loire', 'Mosel', 'Rheingau', 'Rioja', 'Priorat', 'Douro', 'Wachau'];
const atlasNieuw = ['Mendoza', 'Salta', 'Stellenbosch', 'Marlborough', 'Napa', 'Sonoma'];
---

<BrandLayout
  brand={brand}
  locale={locale}
  title={`${brand.name} — Literair reismagazine voor wijnliefhebbers`}
  description="Hand-picked wijnreizen, proefnotities en verhalen van Martin & Sophie. Alleen streken en huizen waar ze zelf geweest zijn."
  schema={{
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: brand.name,
    url: 'https://vinomartino.com',
    description: 'Wijnreizen, proefnotities en persoonlijke verhalen uit de mooiste wijnstreken ter wereld.',
  }}
>
  <BrandHero brand={brand} />

  <!-- ── 1. Vers van de pers ──────────────────────────── -->
  <section class="section-recent" id="artikelen">
    <div class="container">
      <div class="section-top">
        <div>
          <div class="kicker">Nieuw</div>
          <h2 class="section-title">Vers van de pers</h2>
        </div>
        <a href={`${base}/artikelen/`} class="link-more">Alle artikelen →</a>
      </div>

      <div class="recent-grid">
        {recentArticles.map((article, i) => {
          const img = article.heroImage || FALLBACK_IMAGES[i % FALLBACK_IMAGES.length];
          const tag = article.category ? (CATEGORY_LABELS[article.category] || article.category) : 'Wijnreizen';
          return (
            <a href={`${base}/${article.slug}/`} class="recent-card">
              <div class="recent-img-wrap">
                <img src={img} alt={article.title} loading={i === 0 ? 'eager' : 'lazy'} />
                <span class="recent-tag">{tag}</span>
              </div>
              <h3 class="recent-title">{article.title}</h3>
              <span class="link-read">Lees meer →</span>
            </a>
          );
        })}
        {recentArticles.length === 0 && [0,1,2,3,4].map((i) => (
          <a href="#" class="recent-card">
            <div class="recent-img-wrap recent-img-placeholder" style={`background: var(--paperShade)`}>
              <span class="recent-tag">{['Piemonte','Bourgogne','Rioja','Mosel','Roero'][i]}</span>
            </div>
            <h3 class="recent-title">{['Drie dagen door de Langhe','Witte Bourgogne en geitenkaas','Rioja in oktober: oogst zonder drukte','Met de trein door Riesling-land','Arneis: de witte die bijna verdween'][i]}</h3>
            <span class="link-read">Lees meer →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── 2. Spotlight ─────────────────────────────────── -->
  <section class="section-spotlight" aria-label="Uitgelicht">
    <div class="spotlight-bg">
      <img src={spotlight.image} alt="" loading="lazy" />
      <div class="spotlight-overlay"></div>
    </div>
    <div class="container spotlight-content">
      <div class="spotlight-inner">
        <div class="spotlight-label">{spotlight.label}</div>
        <h2 class="spotlight-headline">
          {spotlight.headline[0]}<em>{spotlight.headline[1]}</em>{spotlight.headline[2]}
        </h2>
        <p class="spotlight-body">{spotlight.body}</p>
        <a href={spotlight.href} class="btn-spotlight">Ontdek {spotlight.region} →</a>
      </div>
    </div>
  </section>

  <!-- ── 3. Favoriete streken ─────────────────────────── -->
  <section class="section-regions" id="streken">
    <div class="container">
      <div class="section-center-header">
        <div class="kicker">Onze favorieten</div>
        <h2 class="section-title">Wat wordt jouw volgende streek?</h2>
      </div>
      <div class="regions-grid">
        {favoriteRegions.map(region => (
          <a href="#" class="region-card">
            <img src={region.image} alt={region.name} loading="lazy" />
            <div class="region-overlay"></div>
            <div class="region-content">
              <div class="region-tag">{region.tag}</div>
              <h3 class="region-name">{region.name}</h3>
              <span class="region-cta">Bekijk meer →</span>
            </div>
          </a>
        ))}
      </div>
      <div class="section-center-cta">
        <a href="#" class="btn-primary-sm">Bekijk alle 18 streken →</a>
      </div>
    </div>
  </section>

  <!-- ── 4. Over ons ──────────────────────────────────── -->
  <section class="section-about">
    <div class="container about-grid">
      <div class="about-text">
        <div class="kicker kicker--vine">De redactie</div>
        <h2 class="about-title">Hi! Wij zijn <em>Martin &amp; Sophie</em></h2>
        <p class="about-body">
          Sinds 2019 reizen we per auto, trein en soms te voet door Europese wijnstreken — Martin vanuit de Rhône, Sophie vanuit Piemonte. We schrijven alleen over wijnhuizen waar we zelf binnen zijn geweest, en routes die we zelf hebben gereden.
        </p>
        <p class="about-body">
          Geen affiliate-lijstjes met "10 beste wijnhuizen". Geen sponsoring. Wel: lange brieven, eerlijke proefnotities en de routebeschrijving om er heen te komen.
        </p>
        <div class="about-actions">
          <a href={`${base}/over-ons/`} class="link-primary">Lees meer over ons →</a>
          <span class="about-meta">· 47 streken bezocht · 1.842 lezers</span>
        </div>
      </div>
      <div class="about-photo" aria-hidden="true">
        <span class="photo-placeholder">foto · Martin & Sophie in Barolo</span>
      </div>
    </div>
  </section>

  <!-- ── 5. Routes ────────────────────────────────────── -->
  <section class="section-routes" id="routes">
    <div class="container">
      <div class="routes-header">
        <div>
          <div class="kicker kicker--vine">Reisroutes</div>
          <h2 class="section-title">Onze kant-en-klare wijnroutes</h2>
        </div>
        <p class="routes-intro">
          Speciaal samengesteld op basis van onze eigen ervaring. Met dagindeling, slaapadressen en de wijnhuizen die je écht moet bezoeken — niet alleen de bekende namen.
        </p>
      </div>
      <div class="routes-grid">
        {routes.map((route, i) => (
          <a href="#" class="route-card">
            <div class="route-img-wrap">
              <img src={route.image} alt={route.title} loading="lazy" />
              <div class="route-badges">
                <span class="route-badge route-badge--days">{route.days}</span>
                <span class="route-badge route-badge--mode">{route.mode}</span>
              </div>
            </div>
            <div class="route-country">{route.country}</div>
            <h3 class="route-title">{route.title}</h3>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── 6. Thema's ───────────────────────────────────── -->
  <section class="section-themes">
    <div class="container">
      <div class="section-center-header">
        <div class="kicker">Thema's</div>
        <h2 class="section-title">Wat voor wijnreis zoek je?</h2>
      </div>
      <div class="themes-grid">
        {themes.map((theme, i) => (
          <a href="#" class="theme-cell">
            <div class="theme-top">
              <h3 class="theme-label">{theme.label}</h3>
              <span class="theme-count">{theme.count}</span>
            </div>
            <p class="theme-desc">{theme.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── 7. Wijnatlas ─────────────────────────────────── -->
  <section class="section-atlas" id="bestemmingen">
    <div class="container">
      <div class="section-center-header">
        <div class="kicker">De wijnatlas</div>
        <h2 class="section-title">Naar welke streek wil je reizen?</h2>
      </div>
      <div class="atlas-continent">
        <div class="atlas-continent-label">Europa</div>
        <div class="atlas-regions">
          {atlasEuropa.map(region => (
            <a href="#" class="atlas-region">{region}</a>
          ))}
        </div>
      </div>
      <div class="atlas-continent">
        <div class="atlas-continent-label">Nieuwe wereld</div>
        <div class="atlas-regions">
          {atlasNieuw.map(region => (
            <a href="#" class="atlas-region">{region}</a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── 8. Newsletter ────────────────────────────────── -->
  <section class="section-newsletter">
    <div class="container newsletter-grid">
      <div>
        <div class="kicker kicker--gold">De Brief</div>
        <h2 class="newsletter-title">Eén keer per maand, op een vrijdag.</h2>
      </div>
      <div>
        <p class="newsletter-body">
          Een lange brief uit een wijnstreek, drie wijnen die we zelf hebben geopend, en de routebeschrijving om er heen te komen.
        </p>
        <form class="newsletter-form" action="#" method="post">
          <input type="email" name="email" placeholder="je@adres.nl" required aria-label="E-mailadres" class="newsletter-input" />
          <button type="submit" class="newsletter-btn">Abonneer →</button>
        </form>
        <p class="newsletter-meta">1.842 lezers · uitschrijven met één klik</p>
      </div>
    </div>
  </section>
</BrandLayout>

<style>
  /* ── Shared section utilities ────────────────────── */
  .kicker {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rust);
    margin-bottom: 6px;
  }
  .kicker--vine { color: var(--vine); }
  .kicker--gold { color: var(--gold); }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 1.5rem + 1.25vw, 2.75rem);
    font-weight: 500;
    color: var(--ink);
    margin: 0;
    line-height: 1.05;
  }

  .section-top {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 32px;
    gap: 1rem;
  }

  .section-center-header {
    text-align: center;
    margin-bottom: 40px;
  }
  .section-center-header .kicker { margin-bottom: 8px; }

  .link-more {
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    color: var(--burgundy);
    text-decoration: none;
    font-weight: 600;
    white-space: nowrap;
  }
  .link-more:hover { color: var(--burgundyDeep); }

  .link-read {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    color: var(--burgundy);
    font-weight: 500;
    margin-top: 6px;
    display: inline-block;
  }

  .link-primary {
    font-family: var(--font-ui);
    font-size: 0.875rem;
    color: var(--burgundy);
    text-decoration: none;
    font-weight: 600;
    border-bottom: 1px solid var(--burgundy);
    padding-bottom: 2px;
  }
  .link-primary:hover { color: var(--burgundyDeep); border-bottom-color: var(--burgundyDeep); }

  .btn-primary-sm {
    display: inline-block;
    background: var(--burgundy);
    color: var(--paper);
    padding: 14px 28px;
    text-decoration: none;
    font-family: var(--font-ui);
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: var(--radius-sm);
    transition: background var(--duration-fast) var(--ease-out);
  }
  .btn-primary-sm:hover { background: var(--burgundyDeep); color: var(--paper); }

  /* ── 1. Recent articles ──────────────────────────── */
  .section-recent {
    padding: 72px 0;
    border-bottom: 1px solid var(--rule);
  }

  .recent-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
  }

  .recent-card {
    text-decoration: none;
    color: inherit;
  }

  .recent-img-wrap {
    aspect-ratio: 4/5;
    overflow: hidden;
    margin-bottom: 12px;
    position: relative;
    background: var(--paperShade);
  }

  .recent-img-placeholder {
    min-height: 200px;
  }

  .recent-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .recent-card:hover .recent-img-wrap img {
    transform: scale(1.04);
  }

  .recent-tag {
    position: absolute;
    top: 10px;
    left: 10px;
    background: var(--paper);
    padding: 4px 10px;
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--burgundy);
  }

  .recent-title {
    font-family: var(--font-display);
    font-size: 1.1875rem;
    font-weight: 500;
    line-height: 1.2;
    color: var(--ink);
    margin: 0 0 4px;
    text-wrap: balance;
  }

  /* ── 2. Spotlight ───────────────────────────────── */
  .section-spotlight {
    position: relative;
    min-height: 480px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .spotlight-bg {
    position: absolute;
    inset: 0;
  }

  .spotlight-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .spotlight-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(31, 26, 22, 0.85) 0%,
      rgba(31, 26, 22, 0.5) 70%,
      transparent 100%
    );
  }

  .spotlight-content {
    position: relative;
    z-index: 1;
    padding: 80px 0;
    color: var(--paper);
  }

  .spotlight-inner { max-width: 560px; }

  .spotlight-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 12px;
  }

  .spotlight-headline {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 2rem + 2.5vw, 4rem);
    font-weight: 500;
    line-height: 1;
    margin: 0 0 20px;
    color: var(--paper);
  }

  .spotlight-headline em { font-style: italic; }

  .spotlight-body {
    font-family: var(--font-body);
    font-size: 1.125rem;
    line-height: 1.5;
    color: rgba(250, 245, 233, 0.85);
    margin: 0 0 24px;
    max-width: 46ch;
  }

  .btn-spotlight {
    display: inline-block;
    background: var(--paper);
    color: var(--ink);
    padding: 14px 24px;
    text-decoration: none;
    font-family: var(--font-ui);
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: var(--radius-sm);
    transition: background var(--duration-fast) var(--ease-out);
  }
  .btn-spotlight:hover { background: var(--paperDeep); color: var(--ink); }

  /* ── 3. Favorite regions ─────────────────────────── */
  .section-regions {
    padding: 80px 0;
    background: var(--paperDeep);
    border-bottom: 1px solid var(--rule);
  }

  .regions-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 40px;
  }

  .region-card {
    position: relative;
    aspect-ratio: 3/4;
    overflow: hidden;
    display: block;
    text-decoration: none;
  }

  .region-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .region-card:hover img { transform: scale(1.04); }

  .region-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(31, 26, 22, 0.85) 0%, transparent 50%);
  }

  .region-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 24px;
    color: var(--paper);
  }

  .region-tag {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 6px;
  }

  .region-name {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 500;
    margin: 0 0 12px;
    line-height: 1;
  }

  .region-cta {
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    border-bottom: 1px solid var(--paper);
    padding-bottom: 2px;
  }

  .section-center-cta { text-align: center; }

  /* ── 4. About ────────────────────────────────────── */
  .section-about {
    padding: 80px 0;
    border-bottom: 1px solid var(--rule);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .about-title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 1.8rem + 2vw, 3.5rem);
    font-weight: 500;
    line-height: 1;
    margin: 0 0 20px;
    color: var(--ink);
  }

  .about-title em { color: var(--burgundy); font-style: italic; }

  .about-body {
    font-family: var(--font-body);
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--inkSoft);
