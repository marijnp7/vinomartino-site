---
import BrandLayout from '../../layouts/BrandLayout.astro';
import BrandHero from '../../components/BrandHero.astro';
import type { Brand } from '../../lib/brands';
import type { Article } from '../../lib/articles';

interface Props {
  brand: Brand;
  locale: string;
  articles: Article[];
}

const { brand, locale, articles } = Astro.props;
const base = `/${brand.slug}/${locale}`;

const CATEGORY_LABELS: Record<string, string> = {
  'culture-history': 'Cultuur & Geschiedenis',
  'wine-regions': "Wijnregio's",
  'travel-tips': 'Reistips',
  'food-pairing': 'Spijs & Wijn',
  'tasting-notes': 'Proefnotities',
  'winery-portraits': 'Wijnhuizen',
  'sustainable-travel': 'Duurzaam Reizen',
  'digital-nomads': 'Digital Nomads',
};

const FALLBACK_IMAGES = [
  'https://images.unsplash.com/photo-1558618666-fcd25c85f82e?w=800&h=600&fit=crop&q=80',
  'https://images.unsplash.com/photo-1504279577054-acfeccf8fc52?w=800&h=600&fit=crop&q=80',
  'https://images.unsplash.com/photo-1543783207-ec64e4d95325?w=800&h=600&fit=crop&q=80',
  'https://images.unsplash.com/photo-1474722883778-792e7990302f?w=800&h=600&fit=crop&q=80',
  'https://images.unsplash.com/photo-1510812431401-41d2bd2722f3?w=800&h=600&fit=crop&q=80',
];

const recentArticles = articles.slice(0, 5);

const spotlight = {
  region: 'Etna',
  country: 'Sicilië',
  claim: 'Vulkanisch, hoogte-gedreven, onvervangbaar.',
  body: 'Op de zuidflank van de Etna groeit Nerello Mascalese op 600–1000 meter hoogte. Geen enkel ander terroir in Italië combineert lavagrondige mineraliteit met zulke elegante tannines. Martin rijdt hier elk najaar naartoe.',
  image: 'https://images.unsplash.com/photo-1513836279014-a89f7a76ae86?w=1400&h=900&fit=crop&q=85',
};

const favoriteRegions = [
  { name: 'Piemonte', country: 'Italië', image: 'https://images.unsplash.com/photo-1507692049790-de58290a4334?w=600&h=800&fit=crop&q=80' },
  { name: 'Bourgogne', country: 'Frankrijk', image: 'https://images.unsplash.com/photo-1506377247377-2a5b3b417ebb?w=600&h=800&fit=crop&q=80' },
  { name: 'Priorat', country: 'Spanje', image: 'https://images.unsplash.com/photo-1543783207-ec64e4d95325?w=600&h=800&fit=crop&q=80' },
  { name: 'Mosel', country: 'Duitsland', image: 'https://images.unsplash.com/photo-1474722883778-792e7990302f?w=600&h=800&fit=crop&q=80' },
  { name: 'Wachau', country: 'Oostenrijk', image: 'https://images.unsplash.com/photo-1527838832700-5059252407fa?w=600&h=800&fit=crop&q=80' },
  { name: 'Etna', country: 'Sicilië', image: 'https://images.unsplash.com/photo-1513836279014-a89f7a76ae86?w=600&h=800&fit=crop&q=80' },
];

const routes = [
  { title: 'Langhe in 4 dagen', days: 4, transport: 'Huurauto', region: 'Piemonte', slug: 'langhe-4-dagen' },
  { title: 'Bourgogne per trein', days: 5, transport: 'Trein', region: 'Bourgogne', slug: 'bourgogne-trein' },
  { title: 'Etna noord-flank', days: 3, transport: 'Huurauto', region: 'Sicilië', slug: 'etna-noord' },
  { title: 'Mosel-vallei langzaam', days: 6, transport: 'Fiets + trein', region: 'Mosel', slug: 'mosel-fietsvakantie' },
];

const themes = [
  { label: 'Weekendjes proeven', icon: '§ 01', slug: 'weekends' },
  { label: 'Per trein door Europa', icon: '§ 02', slug: 'per-trein' },
  { label: 'Druif-deepdives', icon: '§ 03', slug: 'druiven' },
  { label: 'Wijnhuisportretten', icon: '§ 04', slug: 'wijnhuizen' },
  { label: 'Biodynamisch & natuur', icon: '§ 05', slug: 'natuur' },
  { label: 'Bubbels van kleine makers', icon: '§ 06', slug: 'bubbels' },
  { label: 'Eten & wijn samen', icon: '§ 07', slug: 'spijs-wijn' },
  { label: "Opkomende regio's", icon: '§ 08', slug: 'opkomend' },
];

const atlasRegions = [
  { name: 'Piemonte', sub: 'Barolo · Barbaresco · Roero' },
  { name: 'Toscane', sub: 'Bolgheri · Montalcino · Carmignano' },
  { name: 'Bourgogne', sub: 'Côte de Nuits · Côte de Beaune · Chablis' },
  { name: 'Champagne', sub: 'Grower-producenten · Blanc de blancs' },
  { name: 'Priorat', sub: 'Garnatxa · Cariñena · Licorella' },
  { name: 'Mosel', sub: 'Riesling · Spätlese · GG' },
  { name: 'Etna', sub: 'Nerello · Carricante · Contrade' },
  { name: 'Wachau', sub: 'Grüner Veltliner · Riesling · Smaragd' },
  { name: 'Douro', sub: 'Port · Tawny · Droge rode wijnen' },
  { name: 'Georgië', sub: 'Qvevri · Rkatsiteli · Saperavi' },
  { name: 'Slovenië', sub: 'Brda · Vipavska dolina · Karst' },
  { name: 'Engeland', sub: 'Sussex · Kent · Sparkling' },
];
---

<BrandLayout
  brand={brand}
  locale={locale}
  title={`${brand.name} — Literair reismagazine voor wijnliefhebbers`}
  description="Hand-picked wijnreizen, proefnotities en verhalen van Martin & Sophie. Alleen streken en huizen waar ze zelf geweest zijn."
>
  <!-- Hero -->
  <BrandHero brand={brand} />

  <!-- § 1 — Recent articles -->
  <section class="recent-strip section-lg" id="artikelen" aria-labelledby="recent-heading">
    <div class="container">
      <header class="section-header section-header--left">
        <span class="section-label">Vers van de pers</span>
        <h2 id="recent-heading">Laatste verhalen</h2>
      </header>

      {recentArticles.length === 0 ? (
        <p class="no-articles">Artikelen worden binnenkort gepubliceerd.</p>
      ) : (
        <div class="strip-grid">
          {recentArticles.map((article, i) => {
            const img = article.heroImage || FALLBACK_IMAGES[i % FALLBACK_IMAGES.length];
            const catLabel = CATEGORY_LABELS[article.category] || article.category;
            const dateStr = new Date(article.pubDate).toLocaleDateString('nl-NL', {
              day: 'numeric', month: 'short', year: 'numeric',
            });
            const isHero = i === 0;
            return (
              <article class={`strip-card ${isHero ? 'strip-card--hero' : ''}`}>
                <a href={`${base}/${article.slug}/`} class="strip-card-link">
                  <div class="strip-card-image">
                    <img src={img} alt={article.title} loading={isHero ? 'eager' : 'lazy'} />
                    <div class="strip-card-image-overlay"></div>
                  </div>
                  <div class="strip-card-body">
                    {catLabel && <span class="card-kicker">{catLabel}</span>}
                    <h3 class="strip-card-title">{article.title}</h3>
                    {isHero && article.description && (
                      <p class="strip-card-excerpt">
                        {article.description.slice(0, 140)}{article.description.length > 140 ? '…' : ''}
                      </p>
                    )}
                    <div class="card-meta">
                      <time datetime={article.pubDate}>{dateStr}</time>
                      <span class="card-meta-arrow" aria-hidden="true">→</span>
                    </div>
                  </div>
                </a>
              </article>
            );
          })}
        </div>
      )}

      <div class="strip-footer">
        <a href={`${base}/verhalen/`} class="btn btn-secondary">Alle verhalen bekijken</a>
      </div>
    </div>
  </section>

  <!-- § 2 — Region spotlight -->
  <section class="region-spotlight" id="bestemmingen" aria-labelledby="spotlight-heading">
    <div class="spotlight-image-wrap">
      <img src={spotlight.image} alt={spotlight.region} loading="lazy" />
      <div class="spotlight-overlay"></div>
    </div>
    <div class="container spotlight-content">
      <div class="spotlight-eyebrow">
        <span class="section-label" style="color: var(--rule); margin-bottom: 0;">
          {spotlight.country}
        </span>
        <span class="spotlight-badge">Nu uitgelicht</span>
      </div>
      <h2 id="spotlight-heading" class="spotlight-region">{spotlight.region}</h2>
      <p class="spotlight-claim">{spotlight.claim}</p>
      <p class="spotlight-body">{spotlight.body}</p>
      <a href={`${base}/streken/${spotlight.region.toLowerCase()}/`} class="btn btn-ghost-light">
        Alles over {spotlight.region} →
      </a>
    </div>
  </section>

  <!-- § 3 — Favorite regions grid -->
  <section class="fav-regions section-lg" aria-labelledby="fav-heading">
    <div class="container">
      <header class="section-header">
        <span class="section-label">Vaste bestemmingen</span>
        <h2 id="fav-heading">Streken die Martin steeds terugtrekt</h2>
      </header>
      <div class="fav-grid">
        {favoriteRegions.map((r, i) => (
          <a href={`${base}/streken/${r.name.toLowerCase()}/`} class="fav-card">
            <div class="fav-card-image">
              <img src={r.image} alt={r.name} loading="lazy" />
              <div class="fav-card-overlay"></div>
            </div>
            <div class="fav-card-content">
              <span class="fav-index">{String(i + 1).padStart(2, '0')}</span>
              <span class="fav-country">{r.country}</span>
              <span class="fav-name">{r.name}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- § 4 — Editor intro -->
  <section class="editor-intro section" aria-labelledby="intro-heading">
    <div class="container editor-inner">
      <div class="editor-text">
        <span class="section-label">Over ons</span>
        <h2 id="intro-heading">Hallo, wij zijn Martin&nbsp;&amp;&nbsp;Sophie</h2>
        <p>
          Martin heeft een WSET Level 4 Diploma en heeft de afgelopen tien jaar elke vrije week besteed
          aan reizen door Europese wijnregio's. Sophie heeft een scherp palat voor oranje wijnen en weet
          precies wanneer de wijnmaker het te serieus neemt.
        </p>
        <p>
          Op VinoMartino schrijven we alleen over plaatsen waar we zelf zijn geweest, en wijnen die we
          zelf hebben gedronken — zonder sponsoring, zonder afgekochte verblijven, zonder 95-puntenscores
          van anderen.
        </p>
        <a href={`${base}/over-ons/`} class="btn btn-secondary">Meer over Martin &amp; Sophie</a>
      </div>
      <div class="editor-aside">
        <div class="editor-quote-wrap">
          <span class="editor-quote-mark" aria-hidden="true">"</span>
          <blockquote class="editor-quote">
            <p>
              Een wijnmaker die op woensdagmiddag haar eigen ranken snoeit vertelt meer over haar wijnen
              dan welke website-bio dan ook.
            </p>
            <cite>— Martin, Occhipinti, Vittoria 2024</cite>
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- § 5 — Routes grid -->
  <section class="routes-section section" aria-labelledby="routes-heading">
    <div class="container">
      <header class="section-header">
        <span class="section-label">Kant-en-klare routes</span>
        <h2 id="routes-heading">Zo plan je een wijnreis</h2>
        <p class="section-desc">
          Dagindelingen, wijnhuizen, restaurants en logies — alles uitgedacht, jij rijdt alleen nog maar.
        </p>
      </header>
      <div class="routes-grid">
        {routes.map((route, i) => (
          <a href={`${base}/routes/${route.slug}/`} class="route-card">
            <div class="route-number" aria-hidden="true">{String(i + 1).padStart(2, '0')}</div>
            <div class="route-meta">
              <span class="route-region">{route.region}</span>
              <span class="route-days">{route.days} dagen</span>
            </div>
            <h3 class="route-title">{route.title}</h3>
            <div class="route-footer">
              <div class="route-transport">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.2"/>
                  <path d="M6 3.5v2.5l1.5 1.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                {route.transport}
              </div>
              <span class="route-arrow" aria-hidden="true">→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- § 6 — Themes grid -->
  <section class="themes-section section" aria-labelledby="themes-heading">
    <div class="container">
      <header class="section-header">
        <span class="section-label">Thema's</span>
        <h2 id="themes-heading">Instappen op jouw manier</h2>
      </header>
      <div class="themes-grid">
        {themes.map((theme) => (
          <a href={`${base}/themas/${theme.slug}/`} class="theme-tile">
            <span class="theme-icon">{theme.icon}</span>
            <span class="theme-label">{theme.label}</span>
            <span class="theme-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- § 7 — Region atlas (typographic) -->
  <section class="atlas-section section-lg" aria-labelledby="atlas-heading">
    <div class="container">
      <header class="section-header">
        <span class="section-label">Streekgids</span>
        <h2 id="atlas-heading">De atlas van Martin</h2>
        <p class="section-desc">Alle regio's die terugkomen — van Piemonte tot Georgië.</p>
      </header>
      <div class="atlas-grid">
        {atlasRegions.map((r) => (
          <a href={`${base}/streken/${r.name.toLowerCase()}/`} class="atlas-entry">
            <span class="atlas-name">{r.name}</span>
            <span class="atlas-sub">{r.sub}</span>
            <span class="atlas-arrow" aria-hidden="true">↗</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- § 8 — Newsletter CTA -->
  <section class="newsletter-section" id="nieuwsbrief" aria-labelledby="nl-heading">
    <div class="newsletter-bg" aria-hidden="true">
      <img
        src="https://images.unsplash.com/photo-1510812431401-41d2bd2722f3?w=1400&h=600&fit=crop&q=80"
        alt=""
        loading="lazy"
      />
      <div class="newsletter-overlay"></div>
    </div>
    <div class="container newsletter-inner">
      <span class="section-label" style="color: var(--rule); justify-content: center;">Nieuwsbrief</span>
      <h2 id="nl-heading">Wijnreisverhalen in je inbox</h2>
      <p>
        Eén keer per maand: nieuwe artikelen, proefnotities en de routes die Martin écht aanraadt.
        Geen reclame, geen affiliate-lijstjes — gewoon het goede spul.
      </p>
      <form class="nl-form" action="#" method="post" novalidate>
        <label for="nl-email" class="sr-only">E-mailadres</label>
        <input
          type="email"
          id="nl-email"
          name="email"
          placeholder="jouw@email.nl"
          required
          autocomplete="email"
          class="nl-input"
        />
        <button type="submit" class="btn btn-primary nl-submit">Aanmelden</button>
      </form>
      <p class="nl-note">Geen spam. Afmelden wanneer je wilt.</p>
    </div>
  </section>
</BrandLayout>

<style>
  /* ── § 1 Recent strip ─────────────────────────────── */
  .section-header--left { text-align: left; margin-bottom: var(--space-8); }
  .section-header--left .section-label { justify-content: flex-start; }
  .section-header--left .section-label::before { display: none; }

  .strip-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    gap: 2px;
    background: var(--rule-20);
    border: 1px solid var(--rule-20);
  }

  .strip-card { background: var(--paper); overflow: hidden; }
  .strip-card--hero { grid-row: span 2; }

  .strip-card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .strip-card-image {
    overflow: hidden;
    aspect-ratio: 4 / 3;
    flex-shrink: 0;
    position: relative;
  }
  .strip-card--hero .strip-card-image { aspect-ratio: 3 / 4; }

  .strip-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(100%) brightness(100%);
    transition: transform var(--duration-image) var(--ease-out),
                filter var(--duration-base) var(--ease-out);
  }
  .strip-card:hover .strip-card-image img {
    transform: scale(1.05);
    filter: saturate(108%) brightness(103%);
  }

  .strip-card-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(26, 20, 16, 0.3), transparent 40%);
    opacity: 0;
    transition: opacity var(--duration-base) var(--ease-out);
  }
  .strip-card:hover .strip-card-image-overlay { opacity: 1; }

  .strip-card-body {
    padding: var(--space-5) var(--space-5) var(--space-5);
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .card-kicker {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--rust);
    margin-bottom: var(--space-2);
    display: block;
  }

  .strip-card-title {
    font-family: var(--font-display);
    font-size: clamp(0.9375rem, 0.85rem + 0.4vw, 1.25rem);
    font-weight: 400;
    line-height: 1.2;
    color: var(--ink);
  }
  .strip-card--hero .strip-card-title {
    font-size: clamp(1.375rem, 1.2rem + 0.8vw, 1.875rem);
  }

  .strip-card-excerpt {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--inkSoft);
    line-height: 1.6;
    margin-top: var(--space-3);
    font-weight: 300;
  }

  .card-meta {
    margin-top: auto;
    padding-top: var(--space-4);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--inkSoft);
    opacity: 0.6;
  }

  .card-meta-arrow {
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity var(--duration-fast) var(--ease-out),
                transform var(--duration-fast) var(--ease-out);
    font-style: normal;
  }
  .strip-card:hover .card-meta-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .no-articles {
    text-align: center;
    color: var(--inkSoft);
    padding: var(--space-12) 0;
    font-family: var(--font-ui);
  }

  .strip-footer {
    display: flex;
    justify-content: center;
    margin-top: var(--space-10);
  }

  /* ── § 2 Spotlight ───────────────────────────────── */
  .region-spotlight {
    position: relative;
    min-height: 600px;
    display: flex;
    align-items: flex-end;
    padding: var(--space-32) 0 var(--space-20);
    overflow: hidden;
  }

  .spotlight-image-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .spotlight-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .spotlight-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      100deg,
      rgba(13, 10, 7, 0.90) 0%,
      rgba(13, 10, 7, 0.65) 50%,
      rgba(13, 10, 7, 0.25) 100%
    );
  }

  .spotlight-content {
    position: relative;
    z-index: 1;
    max-width: 44rem;
  }

  .spotlight-eyebrow {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-3);
  }

  .spotlight-badge {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: rgba(196, 164, 85, 0.7);
    padding: 0.25rem 0.625rem;
    border: 1px solid rgba(196, 164, 85, 0.3);
    border-radius: var(--radius-sm);
  }

  .spotlight-region {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 2.5rem + 4vw, 6.5rem);
    font-style: italic;
    font-weight: 400;
    color: var(--paper);
    line-height: 0.95;
    margin-bottom: var(--space-5);
    letter-spacing: -0.03em;
  }

  .spotlight-claim {
    font-family: var(--font-display);
    font-size: clamp(1.125rem, 1rem + 0.5vw, 1.5rem);
    font-style: italic;
    color: var(--rule);
    margin-bottom: var(--space-5);
    line-height: 1.3;
  }

  .spotlight-body {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    color: rgba(251, 247, 239, 0.75);
    line-height: 1.72;
    margin-bottom: var(--space-8);
    max-width: 36rem;
    font-weight: 300;
  }

  /* ── § 3 Favorite regions ────────────────────────── */
  .fav-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(2, 340px);
    gap: 3px;
  }

  .fav-card {
    position: relative;
    overflow: hidden;
    display: block;
    text-decoration: none;
  }

  .fav-card-image {
    position: absolute;
    inset: 0;
  }
  .fav-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-image) var(--ease-out);
  }
  .fav-card:hover .fav-card-image img { transform: scale(1.06); }

  .fav-card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(13, 10, 7, 0.75) 0%,
      rgba(13, 10, 7, 0.2) 50%,
      rgba(13, 10, 7, 0.05) 100%
    );
    transition: background var(--duration-base) var(--ease-out);
  }
  .fav-card:hover .fav-card-overlay {
    background: linear-gradient(
      to top,
      rgba(13, 10, 7, 0.85) 0%,
      rgba(13, 10, 7, 0.35) 55%,
      rgba(13, 10, 7, 0.08) 100%
    );
  }

  .fav-card-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-6);
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .fav-index {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    font-weight: 500;
    letter-spacing: 0.15em;
