---
interface Props {
  wine: string;
  winery?: string;
  vintage?: number | string;
  region?: string;
  grape?: string;
  score?: string;
  price?: string;
  drinkFrom?: string;
}

const { wine, winery, vintage, region, grape, score, price, drinkFrom } = Astro.props;
---

<aside class="tasting-note" aria-label={`Proefnotitie: ${wine}`}>
  <header class="tn-header">
    <span class="tn-label">Proefnotitie</span>
    <h4 class="tn-wine">{wine}</h4>
    {winery && <span class="tn-winery">{winery}</span>}
  </header>

  <div class="tn-meta">
    {vintage && <div class="tn-pair"><span>Jaargang</span><strong>{vintage}</strong></div>}
    {region && <div class="tn-pair"><span>Streek</span><strong>{region}</strong></div>}
    {grape && <div class="tn-pair"><span>Druif</span><strong>{grape}</strong></div>}
    {score && <div class="tn-pair"><span>Score</span><strong class="tn-score">{score}</strong></div>}
    {price && <div class="tn-pair"><span>Prijs</span><strong>{price}</strong></div>}
    {drinkFrom && <div class="tn-pair"><span>Drinkrijp</span><strong>{drinkFrom}</strong></div>}
  </div>

  <div class="tn-body">
    <slot />
  </div>
</aside>

<style>
  .tasting-note {
    border: 1px solid var(--rule);
    background: var(--paperDeep);
    padding: var(--space-6);
    margin: var(--space-8) 0;
    position: relative;
  }

  .tasting-note::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: var(--burgundy);
  }

  .tn-header { margin-bottom: var(--space-4); }

  .tn-label {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--rust);
    display: block;
    margin-bottom: var(--space-2);
  }

  .tn-wine {
    font-family: var(--font-display);
    font-size: 1.1875rem;
    font-style: italic;
    font-weight: 400;
    color: var(--ink);
    line-height: 1.2;
    margin-bottom: var(--space-1);
  }

  .tn-winery {
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    color: var(--inkSoft);
    display: block;
  }

  .tn-meta {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3) var(--space-4);
    padding: var(--space-4) 0;
    border-top: 1px solid var(--rule-20);
    border-bottom: 1px solid var(--rule-20);
    margin-bottom: var(--space-4);
  }

  .tn-pair {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .tn-pair span {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--inkSoft);
    opacity: 0.7;
  }

  .tn-pair strong {
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--ink);
  }

  .tn-score { color: var(--burgundy); }

  .tn-body {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--inkSoft);
  }

  .tn-body :global(p) { margin-bottom: var(--space-3); }
  .tn-body :global(p:last-child) { margin-bottom: 0; }

  @media (max-width: 640px) {
    .tn-meta { grid-template-columns: repeat(2, 1fr); }
  }
</style>
