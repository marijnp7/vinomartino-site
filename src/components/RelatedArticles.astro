---
// LAT-1098: reverse cross-link block onderaan streek/wijnhuis/wijnroute/land
// detail-pages. Lijst gerelateerde artikelen. Section verschijnt niet als de
// items-array leeg is (per spec acceptance).
import type { RelatedRef } from '../lib/articles';

interface Props {
  items: RelatedRef[];
  title?: string;
  maxItems?: number;
}

const { items, title = 'Gerelateerde artikelen', maxItems = 6 } = Astro.props;
const cards = items.slice(0, maxItems);
---

{cards.length > 0 && (
  <section class="related-articles">
    <div class="container">
      <span class="related-label">Artikelen</span>
      <h2 class="related-title">{title}</h2>
      <div class="related-grid">
        {cards.map((card) => (
          <a href={`/artikelen/${card.slug}/`} class="related-card">
            <span class="related-meta">Artikel</span>
            <span class="related-name">{card.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .related-articles {
    padding: 3rem 0;
    border-top: 1px solid var(--rule);
  }
  .related-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--burgundy);
    display: block;
    margin-bottom: 0.5rem;
  }
  .related-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--ink);
    margin: 0 0 1.5rem;
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .related-card {
    text-decoration: none;
    color: inherit;
    background: var(--paperDeep);
    padding: 1rem 1.25rem;
    border-radius: var(--radius-sm);
    transition: box-shadow var(--duration-fast) var(--ease-out);
  }
  .related-card:hover {
    box-shadow: var(--shadow-card-hover);
  }
  .related-meta {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--rust);
    display: block;
    margin-bottom: 0.25rem;
  }
  .related-name {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--ink);
  }
  @media (max-width: 900px) {
    .related-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .related-grid { grid-template-columns: 1fr; }
  }
</style>
