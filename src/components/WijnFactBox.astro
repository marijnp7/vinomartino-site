---
// LAT-1676 — Compacte WijnFactBox bovenaan een regiopagina (ReisJunk fact-box-les,
// vertaald naar WSET-kennis i.p.v. land-feiten). Geen marketingkopij: harde,
// scanbare feiten die meteen vertrouwen opbouwen.
//
// Alle waarden komen uit Directus (streken-loader). Een rij verschijnt alleen als
// die waarde gevuld is — zo rendert de box niets op streken die de velden nog niet
// hebben (geen lege box, geen "coming soon"). Velden best_vintages/harvest_period/
// min_visit_time/tasting_budget moeten nog aan het Directus-schema worden toegevoegd.
interface Props {
  dominantGrapes?: string[];
  appellations?: string[];
  bestVintages?: string;
  harvestPeriod?: string;
  minVisitTime?: string;
  tastingBudget?: string;
}

const {
  dominantGrapes = [],
  appellations = [],
  bestVintages = '',
  harvestPeriod = '',
  minVisitTime = '',
  tastingBudget = '',
} = Astro.props;

const rows: Array<{ label: string; value: string }> = [];
if (dominantGrapes.length) rows.push({ label: 'Dominante druif', value: dominantGrapes.join(', ') });
if (appellations.length) rows.push({ label: 'Appellatieniveau', value: appellations.join(', ') });
if (bestVintages.trim()) rows.push({ label: 'Beste jaargangen', value: bestVintages.trim() });
if (harvestPeriod.trim()) rows.push({ label: 'Oogstperiode', value: harvestPeriod.trim() });
if (minVisitTime.trim()) rows.push({ label: 'Min. bezoektijd', value: minVisitTime.trim() });
if (tastingBudget.trim()) rows.push({ label: 'Budget proeverij', value: tastingBudget.trim() });
---

{rows.length > 0 && (
  <aside class="vm-factbox" aria-label="Wijnregio in het kort">
    <h2 class="vm-factbox__heading">In het kort</h2>
    <dl class="vm-factbox__grid">
      {rows.map((row) => (
        <div class="vm-factbox__row">
          <dt class="vm-factbox__label">{row.label}</dt>
          <dd class="vm-factbox__value">{row.value}</dd>
        </div>
      ))}
    </dl>
  </aside>
)}

<style>
  .vm-factbox {
    border: 1px solid var(--rule, #c9b98f);
    border-radius: var(--radius-lg, 4px);
    background: var(--paperDeep, #f0e6d0);
    padding: 1.25rem 1.4rem;
  }

  .vm-factbox__heading {
    margin: 0 0 0.9rem;
    font-family: var(--font-ui, system-ui, sans-serif);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--burgundy, #5a1a1f);
  }

  .vm-factbox__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.85rem 1.6rem;
    margin: 0;
  }

  .vm-factbox__row {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    border-top: 1px solid var(--ruleSoft, #e0d2b0);
    padding-top: 0.6rem;
  }

  .vm-factbox__label {
    font-family: var(--font-ui, system-ui, sans-serif);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--inkFaint, #8a7e70);
  }

  .vm-factbox__value {
    margin: 0;
    font-family: var(--font-body, Georgia, serif);
    font-size: 1rem;
    line-height: 1.3;
    color: var(--ink, #1f1a16);
  }
</style>
