---
// LAT-2575 — gedeeld streek-detailsjabloon. Geëxtraheerd uit
// src/pages/streken/[slug].astro zodat zowel de NL-route (prefixloos) als de
// /en/-route dezelfde markup delen. Alle chrome loopt via de UI-dictionary
// (loadUiStrings(locale)); de vertaalde content (naam/beschrijving/body) komt
// uit de per-locale loaders in getStaticPaths. Op DEFAULT_LOCALE geeft t() de
// bestaande NL-copy byte-identiek terug (nul NL-regressie); /en/ overlayt EN.
import SiteLayout from '../layouts/SiteLayout.astro';
import AffiliatePlaceholder from './AffiliatePlaceholder.astro';
import AffiliateDisclosure from './AffiliateDisclosure.astro';
import RelatedArticles from './RelatedArticles.astro';
import CtaStructure from './CtaStructure.astro';
import HubBacklink from './HubBacklink.astro';
import AccommodatieRoundup from './AccommodatieRoundup.astro';
import StreekKaart, { type StreekPoiInput } from './StreekKaart.astro';
import StreekFeitenblok from './StreekFeitenblok.astro';
import RouteMap from './RouteMap.astro';
import TourCards from './TourCards.astro';
import ZelfGereisdBadge from './ZelfGereisdBadge.astro';
import NewsletterFooter from './NewsletterFooter.astro';
import { accommodatieBookingDeeplink } from '../lib/affiliates';
import { type Streek, type Accommodation } from '../lib/streken';
import { clustersFromCuratedStays, staySlug } from '../lib/curated-stays';
import { matchWijnhuisByName, type Wijnhuis } from '../lib/wijnhuizen';
import type { AccommodatieRoundup as AccommodatieRoundupData } from '../lib/accommodaties';
import { type WijnRoute } from '../lib/routes';
import { currencyForLand, formatNightlyPrice } from '../lib/currency';
import { streekSchema, streekMetaTitle, streekMetaDescription, breadcrumbSchema } from '../lib/seo';
import { DEFAULT_LOCALE, type Locale, localizeHref } from '../lib/i18n';
import { loadUiStrings } from '../lib/ui-strings';

interface Props {
  entry: Streek;
  wijnhuizen: Wijnhuis[];
  routes: WijnRoute[];
  accRoundup: AccommodatieRoundupData | null;
  /** LAT-2575: NL byte-identiek op DEFAULT_LOCALE; /en/ geeft "en" mee. */
  locale?: Locale;
  /** LAT-2575: pad-URLs van de tegenhanger per taal voor hreflang. De route
   *  bepaalt of een EN-tegenhanger bestaat (launch-gate); zonder EN-vertaling
   *  bevat dit alleen `nl` en wordt er geen en-hreflang geëmit. */
  alternates?: Partial<Record<Locale, string>>;
}

const { entry, wijnhuizen, routes, accRoundup, locale = DEFAULT_LOCALE, alternates } = Astro.props;

// LAT-2704 — interne hrefs locale-aware; NL blijft byte-identiek.
const lh = (href: string) => localizeHref(href, locale);
// LAT-2575: chrome-labels via de UI-dictionary i.p.v. hardcoded literals. Op
// DEFAULT_LOCALE geeft t() byte-identiek de bestaande NL-copy terug; de
// /en/-tegenhanger overlayt dezelfde keys.
const ui = await loadUiStrings(locale);
const localePrefix = locale === DEFAULT_LOCALE ? '' : `/${locale}`;
const pageUrl = new URL(`${localePrefix}/streken/${entry.slug}/`, Astro.site ?? 'https://vinomartino.com').href;
// LAT-1664: bron-valuta volgt het land van de streek (Zuid-Afrika → ZAR);
// bedragen worden naar EUR geconverteerd voor weergave (board-besluit). Een
// per-accommodatie valuta (acc.valuta) wint als bron over de land-default.
const streekValuta = currencyForLand(entry.landSlug);

// LAT-2436: preselecteer de regiovraag in de nieuwsbrief-footer wanneer de streek
// overeenkomt met een van de 4 MailerLite-routing-regio's (region_preference).
const streekRegio = `${entry.slug} ${entry.landSlug ?? ''}`.toLowerCase();
const newsletterRegion: 'Piemonte' | 'Toscane' | 'Alsace' | null =
  /piemonte|langhe/.test(streekRegio) ? 'Piemonte'
  : /toscane|toscana/.test(streekRegio) ? 'Toscane'
  : /alsace|elzas/.test(streekRegio) ? 'Alsace'
  : null;

// LAT-1199: verticale kruimel Land → Streek.
const hasParentLand = Boolean(entry.landSlug && entry.country);
// LAT-1607: de afgesproken 3x3x3 gouden-standaard (LAT-1413/LAT-1599) wint.
// Heeft de streek een curated accommodatie-set (Accommodation Scout → Directus,
// 9 verblijven in 3 tiers), dan rendert het overnachten-blok als die 3x3x3-grid.
// Pas zonder curated set valt de pagina terug op de reisjunk-roundup; ontbreekt
// ook die, dan rendert er geen overnachten-blok (LAT-1640: geen generieke
// Stay22-zoekwidget meer).
const hasCuratedStays = entry.accommodaties.length > 0;
const hasReisjunkRoundup = Boolean(accRoundup && accRoundup.clusters.some(c => c.kaarten.length > 0));

// LAT-1592 — unified streek "money page": bouw de vier POI-categorieën voor de
// gedeelde kaart + genummerde blokken. Categorieën zonder data renderen niet.

// LAT-2554: pin-coördinaten (entry.wijnhuizen) gekoppeld aan de detailpagina's
// (loadWijnhuizen) via een tolerante naam-matcher (matchWijnhuisByName), zodat
// producer-prefixen/accenten/aliassen (bv. "Terroir al Limit" ↔ "Terroir al
// Límit", "F.X. Pichler") toch koppelen. Een pin die NIET matcht met een
// gepubliceerd wijnhuis-record wordt overgeslagen: een half record (alleen titel,
// geen foto/beschrijving/link) mag NOOIT als ghost-card renderen (HARDE REGEL 3).
const usedWijnhuisSlugs = new Set<string>();
const wijnhuizenInput: StreekPoiInput[] = [];
for (const pin of entry.wijnhuizen) {
  const detail = matchWijnhuisByName(pin.naam, wijnhuizen);
  if (!detail) continue;
  usedWijnhuisSlugs.add(detail.slug);
  wijnhuizenInput.push({
    naam: detail.name,
    lat: pin.lat,
    lng: pin.lng,
    beschrijving: detail.description ?? '',
    detailUrl: `/wijnhuizen/${detail.slug}/`,
    foto: detail.heroImage ?? null,
    fotoAlt: detail.name,
  });
}
for (const detail of wijnhuizen) {
  if (usedWijnhuisSlugs.has(detail.slug)) continue;
  wijnhuizenInput.push({
    naam: detail.name,
    lat: null,
    lng: null,
    beschrijving: detail.description ?? '',
    detailUrl: `/wijnhuizen/${detail.slug}/`,
    foto: detail.heroImage ?? null,
    fotoAlt: detail.name,
  });
}

function accPrice(acc: Accommodation): string | null {
  // LAT-1775: bron-valuta volgt het verblijf zelf, default EUR (streekValuta is
  // sinds LAT-1775 EUR voor alle landen — geen land-aanname meer die EUR-prijzen als
  // ZAR door ~20 deelt). formatNightlyPrice onderdrukt absurde uitschieters.
  const bron = acc.valuta || streekValuta;
  const laag = formatNightlyPrice(acc.prijsLaag, bron, 'EUR', `${acc.naam} (laag)`);
  const hoog = formatNightlyPrice(acc.prijsHoog, bron, 'EUR', `${acc.naam} (hoog)`);
  // LAT-2771: prijs-affixen via de UI-dictionary, anders NL op /en/.
  const perNight = ui.t('stay.price.perNight');
  if (laag && hoog) return `${laag}–${hoog} ${perNight}`;
  if (laag) return `${ui.t('stay.price.fromPrefix')} ${laag} ${perNight}`;
  if (hoog) return `${ui.t('stay.price.upToPrefix')} ${hoog} ${perNight}`;
  return null;
}
// LAT-1634: het 3x3x3-grid linkte via Stay22 Allez (allezSearchUrl), wat bij
// verblijven zonder eigen property-URL op een generieke stad-/zoekpagina landde
// (3 van 4 fout). We volgen nu dezelfde regel als de artikel-affiliateblokken
// (LAT-1549/1400): ALTIJD een directe, ad-blocker-bestendige booking.com-deeplink
// mét affiliate-aid + CJ-label, onafhankelijk van wat de data bevat.
function accSid(acc: Accommodation): string {
  const namePart = acc.naam.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
  return `streek-${entry.slug}-${namePart}`;
}
function accBoeklink(acc: Accommodation): string {
  // LAT-1775: gedeelde resolver met /accommodaties/<slug>/. Een kale /hotel/-URL
  // resolvet niet en bounced met aid=818285 toch naar searchresults → we bouwen
  // direct een boekbare booking.com-searchresults-deeplink op de hotelnaam (aid + label).
  return accommodatieBookingDeeplink(acc.naam, entry.name, acc.boeklink, accSid(acc));
}
// LAT-1644: de curated set voedt het overnachten-blok, maar gegroepeerd op
// 40-min-cluster (LAT-1406) i.p.v. op tier. De tiers staan GEMENGD binnen een
// cluster en blijven als badge per kaart zichtbaar (STAY_TIER_META). Zo toont
// /streken dezelfde geografische cluster-layout als /accommodaties i.p.v. de
// oude Slim geboekt / Prijs-kwaliteit / Pure luxe tier-secties. We bouwen de
// POI's in clustervolgorde (binnen cluster al op tier gesorteerd) zodat de
// gedeelde nummering 1..N per cluster oploopt.
const stayClusters = hasCuratedStays ? clustersFromCuratedStays(entry) : [];
const accBySlug = new Map(entry.accommodaties.map(acc => [staySlug(acc.naam), acc]));
const overnachtenInput: StreekPoiInput[] = stayClusters.flatMap(cluster =>
  cluster.kaarten.flatMap(kaart => {
    const acc = accBySlug.get(kaart.slug);
    if (!acc) return [];
    return [{
      naam: acc.naam,
      lat: acc.lat,
      lng: acc.lng,
      whyRegel: acc.whyThisOne,
      disclosure: ui.t('stay.disclosure.microcopy'),
      prijs: accPrice(acc),
      boeklink: accBoeklink(acc),
      tier: acc.tier,
      badge: acc.tier ? ui.t(`stay.tier.${acc.tier}`) : null,
      clusterSlug: cluster.slug,
      clusterTitel: cluster.titel,
      partner: 'booking',
      foto: acc.foto ?? null,
      fotoAlt: acc.naam,
    }];
  }),
);

const etenInput: StreekPoiInput[] = entry.eten.map(p => ({
  naam: p.naam,
  lat: p.lat,
  lng: p.lng,
  beschrijving: p.beschrijving,
  prijs: p.prijs || null,
  boeklink: p.boeklink || null,
  partner: 'eten',
}));
const activiteitenInput: StreekPoiInput[] = entry.activiteiten.map(p => ({
  naam: p.naam,
  lat: p.lat,
  lng: p.lng,
  beschrijving: p.beschrijving,
  prijs: p.prijs || null,
  boeklink: p.boeklink || null,
  partner: 'getyourguide',
}));

const hasUnifiedPoi = wijnhuizenInput.length > 0 || overnachtenInput.length > 0 || etenInput.length > 0 || activiteitenInput.length > 0;

// LAT-2009 (VIS-BL-10) — "aantal adressen" voor het feitenblok: tel de gecureerde
// POI's met coördinaten over alle vier categorieën, zodat het getal exact matcht
// met de genummerde pins op de kaart (StreekKaart nummert enkel geplotte POI's).
const aantalAdressen = [...wijnhuizenInput, ...overnachtenInput, ...etenInput, ...activiteitenInput]
  .filter((p) => p.lat != null && p.lng != null).length;

const schema = [
  streekSchema({
    name: entry.name,
    description: entry.description,
    image: entry.heroImage,
    country: entry.country,
    subregions: entry.subRegions,
    grapeVarieties: entry.mainGrapes,
    pageUrl,
  }),
  breadcrumbSchema([
    { name: ui.t('streek.breadcrumb.home'), url: '/' },
    ...(hasParentLand
      ? [
          { name: ui.t('streek.breadcrumb.landen'), url: '/landen/' },
          { name: entry.country, url: `/landen/${entry.landSlug}/` },
        ]
      : [{ name: ui.t('streek.breadcrumb.streken'), url: '/streken/' }]),
    { name: entry.name, url: pageUrl },
  ]),
];

// LAT-2009: druiven verhuisd naar het feitenblok, dus niet langer een trigger
// voor de hero-stats-sidebar.
const hasStats = Boolean(
  entry.climate ||
  entry.soil ||
  entry.vineyardArea ||
  entry.altitude,
);
// LAT-1676/LAT-2009 — render het feitenblok alleen als er minstens één gevuld
// veld (of afgeleid aantal adressen) is.
const hasFactBox = Boolean(
  entry.mainGrapes.length ||
  entry.appellations.length ||
  entry.bestVintages ||
  entry.harvestPeriod ||
  entry.minVisitTime ||
  entry.tastingBudget ||
  entry.bestSeason ||
  entry.driveDays ||
  entry.nearestAirport ||
  aantalAdressen > 0,
);
---

<SiteLayout
  title={streekMetaTitle(entry.name, entry.country, locale)}
  description={streekMetaDescription({ name: entry.name, country: entry.country, grapeVarieties: entry.mainGrapes, description: entry.description }, locale)}
  ogImage={entry.ogImage || entry.heroImage || undefined}
  schema={schema}
  activeNav="streken"
  locale={locale}
  alternates={alternates}
>
  <article class="streek-page">
    <section class="streek-hero">
      <div class="container">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href={lh('/')}>{ui.t('streek.breadcrumb.home')}</a> /
          {hasParentLand ? (
            <><a href={lh('/landen/')}>{ui.t('streek.breadcrumb.landen')}</a> / <a href={lh(`/landen/${entry.landSlug}/`)}>{entry.country}</a> / </>
          ) : (
            <><a href={lh('/streken/')}>{ui.t('streek.breadcrumb.streken')}</a> / </>
          )}
          <span>{entry.name}</span>
        </nav>
        <div class:list={['streek-hero__grid', !hasStats && 'streek-hero__grid--no-stats']}>
          <div>
            <span class="section-label">{ui.t('streek.label.wijnstreek')}</span>
            <ZelfGereisdBadge visited={entry.zelfGereisd} year={entry.bezoekjaar} locale={locale} />
            <h1>{entry.name}</h1>
            {entry.country && <p class="streek-country">{entry.country}</p>}
            {entry.description && <p class="streek-subtitle">{entry.description}</p>}
          </div>
          {hasStats && (
            <div class="streek-stats">
              {/* LAT-2009 (VIS-BL-10): "Druivenrassen" verwijderd uit de hero-sidebar.
                  De druiven staan nu nog maar op één plek: het feitenblok "In het
                  kort" eronder. Zo vervalt de dubbele druivenlijst. */}
              {entry.climate && (
                <div class="stat">
                  <span class="stat-label">{ui.t('streek.stat.klimaat')}</span>
                  <span class="stat-value">{entry.climate}</span>
                </div>
              )}
              {entry.soil && (
                <div class="stat">
                  <span class="stat-label">{ui.t('streek.stat.bodem')}</span>
                  <span class="stat-value">{entry.soil}</span>
                </div>
              )}
              {entry.vineyardArea && (
                <div class="stat">
                  <span class="stat-label">{ui.t('streek.stat.oppervlakte')}</span>
                  <span class="stat-value">{entry.vineyardArea}</span>
                </div>
              )}
              {entry.altitude && (
                <div class="stat">
                  <span class="stat-label">{ui.t('streek.stat.hoogte')}</span>
                  <span class="stat-value">{entry.altitude}</span>
                </div>
              )}
            </div>
          )}
        </div>
      </div>
      {entry.heroImage && (
        <figure class="streek-hero-img-wrap">
          <img src={entry.heroImage} alt={entry.name} class="streek-hero-img" loading="eager" />
          {entry.heroCredit && (
            <figcaption class="streek-hero-credit">
              {entry.heroCredit.author}
              {entry.heroCredit.licenseLabel && (
                <> — {entry.heroCredit.licenseUrl
                  ? <a href={entry.heroCredit.licenseUrl} rel="license noopener" target="_blank">{entry.heroCredit.licenseLabel}</a>
                  : entry.heroCredit.licenseLabel}</>
              )}
              {entry.heroCredit.sourceUrl && (
                <> — <a href={entry.heroCredit.sourceUrl} rel="noopener" target="_blank">{ui.t('streek.hero.bron')}</a></>
              )}
            </figcaption>
          )}
        </figure>
      )}
    </section>

    {/* LAT-2009 (VIS-BL-10) — Streek-feitenblok "In het kort 2.0": één monospace
        feitenblok met druiven, beste seizoen, rijdagen, dichtstbijzijnd vliegveld,
        aantal adressen en tier-badge (+ wijndetailrijen). Vervangt de oude
        WijnFactBox én de dubbele druivenlijst in de hero-sidebar. Rendert alleen
        als er gevulde velden zijn (geen lege box op streken zonder data). */}
    {hasFactBox && (
      <section class="streek-factbox-section">
        <div class="container">
          <StreekFeitenblok
            dominantGrapes={entry.mainGrapes}
            bestSeason={entry.bestSeason}
            driveDays={entry.driveDays}
            nearestAirport={entry.nearestAirport}
            aantalAdressen={aantalAdressen}
            appellations={entry.appellations}
            bestVintages={entry.bestVintages}
            harvestPeriod={entry.harvestPeriod}
            minVisitTime={entry.minVisitTime}
            tastingBudget={entry.tastingBudget}
            visited={entry.zelfGereisd}
            bezoekjaar={entry.bezoekjaar}
            locale={locale}
          />
        </div>
      </section>
    )}

    {/* LAT-1592 — unified POI "geld-pagina": dubbele kaart + genummerde blokken
        over alle vier categorieën (wijnhuizen, eten, overnachten, activiteiten).
        LAT-1607: het overnachten-blok groepeert de gecureerde 9 in de 3x3x3
        gouden-standaard (slim_geboekt / prijs_kwaliteit / pure_luxe). Heeft een
        streek geen gecureerde accommodaties, dan valt het terug op de reisjunk-
        roundup. LAT-1640: zonder gecureerde data rendert er geen blok meer
        (geen generieke Stay22-zoekwidget). */}
    {(hasUnifiedPoi || (!hasCuratedStays && hasReisjunkRoundup)) && (
      <section class="streek-poi">
        <div class="container">
          {hasUnifiedPoi && (
            <StreekKaart
              streek={entry.name}
              slug={entry.slug}
              country={entry.country}
              wijnhuizen={wijnhuizenInput}
              overnachten={overnachtenInput}
              eten={etenInput}
              activiteiten={activiteitenInput}
              locale={locale}
            />
          )}
          {!hasCuratedStays && hasReisjunkRoundup && (
            <AccommodatieRoundup roundup={accRoundup!} context={entry.slug} bronValuta={streekValuta} locale={locale} />
          )}
        </div>
      </section>
    )}

    {/* LAT-1608 — routes prominenter: direct na de POI-kaart, met een visueel
        van-naar kaartje per route i.p.v. onderaan de pagina. */}
    {routes.length > 0 && (
      <section class="streek-routes">
        <div class="container">
          <div class="streek-routes__head">
            <span class="section-label">{ui.t('streek.section.wijnroutes')}</span>
            <h2 class="streek-routes__title">{`${ui.t('streek.routes.rijdPrefix')} ${entry.name}`}</h2>
            <p class="streek-routes__intro">{ui.t('streek.routes.intro')}</p>
          </div>
          <div class="route-grid">
            {routes.map(route => (
              <a class="route-card" href={lh(`/wijnroutes/${route.slug}/`)}>
                <span class="route-card__name">{route.title}</span>
                {route.stops.length >= 2 && (
                  <RouteMap stops={route.stops} variant="mini" locale={locale} />
                )}
                {route.description && <span class="route-card__desc">{route.description}</span>}
                <div class="route-card__meta">
                  {route.duration && <span class="route-card__tag">{route.duration}</span>}
                  {route.transport && <span class="route-card__tag">{route.transport}</span>}
                </div>
                <span class="route-card__cta">{ui.t('streek.route.bekijkCta')} &rarr;</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    {/* LAT-2252 — gecureerde GetYourGuide-tours (activiteitenkanaal). Rendert
        alleen als er tours in Directus (streken.gyg_tours) staan. */}
    <TourCards streekSlug={entry.slug} streekName={entry.name} tours={entry.gygTours} locale={locale} />

    {entry.bodyHtml && (
      <section class="streek-body">
        <div class="streek-body__inner">
          <div class="streek-prose" set:html={entry.bodyHtml} />
          {entry.activiteiten.length === 0 && (
            <AffiliatePlaceholder type="activity" partner="getyourguide" region={entry.name} placement="inline-end" context="streek-activity" locale={locale} />
          )}
        </div>
      </section>
    )}

    {entry.subRegions.length > 0 && (
      <section class="streek-subregions">
        <div class="container">
          <span class="section-label">{ui.t('streek.section.deelregios')}</span>
          <div class="subregion-grid">
            {entry.subRegions.map(sub => (
              <div class="subregion-chip">{sub}</div>
            ))}
          </div>
        </div>
      </section>
    )}

    {entry.appellations.length > 0 && (
      <section class="streek-appellations">
        <div class="container">
          <span class="section-label">{ui.t('streek.section.appellations')}</span>
          <div class="appellation-grid">
            {entry.appellations.map(app => (
              <div class="appellation-chip">{app}</div>
            ))}
          </div>
        </div>
      </section>
    )}

    <CtaStructure data={entry.cta} sid={entry.slug} locale={locale} />

    <RelatedArticles items={entry.relatedArticles} locale={locale} />

    <HubBacklink type="streek" slug={entry.slug} locale={locale} />

    <AffiliateDisclosure locale={locale} />
  </article>

  <NewsletterFooter defaultRegion={newsletterRegion} locale={locale} />
</SiteLayout>

<style>
  .streek-hero {
    background: var(--paper);
    padding-top: 3rem;
  }
  .breadcrumb {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--inkFaint);
    margin-bottom: var(--space-4);
  }
  .breadcrumb a {
    color: var(--inkSoft);
    text-decoration: none;
  }
  .breadcrumb a:hover { text-decoration: underline; }
  .streek-hero__grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 3rem;
    align-items: end;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--rule);
  }
  .streek-hero__grid--no-stats {
    grid-template-columns: 1fr;
  }
  .streek-hero__grid h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 1.5rem + 5vw, 5rem);
    font-weight: 500;
    line-height: 0.95;
    color: var(--ink);
    margin: 0;
  }
  .streek-country {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--rust);
    margin-top: var(--space-3);
  }
  .streek-subtitle {
    font-family: var(--font-body);
    font-size: 1.125rem;
    line-height: 1.5;
    font-style: italic;
    color: var(--inkSoft);
    margin-top: var(--space-3);
    max-width: 46ch;
    /* LAT-2009 (VIS-BL-10): cursief-intro's beperken tot max 4 regels. */
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 4;
    overflow: hidden;
  }
  .streek-stats {
