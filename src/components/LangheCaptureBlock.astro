---
// LAT-2022: Langhe-PDF lead magnet capture block.
// Variant: Configurable (A = mid-article, C = homepage-style)
// MailerLite form posts to PUBLIC_MAILERLITE_FORM_ACTION (same as /de-brief/ page).

export interface Props {
  variant?: 'a' | 'c';
}

const { variant = 'a' } = Astro.props;

const FORM_ACTION =
  import.meta.env.PUBLIC_MAILERLITE_FORM_ACTION ||
  'https://assets.mailerlite.com/jsonp/2415940/forms/189828746131277541/subscribe';

const variants = {
  a: {
    koptekst: 'De volledige reisplanner als PDF',
    body: 'Dit artikel geeft de kern. Als je de route daadwerkelijk rijdt, is er meer: telefoonnummers voor de wijnhuizen, openingstijden per seizoen, en een overzicht van wat elke dag kost. Dat staat in de compacte Langhe-PDF die ik stuur naar iedereen die zich aanmeldt voor De Brief.',
    ctaText: 'Stuur me de Langhe-PDF',
    subCopy: 'Elke twee weken ontvang je ook De Brief: over wijn, reizen en de mensen erachter. Uitschrijven kan altijd.',
  },
  c: {
    koptekst: 'Begin met Piemonte',
    body: 'Als je wilt weten waar te beginnen in de Langhe: ik schreef een compacte reisplanner. Route, wijnhuizen, hotels, budget. Aanmelden voor De Brief, en hij is meteen van jou.',
    ctaText: 'Stuur me de Langhe-PDF',
    subCopy: 'Elke twee weken volgt De Brief: over wijn en reizen vanuit eigen ervaring.',
  },
};

const copy = variants[variant];
---

<section class="langhe-capture-block langhe-capture-block--{variant}">
  <div class="capture-inner">
    <h2 class="capture-koptekst">{copy.koptekst}</h2>
    <p class="capture-body">{copy.body}</p>

    <form
      class="capture-form"
      action={FORM_ACTION}
      method="post"
      target="_blank"
      data-newsletter-signup
    >
      <label for="ml-email-{variant}" class="visually-hidden">E-mailadres</label>
      <input
        id="ml-email-{variant}"
        type="email"
        name="fields[email]"
        autocomplete="email"
        placeholder="je@adres.nl"
        required
      />
      {/* Langhe-leadmagneet hoort bij Piemonte: routeer naar de Piemonte-automation. */}
      <input type="hidden" name="fields[region_preference]" value="Piemonte" />
      <button type="submit" data-plausible-cta="langhe_pdf_signup">{copy.ctaText}</button>
    </form>

    <p class="capture-subtext">{copy.subCopy}</p>
  </div>
</section>

<style>
  .langhe-capture-block {
    margin: var(--space-12) 0;
    padding: var(--space-8) var(--space-6);
    background: var(--paperDeep);
    border-radius: 4px;
  }

  .langhe-capture-block--c {
    background: var(--paper);
    padding: var(--space-12) var(--space-8);
    margin: var(--space-16) 0;
  }

  .capture-inner {
    max-width: 640px;
    margin: 0 auto;
  }

  .capture-koptekst {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.5rem, 2vw, 2rem);
    line-height: 1.1;
    color: var(--ink);
    margin: 0 0 var(--space-4);
  }

  .capture-body {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--inkSoft);
    margin: 0 0 var(--space-6);
  }

  .capture-form {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .capture-form input {
    flex: 1;
    min-width: 240px;
    padding: 0.95rem 1rem;
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    border: 1px solid var(--rule);
    border-radius: 2px;
    background: var(--fixed-cream);
    color: var(--ink);
  }

  .capture-form input::placeholder {
    color: var(--inkFaint);
  }

  .capture-form input:focus {
    outline: none;
    border-color: var(--burgundy);
    box-shadow: 0 0 0 2px rgba(94, 26, 29, 0.1);
  }

  .capture-form button {
    padding: 0.95rem 1.85rem;
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    background: var(--burgundy);
    color: var(--fixed-cream);
    border: 1px solid var(--burgundy);
    border-radius: 2px;
    cursor: pointer;
    transition: background var(--duration-fast) var(--ease-out), border-color var(--duration-fast) var(--ease-out);
  }

  .capture-form button:hover {
    background: var(--burgundyDeep);
    border-color: var(--burgundyDeep);
  }

  .capture-subtext {
    font-family: var(--font-body);
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--inkFaint);
    margin: 0;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
