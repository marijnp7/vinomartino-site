---
// LAT-1784 — Orchestrator voor de gestandaardiseerde 3-CTA-structuur.
// Twee gebruiksmodi:
//   1. Inline op één plek (money-pages / landen-hub LAT-1786): mount deze
//      component één keer en de drie CTA's stapelen in volgorde.
//   2. Verspreid over de pagina (streek-/wijnhuis-templates): importeer in plaats
//      hiervan de discrete CtaPrimary/CtaComparison/CtaClosing en plaats ze op de
//      gewenste scrollposities (boven / midden / einde).
// Data-driven uit Directus via getCtaStructure(); graceful degradation overal.
import CtaPrimary from './CtaPrimary.astro';
import CtaComparison from './CtaComparison.astro';
import CtaClosing from './CtaClosing.astro';
import type { CtaStructure } from '../lib/cta-blocks';
import { DEFAULT_LOCALE, type Locale } from '../lib/i18n';

interface Props {
  data: CtaStructure;
  sid: string;
  locale?: Locale;
}

const { data, sid, locale = DEFAULT_LOCALE } = Astro.props;
---

<CtaPrimary data={data.primary} sid={sid} locale={locale} />
<CtaComparison data={data.comparison} sid={sid} locale={locale} />
<CtaClosing data={data.closing} sid={sid} locale={locale} />
