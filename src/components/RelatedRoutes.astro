---
import { DEFAULT_LOCALE, type Locale, localizeHref } from '../lib/i18n';
interface RelatedItem {
  title: string;
  slug: string;
  duration?: string;
  transport?: string;
}

interface Props {
  /** LAT-2704 — locale van de renderende pagina; stuurt de interne hrefs. */
  locale?: Locale;
  items: RelatedItem[];
  title?: string;
}

const { items, title = 'Wijnroutes in de buurt', locale = DEFAULT_LOCALE } = Astro.props;

// LAT-2704 — interne hrefs locale-aware; NL blijft byte-identiek.
const lh = (href: string) => localizeHref(href, locale);
---

{items.length > 0 && (
  <section class="related-section">
    <div class="container">
      <span class="related-label">Wijnroutes</span>
      <h2 class="related-title">{title}</h2>
      <div class="related-grid">
        {items.map(item => (
          <a href={lh(`/wijnroutes/${item.slug}/`)} class="related-card">
            <div class="related-body">
              <div class="related-badges">
                {item.duration && <span class="related-badge">{item.duration}</span>}
                {item.transport && <span class="related-badge">{item.transport}</span>}
              </div>
              <span class="related-name">{item.title}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .related-section {
    padding: 3rem 0;
    border-top: 1px solid var(--rule);
  }
  .related-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--burgundy);
    display: block;
    margin-bottom: 0.5rem;
  }
  .related-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--ink);
    margin: 0 0 1.5rem;
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .related-card {
    text-decoration: none;
    color: inherit;
    background: var(--paperDeep);
    padding: 1rem 1.25rem;
    border-radius: var(--radius-sm);
    transition: box-shadow var(--duration-fast) var(--ease-out);
  }
  .related-card:hover {
    box-shadow: var(--shadow-card-hover);
  }
  .related-badges {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.375rem;
  }
  .related-badge {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: var(--paper);
    color: var(--inkSoft);
    padding: 0.15rem 0.5rem;
    border-radius: 1px;
  }
  .related-name {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--ink);
  }
  @media (max-width: 900px) {
    .related-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .related-grid { grid-template-columns: 1fr; }
  }
</style>
