---
// LAT-2709 — gedeeld landen-overzicht (listing-index). De NL-route
// (src/pages/landen/index.astro) en de /en/-tegenhanger
// (src/pages/en/landen/index.astro) renderen dit component; `locale` stuurt de
// data-loader (loadLanden) en de UI-dictionary (ui.t). NL is byte-identiek: elke
// chrome-string valt terug op de NL-default in UI_STRING_DEFAULTS en de
// empty-state-link rendert alleen als er een descLink is (NL = leeg).
import SiteLayout from '../layouts/SiteLayout.astro';
import SmartImg from '../components/SmartImg.astro';
import { loadLanden } from '../lib/landen';
import { organizationSchema, breadcrumbSchema } from '../lib/seo';
import { loadUiStrings } from '../lib/ui-strings';
import { DEFAULT_LOCALE, localizePath, type Locale } from '../lib/i18n';

interface Props {
  locale?: Locale;
  alternates?: Partial<Record<Locale, string>>;
}

const { locale = DEFAULT_LOCALE, alternates } = Astro.props;
const ui = await loadUiStrings(locale);

const entries = await loadLanden(locale);

const emptyLink = ui.t('landen.index.empty.descLink');

const schema = [
  organizationSchema(),
  breadcrumbSchema([
    { name: ui.t('streek.breadcrumb.home'), url: localizePath('/', locale) },
    { name: ui.t('streek.breadcrumb.landen'), url: localizePath('/landen/', locale) },
  ]),
];
---

<SiteLayout
  title={ui.t('landen.index.meta.title')}
  description={ui.t('landen.index.meta.description')}
  schema={schema}
  activeNav="landen"
  locale={locale}
  alternates={alternates}
>
  <section class="hero-sm">
    <div class="container">
      <span class="section-label">{ui.t('landen.index.hero.label')}</span>
      <h1 set:html={ui.t('landen.index.hero.h1')} />
      <p class="hero-desc">{ui.t('landen.index.hero.desc')}</p>
    </div>
  </section>

  <section class="section container">
    {entries.length > 0 ? (
      <div class="grid">
        {entries.map(entry => (
          <a href={localizePath(`/landen/${entry.slug}/`, locale)} class="card card-link">
            <div class:list={['card-img-wrap', !entry.heroImage && 'is-empty']}>
              <SmartImg src={entry.heroImage || undefined} alt={entry.name} theme="region" class="card-img" />
            </div>
            <div class="card-body">
              {entry.continent && <span class="card-continent">{entry.continent}</span>}
              <h2 class="card-title">{entry.name}</h2>
              {entry.description && <p class="card-desc">{entry.description}</p>}
              {entry.mainGrapes && entry.mainGrapes.length > 0 && (
                <div class="card-tags">
                  {entry.mainGrapes.slice(0, 4).map(g => <span class="tag">{g}</span>)}
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <h2>{ui.t('landen.index.empty.title')}</h2>
        <p>{ui.t('landen.index.empty.descPre')}{emptyLink && <a href={localizePath('/artikelen/', locale)}>{emptyLink}</a>}{ui.t('landen.index.empty.descPost')}</p>
      </div>
    )}
  </section>
</SiteLayout>

<style>
  .hero-sm {
    background: var(--paperDeep);
    padding: var(--space-12) 0 var(--space-8);
    text-align: center;
  }
  .hero-sm h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.6rem + 1.5vw, 3rem);
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin-top: var(--space-3);
  }
  .hero-desc {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--inkSoft);
    margin-top: var(--space-3);
    max-width: 36rem;
    margin-inline: auto;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: var(--space-6);
  }
  /* LAT-1118 (M5-hardening): voorkom horizontale overflow op smalle telefoons
     (<=360px Android / 320px iPhone SE) waar de track de viewport overschrijdt. */
  @media (max-width: 420px) {
    .grid { grid-template-columns: 1fr; }
  }
  .card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .card-img-wrap {
    aspect-ratio: 16 / 11;
    overflow: hidden;
    background: var(--paperShade);
  }
  /* LAT-2455: geen beeld → compacte branded band i.p.v. loze reuzenvlak op mobiel. */
  .card-img-wrap.is-empty {
    aspect-ratio: auto;
    height: clamp(96px, 26vw, 140px);
  }
  .card-img-wrap :global(img),
  .card-img-wrap :global(.smart-img-placeholder) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-image) var(--ease-out);
  }
  .card-link:hover .card-img-wrap :global(img) { transform: scale(1.03); }
  .card-body { padding: 1.25rem; }
  .card-continent {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--vine);
    display: block;
    margin-bottom: var(--space-2);
  }
  .card-title {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: var(--space-2);
    line-height: 1.25;
  }
  .card-desc {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--inkSoft);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: var(--space-3);
  }
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: var(--paperDeep);
    color: var(--inkSoft);
    padding: 0.25rem 0.625rem;
    border-radius: 1px;
  }
  .empty-state {
    text-align: center;
    padding: var(--space-16) var(--space-4);
  }
  .empty-state h2 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin-bottom: var(--space-3);
  }
  .empty-state p {
    font-size: 1rem;
    color: var(--inkSoft);
  }
</style>
