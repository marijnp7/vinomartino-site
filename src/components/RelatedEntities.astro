---
// LAT-1098: forward cross-link block onderaan article-pages. Mengt vier
// gerelateerde-entiteit lijsten in vaste volgorde (streken → wijnhuizen →
// wijnroutes → landen), cap op 6 cards. Section verschijnt niet als alle vier
// leeg zijn (per spec acceptance: geen lege "Gerelateerd"-kop).
import type { RelatedRef } from '../lib/articles';

interface Props {
  streken?: RelatedRef[];
  wijnhuizen?: RelatedRef[];
  wijnroutes?: RelatedRef[];
  landen?: RelatedRef[];
  title?: string;
  maxItems?: number;
}

const {
  streken = [],
  wijnhuizen = [],
  wijnroutes = [],
  landen = [],
  title = 'Lees verder',
  maxItems = 6,
} = Astro.props;

type Card = { slug: string; name: string; type: 'streek' | 'wijnhuis' | 'wijnroute' | 'land' };

const href: Record<Card['type'], (slug: string) => string> = {
  streek: (s) => `/streken/${s}/`,
  wijnhuis: (s) => `/wijnhuizen/${s}/`,
  wijnroute: (s) => `/wijnroutes/${s}/`,
  land: (s) => `/landen/${s}/`,
};

const label: Record<Card['type'], string> = {
  streek: 'Streek',
  wijnhuis: 'Wijnhuis',
  wijnroute: 'Wijnroute',
  land: 'Land',
};

const cards: Card[] = [
  ...streken.map((r) => ({ ...r, type: 'streek' as const })),
  ...wijnhuizen.map((r) => ({ ...r, type: 'wijnhuis' as const })),
  ...wijnroutes.map((r) => ({ ...r, type: 'wijnroute' as const })),
  ...landen.map((r) => ({ ...r, type: 'land' as const })),
].slice(0, maxItems);
---

{cards.length > 0 && (
  <section class="related-entities">
    <div class="container">
      <span class="related-label">Gerelateerd</span>
      <h2 class="related-title">{title}</h2>
      <div class="related-grid">
        {cards.map((card) => (
          <a href={href[card.type](card.slug)} class="related-card">
            <span class="related-meta">{label[card.type]}</span>
            <span class="related-name">{card.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .related-entities {
    padding: 3rem 0;
    border-top: 1px solid var(--rule);
  }
  .related-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--burgundy);
    display: block;
    margin-bottom: 0.5rem;
  }
  .related-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--ink);
    margin: 0 0 1.5rem;
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .related-card {
    text-decoration: none;
    color: inherit;
    background: var(--paperDeep);
    padding: 1rem 1.25rem;
    border-radius: var(--radius-sm);
    transition: box-shadow var(--duration-fast) var(--ease-out);
  }
  .related-card:hover {
    box-shadow: var(--shadow-card-hover);
  }
  .related-meta {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--rust);
    display: block;
    margin-bottom: 0.25rem;
  }
  .related-name {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--ink);
  }
  @media (max-width: 900px) {
    .related-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .related-grid { grid-template-columns: 1fr; }
  }
</style>
