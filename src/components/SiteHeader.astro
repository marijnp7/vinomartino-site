---
import type { Country } from '../lib/countries';

interface Props {
  countries?: Country[];
  activeNav?: string;
}

const { countries = [], activeNav } = Astro.props;

const grouped: Record<string, Country[]> = {};
for (const c of countries) {
  const continent = c.continent || 'Overig';
  if (!grouped[continent]) grouped[continent] = [];
  grouped[continent].push(c);
}

const continentOrder = ['Europa', 'Azië', 'Noord-Amerika', 'Zuid-Amerika', 'Afrika', 'Oceanië', 'Overig'];
const sortedContinents = Object.keys(grouped).sort(
  (a, b) => (continentOrder.indexOf(a) === -1 ? 99 : continentOrder.indexOf(a)) -
            (continentOrder.indexOf(b) === -1 ? 99 : continentOrder.indexOf(b))
);

const nav = [
  { label: 'Landen', href: '/landen/', key: 'landen', hasMega: true },
  { label: 'Bestemmingen', href: '/bestemmingen/', key: 'bestemmingen', hasMega: false },
  { label: 'Reisroutes', href: '/reisroutes/', key: 'reisroutes', hasMega: false },
  { label: 'Artikelen', href: '/artikelen/', key: 'artikelen', hasMega: false },
  { label: 'Over ons', href: '/over-ons/', key: 'over-ons', hasMega: false },
];
---

<header class="site-header">
  <div class="header-utility">
    <div class="header-utility-inner">
      <span>Jouw reisgids voor de wereld</span>
    </div>
  </div>

  <div class="header-main">
    <div class="header-inner">
      <a href="/" class="header-logo" aria-label="Reisgids">
        Reis<span class="logo-dot">·</span>platform
      </a>

      <nav class="header-nav" aria-label="Hoofdnavigatie">
        {nav.map(item => (
          <a
            href={item.href}
            class={`nav-link ${activeNav === item.key ? 'nav-link--active' : ''}`}
            data-menu={item.hasMega ? 'landen' : undefined}
          >
            {item.label}
            {item.hasMega && <span class="nav-chevron" aria-hidden="true">▾</span>}
          </a>
        ))}
      </nav>

      <button class="mobile-toggle" aria-label="Menu openen" aria-expanded="false" aria-controls="mobile-menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  {countries.length > 0 && (
    <div class="mega-menu" id="mega-landen" role="region" aria-label="Landen menu" hidden>
      <div class="mega-inner">
        <div class="mega-brand">
          <div class="mega-brand-icon" aria-hidden="true">🌍</div>
          <strong class="mega-brand-title">Ontdek per land</strong>
          <p class="mega-brand-desc">Kies een continent en ontdek onze landengidsen met praktische info, bestemmingen en reisroutes.</p>
        </div>
        {sortedContinents.map(continent => (
          <div class="mega-col">
            <h4 class="mega-col-heading">{continent}</h4>
            <ul class="mega-col-list" role="list">
              {grouped[continent].map(country => (
                <li><a href={`/landen/${country.slug}/`} class="mega-link">{country.name}</a></li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  )}

  <div class="mobile-menu" id="mobile-menu" hidden>
    <nav>
      {nav.map(item => (
        <a href={item.href} class="mobile-nav-link">{item.label}</a>
      ))}
      {countries.length > 0 && (
        <div class="mobile-countries">
          <span class="mobile-section-label">Landen</span>
          {countries.map(c => (
            <a href={`/landen/${c.slug}/`} class="mobile-nav-link mobile-nav-link--sub">{c.name}</a>
          ))}
        </div>
      )}
    </nav>
  </div>
</header>

<style>
  .header-utility {
    background: var(--paper);
    border-bottom: 1px solid var(--ruleSoft);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--inkSoft);
  }
  .header-utility-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 8px var(--gutter);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .site-header {
    background: var(--paper);
    border-bottom: 1px solid var(--rule);
    position: relative;
    z-index: 100;
  }
  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 20px var(--gutter);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }
  .header-logo {
    font-family: var(--font-display);
    font-size: 2rem;
    font-style: italic;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    line-height: 1;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .logo-dot { font-style: normal; }
  .header-nav {
    display: flex;
    align-items: center;
    gap: 1.75rem;
  }
  .nav-link {
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    padding-bottom: 4px;
    border-bottom: 2px solid transparent;
    transition: color var(--duration-fast) var(--ease-out),
                border-color var(--duration-fast) var(--ease-out);
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    white-space: nowrap;
  }
  .nav-link:hover, .nav-link--active {
    color: var(--burgundy);
    border-bottom-color: var(--burgundy);
  }
  .nav-chevron {
    font-size: 0.5625rem;
    opacity: 0.6;
  }

  .mega-menu {
    background: var(--paperDeep);
    border-top: 1px solid var(--ruleSoft);
    border-bottom: 1px solid var(--rule);
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 99;
    box-shadow: var(--shadow-md);
  }
  .mega-menu[hidden] { display: none; }
  .mega-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 32px var(--gutter);
    display: grid;
    grid-template-columns: 240px repeat(auto-fit, minmax(140px, 1fr));
    gap: 32px;
  }
  .mega-brand-icon {
    font-size: 2rem;
    margin-bottom: 12px;
  }
  .mega-brand-title {
    display: block;
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 8px;
  }
  .mega-brand-desc {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--inkSoft);
    margin: 0;
  }
  .mega-col-heading {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--burgundy);
    margin: 0 0 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--rule);
  }
  .mega-col-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .mega-link {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--ink);
    text-decoration: none;
    transition: color var(--duration-fast);
  }
  .mega-link:hover { color: var(--burgundy); }

  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .mobile-toggle span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--ink);
    border-radius: 1px;
  }
  .mobile-menu {
    background: var(--paper);
    border-top: 1px solid var(--rule);
    padding: 1rem var(--gutter);
  }
  .mobile-menu[hidden] { display: none; }
  .mobile-nav-link {
    display: block;
    padding: 0.75rem 0;
    font-family: var(--font-ui);
    font-size: 1rem;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--ruleSoft);
  }
  .mobile-nav-link--sub {
    padding-left: 1rem;
    font-weight: 400;
    font-size: 0.9375rem;
  }
  .mobile-section-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--inkFaint);
    padding: 1rem 0 0.5rem;
  }
  .mobile-countries {
    border-top: 1px solid var(--rule);
    margin-top: 0.5rem;
  }

  @media (max-width: 900px) {
    .header-nav, .header-utility { display: none; }
    .mobile-toggle { display: flex; }
  }
  @media (max-width: 640px) {
    .header-inner { padding: 16px var(--gutter); }
    .header-logo { font-size: 1.625rem; }
  }
</style>

<script>
  const landenLink = document.querySelector('[data-menu="landen"]') as HTMLElement;
  const megaLanden = document.getElementById('mega-landen') as HTMLElement;
  let closeTimer: ReturnType<typeof setTimeout>;

  function openMega() {
    clearTimeout(closeTimer);
    if (megaLanden) megaLanden.hidden = false;
  }
  function closeMega() {
    closeTimer = setTimeout(() => { if (megaLanden) megaLanden.hidden = true; }, 120);
  }

  if (landenLink && megaLanden) {
    landenLink.addEventListener('mouseenter', openMega);
    landenLink.addEventListener('mouseleave', closeMega);
    megaLanden.addEventListener('mouseenter', () => clearTimeout(closeTimer));
    megaLanden.addEventListener('mouseleave', closeMega);
  }

  const mobileToggle = document.querySelector('.mobile-toggle') as HTMLButtonElement;
  const mobileMenu = document.getElementById('mobile-menu') as HTMLElement;
  mobileToggle?.addEventListener('click', () => {
    const expanded = mobileToggle.getAttribute('aria-expanded') === 'true';
    mobileToggle.setAttribute('aria-expanded', expanded ? 'false' : 'true');
    mobileMenu.hidden = expanded;
  });
</script>
