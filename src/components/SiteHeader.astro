---
import { loadNavigation } from '../lib/navigation';

interface Props {
  activeNav?: string;
}

const { activeNav } = Astro.props;

const nav = await loadNavigation();
---

<header class="site-header">
  <div class="header-utility">
    <div class="header-utility-inner">
      <span>Wijnreizen met karakter</span>
    </div>
  </div>

  <div class="header-main">
    <div class="header-inner">
      <a href="/" class="header-logo" aria-label="VinoMartino">
        Vino<span class="logo-dot">·</span>Martino
      </a>

      <nav class="header-nav" aria-label="Hoofdnavigatie">
        {nav.map(item => (
          <a
            href={item.href}
            class={`nav-link ${activeNav === item.key ? 'nav-link--active' : ''}`}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <div class="header-actions">
        <button
          class="search-trigger"
          type="button"
          data-search-open
          aria-label="Zoeken openen"
          aria-keyshortcuts="Meta+K Control+K"
        >
          <svg class="search-trigger-icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6">
            <circle cx="11" cy="11" r="7"></circle>
            <line x1="16.5" y1="16.5" x2="21" y2="21" stroke-linecap="round"></line>
          </svg>
          <span class="search-trigger-label">Zoeken</span>
          <kbd class="search-trigger-kbd" aria-hidden="true">⌘K</kbd>
        </button>

        <button
          class="cellar-toggle"
          type="button"
          aria-label="Wissel Kelder-modus"
          aria-pressed="false"
          data-cellar-toggle
        >
          <span class="cellar-icon" aria-hidden="true">🌙</span>
          <span class="cellar-label">Kelder</span>
        </button>

        <button class="mobile-toggle" aria-label="Menu openen" aria-expanded="false" aria-controls="mobile-menu">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </div>

  <div class="mobile-menu" id="mobile-menu" hidden>
    <nav>
      <button type="button" class="mobile-nav-link mobile-search-link" data-search-open>
        <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6" width="18" height="18">
          <circle cx="11" cy="11" r="7"></circle>
          <line x1="16.5" y1="16.5" x2="21" y2="21" stroke-linecap="round"></line>
        </svg>
        Zoeken
      </button>
      {nav.map(item => (
        <a href={item.href} class="mobile-nav-link">{item.label}</a>
      ))}
    </nav>
  </div>
</header>

<style>
  .header-utility {
    background: var(--paper);
    border-bottom: 1px solid var(--ruleSoft);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--inkSoft);
  }
  .header-utility-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 8px var(--gutter);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .site-header {
    background: var(--paper);
    border-bottom: 1px solid var(--rule);
    position: relative;
    z-index: 100;
  }
  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 20px var(--gutter);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }
  .header-logo {
    font-family: var(--font-display);
    font-size: 2rem;
    font-style: italic;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    line-height: 1;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .logo-dot { font-style: normal; }
  .header-nav {
    display: flex;
    align-items: center;
    gap: 1.75rem;
  }
  .nav-link {
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    padding-bottom: 4px;
    border-bottom: 2px solid transparent;
    transition: color var(--duration-fast) var(--ease-out),
                border-color var(--duration-fast) var(--ease-out);
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    white-space: nowrap;
  }
  .nav-link:hover, .nav-link--active {
    color: var(--burgundy);
    border-bottom-color: var(--burgundy);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .search-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: transparent;
    border: 1px solid var(--rule);
    color: var(--inkSoft);
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    padding: 0.4375rem 0.625rem;
    cursor: pointer;
    line-height: 1;
    transition: color var(--duration-fast) var(--ease-out),
                border-color var(--duration-fast) var(--ease-out);
  }
  .search-trigger:hover { color: var(--burgundy); border-color: var(--burgundy); }
  .search-trigger-icon { width: 1rem; height: 1rem; flex-shrink: 0; }
  .search-trigger-label { font-weight: 500; }
  .search-trigger-kbd {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--inkFaint);
    border: 1px solid var(--ruleSoft);
    border-radius: var(--radius-sm, 2px);
    padding: 0.125rem 0.3125rem;
    line-height: 1;
  }
  .mobile-search-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--ruleSoft);
    text-align: left;
    cursor: pointer;
    color: var(--ink);
  }
  .cellar-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    background: transparent;
    border: 1px solid var(--rule);
    color: var(--inkSoft);
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 0.4375rem 0.625rem;
    cursor: pointer;
    line-height: 1;
    transition: color var(--duration-fast) var(--ease-out),
                border-color var(--duration-fast) var(--ease-out);
  }
  .cellar-toggle:hover {
    color: var(--burgundy);
    border-color: var(--burgundy);
  }
  [data-theme='cellar'] .cellar-toggle {
    color: var(--gold);
    border-color: var(--gold);
  }
  .cellar-icon { font-size: 0.75rem; }

  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .mobile-toggle span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--ink);
    border-radius: 1px;
  }
  .mobile-menu {
    background: var(--paper);
    border-top: 1px solid var(--rule);
    padding: 1rem var(--gutter);
  }
  .mobile-menu[hidden] { display: none; }
  .mobile-nav-link {
    display: block;
    padding: 0.75rem 0;
    font-family: var(--font-ui);
    font-size: 1rem;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--ruleSoft);
  }

  @media (max-width: 900px) {
    .header-nav, .header-utility { display: none; }
    .mobile-toggle { display: flex; }
    .search-trigger-kbd { display: none; }
  }
  @media (max-width: 640px) {
    .header-inner { padding: 16px var(--gutter); }
    .header-logo { font-size: 1.625rem; }
    .search-trigger { display: none; }
  }
</style>

<script>
  const mobileToggle = document.querySelector('.mobile-toggle') as HTMLButtonElement;
  const mobileMenu = document.getElementById('mobile-menu') as HTMLElement;
  mobileToggle?.addEventListener('click', () => {
    const expanded = mobileToggle.getAttribute('aria-expanded') === 'true';
    mobileToggle.setAttribute('aria-expanded', expanded ? 'false' : 'true');
    mobileMenu.hidden = expanded;
  });

  const cellarToggle = document.querySelector('[data-cellar-toggle]') as HTMLButtonElement;
  cellarToggle?.addEventListener('click', () => {
    const isCellar = document.documentElement.getAttribute('data-theme') === 'cellar';
    if (isCellar) {
      document.documentElement.removeAttribute('data-theme');
      localStorage.setItem('vm-theme', 'paper');
      cellarToggle.setAttribute('aria-pressed', 'false');
    } else {
      document.documentElement.setAttribute('data-theme', 'cellar');
      localStorage.setItem('vm-theme', 'cellar');
      cellarToggle.setAttribute('aria-pressed', 'true');
    }
  });

  if (cellarToggle && document.documentElement.getAttribute('data-theme') === 'cellar') {
    cellarToggle.setAttribute('aria-pressed', 'true');
  }
</script>
