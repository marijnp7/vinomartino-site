---
interface Props {
  activeNav?: string;
}

const { activeNav } = Astro.props;

const nav = [
  { label: 'Artikelen', href: '/artikelen/', key: 'artikelen' },
  { label: 'Over ons', href: '/over-ons/', key: 'over-ons' },
];
---

<header class="site-header">
  <div class="header-utility">
    <div class="header-utility-inner">
      <span>Wijnreizen met karakter</span>
    </div>
  </div>

  <div class="header-main">
    <div class="header-inner">
      <a href="/" class="header-logo" aria-label="VinoMartino">
        Vino<span class="logo-dot">·</span>Martino
      </a>

      <nav class="header-nav" aria-label="Hoofdnavigatie">
        {nav.map(item => (
          <a
            href={item.href}
            class={`nav-link ${activeNav === item.key ? 'nav-link--active' : ''}`}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <button class="mobile-toggle" aria-label="Menu openen" aria-expanded="false" aria-controls="mobile-menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <div class="mobile-menu" id="mobile-menu" hidden>
    <nav>
      {nav.map(item => (
        <a href={item.href} class="mobile-nav-link">{item.label}</a>
      ))}
    </nav>
  </div>
</header>

<style>
  .header-utility {
    background: var(--paper);
    border-bottom: 1px solid var(--ruleSoft);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--inkSoft);
  }
  .header-utility-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 8px var(--gutter);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .site-header {
    background: var(--paper);
    border-bottom: 1px solid var(--rule);
    position: relative;
    z-index: 100;
  }
  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 20px var(--gutter);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }
  .header-logo {
    font-family: var(--font-display);
    font-size: 2rem;
    font-style: italic;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    line-height: 1;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .logo-dot { font-style: normal; }
  .header-nav {
    display: flex;
    align-items: center;
    gap: 1.75rem;
  }
  .nav-link {
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    padding-bottom: 4px;
    border-bottom: 2px solid transparent;
    transition: color var(--duration-fast) var(--ease-out),
                border-color var(--duration-fast) var(--ease-out);
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    white-space: nowrap;
  }
  .nav-link:hover, .nav-link--active {
    color: var(--burgundy);
    border-bottom-color: var(--burgundy);
  }

  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .mobile-toggle span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--ink);
    border-radius: 1px;
  }
  .mobile-menu {
    background: var(--paper);
    border-top: 1px solid var(--rule);
    padding: 1rem var(--gutter);
  }
  .mobile-menu[hidden] { display: none; }
  .mobile-nav-link {
    display: block;
    padding: 0.75rem 0;
    font-family: var(--font-ui);
    font-size: 1rem;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--ruleSoft);
  }

  @media (max-width: 900px) {
    .header-nav, .header-utility { display: none; }
    .mobile-toggle { display: flex; }
  }
  @media (max-width: 640px) {
    .header-inner { padding: 16px var(--gutter); }
    .header-logo { font-size: 1.625rem; }
  }
</style>

<script>
  const mobileToggle = document.querySelector('.mobile-toggle') as HTMLButtonElement;
  const mobileMenu = document.getElementById('mobile-menu') as HTMLElement;
  mobileToggle?.addEventListener('click', () => {
    const expanded = mobileToggle.getAttribute('aria-expanded') === 'true';
    mobileToggle.setAttribute('aria-expanded', expanded ? 'false' : 'true');
    mobileMenu.hidden = expanded;
  });
</script>
