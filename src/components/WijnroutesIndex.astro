---
// LAT-2693 — gedeeld wijnroutes-overzicht (listing-index). NL-route +
// /en/-tegenhanger renderen dit component; `locale` stuurt de loader
// (no-translation-guard) en de UI-dictionary. NL byte-identiek via NL-defaults.
import SiteLayout from '../layouts/SiteLayout.astro';
import SmartImg from '../components/SmartImg.astro';
import HomeRoutesMap from '../components/HomeRoutesMap.astro';
import { loadRoutes } from '../lib/routes';
import { organizationSchema, breadcrumbSchema } from '../lib/seo';
import { loadUiStrings } from '../lib/ui-strings';
import { DEFAULT_LOCALE, localizePath, type Locale } from '../lib/i18n';

interface Props {
  locale?: Locale;
  alternates?: Partial<Record<Locale, string>>;
}

const { locale = DEFAULT_LOCALE, alternates } = Astro.props;
const ui = await loadUiStrings(locale);

const entries = await loadRoutes(locale);

const schema = [
  organizationSchema(),
  breadcrumbSchema([
    { name: ui.t('streek.breadcrumb.home'), url: localizePath('/', locale) },
    { name: ui.t('route.breadcrumb.index'), url: localizePath('/wijnroutes/', locale) },
  ]),
];
---

<SiteLayout
  title={ui.t('wijnroutes.index.meta.title')}
  description={ui.t('wijnroutes.index.meta.description')}
  schema={schema}
  activeNav="wijnroutes"
  locale={locale}
  alternates={alternates}
>
  <section class="hero-sm">
    <div class="container">
      <span class="section-label">{ui.t('wijnroutes.index.hero.label')}</span>
      <h1>{ui.t('wijnroutes.index.hero.h1')}</h1>
      <p class="hero-desc">{ui.t('wijnroutes.index.hero.desc')}</p>
    </div>
  </section>

  <section class="section container">
    {/* LAT-2267 — de kaart toont ALLE routes; het aantal markers == werkelijk
        aantal routes, zodat kaart en lijst eronder één op één overeenkomen. */}
    {entries.length > 0 && <HomeRoutesMap routes={entries} title={ui.t('wijnroutes.index.map.title')} />}
    {entries.length > 0 ? (
      <div class="grid">
        {entries.map(entry => (
          <a href={localizePath(`/wijnroutes/${entry.slug}/`, locale)} class="card card-link">
            <div class:list={['card-img-wrap', !entry.heroImage && 'is-empty']}>
              <SmartImg src={entry.heroImage || undefined} alt={entry.title} theme="region" class="card-img" />
            </div>
            <div class="card-body">
              <div class="card-meta-row">
                {entry.duration && <span class="card-duration">{entry.duration}</span>}
                {entry.transport && <span class="card-transport">{entry.transport}</span>}
                {entry.style && <span class="card-style">{entry.style}</span>}
              </div>
              <h2 class="card-title">{entry.title}</h2>
              {entry.description && <p class="card-desc">{entry.description}</p>}
              {entry.highlights && entry.highlights.length > 0 && (
                <ul class="card-highlights">
                  {entry.highlights.slice(0, 3).map(h => <li>{h}</li>)}
                </ul>
              )}
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <h2>{ui.t('wijnroutes.index.empty.title')}</h2>
        <p>{ui.t('wijnroutes.index.empty.descPre')}<a href={localizePath('/artikelen/', locale)}>{ui.t('wijnroutes.index.empty.descLink')}</a>{ui.t('wijnroutes.index.empty.descPost')}</p>
      </div>
    )}
  </section>
</SiteLayout>

<style>
  .hero-sm {
    background: var(--paperDeep);
    padding: var(--space-12) 0 var(--space-8);
    text-align: center;
  }
  .hero-sm h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.6rem + 1.5vw, 3rem);
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin-top: var(--space-3);
  }
  .hero-desc {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--inkSoft);
    margin-top: var(--space-3);
    max-width: 36rem;
    margin-inline: auto;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: var(--space-6);
  }
  /* LAT-1118 (M5-hardening): voorkom horizontale overflow op smalle telefoons
     (<=360px Android / 320px iPhone SE) waar de track de viewport overschrijdt. */
  @media (max-width: 420px) {
    .grid { grid-template-columns: 1fr; }
  }
  .card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .card-img-wrap {
    aspect-ratio: 16 / 11;
    overflow: hidden;
    background: var(--paperShade);
  }
  /* LAT-2455: geen beeld → compacte branded band i.p.v. loze reuzenvlak op mobiel. */
  .card-img-wrap.is-empty {
    aspect-ratio: auto;
    height: clamp(96px, 26vw, 140px);
  }
  .card-img-wrap :global(img),
  .card-img-wrap :global(.smart-img-placeholder) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-image) var(--ease-out);
  }
  .card-link:hover .card-img-wrap :global(img) { transform: scale(1.03); }
  .card-body { padding: 1.25rem; }
  .card-meta-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: var(--space-2);
    flex-wrap: wrap;
  }
  .card-duration, .card-transport, .card-style {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: var(--paperDeep);
    color: var(--inkSoft);
    padding: 0.2rem 0.5rem;
    border-radius: 1px;
  }
  .card-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: var(--space-2);
    line-height: 1.25;
  }
  .card-desc {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--inkSoft);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: var(--space-3);
  }
  .card-highlights {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .card-highlights li {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--inkFaint);
  }
  .card-highlights li::before {
    content: '— ';
  }
  .empty-state {
    text-align: center;
    padding: var(--space-16) var(--space-4);
  }
  .empty-state h2 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin-bottom: var(--space-3);
  }
  .empty-state p {
    font-size: 1rem;
    color: var(--inkSoft);
  }
</style>
