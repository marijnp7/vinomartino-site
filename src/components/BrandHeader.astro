---
import type { Brand } from '../lib/brands';

interface Props {
  brand: Brand;
  locale: string;
}

const { brand, locale } = Astro.props;
const base = `/${brand.slug}/${locale}`;

const megaRegions: Record<string, { name: string; slug: string }[]> = {
  'Italië': [
    { name: 'Piemonte', slug: 'piemonte' },
    { name: 'Toscane', slug: 'toscane' },
    { name: 'Etna / Sicilië', slug: 'sicilie' },
    { name: 'Veneto', slug: 'veneto' },
  ],
  'Frankrijk': [
    { name: 'Bourgogne', slug: 'bourgogne' },
    { name: 'Champagne (grower)', slug: 'champagne' },
    { name: 'Languedoc', slug: 'languedoc' },
    { name: 'Loire', slug: 'loire' },
  ],
  'Spanje': [
    { name: 'Priorat & Montsant', slug: 'priorat' },
    { name: 'Rioja', slug: 'rioja' },
    { name: 'Ribera del Duero', slug: 'ribera-del-duero' },
    { name: 'Sherry', slug: 'sherry' },
  ],
  'Duitsland & Oostenrijk': [
    { name: 'Mosel', slug: 'mosel' },
    { name: 'Pfalz', slug: 'pfalz' },
    { name: 'Wachau', slug: 'wachau' },
    { name: 'Burgenland', slug: 'burgenland' },
  ],
  'Opkomend': [
    { name: 'Georgië', slug: 'georgie' },
    { name: 'Slovenië / Brda', slug: 'slovenie' },
    { name: 'Engeland', slug: 'engeland' },
    { name: 'Portugal', slug: 'portugal' },
  ],
};
---

<header class="site-header" id="site-header">
  <nav class="container header-nav" aria-label="Hoofdnavigatie">
    <a href={base} class="logo" aria-label={brand.name}>
      <svg class="logo-mark" width="20" height="26" viewBox="0 0 20 26" fill="none" aria-hidden="true">
        <path d="M10 1C10 1 1 7.5 1 15a9 9 0 0 0 18 0C19 7.5 10 1 10 1Z" stroke="currentColor" stroke-width="1.25" fill="none"/>
        <path d="M10 24v-5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
        <path d="M6.5 25.5h7" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
        <path d="M5 13c0 0 1.5-2 5-2" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.5"/>
      </svg>
      <span class="logo-text">{brand.name}</span>
    </a>

    <div class="nav-main" id="nav-main">
      <ul class="nav-links" role="list">
        <!-- Streken met mega-menu -->
        <li class="nav-item has-mega" id="nav-streken">
          <button class="nav-link nav-trigger" aria-expanded="false" aria-controls="mega-streken">
            Streken
            <svg class="nav-chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
              <path d="M2 3.5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="mega-menu" id="mega-streken" role="region" aria-label="Wijnstreken">
            <div class="mega-inner container">
              {Object.entries(megaRegions).map(([country, regions]) => (
                <div class="mega-col">
                  <span class="mega-country">{country}</span>
                  <ul role="list">
                    {regions.map((r) => (
                      <li>
                        <a href={`${base}/streken/${r.slug}/`} class="mega-link">{r.name}</a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        </li>

        <li class="nav-item">
          <a href={`${base}/verhalen/`} class="nav-link">Verhalen</a>
        </li>
        <li class="nav-item">
          <a href={`${base}/routes/`} class="nav-link">Routes</a>
        </li>
        <li class="nav-item">
          <a href={`${base}/proefnotities/`} class="nav-link">Proefnotities</a>
        </li>
      </ul>

      <a href="#nieuwsbrief" class="btn btn-primary nav-cta">Nieuwsbrief</a>
    </div>

    <!-- Mobiel hamburger -->
    <button class="nav-hamburger" id="nav-hamburger" aria-label="Menu openen" aria-expanded="false" aria-controls="nav-main">
      <span></span><span></span><span></span>
    </button>
  </nav>
</header>

<script>
  const header = document.getElementById('site-header')!;
  const hamburger = document.getElementById('nav-hamburger')!;
  const navMain = document.getElementById('nav-main')!;

  // Scroll-aware header shadow
  function updateScroll() {
    header.toggleAttribute('data-scrolled', window.scrollY > 30);
  }
  window.addEventListener('scroll', updateScroll, { passive: true });
  updateScroll();

  // Hamburger toggle
  hamburger.addEventListener('click', () => {
    const open = hamburger.getAttribute('aria-expanded') === 'true';
    hamburger.setAttribute('aria-expanded', String(!open));
    navMain.classList.toggle('nav-open', !open);
    document.body.style.overflow = !open ? 'hidden' : '';
  });

  // Mega-menu hover (desktop) + click (mobile)
  const navStreken = document.getElementById('nav-streken')!;
  const trigger = navStreken.querySelector<HTMLButtonElement>('.nav-trigger')!;
  const mega = document.getElementById('mega-streken')!;

  function openMega() {
    trigger.setAttribute('aria-expanded', 'true');
    mega.classList.add('mega-visible');
  }
  function closeMega() {
    trigger.setAttribute('aria-expanded', 'false');
    mega.classList.remove('mega-visible');
  }

  navStreken.addEventListener('mouseenter', openMega);
  navStreken.addEventListener('mouseleave', closeMega);

  trigger.addEventListener('click', (e) => {
    e.stopPropagation();
    trigger.getAttribute('aria-expanded') === 'true' ? closeMega() : openMega();
  });

  document.addEventListener('click', closeMega);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMega(); });
</script>

<style>
  .site-header {
    padding: 0;
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(16px) saturate(1.4);
    background: rgba(251, 247, 239, 0.92);
    border-bottom: 1px solid transparent;
    transition:
      border-color var(--duration-base) var(--ease-out),
      box-shadow var(--duration-base) var(--ease-out);
  }

  .site-header[data-scrolled] {
    border-bottom-color: var(--rule-20);
    box-shadow: 0 1px 24px rgba(26, 20, 16, 0.07);
  }

  .header-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-8);
    height: var(--header-height);
  }

  /* ── Logo ─────────────────────────────────────────── */
  .logo {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    flex-shrink: 0;
  }
  .logo-mark {
    color: var(--burgundy);
    flex-shrink: 0;
    transition: color var(--duration-fast) var(--ease-out);
  }
  .logo-text {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-style: italic;
    font-weight: 400;
    color: var(--ink);
    letter-spacing: -0.015em;
    transition: color var(--duration-fast) var(--ease-out);
  }
  .logo:hover .logo-mark { color: var(--burgundyDeep); }
  .logo:hover .logo-text { color: var(--burgundy); }

  /* ── Main nav ─────────────────────────────────────── */
  .nav-main {
    display: flex;
    align-items: center;
    gap: var(--space-8);
  }

  .nav-links {
    display: flex;
    list-style: none;
    align-items: center;
    gap: 0;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-2) var(--space-4);
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--inkSoft);
    background: none;
    border: none;
    cursor: pointer;
    border-radius: var(--radius-sm);
    transition: color var(--duration-fast) var(--ease-out),
                background var(--duration-fast) var(--ease-out);
    white-space: nowrap;
    text-decoration: none;
    position: relative;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: var(--space-4);
    right: var(--space-4);
    height: 1.5px;
    background: var(--burgundy);
    transform: scaleX(0);
    transition: transform var(--duration-fast) var(--ease-out);
    transform-origin: center;
  }
  .nav-link:hover { color: var(--ink); background: transparent; }
  .nav-link:hover::after { transform: scaleX(1); }
  .nav-trigger[aria-expanded="true"] { color: var(--ink); }
  .nav-trigger[aria-expanded="true"]::after { transform: scaleX(1); }

  .nav-chevron {
    transition: transform var(--duration-fast) var(--ease-out);
    margin-top: 1px;
  }
  .nav-trigger[aria-expanded="true"] .nav-chevron {
    transform: rotate(180deg);
  }

  .nav-cta {
    font-size: 0.75rem;
    height: 2.25rem;
    padding: 0 var(--space-5);
    letter-spacing: 0.06em;
  }

  /* ── Mega-menu ───────────────────────────────────────── */
  .has-mega { position: static; }

  .mega-menu {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--paper);
    border-top: 2px solid var(--burgundy);
    border-bottom: 1px solid var(--rule-20);
    padding: var(--space-8) 0 var(--space-10);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: opacity var(--duration-base) var(--ease-out),
                transform var(--duration-base) var(--ease-out),
                visibility 0s var(--duration-base);
    pointer-events: none;
    box-shadow: 0 12px 40px rgba(26, 20, 16, 0.10);
  }

  .mega-menu.mega-visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    transition: opacity var(--duration-base) var(--ease-out),
                transform var(--duration-base) var(--ease-out),
                visibility 0s 0s;
    pointer-events: auto;
  }

  .mega-inner {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--space-8);
  }

  .mega-country {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--burgundy);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--rule-20);
  }

  .mega-col ul { list-style: none; display: flex; flex-direction: column; gap: var(--space-2); }

  .mega-link {
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    color: var(--inkSoft);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out),
                padding-left var(--duration-fast) var(--ease-out);
    display: block;
    padding: var(--space-1) 0;
  }
  .mega-link:hover {
    color: var(--burgundy);
    padding-left: var(--space-2);
  }

  /* ── Hamburger ───────────────────────────────────────── */
  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: var(--space-2);
    background: none;
    border: none;
    cursor: pointer;
  }
  .nav-hamburger span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--ink);
    transition: transform var(--duration-base) var(--ease-out),
                opacity var(--duration-fast) var(--ease-out);
    border-radius: 1px;
  }
  .nav-hamburger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .nav-hamburger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .nav-hamburger[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* ── Mobile ──────────────────────────────────────────── */
  @media (max-width: 900px) {
    .nav-hamburger { display: flex; }

    .nav-main {
      display: none;
      position: fixed;
      top: var(--header-height);
      left: 0;
      right: 0;
      bottom: 0;
      flex-direction: column;
      align-items: stretch;
      background: var(--paper);
      border-top: 1px solid var(--rule-20);
      padding: var(--space-6) var(--gutter) var(--space-8);
      gap: var(--space-1);
      overflow-y: auto;
    }
    .nav-main.nav-open { display: flex; }

    .nav-links {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
    }

    .nav-link {
      padding: var(--space-4) var(--space-2);
      font-size: 0.875rem;
      border-bottom: 1px solid var(--rule-20);
    }
    .nav-link::after { display: none; }

    .mega-menu {
      position: static;
      border: none;
      border-top: 1px solid var(--rule-20);
      padding: var(--space-4) 0 0;
      opacity: 1;
      visibility: visible;
      transform: none;
      pointer-events: auto;
      display: none;
      box-shadow: none;
    }
    .mega-menu.mega-visible { display: block; }

    .mega-inner {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-6);
      padding: 0;
    }

    .nav-cta { align-self: flex-start; margin-top: var(--space-6); }
  }

  @media (max-width: 480px) {
    .mega-inner { grid-template-columns: 1fr; }
  }
</style>
