---
import type { Brand } from '../lib/brands';

interface Props {
  brand: Brand;
  locale: string;
  activeNav?: string;
}

const { brand, locale, activeNav } = Astro.props;
const nav = ['Streken', 'Routes', 'Proeven', 'Wijnhuizen', "Thema's", 'Over ons'];

const megaMenuCols = [
  { country: 'Italië', regions: ['Piemonte', 'Toscane', 'Etna', 'Friuli', 'Alto Adige', 'Veneto'] },
  { country: 'Frankrijk', regions: ['Bourgogne', 'Rhône', 'Jura', 'Loire', 'Champagne', 'Beaujolais'] },
  { country: 'Spanje & Portugal', regions: ['Rioja', 'Priorat', 'Ribera del Duero', 'Douro', 'Dão', 'Alentejo'] },
  { country: 'Duitsland & verder', regions: ['Mosel', 'Rheingau', 'Pfalz', 'Wachau (AT)', 'Mendoza (AR)', 'Stellenbosch (ZA)'] },
];
---

<header class="site-header">
  <!-- Utility bar -->
  <div class="header-utility">
    <div class="header-utility-inner">
      <span>Wijnreizen, hand-picked door Martin &amp; Sophie</span>
      <span>NL · EN binnenkort</span>
    </div>
  </div>

  <!-- Main bar -->
  <div class="header-main">
    <div class="header-inner">
      <a href={`/${brand.slug}/nl/`} class="header-logo" aria-label={brand.name}>
        Vino<span class="logo-dot">·</span>Martino
      </a>

      <nav class="header-nav" aria-label="Hoofdnavigatie">
        {nav.map(item => (
          <a
            href={`/${brand.slug}/nl/${item.toLowerCase().replace(/'/g, '').replace(/\s+/g, '-')}/`}
            class={`nav-link ${(activeNav === item || activeNav === item.toLowerCase()) ? 'nav-link--active' : ''}`}
            data-menu={item === 'Streken' ? 'streken' : undefined}
          >
            {item}{['Streken', 'Routes'].includes(item) && <span class="nav-chevron" aria-hidden="true">▾</span>}
          </a>
        ))}
      </nav>

      <a href={`/${brand.slug}/nl/de-brief/`} class="header-cta">De Brief →</a>

      <!-- Mobile toggle -->
      <button class="mobile-toggle" aria-label="Menu openen" aria-expanded="false" aria-controls="mobile-menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <!-- Streken mega-menu -->
  <div class="mega-menu" id="mega-streken" role="region" aria-label="Streken menu" hidden>
    <div class="mega-inner">
      <div class="mega-brand">
        <div class="mega-brand-icon" aria-hidden="true">§</div>
        <strong class="mega-brand-title">Hand-picked, glas voor glas</strong>
        <p class="mega-brand-desc">Elke streek hieronder hebben we zelf afgereisd. Geen affiliate-lijstjes — alleen wijnhuizen waar we zelf binnen zijn geweest.</p>
      </div>
      {megaMenuCols.map(col => (
        <div class="mega-col">
          <h4 class="mega-col-heading">{col.country}</h4>
          <ul class="mega-col-list" role="list">
            {col.regions.map(region => (
              <li><a href="#" class="mega-link">{region}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobile-menu" hidden>
    <nav>
      {nav.map(item => (
        <a href={`/${brand.slug}/nl/${item.toLowerCase().replace(/'/g, '').replace(/\s+/g, '-')}/`} class="mobile-nav-link">{item}</a>
      ))}
      <a href={`/${brand.slug}/nl/de-brief/`} class="mobile-nav-link mobile-nav-link--cta">De Brief →</a>
    </nav>
  </div>
</header>

<style>
  /* ── Utility bar ─────────────────────────────────── */
  .header-utility {
    background: var(--paper);
    border-bottom: 1px solid var(--ruleSoft);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--inkSoft);
  }

  .header-utility-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 8px var(--gutter);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  /* ── Main bar ─────────────────────────────────────── */
  .site-header {
    background: var(--paper);
    border-bottom: 1px solid var(--rule);
    position: relative;
    z-index: 100;
  }

  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 20px var(--gutter);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  /* ── Logo ─────────────────────────────────────────── */
  .header-logo {
    font-family: var(--font-display);
    font-size: 2rem;
    font-style: italic;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    line-height: 1;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .logo-dot { font-style: normal; }

  /* ── Nav ──────────────────────────────────────────── */
  .header-nav {
    display: flex;
    align-items: center;
    gap: 1.75rem;
  }

  .nav-link {
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    padding-bottom: 4px;
    border-bottom: 2px solid transparent;
    transition: color var(--duration-fast) var(--ease-out),
                border-color var(--duration-fast) var(--ease-out);
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    white-space: nowrap;
  }

  .nav-link:hover,
  .nav-link--active {
    color: var(--burgundy);
    border-bottom-color: var(--burgundy);
  }

  .nav-chevron {
    font-size: 0.5625rem;
    opacity: 0.6;
  }

  /* ── CTA ──────────────────────────────────────────── */
  .header-cta {
    background: var(--burgundy);
    color: var(--paper);
    padding: 10px 20px;
    text-decoration: none;
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    font-weight: 600;
    border-radius: var(--radius-sm);
    white-space: nowrap;
    flex-shrink: 0;
    transition: background var(--duration-fast) var(--ease-out);
  }

  .header-cta:hover {
    background: var(--burgundyDeep);
    color: var(--paper);
  }

  /* ── Mega-menu ────────────────────────────────────── */
  .mega-menu {
    background: var(--paperDeep);
    border-top: 1px solid var(--ruleSoft);
    border-bottom: 1px solid var(--rule);
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 99;
    box-shadow: var(--shadow-md);
  }

  .mega-menu[hidden] { display: none; }

  .mega-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 32px var(--gutter);
    display: grid;
    grid-template-columns: 240px repeat(4, 1fr);
    gap: 32px;
  }

  .mega-brand-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--burgundy);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--paper);
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-style: italic;
    margin-bottom: 12px;
  }

  .mega-brand-title {
    display: block;
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 8px;
  }

  .mega-brand-desc {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--inkSoft);
    margin: 0;
  }

  .mega-col-heading {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--burgundy);
    margin: 0 0 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--rule);
  }

  .mega-col-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .mega-link {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--ink);
    text-decoration: none;
    transition: color var(--duration-fast);
  }

  .mega-link:hover { color: var(--burgundy); }

  /* ── Mobile ───────────────────────────────────────── */
  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .mobile-toggle span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--ink);
    border-radius: 1px;
  }

  .mobile-menu {
    background: var(--paper);
    border-top: 1px solid var(--rule);
    padding: 1rem var(--gutter);
  }

  .mobile-menu[hidden] { display: none; }

  .mobile-nav-link {
    display: block;
    padding: 0.75rem 0;
    font-family: var(--font-ui);
    font-size: 1rem;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--ruleSoft);
  }

  .mobile-nav-link--cta {
    color: var(--burgundy);
    border-bottom: none;
    margin-top: 0.5rem;
  }

  @media (max-width: 900px) {
    .header-nav,
    .header-cta,
    .header-utility { display: none; }

    .mobile-toggle { display: flex; }
  }

  @media (max-width: 640px) {
    .header-inner { padding: 16px var(--gutter); }
    .header-logo { font-size: 1.625rem; }
  }
</style>

<script>
  const strekenLink = document.querySelector('[data-menu="streken"]') as HTMLElement;
  const megaStreken = document.getElementById('mega-streken') as HTMLElement;
  let closeTimer: ReturnType<typeof setTimeout>;

  function openMega() {
    clearTimeout(closeTimer);
    megaStreken.hidden = false;
  }

  function closeMega() {
    closeTimer = setTimeout(() => { megaStreken.hidden = true; }, 120);
  }

  if (strekenLink && megaStreken) {
    strekenLink.addEventListener('mouseenter', openMega);
    strekenLink.addEventListener('mouseleave', closeMega);
    megaStreken.addEventListener('mouseenter', () => clearTimeout(closeTimer));
    megaStreken.addEventListener('mouseleave', closeMega);
  }

  const mobileToggle = document.querySelector('.mobile-toggle') as HTMLButtonElement;
  const mobileMenu = document.getElementById('mobile-menu') as HTMLElement;

  mobileToggle?.addEventListener('click', () => {
    const expanded = mobileToggle.getAttribute('aria-expanded') === 'true';
    mobileToggle.setAttribute('aria-expanded', expanded ? 'false' : 'true');
    mobileMenu.hidden = expanded;
  });
</script>
