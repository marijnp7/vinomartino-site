---
// LAT-2709 — gedeelde wijnatlas (/ontdek/). De NL-route
// (src/pages/ontdek/index.astro) en de /en/-tegenhanger
// (src/pages/en/ontdek/index.astro) renderen dit component; `locale` stuurt de
// data-loaders (loadLanden/loadStreken) en de UI-dictionary (ui.t). NL is
// byte-identiek: elke chrome-string valt terug op de NL-default in
// UI_STRING_DEFAULTS en localizePath(..., 'nl') levert het kale pad.
import SiteLayout from '../layouts/SiteLayout.astro';
import SmartImg from '../components/SmartImg.astro';
import DiscoverMapEurope from '../components/DiscoverMapEurope.astro';
import { loadLanden } from '../lib/landen';
import { loadStreken } from '../lib/streken';
import { organizationSchema, breadcrumbSchema } from '../lib/seo';
import { loadUiStrings } from '../lib/ui-strings';
import { DEFAULT_LOCALE, localizePath, type Locale } from '../lib/i18n';

interface Props {
  locale?: Locale;
  alternates?: Partial<Record<Locale, string>>;
}

const { locale = DEFAULT_LOCALE, alternates } = Astro.props;
const ui = await loadUiStrings(locale);
const collation = locale === 'en' ? 'en' : 'nl';

const [landen, streken] = await Promise.all([loadLanden(locale), loadStreken(locale)]);

// Groepeer gepubliceerde streken onder hun land. loadStreken levert alleen
// publiceerbare rijen, dus elke streek hier heeft een echte /streken/{slug}/.
const strekenByLand = new Map<string, { slug: string; name: string }[]>();
for (const s of streken) {
  if (!s.landSlug) continue;
  const list = strekenByLand.get(s.landSlug) ?? [];
  list.push({ slug: s.slug, name: s.name });
  strekenByLand.set(s.landSlug, list);
}
for (const list of strekenByLand.values()) {
  list.sort((a, b) => a.name.localeCompare(b.name, collation));
}

// Foto-rijke land-tegel. Kleur is data-gedreven (vaste merk-agnostische palet,
// deterministisch per land) — nieuw land = tegel erbij, geen nav-item erbij.
const PALETTE = ['#5A1A1F', '#A14F2A', '#5C6B3F', '#B86030', '#6B3A4A', '#7A6A2C'];

const OVERIG = ui.t('ontdek.continent.overig');

interface Tile {
  slug: string;
  name: string;
  continent: string;
  color: string;
  heroImage: string | null;
  regions: { slug: string; name: string }[];
}

const tiles: Tile[] = landen.map((land, i) => ({
  slug: land.slug,
  name: land.name,
  continent: land.continent || OVERIG,
  color: PALETTE[i % PALETTE.length] as string,
  heroImage: land.heroImage,
  regions: strekenByLand.get(land.slug) ?? [],
}));

// Groepeer per continent (reisjunk-patroon: continent-sectiekop + foto-tegels).
// Europa eerst — dat is de wijnkern — daarna de overige continenten alfabetisch.
// Zowel de NL- als EN-continentnaam staan vooraan zodat de kern-ordening blijft
// als de dataloader continenten vertaalt.
const CONTINENT_ORDER = ['Europa', 'Europe'];
const continentGroups = [...new Set(tiles.map(t => t.continent))]
  .sort((a, b) => {
    const ia = CONTINENT_ORDER.indexOf(a);
    const ib = CONTINENT_ORDER.indexOf(b);
    if (ia !== -1 || ib !== -1) return (ia === -1 ? 99 : ia) - (ib === -1 ? 99 : ib);
    return a.localeCompare(b, collation);
  })
  .map(continent => ({
    continent,
    landen: tiles
      .filter(t => t.continent === continent)
      .sort((a, b) => a.name.localeCompare(b.name, collation)),
  }));

const totaalStreken = streken.length;

const landLabel = (n: number) =>
  n === 1 ? ui.t('ontdek.continent.landen.singular') : ui.t('ontdek.continent.landen.plural');
const wijnlandLabel = (n: number) =>
  n === 1 ? ui.t('ontdek.atlas.foot.wijnlanden.singular') : ui.t('ontdek.atlas.foot.wijnlanden.plural');
const streekLabel = (n: number) =>
  n === 1 ? ui.t('ontdek.atlas.foot.streken.singular') : ui.t('ontdek.atlas.foot.streken.plural');

const emptyLink = ui.t('ontdek.empty.descLink');

const schema = [
  organizationSchema(),
  breadcrumbSchema([
    { name: ui.t('streek.breadcrumb.home'), url: localizePath('/', locale) },
    { name: ui.t('ontdek.breadcrumb'), url: localizePath('/ontdek/', locale) },
  ]),
];
---

<SiteLayout
  title={ui.t('ontdek.index.meta.title')}
  description={ui.t('ontdek.index.meta.description')}
  schema={schema}
  activeNav="ontdek"
  locale={locale}
  alternates={alternates}
>
  <section class="hero-sm">
    <div class="container">
      <span class="section-label">{ui.t('ontdek.index.hero.label')}</span>
      <h1>{ui.t('ontdek.index.hero.h1')}</h1>
      <p class="hero-desc">{ui.t('ontdek.index.hero.desc')}</p>
    </div>
  </section>

  {tiles.length > 0 && (
    <section class="section container map-hero">
      <DiscoverMapEurope
        locale={locale}
        countries={tiles.map(t => ({ slug: t.slug, name: t.name, color: t.color, regionCount: t.regions.length }))}
      />
    </section>
  )}

  {tiles.length > 0 ? (
    continentGroups.map(group => (
      <section class="section container continent-block">
        <header class="continent-head">
          <span class="continent-label">{group.continent}</span>
          <span class="continent-count">{group.landen.length} {landLabel(group.landen.length)}</span>
        </header>
        <div class="tile-grid">
          {group.landen.map(t => (
            <article class="tile" style={`--accent: ${t.color};`}>
              <a href={localizePath(`/landen/${t.slug}/`, locale)} class="tile-img-link" aria-label={`${ui.t('ontdek.tile.aria.prefix')} ${t.name}`}>
                <div class="tile-img-wrap">
                  <SmartImg src={t.heroImage || undefined} alt={t.name} theme="region" class="tile-img" />
                  <span class="tile-name">{t.name}</span>
                </div>
              </a>
              {t.regions.length > 0 ? (
                <ul class="region-list">
                  {t.regions.map(r => (
                    <li>
                      <a href={localizePath(`/streken/${r.slug}/`, locale)} class="region-link">{r.name}</a>
                    </li>
                  ))}
                </ul>
              ) : (
                <p class="region-empty">
                  <a href={localizePath(`/landen/${t.slug}/`, locale)}>{ui.t('ontdek.tile.region.link.prefix')} &rsaquo;</a>
                </p>
              )}
            </article>
          ))}
        </div>
      </section>
    ))
  ) : (
    <section class="section container">
      <div class="empty-state">
        <h2>{ui.t('ontdek.empty.h2')}</h2>
        <p>{ui.t('ontdek.empty.descPre')}<a href={localizePath('/artikelen/', locale)}>{emptyLink}</a>{ui.t('ontdek.empty.descPost')}</p>
      </div>
    </section>
  )}

  {tiles.length > 0 && (
    <section class="section container atlas-foot">
      <p>{tiles.length} {wijnlandLabel(tiles.length)} &middot; {totaalStreken} {streekLabel(totaalStreken)}{ui.t('ontdek.atlas.foot.tail')}</p>
    </section>
  )}
</SiteLayout>

<style>
  .hero-sm {
    background: var(--paperDeep);
    padding: var(--space-12) 0 var(--space-8);
    text-align: center;
  }
  .hero-sm h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.6rem + 1.5vw, 3rem);
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin-top: var(--space-3);
  }
  .hero-desc {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--inkSoft);
    margin-top: var(--space-3);
    max-width: 40rem;
    margin-inline: auto;
  }
  .map-hero {
    padding-bottom: var(--space-6);
  }
  .continent-block {
    padding-top: var(--space-6);
    padding-bottom: var(--space-6);
  }
  .continent-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-3);
    padding-bottom: var(--space-4);
    margin-bottom: var(--space-6);
    border-bottom: 1px solid var(--ruleSoft);
  }
  .continent-label {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 1.2rem + 1vw, 2rem);
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
  }
  .continent-count {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--inkFaint);
    white-space: nowrap;
  }
  .tile-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-6);
  }
  @media (max-width: 420px) {
    .tile-grid { grid-template-columns: 1fr; }
  }
  .tile {
    border: 1px solid var(--ruleSoft);
    border-top: 4px solid var(--accent);
    background: var(--paper);
    display: flex;
    flex-direction: column;
  }
  .tile-img-link {
    display: block;
    text-decoration: none;
  }
  .tile-img-wrap {
    position: relative;
    aspect-ratio: 16 / 11;
    overflow: hidden;
    background: var(--paperShade);
  }
  .tile-img-wrap :global(img),
  .tile-img-wrap :global(.smart-img-placeholder) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-image) var(--ease-out);
  }
  .tile-img-link:hover .tile-img-wrap :global(img),
  .tile-img-link:hover .tile-img-wrap :global(.smart-img-placeholder) {
    transform: scale(1.03);
  }
  .tile-img-wrap::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top,
      color-mix(in srgb, var(--accent) 78%, #1a1208) 0%,
      color-mix(in srgb, var(--accent) 30%, transparent) 42%,
      transparent 72%);
    pointer-events: none;
  }
  .tile-name {
    position: absolute;
    left: 1.125rem;
    right: 1.125rem;
    bottom: 0.875rem;
    z-index: 1;
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 500;
    line-height: 1.15;
    color: #FBF6EC;
    text-shadow: 0 1px 6px rgba(20, 12, 6, 0.45);
  }
  .region-list {
    list-style: none;
    margin: 0;
    padding: 0.75rem 1.25rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  .region-link {
    display: block;
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    color: var(--ink);
    text-decoration: none;
    padding: 0.4375rem 0;
    border-bottom: 1px solid var(--ruleSoft);
    transition: color var(--duration-fast) var(--ease-out),
                padding-left var(--duration-fast) var(--ease-out);
  }
  .region-list li:last-child .region-link { border-bottom: none; }
  .region-link:hover {
    color: var(--accent);
    padding-left: 0.375rem;
  }
  .region-empty {
    padding: 0.75rem 1.25rem 1.25rem;
    font-family: var(--font-ui);
    font-size: 0.9375rem;
  }
  .region-empty a {
    color: var(--accent);
    text-decoration: none;
  }
  .region-empty a:hover { text-decoration: underline; }
  .atlas-foot {
    text-align: center;
    padding-top: 0;
  }
  .atlas-foot p {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--inkFaint);
  }
  .empty-state {
    text-align: center;
    padding: var(--space-16) var(--space-4);
  }
  .empty-state h2 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin-bottom: var(--space-3);
  }
  .empty-state p { font-size: 1rem; color: var(--inkSoft); }
</style>
