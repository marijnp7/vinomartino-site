---
/**
 * <DiscoverMapEurope> — klikbare Europa-wijnkaart op /ontdek/ (LAT-1624)
 *
 * Ontwerp + scope: LAT-1605 plan. Renderingsmodel volgt 1:1 de regels van
 * <InfographicAtlasInteractive> (LAT-1122):
 *   • Klik = échte navigatie (<a href="/landen/{slug}/">) — geen JS, geen 404-trap.
 *   • Alleen landen met een gepubliceerde /landen/{slug}/ zijn klikbaar; de rest
 *     wordt gedempt/inert (aria-hidden) als geografische context getekend.
 *   • Hover/focus → tooltip (land + aantal streken). JS verrijkt alleen; de
 *     native <title> geeft dezelfde info zonder JS.
 *
 * Geometrie komt uit het gedeelde, statische databestand
 * `src/data/atlas/europe-countries.json` (gekeyd op land-slug). De kaart is een
 * *enhancement* boven het bubbel-grid; het grid blijft de canonieke a11y- en
 * mobiele fallback (de kaart verbergt zich op smalle viewports).
 */
import geo from '../data/atlas/europe-countries.json';

export interface MapCountry {
  slug: string;
  name: string;
  /** Deterministische merk-paletkleur — koppelt kaart visueel aan de bubbel. */
  color: string;
  /** Aantal gepubliceerde streken onder dit land (tooltip-context). */
  regionCount: number;
}

export interface Props {
  /** Gepubliceerde landen (met /landen/{slug}/). Bepaalt klikbaarheid + kleur. */
  countries: MapCountry[];
  class?: string;
}

const { countries, class: className } = Astro.props;

interface GeoEntry { name: string; d: string; labelOffset?: { x: number; y: number } }
const viewBox = (geo._meta?.viewBox as string) || '0 0 800 700';
const entries = geo.countries as Record<string, GeoEntry>;

const vb = viewBox.split(/\s+/).map(Number);
const minX = vb[0] || 0;
const minY = vb[1] || 0;
const innerW = vb[2] || 800;
const innerH = vb[3] || 700;
const maxX = minX + innerW;
const maxY = minY + innerH;

const byLand = new Map(countries.map((c) => [c.slug, c]));

// ── Validatie numeriek (LAT-1624 scope #5; we hebben geen lokale visuele QA) ──
// Fail-loud conform content-loader-conventie: waarschuw maar render door.
for (const land of countries) {
  if (!entries[land.slug]) {
    console.warn(`[DiscoverMapEurope] gepubliceerd land '${land.slug}' heeft geen geometrie-entry in europe-countries.json — niet op de kaart, alleen in het bubbel-grid. Voeg een path toe (LAT-1624).`);
  }
}
for (const [slug, entry] of Object.entries(entries)) {
  const nums = (entry.d.match(/-?\d+(?:\.\d+)?/g) || []).map(Number);
  if (nums.length < 6 || nums.length % 2 !== 0) {
    console.warn(`[DiscoverMapEurope] geometrie '${slug}' parset niet als coördinaten-paren (${nums.length} getallen).`);
    continue;
  }
  for (let i = 0; i + 1 < nums.length; i += 2) {
    const x = nums[i];
    const y = nums[i + 1];
    if (x < minX || x > maxX || y < minY || y > maxY) {
      console.warn(`[DiscoverMapEurope] geometrie '${slug}' valt buiten viewBox-bounds (${x},${y} niet in ${minX}..${maxX} / ${minY}..${maxY}).`);
      break;
    }
  }
}

// Centroid-benadering voor labelplaatsing (zelfde aanpak als InfographicAtlasInteractive).
function labelAnchor(d: string, off?: { x: number; y: number }) {
  const nums = (d.match(/-?\d+(?:\.\d+)?/g) || []).map(Number);
  const xs: number[] = [];
  const ys: number[] = [];
  for (let i = 0; i + 1 < nums.length; i += 2) {
    xs.push(nums[i]);
    ys.push(nums[i + 1]);
  }
  const avg = (a: number[]) => (a.length ? a.reduce((s, n) => s + n, 0) / a.length : 0);
  return { x: avg(xs) + (off?.x ?? 0), y: avg(ys) + (off?.y ?? 0) };
}

const strokeScale = Math.max(innerW, innerH) / 600;

// Klikbare landen eerst tekenen onder context? Nee — context onderlaag eerst,
// dan klikbare landen erbovenop zodat hun stroke/labels niet weggedrukt worden.
const drawn = Object.entries(entries).map(([slug, entry]) => {
  const land = byLand.get(slug);
  const a = labelAnchor(entry.d, entry.labelOffset);
  return { slug, entry, land, a };
});
const linkableCount = drawn.filter((d) => d.land).length;
---

{linkableCount > 0 && (
  <nav class:list={['dme', className]} aria-label="Wijnkaart van Europa">
    <div class="dme-wrap">
      <svg
        viewBox={viewBox}
        class="dme-map"
        role="img"
        aria-label="Klikbare wijnkaart van Europa"
        xmlns="http://www.w3.org/2000/svg"
      >
        <title>Wijnkaart van Europa</title>

        {/* ── Context-onderlaag: landen zonder pagina (inert) ── */}
        <g class="dme-context" aria-hidden="true">
          {drawn.filter((d) => !d.land).map((d) => (
            <g class="dme-country dme-country--static">
              <title>{d.entry.name}</title>
              <path d={d.entry.d} class="dme-fill" />
              <text
                x={d.a.x}
                y={d.a.y}
                text-anchor="middle"
                class="dme-label dme-label--static"
                font-size={11 * strokeScale}
              >{d.entry.name}</text>
            </g>
          ))}
        </g>

        {/* ── Klikbare wijnlanden (gepubliceerd) ── */}
        <g class="dme-countries">
          {drawn.filter((d) => d.land).map((d) => {
            const land = d.land!;
            const tip = `${land.name} — ${land.regionCount} ${land.regionCount === 1 ? 'streek' : 'streken'}`;
            return (
              <a
                href={`/landen/${land.slug}/`}
                class="dme-country"
                style={`--c: ${land.color};`}
                data-name={land.name}
                data-meta={`${land.regionCount} ${land.regionCount === 1 ? 'streek' : 'streken'}`}
                aria-label={tip}
              >
                <title>{tip}</title>
                <path d={d.entry.d} class="dme-fill" />
                <text
                  x={d.a.x}
                  y={d.a.y}
                  text-anchor="middle"
                  class="dme-label"
                  font-size={13 * strokeScale}
                >{land.name}</text>
              </a>
            );
          })}
        </g>
      </svg>

      <div class="dme-tooltip" role="status" aria-live="polite" hidden>
        <p class="dme-tip-name"></p>
        <p class="dme-tip-meta"></p>
      </div>
    </div>
  </nav>
)}

<style>
  /* Kaart = enhancement boven het bubbel-grid. Verbergt zich op smal/mobiel;
     het grid blijft de canonieke a11y/mobiele fallback (LAT-1605 plan). */
  .dme { display: none; }
  @media (min-width: 760px) {
    .dme { display: block; margin-bottom: var(--space-8); }
  }

  .dme-wrap {
    position: relative;
    border: 1px solid var(--ruleSoft);
    background: var(--paperDeep);
    padding: clamp(1rem, 3vw, 2rem);
  }
  .dme-map {
    width: 100%;
    height: auto;
    max-height: 520px;
    display: block;
  }

  /* Klikbare landen ----------------------------------------- */
  .dme-country { cursor: pointer; }
  .dme-country--static { cursor: default; pointer-events: none; }
  .dme-country:focus-visible { outline: none; }
  .dme-country:focus-visible .dme-fill { stroke-opacity: 1; fill-opacity: 0.34; }

  .dme-fill {
    fill: var(--c, #5A1A1F);
    fill-opacity: 0.18;
    stroke: var(--c, #5A1A1F);
    stroke-width: 1.4;
    stroke-opacity: 0.7;
    transition: fill-opacity var(--duration-fast, 160ms) var(--ease-out, ease),
                stroke-opacity var(--duration-fast, 160ms) var(--ease-out, ease);
  }
  .dme-country:hover .dme-fill,
  .dme-country:focus-visible .dme-fill { fill-opacity: 0.34; stroke-opacity: 1; }

  /* Context (geen pagina) — gedempt grijs, niet interactief */
  .dme-country--static .dme-fill {
    fill: var(--inkFaint, #8A7E70);
    fill-opacity: 0.05;
    stroke: var(--inkFaint, #8A7E70);
    stroke-width: 1;
    stroke-opacity: 0.3;
    stroke-dasharray: 4 3;
  }

  .dme-label {
    font-family: var(--font-display, 'Cormorant Garamond', Georgia, serif);
    font-style: italic;
    fill: var(--ink, #1F1A16);
    pointer-events: none;
    paint-order: stroke;
    stroke: var(--paperDeep, #F0E6D0);
    stroke-width: 3px;
    stroke-linejoin: round;
  }
  .dme-label--static {
    font-style: normal;
    fill: var(--inkFaint, #8A7E70);
    font-size: inherit;
  }

  /* Tooltip ------------------------------------------------- */
  .dme-tooltip {
    position: absolute; top: 0; left: 0;
    transform: translate(-50%, -115%);
    pointer-events: none; z-index: 5; max-width: 16rem;
    background: var(--paper); border: 1px solid var(--bubble, #5A1A1F);
    border-color: var(--ruleSoft);
    box-shadow: 0 4px 14px rgba(31, 26, 22, 0.18);
    padding: 0.5rem 0.7rem;
  }
  .dme-tooltip[hidden] { display: none; }
  .dme-tip-name {
    margin: 0;
    font-family: var(--font-display, 'Cormorant Garamond', Georgia, serif);
    font-style: italic; font-size: 1.05rem; color: var(--ink);
  }
  .dme-tip-meta {
    margin: 0.1rem 0 0;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.68rem; letter-spacing: 0.06em; color: var(--inkSoft);
  }

  @media (prefers-reduced-motion: reduce) {
    .dme-fill { transition: none; }
  }
</style>

<script>
  // Hover/focus-tooltip — verrijking; navigatie + native <title> werken zonder JS.
  (function () {
    if (typeof window === 'undefined') return;
    document.querySelectorAll('.dme:not([data-wired])').forEach((root) => {
      root.setAttribute('data-wired', 'true');
      const nav = root as HTMLElement;
      const wrap = nav.querySelector('.dme-wrap') as HTMLElement | null;
      const tip = nav.querySelector('.dme-tooltip') as HTMLElement | null;
      const tipName = nav.querySelector('.dme-tip-name') as HTMLElement | null;
      const tipMeta = nav.querySelector('.dme-tip-meta') as HTMLElement | null;
      if (!wrap || !tip || !tipName || !tipMeta) return;

      const show = (el: HTMLElement, clientX: number, clientY: number) => {
        tipName.textContent = el.getAttribute('data-name') || '';
        tipMeta.textContent = el.getAttribute('data-meta') || '';
        const rect = wrap.getBoundingClientRect();
        tip.style.left = `${clientX - rect.left}px`;
        tip.style.top = `${clientY - rect.top}px`;
        tip.hidden = false;
      };
      const hide = () => { tip.hidden = true; };

      nav.querySelectorAll('.dme-country:not(.dme-country--static)').forEach((node) => {
        const el = node as HTMLElement;
        el.addEventListener('pointerenter', (e) => show(el, (e as PointerEvent).clientX, (e as PointerEvent).clientY));
        el.addEventListener('pointermove', (e) => show(el, (e as PointerEvent).clientX, (e as PointerEvent).clientY));
        el.addEventListener('pointerleave', hide);
        el.addEventListener('focus', () => {
          const b = el.getBoundingClientRect();
          show(el, b.left + b.width / 2, b.top + b.height / 2);
        });
        el.addEventListener('blur', hide);
      });
    });
  })();
</script>
