---
interface Props {
  src?: string;
  alt: string;
  theme?: 'vineyard' | 'cellar' | 'bottle' | 'winery' | 'region';
  class?: string;
  style?: string;
  loading?: 'lazy' | 'eager';
}

const { src, alt, class: className, style, loading = 'lazy' } = Astro.props;
---

{src ? (
  <img src={src} alt={alt} class={className} style={style} loading={loading} />
) : (
  <div class:list={['smart-img-placeholder', className]} style={style} role="img" aria-label={alt}>
    <svg viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" preserveAspectRatio="xMidYMid slice">
      <rect width="400" height="300" fill="#E7DABE"/>
      <rect width="400" height="150" fill="#EFE6D2"/>
      <path d="M0 205 Q100 178 200 194 Q300 210 400 186 L400 300 L0 300 Z" fill="#C4B084" opacity="0.6"/>
      <path d="M0 240 Q120 220 220 236 Q320 252 400 230 L400 300 L0 300 Z" fill="#A88F60" opacity="0.55"/>
    </svg>
  </div>
)}

<style>
  .smart-img-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .smart-img-placeholder svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
