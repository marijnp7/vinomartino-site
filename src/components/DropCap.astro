---
interface Props {
  text: string;
}

const { text } = Astro.props;
const first = text.charAt(0);
const rest = text.slice(1);
---

<p class="dropcap-para">
  <span class="dropcap" aria-hidden="true">{first}</span><span class="sr-only">{first}</span>{rest}
</p>

<style>
  .dropcap-para {
    font-family: var(--font-body);
    font-size: 1.125rem;
    line-height: 1.75;
    color: var(--ink);
    margin-bottom: var(--space-6);
  }

  .dropcap {
    float: left;
    font-family: var(--font-display);
    font-size: 4.5rem;
    font-style: italic;
    font-weight: 400;
    line-height: 0.78;
    color: var(--burgundy);
    margin-right: 0.08em;
    margin-top: 0.06em;
    padding-top: 0.05em;
  }

  .sr-only {
    position: absolute; width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden;
    clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }
</style>
