---
// MailerLite Artikel-Footer embed (LAT-2436 / Fase A stap 3 van LAT-1828).
// Native subscribe-form naar hetzelfde MailerLite-account/form als /de-brief
// (form 189828746131277541, account 2415940). De regiovraag is gekoppeld aan
// custom field `region_preference` (id 1377354); waarden piemonte/toscane/
// alsace/overige triggeren de 4 routing-automations -> region-* groups.
// Override endpoint via PUBLIC_MAILERLITE_FORM_ACTION (net als /de-brief).
import NewsletterRegionField from './NewsletterRegionField.astro';
import { DEFAULT_LOCALE, type Locale } from '../lib/i18n';
import { loadUiStrings } from '../lib/ui-strings';

const FORM_ACTION =
  import.meta.env.PUBLIC_MAILERLITE_FORM_ACTION ||
  'https://assets.mailerlite.com/jsonp/2415940/forms/189828746131277541/subscribe';

interface Props {
  // Preselecteer de regio op region-/streekpagina's (tweede prio). Undefined =
  // lezer kiest zelf; het veld blijft optioneel. Waarden = MailerLite-opties.
  defaultRegion?: 'Piemonte' | 'Toscane' | 'Alsace' | 'Overige' | null;
  /** LAT-2575: NL byte-identiek op DEFAULT_LOCALE; /en/ geeft "en" mee. */
  locale?: Locale;
}

const { defaultRegion = null, locale = DEFAULT_LOCALE } = Astro.props;
const ui = await loadUiStrings(locale);
---

<section class="nl-footer" aria-labelledby="nl-footer-heading">
  <div class="nl-footer__inner">
    <p class="nl-footer__kicker">{ui.t('newsletter.footer.kicker')}</p>
    <h2 id="nl-footer-heading">{ui.t('newsletter.footer.heading')}</h2>
    <p class="nl-footer__lede">{ui.t('newsletter.footer.lede')}</p>

    <form class="nl-footer__form" action={FORM_ACTION} method="post" target="_blank" data-newsletter-signup>
      <div class="nl-footer__row">
        <label for="nl-footer-email" class="visually-hidden">{ui.t('newsletter.footer.emailLabel')}</label>
        <input
          id="nl-footer-email"
          type="email"
          name="fields[email]"
          autocomplete="email"
          placeholder={ui.t('newsletter.footer.emailPlaceholder')}
          required
        />
        <button type="submit">{ui.t('newsletter.footer.submit')}</button>
      </div>

      <NewsletterRegionField id="nl-footer-region" defaultRegion={defaultRegion} locale={locale} />
    </form>

    <p class="nl-footer__fineprint">{ui.t('newsletter.footer.fineprint')}</p>
  </div>
</section>

<style>
  .nl-footer {
    margin: clamp(2.5rem, 6vw, 4rem) auto 0;
    padding: clamp(1.75rem, 4vw, 2.75rem);
    max-width: 760px;
    border: 1px solid var(--color-rule, #C9B98F);
    background: var(--color-bg-soft, var(--color-bg, #fff));
  }
  .nl-footer__inner {
    max-width: 620px;
    margin: 0 auto;
  }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .nl-footer__kicker {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-rust, #A14F2A);
    margin: 0 0 0.5rem;
  }
  .nl-footer h2 {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw + 0.5rem, 2.25rem);
    font-weight: 500;
    color: var(--color-text);
    margin: 0;
    line-height: 1.05;
  }
  .nl-footer__lede {
    font-family: var(--font-serif, var(--font-body));
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--color-text-soft, var(--color-text));
    margin: 0.9rem 0 0;
  }
  .nl-footer__form {
    margin: 1.5rem 0 0;
  }
  .nl-footer__row {
    display: flex;
    gap: 0.5rem;
  }
  .nl-footer__row input {
    flex: 1;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-rule, #C9B98F);
    background: var(--color-bg);
    font-family: var(--font-serif, var(--font-body));
    font-size: 1rem;
    outline: none;
    color: var(--color-text);
  }
  .nl-footer__row input:focus {
    border-color: var(--color-primary);
  }
  .nl-footer__row button {
    background: var(--color-primary);
    color: var(--color-bg);
    padding: 0.75rem 1.25rem;
    border: none;
    font-family: var(--font-ui);
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }
  .nl-footer__row button:hover {
    background: var(--color-primary-hover, var(--color-primary));
  }
  .nl-footer__fineprint {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    line-height: 1.5;
    color: var(--color-text-faint, var(--color-text-soft, var(--color-text)));
    margin: 1rem 0 0;
  }

  @media (max-width: 560px) {
    .nl-footer__row {
      flex-direction: column;
    }
  }
</style>
