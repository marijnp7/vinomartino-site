---
// LAT-1823 — Discrete terugverwijzing van een content-pagina naar zijn
// landenhub (pillar-hub). Rendert niets wanneer de pagina geen hub-lid is, dus
// veilig om onvoorwaardelijk in elke template te mounten.
import { hubBacklinkFor, type HubMemberType } from '../lib/hub-backlinks';
import { DEFAULT_LOCALE, type Locale, localizeHref } from '../lib/i18n';

interface Props {
  /** LAT-2704 — locale van de renderende pagina; stuurt de interne hrefs. */
  locale?: Locale;
  type: HubMemberType;
  slug: string | undefined;
}

const { type, slug, locale = DEFAULT_LOCALE } = Astro.props;

// LAT-2704 — interne hrefs locale-aware; NL blijft byte-identiek.
const lh = (href: string) => localizeHref(href, locale);
const target = hubBacklinkFor(type, slug);
---

{target && (
  <aside class="vm-hub-backlink">
    <div class="container">
      <a href={lh(target.href)}>{target.label}<span aria-hidden="true"> &rarr;</span></a>
    </div>
  </aside>
)}

<style>
  .vm-hub-backlink {
    margin-block: var(--space-5, 2rem);
  }
  .vm-hub-backlink a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--burgundy);
    text-decoration: none;
    border-top: 1px solid var(--rule);
    padding-top: 0.75rem;
  }
  .vm-hub-backlink a:hover {
    text-decoration: underline;
  }
</style>
