---
import { loadUiStrings } from '../lib/ui-strings';
import { type Locale, DEFAULT_LOCALE } from '../lib/i18n';

interface Props {
  locale?: Locale;
}

const { locale = DEFAULT_LOCALE } = Astro.props;
const ui = await loadUiStrings(locale);
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-col">
        <h4 class="footer-heading">VinoMartino</h4>
        <p class="footer-desc">{ui.t('footer.desc')}</p>
        <a
          class="footer-social"
          href="https://www.instagram.com/vinomartino.travel/"
          target="_blank"
          rel="me noopener"
          aria-label="Volg VinoMartino op Instagram (@vinomartino.travel)"
        >
          <svg class="footer-social-icon" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false">
            <path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5Z"></path>
            <circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="2"></circle>
            <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor"></circle>
          </svg>
          <span>@vinomartino.travel</span>
        </a>
      </div>
      <div class="footer-col">
        <h4 class="footer-heading">{ui.t('footer.nav.heading')}</h4>
        <ul class="footer-links">
          <li><a href="/artikelen/">{ui.t('footer.nav.artikelen')}</a></li>
          <li><a href="/auteurs/">{ui.t('footer.nav.auteurs')}</a></li>
          <li><a href="/over-ons/">{ui.t('footer.nav.overOns')}</a></li>
          <li><a href="/voor-accommodaties/">{ui.t('footer.nav.samenwerken')}</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4 class="footer-heading">{ui.t('footer.legal.heading')}</h4>
        <ul class="footer-links">
          <li><a href="/colofon/">{ui.t('footer.legal.colofon')}</a></li>
          <li><a href="/privacy/">{ui.t('footer.legal.privacy')}</a></li>
          <li><a href="/cookies/">{ui.t('footer.legal.cookies')}</a></li>
          <li><a href="/affiliate-verklaring/">{ui.t('footer.legal.affiliate')}</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p class="footer-copy">&copy; {year} VinoMartino. {ui.t('footer.copy.rights')}</p>
      <p class="footer-affiliate-note">
        {ui.t('footer.affiliateNote')}
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--fixed-ink);
    color: var(--fixed-cream);
    margin-top: var(--space-24);
  }
  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-16) var(--gutter) var(--space-8);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-8);
    margin-bottom: var(--space-12);
  }
  .footer-heading {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--gold);
    margin-bottom: var(--space-4);
  }
  .footer-desc {
    font-family: var(--font-body);
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--inkFaint);
    max-width: 28rem;
  }
  .footer-social {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: var(--space-4);
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--fixed-cream);
    text-decoration: none;
    transition: color var(--duration-fast);
  }
  .footer-social:hover { color: var(--gold); }
  .footer-social-icon {
    flex-shrink: 0;
  }
  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .footer-links a {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--fixed-cream);
    text-decoration: none;
    transition: color var(--duration-fast);
  }
  .footer-links a:hover { color: var(--gold); }
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.1);
    padding-top: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .footer-copy {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--inkFaint);
  }
  .footer-affiliate-note {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--inkFaint);
    max-width: 50rem;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-6);
    }
  }
  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
