---
import type { Brand } from '../lib/brands';

interface Props {
  brand: Brand;
}

const { brand } = Astro.props;

const cols = [
  { heading: 'Streken', links: [{ label: 'Italië', href: '#' }, { label: 'Frankrijk', href: '#' }, { label: 'Spanje', href: '#' }, { label: 'Portugal', href: '#' }, { label: 'Duitsland', href: '#' }] },
  { heading: 'Lezen', links: [{ label: 'Routes', href: '#' }, { label: 'Wijnhuizen', href: '#' }, { label: 'Proeven', href: '#' }, { label: "Thema's", href: '#' }] },
  { heading: 'Pagina', links: [{ label: 'Over ons', href: `/${brand.slug}/nl/over-ons/` }, { label: 'De Brief', href: `/${brand.slug}/nl/de-brief/` }, { label: 'Privacy', href: '/privacy/' }, { label: 'Contact', href: '#' }] },
];
---

<footer class="site-footer">
  <div class="footer-inner">
    <!-- Brand col -->
    <div class="footer-brand">
      <a href={`/${brand.slug}/nl/`} class="footer-logo" aria-label={brand.name}>Vino·Martino</a>
      <p class="footer-tagline">Voor de wijnliefhebber die zelf op pad gaat — gewapend met een schroefdop-opener, een notitieboek en een lege koffer.</p>
    </div>

    <!-- Link cols -->
    {cols.map(col => (
      <div class="footer-col">
        <h4 class="footer-col-heading">{col.heading}</h4>
        <ul class="footer-col-list" role="list">
          {col.links.map(link => (
            <li><a href={link.href} class="footer-link">{link.label}</a></li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <div class="footer-bottom-inner">
      <span>© {new Date().getFullYear()} {brand.name}</span>
      <div class="footer-bottom-links">
        <a href="/privacy/">Privacy</a>
        <a href="/cookies/">Cookies</a>
        <a href="/affiliate-verklaring/">Affiliate</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--paper);
    border-top: 1px solid var(--rule);
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    color: var(--inkSoft);
    padding-top: 48px;
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--gutter) 48px;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 48px;
  }

  /* Brand column */
  .footer-logo {
    display: block;
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-style: italic;
    color: var(--ink);
    text-decoration: none;
    margin-bottom: 12px;
    line-height: 1;
  }

  .footer-tagline {
    font-family: var(--font-body);
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--inkSoft);
    max-width: 38ch;
    margin: 0;
  }

  /* Link columns */
  .footer-col-heading {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--ink);
    margin: 0 0 12px;
  }

  .footer-col-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .footer-link {
    color: var(--inkSoft);
    text-decoration: none;
    transition: color var(--duration-fast);
  }

  .footer-link:hover { color: var(--burgundy); }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid var(--ruleSoft);
  }

  .footer-bottom-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 16px var(--gutter);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--inkFaint);
  }

  .footer-bottom-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-bottom-links a {
    color: var(--inkFaint);
    text-decoration: none;
    transition: color var(--duration-fast);
  }

  .footer-bottom-links a:hover { color: var(--ink); }

  /* Responsive */
  @media (max-width: 900px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 540px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .footer-bottom-inner {
      flex-direction: column;
      gap: 8px;
      text-align: center;
    }
  }
</style>
