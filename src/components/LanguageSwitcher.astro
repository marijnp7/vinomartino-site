---
import type { Brand } from '../lib/brands';
import { localeConfigs } from '../lib/i18n';

interface Props {
  brand: Brand;
  currentLocale: string;
  currentPath?: string;
}

const { brand, currentLocale, currentPath = '' } = Astro.props;
const availableLocales = brand.locales
  .map((code) => localeConfigs[code])
  .filter((l) => l && l.active);

const showSwitcher = availableLocales.length > 1;
---

{showSwitcher && (
  <nav class="language-switcher" aria-label="Taalkeuze">
    <div class="switcher-inner">
      {availableLocales.map((locale) => {
        const href = `/${brand.slug}/${locale.code}/${currentPath}`;
        const isCurrent = locale.code === currentLocale;
        return (
          <a
            href={href}
            class:list={['locale-link', { active: isCurrent }]}
            aria-current={isCurrent ? 'true' : undefined}
          >
            {locale.nativeName}
          </a>
        );
      })}
    </div>
  </nav>
)}

<style>
  .language-switcher {
    background: var(--color-secondary);
    padding: 0.4rem 2rem;
    font-size: 0.8rem;
  }

  .switcher-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    gap: 0.75rem;
    justify-content: flex-end;
  }

  .locale-link {
    color: var(--color-text);
    text-decoration: none;
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
    opacity: 0.6;
    transition: opacity 0.15s;
  }

  .locale-link:hover {
    opacity: 1;
    text-decoration: none;
  }

  .locale-link.active {
    opacity: 1;
    font-weight: 600;
  }
</style>
