---
// Affiliate disclosure footer — appears on all content pages with affiliate placeholders.
// LAT-2575: vaste copy via de UI-dictionary. NL draait op DEFAULT_LOCALE →
// byte-identiek; de /en/-tegenhanger geeft `locale="en"` mee.
import { DEFAULT_LOCALE, type Locale } from '../lib/i18n';
import { loadUiStrings } from '../lib/ui-strings';

interface Props {
  locale?: Locale;
}

const { locale = DEFAULT_LOCALE } = Astro.props;
const ui = await loadUiStrings(locale);
---

<footer class="affiliate-disclosure">
  <p class="affiliate-disclosure__text">
    {ui.t('affiliate.disclosure.text')}
    <a href="/affiliate-verklaring/" class="affiliate-disclosure__link">{ui.t('affiliate.disclosure.meer')}</a>
  </p>
</footer>

<style>
  .affiliate-disclosure {
    margin-top: 4rem;
    padding: 1.5rem;
    background: var(--paperDeep, #F5EFE7);
    border-top: 1px solid var(--rule, #D4C5B0);
    border-bottom: 1px solid var(--rule, #D4C5B0);
  }

  .affiliate-disclosure__text {
    max-width: var(--max-width-narrow);
    margin: 0 auto;
    font-family: var(--font-body, serif);
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--inkSoft, #5A4F45);
  }

  .affiliate-disclosure__link {
    color: var(--burgundy, #8B4513);
    text-decoration: underline;
    text-decoration-color: var(--burgundy);
    text-underline-offset: 0.2em;
  }

  .affiliate-disclosure__link:hover {
    opacity: 0.85;
  }

  @media (max-width: 640px) {
    .affiliate-disclosure {
      margin-top: 2rem;
      padding: 1rem;
    }
  }
</style>
