---
// LAT-1619: rechterzijbalk "Gerelateerde stukken". Toont max 3 redactioneel
// gekozen artikel-links (Directus-veld `related_articles` per artikel). Leeg →
// niets renderen (geen lege kop). Sticky meeschuiven regelt de article-sidebar
// in [slug].astro; dit blok blijft puur de inhoud.
import type { RelatedRef } from '../lib/articles';

interface Props {
  items: RelatedRef[];
  title?: string;
  maxItems?: number;
}

const { items, title = 'Gerelateerde stukken', maxItems = 3 } = Astro.props;
const links = items.slice(0, maxItems);
---

{links.length > 0 && (
  <nav class="gerelateerde-stukken" aria-label={title}>
    <p class="gs-heading">{title}</p>
    <ul class="gs-list">
      {links.map((ref) => (
        <li class="gs-item">
          <a href={`/artikelen/${ref.slug}/`} class="gs-link">
            <span class="gs-kicker">Artikel</span>
            <span class="gs-title">{ref.name}</span>
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<style>
  .gerelateerde-stukken {
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--rule);
  }
  .gs-heading {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--inkFaint);
    margin: 0 0 var(--space-3);
  }
  .gs-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .gs-item + .gs-item {
    margin-top: var(--space-3);
  }
  .gs-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .gs-kicker {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--rust);
    display: block;
    margin-bottom: 0.125rem;
  }
  .gs-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.3;
    color: var(--ink);
    display: block;
  }
  .gs-link:hover .gs-title {
    color: var(--burgundy);
  }
  /* LAT-1619 acceptatie: zijbalk is desktop-only; op mobiel valt het blok weg.
    De cross-links blijven op mobiel bereikbaar via het voetblok "Meer over". */
  @media (max-width: 900px) {
    .gerelateerde-stukken { display: none; }
  }
</style>
