---
// LAT-1619: rechterzijbalk "Gerelateerde stukken". Toont max 3 redactioneel
// gekozen artikel-links (Directus-veld `related_articles` per artikel). Leeg →
// niets renderen (geen lege kop). Sticky meeschuiven regelt de article-sidebar
// in [slug].astro; dit blok blijft puur de inhoud.
import type { RelatedRef } from '../lib/articles';
import { DEFAULT_LOCALE, type Locale, localizeHref } from '../lib/i18n';
import { loadUiStrings } from '../lib/ui-strings';

interface Props {
  /** LAT-2704 — locale van de renderende pagina; stuurt de interne hrefs. */
  locale?: Locale;
  items: RelatedRef[];
  title?: string;
  maxItems?: number;
}

const { items, title, maxItems = 3, locale = DEFAULT_LOCALE } = Astro.props;

// LAT-2704 — interne hrefs locale-aware; NL blijft byte-identiek.
const lh = (href: string) => localizeHref(href, locale);
// LAT-2848 — kop via de UI-dictionary; expliciete `title`-prop blijft override.
// NL is een no-op (default = 'Gerelateerde stukken'), dus NL-HTML blijft byte-identiek.
const ui = await loadUiStrings(locale);
const heading = title ?? ui.t('gerelateerdeStukken.title');
const links = items.slice(0, maxItems);
---

{links.length > 0 && (
  <nav class="gerelateerde-stukken" aria-label={heading}>
    <p class="gs-heading">{heading}</p>
    <ul class="gs-list">
      {links.map((ref) => (
        <li class="gs-item">
          <a href={lh(`/artikelen/${ref.slug}/`)} class="gs-link">
            <span class="gs-kicker">Artikel</span>
            <span class="gs-title">{ref.name}</span>
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<style>
  .gerelateerde-stukken {
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--rule);
  }
  .gs-heading {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--inkFaint);
    margin: 0 0 var(--space-3);
  }
  .gs-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .gs-item + .gs-item {
    margin-top: var(--space-3);
  }
  .gs-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .gs-kicker {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--rust);
    display: block;
    margin-bottom: 0.125rem;
  }
  .gs-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.3;
    color: var(--ink);
    display: block;
  }
  .gs-link:hover .gs-title {
    color: var(--burgundy);
  }
  /* LAT-1619 acceptatie: zijbalk is desktop-only; op mobiel valt het blok weg.
    De cross-links blijven op mobiel bereikbaar via het voetblok "Meer over". */
  @media (max-width: 900px) {
    .gerelateerde-stukken { display: none; }
  }
</style>
