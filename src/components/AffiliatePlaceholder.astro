---
// LAT-1029 — Affiliate block.
// Renders nothing unless a real affiliate `href` is supplied. When present, the block
// shows the M1-Optie B layout: per-block disclosure line + CTA link, with data-attrs
// the in-house click-tracker reads (LAT-1019). One link-bron per block — geen stapeling.

import AffiliateBlockDisclosure from './AffiliateBlockDisclosure.astro';
import type { AffiliateLinkBron } from '../lib/affiliates';
import { DEFAULT_LOCALE, type Locale } from '../lib/i18n';
import { loadUiStrings } from '../lib/ui-strings';

interface Props {
  type: 'accommodation' | 'activity' | 'flight' | 'insurance' | 'sidebar';
  context?: string;
  partner?: 'booking.com' | 'getyourguide' | 'skyscanner' | 'reisverzekering';
  region?: string;
  placement?: 'sidebar' | 'inline-mid' | 'inline-end' | 'footer';
  href?: string;
  producent?: string;
  bezoekMaand?: string;
  bezoekJaar?: number;
  linkBron?: AffiliateLinkBron;
  ctaLabel?: string;
  description?: string;
  /** LAT-2575: NL byte-identiek op DEFAULT_LOCALE; /en/ geeft "en" mee. */
  locale?: Locale;
}

const {
  type,
  context,
  partner,
  region,
  placement,
  href,
  producent,
  bezoekMaand,
  bezoekJaar,
  linkBron,
  ctaLabel,
  description,
  locale = DEFAULT_LOCALE,
} = Astro.props;

const ui = await loadUiStrings(locale);

// Alleen de weergave-chrome (titel/omschrijving/cta) loopt via de dictionary; de
// icon-emoji is taal-neutraal. Affiliate-URL/tracking en de blok-disclosure zijn
// ongewijzigd (locale-wiring op de call-sites = T3/LAT-2576).
const ICONS: Record<string, string> = {
  accommodation: '🏨', activity: '🎯', flight: '✈️', insurance: '🛡️', sidebar: '🧳',
};
const labelType = ICONS[type] ? type : 'sidebar';
const label = {
  title: ui.t(`affiliate.block.${labelType}.title`),
  description: ui.t(`affiliate.block.${labelType}.desc`),
  icon: ICONS[labelType],
  cta: ui.t(`affiliate.block.${labelType}.cta`),
};

// No href → no affiliate config → render nothing. M1-Optie B: geen "binnenkort"-placeholders.
const hasAffiliate = Boolean(href && producent && bezoekMaand && bezoekJaar && linkBron);
const ctaText = ctaLabel ?? label.cta;
const descText = description ?? label.description;
---

{hasAffiliate && (
  <aside
    class={`affiliate-block affiliate-${type} affiliate-${placement ?? 'sidebar'}`}
    data-affiliate-type={type}
    data-context={context}
    data-partner={partner}
    data-region={region}
    data-placement={placement}
  >
    <AffiliateBlockDisclosure
      producent={producent!}
      bezoekMaand={bezoekMaand!}
      bezoekJaar={bezoekJaar!}
      linkBron={linkBron!}
    />
    <div class="affiliate-block__inner">
      <span class="affiliate-block__icon" aria-hidden="true">{label.icon}</span>
      <div class="affiliate-block__text">
        <strong class="affiliate-block__title">{label.title}</strong>
        <p class="affiliate-block__desc">{descText}</p>
      </div>
      <a
        class="affiliate-block__cta"
        href={href}
        data-cj-href={href}
        target="_blank"
        rel="sponsored nofollow noopener"
        data-affiliate-track
        data-affiliate-placement={placement ?? 'sidebar'}
        data-affiliate-partner={partner ?? ''}
        data-affiliate-context={context ?? ''}
      >
        {ctaText}
      </a>
    </div>
  </aside>
)}

<style>
  .affiliate-block {
    border: 1px solid var(--ruleSoft, #E0D2B0);
    border-radius: var(--radius-sm, 2px);
    background: var(--paperDeep, #F0E6D0);
    padding: 1.25rem 1.5rem;
    margin: 1.5rem 0;
  }

  .affiliate-block__inner {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .affiliate-block__icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .affiliate-block__text { flex: 1; }

  .affiliate-block__title {
    font-family: var(--font-ui, sans-serif);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--ink, #1F1A16);
    display: block;
  }

  .affiliate-block__desc {
    font-size: 0.8125rem;
    color: var(--inkSoft, #5A4F45);
    margin: 0.125rem 0 0;
  }

  .affiliate-block__cta {
    font-family: var(--font-ui, sans-serif);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--paper, #FBF7EE);
    background: var(--burgundy, #8B4513);
    padding: 0.625rem 1rem;
    border-radius: var(--radius-sm, 2px);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: opacity 0.15s ease;
  }

  .affiliate-block__cta:hover { opacity: 0.9; }

  @media (max-width: 640px) {
    .affiliate-block__inner {
      flex-wrap: wrap;
    }
    .affiliate-block__cta {
      width: 100%;
      text-align: center;
    }
  }
</style>
