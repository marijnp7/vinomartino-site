---
/**
 * LAT-1958 — badge voor het twee-tier authenticiteitsmodel (regels: LAT-1957).
 * Tier 1 (visited=true) toont "Zelf gereisd"; Tier 2 (visited=false/null) toont
 * "Redactiegids" zodat het onderscheid op elke streek/artikel zichtbaar is
 * (LAT-1996). LAT-2575: labels komen uit de UI-dictionary (`ui.badge.*`-keys,
 * NL-default byte-identiek aan de oude UI_COPY); een optionele `locale`-prop
 * (default NL) laadt de dictionary intern zodat de /en/-tegenhanger enkel
 * `locale="en"` doorgeeft. Bezoekjaar is data en wordt subtiel als suffix
 * getoond wanneer aanwezig.
 */
import { DEFAULT_LOCALE, type Locale } from '../lib/i18n';
import { loadUiStrings } from '../lib/ui-strings';

interface Props {
    visited: boolean;
    year?: number | null;
    locale?: Locale;
}

const { visited, year = null, locale = DEFAULT_LOCALE } = Astro.props;
const ui = await loadUiStrings(locale);
---
{visited ? (
  <span class="zelf-gereisd-badge zelf-gereisd-badge--visited" title={ui.t('ui.badge.zelfGereisd.title')}>
    <span class="zelf-gereisd-badge__dot" aria-hidden="true"></span>
    <span class="zelf-gereisd-badge__label">{ui.t('ui.badge.zelfGereisd')}</span>
    {year ? <span class="zelf-gereisd-badge__year">· {year}</span> : null}
  </span>
) : (
  <span class="zelf-gereisd-badge zelf-gereisd-badge--redactie" title={ui.t('ui.badge.redactiegids.title')}>
    <span class="zelf-gereisd-badge__dot" aria-hidden="true"></span>
    <span class="zelf-gereisd-badge__label">{ui.t('ui.badge.redactiegids')}</span>
  </span>
)}

<style>
  .zelf-gereisd-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.25rem 0.65rem;
    border-radius: 999px;
    background: #f2ede2;
    border: 1px solid #d8cdb4;
    color: #6b5a34;
    font-size: 0.8rem;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: 0.01em;
  }
  .zelf-gereisd-badge__dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: #9a7d2e;
  }
  .zelf-gereisd-badge--redactie {
    background: #eef1f4;
    border-color: #cdd6df;
    color: #47555f;
  }
  .zelf-gereisd-badge--redactie .zelf-gereisd-badge__dot {
    background: #6b7b88;
  }
  .zelf-gereisd-badge__year {
    font-weight: 500;
    opacity: 0.75;
  }
</style>
