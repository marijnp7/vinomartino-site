---
// LAT-2693 — gedeelde infographics-previewroute (noindex). NL-route +
// /en/-tegenhanger renderen dit component; `locale` stuurt de chrome + hreflang.
// De preview-inhoud is bewust hard-coded NL (redactie/QA-mockup, geen publieke
// content) → NL byte-identiek. Vertaling van de mockup-data is niet in scope.
import SiteLayout from '../layouts/SiteLayout.astro';
import InfographicCard from '../components/InfographicCard.astro';
import InfographicAtlas from '../components/InfographicAtlas.astro';
import { DEFAULT_LOCALE, type Locale } from '../lib/i18n';

interface Props {
  locale?: Locale;
  alternates?: Partial<Record<Locale, string>>;
}

const { locale = DEFAULT_LOCALE, alternates } = Astro.props;

/**
 * Preview route — LAT-1108.
 * Drie referentie-infographics conform LAT-1107 § 8:
 *   1. Etna-route             — <InfographicAtlas kind="route">
 *   2. Nebbiolo-vergelijking  — drie <InfographicCard type="region">
 *   3. Riesling-aromaprofiel  — <InfographicCard type="aroma">
 *
 * Route is noindex; doel is dat redactie de componenten leert kennen en QA-team
 * de mobiel-fallback en typo-rendering kan toetsen.
 */

const nebbiolos = [
  {
    region: 'Barolo' as const,
    contextLine: 'DOCG · 1980 · 11 GEMEENTEN',
    radial: {
      axes: [
        { label: 'Zuur', value: 7 },
        { label: 'Tannine', value: 9 },
        { label: 'Alc', value: 7 },
        { label: 'Body', value: 8 },
        { label: 'Rijping', value: 9 },
      ] as const,
    },
    dataGrid: [
      { label: 'Hoogte', value: '170–540 m' },
      { label: 'Bodem', value: 'Kalkmergel' },
      { label: 'Rijping', value: '38 maanden' },
      { label: 'Drinkraam', value: '2030–2055' },
    ],
    tasting: ['Rozen, teer en cherry, met een lange', 'mineraal-spannende afdronk.'],
    number: '002A',
  },
  {
    region: 'Barbaresco' as const,
    contextLine: 'DOCG · 1980 · 3 GEMEENTEN',
    radial: {
      axes: [
        { label: 'Zuur', value: 8 },
        { label: 'Tannine', value: 7 },
        { label: 'Alc', value: 6 },
        { label: 'Body', value: 7 },
        { label: 'Rijping', value: 7 },
      ] as const,
    },
    dataGrid: [
      { label: 'Hoogte', value: '170–400 m' },
      { label: 'Bodem', value: 'Mergel · zand' },
      { label: 'Rijping', value: '26 maanden' },
      { label: 'Drinkraam', value: '2028–2045' },
    ],
    tasting: ['Eleganter en frisser dan Barolo:', 'viooltje, framboos en kruidigheid.'],
    number: '002B',
  },
  {
    region: 'Roero' as const,
    contextLine: 'DOCG · 2004 · LINKEROEVER TANARO',
    radial: {
      axes: [
        { label: 'Zuur', value: 7 },
        { label: 'Tannine', value: 6 },
        { label: 'Alc', value: 6 },
        { label: 'Body', value: 6 },
        { label: 'Rijping', value: 5 },
      ] as const,
    },
    dataGrid: [
      { label: 'Hoogte', value: '150–400 m' },
      { label: 'Bodem', value: 'Zand · kalk' },
      { label: 'Rijping', value: '20 maanden' },
      { label: 'Drinkraam', value: '2027–2040' },
    ],
    tasting: ['Vroeger drinkbaar; ronde tannine,', 'rood fruit en lichte kruiding.'],
    number: '002C',
  },
];

const rieslingWheel = {
  wedges: [
    { label: 'Bloem',       primair: 'acacia',    secundair: 'kamille',  tertiair: '—' },
    { label: 'Citrus',      primair: 'limoen',    secundair: 'pomelo',   tertiair: '—' },
    { label: 'Steenfruit',  primair: 'perzik',    secundair: 'abrikoos', tertiair: 'gedroogd' },
    { label: 'Tropisch',    primair: 'ananas',    secundair: 'mango',    tertiair: '—' },
    { label: 'Mineraal',    primair: 'leisteen',  secundair: 'vuursteen', tertiair: 'natte steen' },
    { label: 'Honing',      primair: '—',         secundair: 'bijenwas', tertiair: 'honing' },
    { label: 'Brood/Gist',  primair: '—',         secundair: 'brioche',  tertiair: '—' },
    { label: 'Petroleum',   primair: '—',         secundair: '—',        tertiair: 'kerosine' },
  ],
  centerLine1: 'Riesling',
  centerLine2: 'VinoMartino-proefnotitie · DROOG',
};

const etnaLayers = [
  // Etna cone (zone), waterway, route, 5 numbered stops
  { kind: 'zone' as const, color: 'burgundy' as const,
    d: 'M 380 280 Q 460 200 540 220 Q 620 240 660 320 Q 680 400 600 460 Q 480 480 380 420 Q 320 360 380 280 Z',
    label: 'ETNA DOC' },
  { kind: 'waterway' as const,
    d: 'M 80 480 Q 200 460 320 470 Q 420 480 520 500 Q 620 520 760 540 Q 880 550 940 560' },
  { kind: 'path' as const, color: 'burgundy' as const, dashed: true, width: 2.5,
    d: 'M 160 260 L 280 260 L 360 320 L 480 320 L 560 380 L 660 380 L 760 440' },
  { kind: 'point' as const, x: 160, y: 260, type: 'pin-solid' as const, number: 1, label: 'Randazzo' },
  { kind: 'point' as const, x: 360, y: 320, type: 'pin-solid' as const, number: 2, label: 'Solicchiata' },
  { kind: 'point' as const, x: 480, y: 320, type: 'pin-solid' as const, number: 3, label: 'Passopisciaro' },
  { kind: 'point' as const, x: 660, y: 380, type: 'pin-solid' as const, number: 4, label: 'Linguaglossa' },
  { kind: 'point' as const, x: 760, y: 440, type: 'pin-solid' as const, number: 5, label: 'Riposto' },
];

const etna = {
  kind: 'route' as const,
  kicker: 'WIJNROUTE · ETNA · 03 DAGEN',
  title: 'De noordhelling',
  subtitle: 'Randazzo · Solicchiata · Riposto',
  intro: 'Drie dagen rond de noordflank van de Etna: vijf wijnhuizen, 62 km, één eindeloze vulkaan.',
  map: {
    viewBox: '0 0 960 640',
    bbox: ['37° 55′ N', '15° 18′ E', '37° 38′ S', '14° 50′ W'] as [string, string, string, string],
    layers: etnaLayers,
    compass: true,
    scaleBar: { kmTo: 10, pxLength: 80 },
    backgroundPattern: 'contour' as const,
  },
  legend: [
    { label: 'Etna DOC zone', color: 'burgundy' as const },
    { label: 'Route', color: 'burgundy' as const },
    { label: 'Rivier Alcantara', color: 'vine' as const },
  ],
  dataStrip: [
    { label: 'Stops', value: '5' },
    { label: 'Afstand', value: '62 km' },
    { label: 'Hoogte', value: '600–900 m' },
    { label: 'Beste tijd', value: 'okt–nov' },
  ],
  source: 'Consorzio Tutela Etna DOC',
};

const pageTitle = 'Infographics — preview';
const pageDescription = 'Preview-route voor InfographicCard en InfographicAtlas. Niet voor publieke navigatie — gebruik voor redactie + QA.';
---

<SiteLayout title={pageTitle} description={pageDescription} noindex locale={locale} alternates={alternates}>
  <div class="vm-infographic-preview">
    <header class="vm-preview-header">
      <p class="vm-preview-kicker">PREVIEW · LAT-1108</p>
      <h1 class="vm-preview-title">Infographic-systeem</h1>
      <p class="vm-preview-lead">
        Drie referentie-infographics, gebouwd met <code>&lt;InfographicCard&gt;</code> en <code>&lt;InfographicAtlas&gt;</code>.
        Open op mobiel om de radial → balken fallback te zien (spec § 5.4).
      </p>
    </header>

    {/* 1. Etna — Editorial Atlas */}
    <section class="vm-preview-section">
      <h2 class="vm-preview-section-title">01 · Etna-route</h2>
      <p class="vm-preview-section-desc">
        <code>&lt;InfographicAtlas kind="route"&gt;</code> — Editorial Atlas met genummerde stops, dashed route en compass.
      </p>
      <InfographicAtlas
        kind={etna.kind}
        kicker={etna.kicker}
        title={etna.title}
        subtitle={etna.subtitle}
        intro={etna.intro}
        map={etna.map}
        legend={etna.legend}
        dataStrip={etna.dataStrip}
        source={etna.source}
        alt="Wijnroute kaart van Etna: drie dagen rond de noordhelling, vijf wijnhuizen tussen Randazzo en Riposto, 62 km. Bron: Consorzio Tutela Etna DOC."
      />
    </section>

    {/* 2. Nebbiolo vergelijking — 3 region Cellar Cards */}
    <section class="vm-preview-section">
      <h2 class="vm-preview-section-title">02 · Nebbiolo-vergelijking</h2>
      <p class="vm-preview-section-desc">
        Drie <code>&lt;InfographicCard type="region"&gt;</code> naast elkaar — dezelfde druif, drie appellaties.
      </p>
      <div class="vm-card-grid">
        {nebbiolos.map((n) => (
          <InfographicCard
            type="region"
            number={n.number}
            kicker="VERGELIJKING · NEBBIOLO"
            title={n.region}
            subtitle="Piemonte"
            contextLine={n.contextLine}
            radial={{ axes: n.radial.axes as any }}
            dataGrid={n.dataGrid}
            tastingNote={n.tasting}
            source="Consorzio Tutela Barolo"
            variant="article-inline"
            alt={`Regiokaart van ${n.region}: hoogte ${n.dataGrid[0].value}, bodem ${n.dataGrid[1].value}, rijping ${n.dataGrid[2].value}, drinkraam ${n.dataGrid[3].value}. Bron: Consorzio Tutela Barolo.`}
          />
        ))}
      </div>
    </section>

    {/* 3. Riesling aromaprofiel — Cellar Card + aroma wheel */}
    <section class="vm-preview-section">
      <h2 class="vm-preview-section-title">03 · Riesling-aromaprofiel</h2>
      <p class="vm-preview-section-desc">
        <code>&lt;InfographicCard type="aroma"&gt;</code> met aroma-wheel (3 ringen × 8 wedges) en data-strip.
      </p>
      <InfographicCard
        type="aroma"
        number="003"
        kicker="AROMAPROFIEL · VinoMartino-proefnotitie"
        title="Riesling"
        subtitle="droog, koel klimaat"
        contextLine="MOSEL · NAHE · WACHAU"
        aromaWheel={rieslingWheel}
        dataGrid={[
          { label: 'Alc', value: '11.0%' },
          { label: 'Restzoet', value: '< 9 g/L' },
          { label: 'pH', value: '2.9' },
          { label: 'Drinkraam', value: '2026–2042' },
        ]}
        tastingNote={['Limoen, perzik, leisteen — strakke ruggengraat met', 'lange minerale afdronk en geleidelijk petroleum-doom.']}
        source="VinoMartino-proefnotitie"
        alt="Aromaprofiel van Riesling: 8 aroma-categorieën in 3 ringen (primair druif, secundair vinificatie, tertiair rijping). Droog, 11% alcohol, drinkraam tot 2042."
      />
    </section>

    <footer class="vm-preview-footer">
      <p>Volledige redactie-handleiding: <a href="/assets/INFOGRAPHICS_README.md"><code>INFOGRAPHICS_README.md</code></a> in de repo.</p>
      <p>Design-spec: <a href="https://app.paperclip.ing/LAT/issues/LAT-1107">LAT-1107</a> · Implementatie: <a href="https://app.paperclip.ing/LAT/issues/LAT-1108">LAT-1108</a>.</p>
    </footer>
  </div>
</SiteLayout>

<style>
  .vm-infographic-preview {
    max-width: 1280px;
    margin: 0 auto;
    padding: var(--space-12, 3rem) var(--gutter, 2rem) var(--space-24, 6rem);
  }
  .vm-preview-header {
    text-align: center;
    margin-bottom: var(--space-16, 4rem);
  }
  .vm-preview-kicker {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    color: var(--rust);
    text-transform: uppercase;
    margin-bottom: var(--space-3, 0.75rem);
  }
  .vm-preview-title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(2.5rem, 2rem + 2vw, 3.5rem);
    color: var(--ink);
    line-height: 1.1;
    margin-bottom: var(--space-4, 1rem);
  }
  .vm-preview-lead {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: var(--inkSoft);
    max-width: 42rem;
    margin: 0 auto;
  }
  .vm-preview-lead code,
  .vm-preview-section-desc code {
    font-family: var(--font-mono);
    font-size: 0.95em;
    background: var(--paperDeep);
    padding: 0.05em 0.4em;
    border-radius: 2px;
  }
  .vm-preview-section {
    margin-top: var(--space-20, 5rem);
    padding-top: var(--space-12, 3rem);
    border-top: 1px solid var(--ruleSoft);
  }
  .vm-preview-section:first-of-type {
    border-top: none;
    padding-top: 0;
  }
  .vm-preview-section-title {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--burgundy);
    margin-bottom: var(--space-2, 0.5rem);
  }
  .vm-preview-section-desc {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--inkSoft);
    margin-bottom: var(--space-8, 2rem);
  }
  .vm-card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4, 1rem);
    align-items: start;
  }
  @media (max-width: 900px) {
    .vm-card-grid { grid-template-columns: 1fr; gap: var(--space-8, 2rem); }
  }
  .vm-preview-footer {
    margin-top: var(--space-24, 6rem);
    padding-top: var(--space-8, 2rem);
    border-top: 1px solid var(--ruleSoft);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--inkFaint);
    text-align: center;
  }
  .vm-preview-footer p { margin-bottom: var(--space-2, 0.5rem); }
  .vm-preview-footer a { color: var(--burgundy); }
</style>
