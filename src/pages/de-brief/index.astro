---
import SiteLayout from '../../layouts/SiteLayout.astro';
import Briefkaart from '../../components/Briefkaart.astro';
import { organizationSchema, breadcrumbSchema } from '../../lib/seo';

// Capture-backend = MailerLite (LAT-1188): nieuwe aanmeldingen landen rechtstreeks
// in de groep "Newsletter Subscribers" (1896876) en starten de welkomstserie.
// Form-ID door Marijn bevestigd (LAT-1631). Override via PUBLIC_MAILERLITE_FORM_ACTION.
const FORM_ACTION =
  import.meta.env.PUBLIC_MAILERLITE_FORM_ACTION ||
  'https://assets.mailerlite.com/jsonp/2415940/forms/189828746131277541/subscribe';

const INSTAGRAM_URL =
  import.meta.env.PUBLIC_INSTAGRAM_URL || 'https://instagram.com/vinomartino.travel';
// Substack bewust verborgen (Marijn LAT-1631): alleen Instagram als tussentijds kanaal.
const SUBSTACK_URL = import.meta.env.PUBLIC_SUBSTACK_URL || '';

const schema = [
  organizationSchema(),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'De brief', url: '/de-brief/' },
  ]),
];
---

<SiteLayout
  title="De brief, de nieuwsbrief van VinoMartino"
  description="Elke twee weken stopt Marijn een brief in je inbox: over een wijnmaker die we net bezochten, een regio die opnieuw onze aandacht trok, een fles die indruk maakte. Met aanmelding stuur ik de Langhe-reisplanner meteen."
  schema={schema}
  activeNav="de-brief"
>
  <section class="hero">
    <div class="container container-narrow">
      <span class="kicker">De brief · elke twee weken</span>
      <h1>De brief</h1>
      <p class="lede">
        Elke twee weken stopt Marijn een brief in je inbox. Geen persberichten,
        geen uitnodigingen voor generieke wijnfestivals, een echte brief. Over een
        wijnmaker die we net bezochten, een regio die opnieuw onze aandacht trok, een
        fles die indruk maakte. Bij aanmelding stuur ik de Langhe-reisplanner meteen.
      </p>

      <form
        class="signup"
        action={FORM_ACTION}
        method="post"
        target="_blank"
        data-newsletter-signup
        data-region-preference="unknown"
      >
        <label for="ml-email" class="visually-hidden">E-mailadres</label>
        <input
          id="ml-email"
          type="email"
          name="fields[email]"
          autocomplete="email"
          placeholder="je@adres.nl"
          required
        />
        <button type="submit" data-plausible-cta="newsletter_signup">Stuur me de brief</button>
      </form>

      <p class="follow">
        Al nieuwsgierig? Volg Marijn alvast op
        <a href={INSTAGRAM_URL} target="_blank" rel="noopener">Instagram</a>{SUBSTACK_URL ? (
          <> en <a href={SUBSTACK_URL} target="_blank" rel="noopener">Substack</a></>
        ) : null}, daar verschijnen de eerste verhalen.
      </p>
    </div>
  </section>

  <section class="voorbeeld">
    <div class="container container-narrow">
      <Briefkaart dateline="De Brief, editie 1, juli 2026">
        <p>Beste lezer,</p>
        <p>
          Het was de dag nadat de laatste trossen Nebbiolo waren geoogst, begin
          november, en de Langhe was verlaten op een manier die alleen november kan.
          Geel en stil. We reden op smalle asfaltwegen van La Morra naar Verduno, met
          niemand voor ons en niemand achter ons.
        </p>
        <p>
          Bij Fratelli Alessandria, een huis in Verduno dat niet in de toeristengidsen
          staat, deed de wijnmaker open alsof we deel waren van zijn middag en niet van
          iets bijzonders. We proefden de 2017 Monvigliero: breed, warm, met de typische
          teer en rozen van Nebbiolo en iets wat ik alleen kan omschrijven als november
          zelf in een glas.
        </p>
        <p>
          In de volledige editie: het hele verhaal uit de Langhe, de Piemonte-pakketpagina
          die eraan komt, en een Siciliaanse wijnhuis-tip.
        </p>
        <p>
          Dit is een voorbeeld. Meld je aan, dan valt de eerstvolgende editie in je inbox.
        </p>
      </Briefkaart>
    </div>
  </section>
</SiteLayout>

<style>
  .container { max-width: 1280px; margin: 0 auto; padding-inline: var(--gutter); }
  .container-narrow { max-width: 760px; }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .hero {
    padding: clamp(56px, 10vw, 112px) 0;
    text-align: center;
  }
  .kicker {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-rust, #A14F2A);
    display: inline-block;
    margin-bottom: 0.75rem;
  }
  h1 {
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 5vw + 1rem, 5rem);
    font-weight: 500;
    color: var(--color-text);
    margin: 0;
    line-height: 0.95;
  }
  .lede {
    font-family: var(--font-serif, var(--font-body));
    font-size: 1.1875rem;
    line-height: 1.6;
    color: var(--color-text-soft, var(--color-text));
    margin: 1.5rem auto 0;
    max-width: 600px;
  }
  .signup {
    margin: 2rem auto 0;
    max-width: 480px;
    display: flex;
    gap: 0.5rem;
  }
  .signup input {
    flex: 1;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-rule, #C9B98F);
    background: var(--color-bg);
    font-family: var(--font-serif, var(--font-body));
    font-size: 1rem;
    outline: none;
    color: var(--color-text);
  }
  .signup input:focus {
    border-color: var(--color-primary);
  }
  .signup button {
    background: var(--color-primary);
    color: var(--color-bg);
    padding: 0.75rem 1.25rem;
    border: none;
    font-family: var(--font-ui);
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }
  .signup button:hover {
    background: var(--color-primary-hover, var(--color-primary));
  }
  .follow {
    font-family: var(--font-serif, var(--font-body));
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-text-faint, var(--color-text-soft, var(--color-text)));
    margin: 1.25rem auto 0;
    max-width: 480px;
  }
  .follow a {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .voorbeeld {
    padding: 0 0 clamp(56px, 10vw, 112px);
  }
  .voorbeeld-link {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.25rem;
    line-height: 1.35;
    margin-top: 1.1rem;
  }
  .voorbeeld-link a {
    color: var(--burgundy);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 640px) {
    .signup {
      flex-direction: column;
    }
  }
</style>
