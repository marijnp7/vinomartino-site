---
// LAT-2023 / LAT-2826 — NL "Reizen nareizen"-pakketroute (prefixloos,
// DEFAULT_LOCALE). Markup en chrome leven in het gedeelde ReisPakketDetail-
// component; deze route levert enkel de paden + props. De /en/-tegenhanger
// (src/pages/en/reizen-nareizen/[slug].astro) rendert hetzelfde component met
// locale="en" en de per-locale loader (no-translation-guard → geen EN-pagina
// zonder vertaling).
import ReisPakketDetail from '../../components/ReisPakketDetail.astro';
import { loadReispakketten, type ReisPakket } from '../../lib/reispakketten';
import { loadStreken } from '../../lib/streken';

export async function getStaticPaths() {
  // LAT-2826: de EN-slugset (guard laat alléén vertaalde pakketten door) bepaalt
  // of er een en-hreflang-tegenhanger bestaat. NL blijft altijd primair.
  const [pakketten, streken, enPakketten] = await Promise.all([
    loadReispakketten(),
    loadStreken(),
    loadReispakketten('en'),
  ]);
  const enSlugs = new Set(enPakketten.map((p) => p.slug));
  const streekBySlug = new Map(streken.map((s) => [s.slug, s]));
  return pakketten.map((entry) => {
    const streek = entry.streekSlug ? streekBySlug.get(entry.streekSlug) : undefined;
    return {
      params: { slug: entry.slug },
      props: {
        entry,
        landSlug: streek?.landSlug ?? '',
        landName: streek?.country ?? '',
        streekName: entry.streekName || streek?.name || '',
        // Geen EN-vertaling → geen alternates → SiteLayout emit geen hreflang
        // (byte-identiek aan prod; geen zinloze self-referende nl/x-default).
        alternates: enSlugs.has(entry.slug)
          ? { nl: `/reizen-nareizen/${entry.slug}/`, en: `/en/reizen-nareizen/${entry.slug}/` }
          : undefined,
      },
    };
  });
}

const { entry, landSlug, landName, streekName, alternates } = Astro.props as {
  entry: ReisPakket;
  landSlug: string;
  landName: string;
  streekName: string;
  alternates: Record<string, string> | undefined;
};
---

<ReisPakketDetail
  entry={entry}
  landSlug={landSlug}
  landName={landName}
  streekName={streekName}
  alternates={alternates}
/>
