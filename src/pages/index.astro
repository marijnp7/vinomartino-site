---
import SiteLayout from '../layouts/SiteLayout.astro';
import ZelfGereisdBadge from '../components/ZelfGereisdBadge.astro';
import Briefkaart from '../components/Briefkaart.astro';
import HomeRoutesMap from '../components/HomeRoutesMap.astro';
import DiscoverMapEurope from '../components/DiscoverMapEurope.astro';
import NewsletterRegionField from '../components/NewsletterRegionField.astro';
import { loadArticles } from '../lib/articles';
import { loadRoutes } from '../lib/routes';
import { loadStreken } from '../lib/streken';
import { loadLanden } from '../lib/landen';
import { organizationSchema } from '../lib/seo';
import { getAuthorByByline } from '../lib/authors';

// LAT-2008 (VIS-BL-09) — De Brief inline op de homepage. Zelfde MailerLite-
// capture als /de-brief/ (LAT-1631, form-ID door Marijn bevestigd), override via
// PUBLIC_MAILERLITE_FORM_ACTION zodat homepage en briefpagina niet divergeren.
const BRIEF_FORM_ACTION =
  import.meta.env.PUBLIC_MAILERLITE_FORM_ACTION ||
  'https://assets.mailerlite.com/jsonp/2415940/forms/189828746131277541/subscribe';

// LAT-1848: render altijd de gecanoniseerde auteursnaam uit het auteur-record
// (bv. "Marijn") i.p.v. het ruwe Directus author-veld (dat nog "Martin" kan zijn).
const authorName = (byline: string | null | undefined): string =>
  getAuthorByByline(byline)?.name ?? byline ?? 'VinoMartino';

const articles = await loadArticles();
// LAT-1611: het "verhaal van de week" is instelbaar via het `featured`-veld in
// Directus. Board zet de toggle aan op het gewenste artikel; bij meerdere wint
// het nieuwste. Geen featured-artikel → val terug op het nieuwste artikel.
const spotlight = articles.find((a) => a.featured) ?? articles[0];
const moreArticles = articles.filter((a) => a.slug !== spotlight?.slug).slice(0, 3);
const routes = await loadRoutes();
const allStreken = await loadStreken();
const landen = await loadLanden();

const schema = organizationSchema();

const HERO_IMAGE = '/images/landschap-piemonte-barolo-001.jpg';

// ── LAT-2451 — Atlas als primaire navigatie direct onder de hero ──────────
// Groepeer gepubliceerde streken onder hun land (zelfde patroon als /ontdek/),
// zodat de Europa-kaart per land de streek-telling én de kerndruif toont in de
// hover-tooltip. Data-gedreven: nieuw land in Directus = extra kaartvlak, geen
// hardcoded nav-item. Kleur is deterministisch per land (merk-agnostisch palet).
const ATLAS_PALETTE = ['#5A1A1F', '#A14F2A', '#5C6B3F', '#B86030', '#6B3A4A', '#7A6A2C'];
const strekenPerLand = new Map<string, number>();
for (const s of allStreken) {
  if (!s.landSlug) continue;
  strekenPerLand.set(s.landSlug, (strekenPerLand.get(s.landSlug) ?? 0) + 1);
}
const atlasCountries = landen.map((land, i) => ({
  slug: land.slug,
  name: land.name,
  color: ATLAS_PALETTE[i % ATLAS_PALETTE.length] as string,
  regionCount: strekenPerLand.get(land.slug) ?? 0,
  // Kerndruif-hover: de eerste twee hoofddruiven van het land (Directus main_grapes).
  grapes: land.mainGrapes.slice(0, 2).join(' · '),
}));

// ── LAT-2451 — Curated hero-streken ("Zelf gereisd" voorrang) ─────────────
// Marijn-besluit Optie B (2026-07-14): de tile toont bij voorkeur het dedicated
// `streken.card_blurb`-veld (max 140, redactioneel gevuld voor de 6-8 uitgelichte
// streken). Is dat leeg, dan valt de tile terug op zinsgrens-truncatie van
// `description`. Het ruwe `description`-veld (elders intro/meta, ~220-760 tekens)
// blijft ONGEWIJZIGD — we korten alleen de gerenderde tegel-copy op build-tijd,
// geen CSS-ellipsis midden in een zin.
const HERO_STREKEN_MAX = 8;

// Kap op een woordgrens met ellipsis als de tekst > max is; laat kortere tekst heel.
function clampToWord(text: string, max = 140): string {
  const clean = text.replace(/\s+/g, ' ').trim();
  if (clean.length <= max) return clean;
  const lastSpace = clean.slice(0, max).lastIndexOf(' ');
  return `${clean.slice(0, lastSpace > 0 ? lastSpace : max).trimEnd()}…`;
}

// Neem de eerste zin (eerste .!? gevolgd door spatie/eind, met een 40-teken-
// ondergrens zodat afkortingen als "St." niet vroeg afkappen). Is die zin langer
// dan max, dan kap op woordgrens met een ellipsis; ontbreekt een zin-einde, dan
// val terug op de hele tekst (met dezelfde woordgrens-cap).
function clampToSentence(text: string, max = 140): string {
  const clean = text.replace(/\s+/g, ' ').trim();
  if (!clean) return clean;
  const re = /[.!?](?=\s|$)/g;
  let end = -1;
  let m: RegExpExecArray | null;
  while ((m = re.exec(clean)) !== null) {
    if (m.index >= 40) { end = m.index + 1; break; }
  }
  const firstSentence = end > 0 ? clean.slice(0, end).trim() : clean;
  return clampToWord(firstSentence, max);
}

// Kaart-blurb: dedicated card_blurb (defensief op 140 gekapt) heeft voorrang;
// anders zinsgrens-truncatie van description.
function heroBlurb(cardBlurb: string, description: string): string {
  const cb = cardBlurb.trim();
  if (cb) return clampToWord(cb);
  return clampToSentence(description);
}

// Foto- + tekst-guard (LAT-2267/LAT-2356): alleen streken mét hero-foto én blurb.
// Zelf-gereisd eerst (nieuwste bezoek bovenaan), daarna de overige foto-streken
// als opvulling; harde cap op acht (VIS: curated rij van 6-8).
const heroStreken = allStreken
  .filter((s) => Boolean(s.heroImage) && Boolean(s.name) && Boolean(s.description?.trim()))
  .sort((a, b) => {
    if (a.zelfGereisd !== b.zelfGereisd) return a.zelfGereisd ? -1 : 1;
    if (a.zelfGereisd && b.zelfGereisd) {
      const ja = a.bezoekjaar ?? 0;
      const jb = b.bezoekjaar ?? 0;
      if (ja !== jb) return jb - ja;
    }
    return a.name.localeCompare(b.name, 'nl');
  })
  .slice(0, HERO_STREKEN_MAX)
  .map((s) => ({
    name: s.name,
    eyebrow: s.country,
    blurb: heroBlurb(s.cardBlurb, s.description),
    href: `/streken/${s.slug}/`,
    image: s.heroImage as string,
    visited: s.zelfGereisd,
  }));

// ── LAT-2451 — Uitgelichte routes: max zes, foto verplicht, met duur + streek-tag ──
const strekenBySlug = new Map(allStreken.map((s) => [s.slug, s]));
const FEATURED_ROUTES_MAX = 6;
const featuredRoutes = routes
  .filter((r) => Boolean(r.heroImage))
  .slice(0, FEATURED_ROUTES_MAX)
  .map((r) => {
    const streek = r.streekSlug ? strekenBySlug.get(r.streekSlug) : undefined;
    return {
      slug: r.slug,
      title: r.title,
      description: r.description,
      image: r.heroImage as string,
      duration: r.duration,
      regionTag: streek?.name || streek?.country || '',
    };
  });

function formatDate(value?: string | null) {
  if (!value) return '';
  try {
    return new Date(value).toLocaleDateString('nl-NL', { day: 'numeric', month: 'long', year: 'numeric' });
  } catch {
    return '';
  }
}
---

<SiteLayout
  title="VinoMartino: Wijnreizen met karakter"
  description="Image-led wijnreis-verhalen, routes en proefnotities uit Piemonte, de Douro, de Kaap en wijnstreken wereldwijd, geschreven door wijnliefhebbers die zelf op pad gaan."
  ogImage={HERO_IMAGE}
  schema={schema}
>
  <section class="hero" aria-label="Wijnreizen met karakter">
    <div class="hero-media">
      <img
        src={HERO_IMAGE}
        alt="Golden-hour wijngaardlandschap in de Langhe, pad door de vines richting Barolo, Piemonte"
        width="1600"
        height="1067"
        fetchpriority="high"
        decoding="async"
      />
    </div>
    <div class="hero-veil" aria-hidden="true"></div>
    <div class="hero-inner container">
      <span class="hero-eyebrow">Zelf gereisd sinds 2019</span>
      <h1 class="hero-title">
        De wijnreizen die wij zelf maakten,
        <em>klaar om na te reizen.</em>
      </h1>
      <p class="hero-lede">
        Routes, wijnhuizen en adressen uit elf zelf-gereisde streken. Geen lijstjes, wel de weg ernaartoe.
      </p>
      <div class="hero-ctas">
        <a href="#bestemmingen" class="btn btn-primary">Kies je bestemming</a>
        <a href="#routes" class="btn btn-ghost">Bekijk de routes</a>
      </div>
    </div>
    <a href="#bestemmingen" class="hero-scroll" aria-label="Scroll verder">
      <span class="hero-scroll-line" aria-hidden="true"></span>
      <span class="hero-scroll-label">Verder</span>
    </a>
  </section>

  {atlasCountries.length > 0 && (
    <section id="atlas" class="atlas-section" aria-label="Wijnatlas">
      <div class="container">
        <header class="strip-header atlas-head">
          <span class="kicker">De wijnatlas</span>
          <h2 class="strip-title">Kies je land, vind je streek</h2>
          <p class="strip-lede">
            Beweeg over een wijnland voor de kerndruif, klik door naar de streekgids. De hele atlas onder één kaart, geen menu dat meegroeit.
          </p>
        </header>
        <DiscoverMapEurope countries={atlasCountries} />
        <ul class="atlas-fallback" aria-label="Wijnlanden">
          {atlasCountries.map((c) => (
            <li>
              <a href={`/landen/${c.slug}/`} class="atlas-chip" style={`--c: ${c.color};`}>
                <span class="atlas-chip-name">{c.name}</span>
                <span class="atlas-chip-meta">{c.regionCount} {c.regionCount === 1 ? 'streek' : 'streken'}</span>
              </a>
            </li>
          ))}
        </ul>
        <p class="section-cta"><a href="/ontdek/" class="btn btn-outline">Naar de volledige atlas →</a></p>
      </div>
    </section>
  )}

  <section id="bestemmingen" class="strip">
    <div class="container">
      <header class="strip-header">
        <span class="kicker">Zelf gereisd, dus we weten het</span>
        <h2 class="strip-title">Waar begint jouw wijnreis?</h2>
        <p class="strip-lede">
          De streken waar we zélf waren, staan vooraan. Kies waar je heen wilt, en het verhaal, de routes en de adressen volgen.
        </p>
      </header>
      <div class="streken-grid">
        {heroStreken.map((streek, idx) => (
          <a href={streek.href} class="streek-tile">
            <div class="streek-media">
              <img
                src={streek.image}
                alt={`${streek.name}, wijngaardlandschap`}
                width="800"
                height="1000"
                loading={idx < 2 ? 'eager' : 'lazy'}
                decoding="async"
              />
            </div>
            {streek.visited && (
              <div class="streek-tile-badge">
                <ZelfGereisdBadge visited={true} />
              </div>
            )}
            <div class="streek-body">
              <span class="streek-eyebrow">{streek.eyebrow}</span>
              <h3 class="streek-name">{streek.name}</h3>
              <p class="streek-blurb">{streek.blurb}</p>
              <span class="streek-link" aria-hidden="true">Ontdek de streek →</span>
            </div>
          </a>
        ))}
      </div>
      <p class="section-cta"><a href="/streken/" class="btn btn-outline">Alle streken →</a></p>
    </div>
  </section>

  <section id="routes" class="cards-section">
    <div class="container">
      <header class="section-head">
        <span class="kicker">Op pad</span>
        <h2 class="section-h">Wijnroutes met karakter</h2>
        <p class="section-sub">
          Geen Google-maps-grids, maar reizen van twee tot vijf dagen, met wijnhuizen, eetadressen en de weg ertussen.
        </p>
      </header>
      <HomeRoutesMap routes={routes} />
      <div class="cards-grid">
        {featuredRoutes.map((r, idx) => (
          <a href={`/wijnroutes/${r.slug}/`} class="card-tile">
            <div class="card-media">
              <img src={r.image} alt={r.title} width="600" height="450" loading={idx < 3 ? 'eager' : 'lazy'} decoding="async" />
            </div>
            <div class="card-body">
              {(r.duration || r.regionTag) && (
                <span class="card-eyebrow card-meter">
                  {r.duration && <span>{r.duration}</span>}
                  {r.duration && r.regionTag && <span class="card-meter-dot" aria-hidden="true"> · </span>}
                  {r.regionTag && <span>{r.regionTag}</span>}
                </span>
              )}
              <h3 class="card-title">{r.title}</h3>
              {r.description && <p class="card-desc">{r.description}</p>}
            </div>
          </a>
        ))}
      </div>
      <p class="section-cta"><a href="/wijnroutes/" class="btn btn-outline">Alle routes →</a></p>
    </div>
  </section>

  {spotlight && (
    <section class="spotlight">
      <div class="container spotlight-inner">
        <a href={`/artikelen/${spotlight.slug}/`} class="spotlight-media-link" aria-label={spotlight.title}>
          {spotlight.heroImage ? (
            <img
              src={spotlight.heroImage}
              alt={spotlight.title}
              width="1200"
              height="900"
              loading="lazy"
              decoding="async"
              class="spotlight-img"
            />
          ) : (
            <div class="spotlight-img spotlight-placeholder" aria-hidden="true"></div>
          )}
        </a>
        <div class="spotlight-body">
          <span class="kicker">Verhaal van de week</span>
          {spotlight.category && <span class="spotlight-cat">{spotlight.category.replace(/-/g, ' ')}</span>}
          <h2 class="spotlight-title">
            <a href={`/artikelen/${spotlight.slug}/`}>{spotlight.title}</a>
          </h2>
          {spotlight.description && <p class="spotlight-desc">{spotlight.description}</p>}
          <p class="spotlight-meta">
            <span>{authorName(spotlight.author)}</span>
            <span class="dot" aria-hidden="true">·</span>
            <span>{formatDate(spotlight.pubDate)}</span>
          </p>
          <a href={`/artikelen/${spotlight.slug}/`} class="quiet-cta">Lees het hele verhaal →</a>
        </div>
      </div>
    </section>
  )}

  {moreArticles.length > 0 && (
    <section class="cards-section cards-section--alt">
      <div class="container">
        <header class="section-head">
          <span class="kicker">Laatste verhalen</span>
          <h2 class="section-h">Vers van de pers</h2>
          <p class="section-sub">
            Reisverslagen, proefnotities en achtergronden. Onze tips komen uit eigen bezoek en geteste adressen; boek je via onze links, dan steun je de site zonder dat jij meer betaalt.
          </p>
        </header>
        <div class="cards-grid">
          {moreArticles.map(article => (
            <a href={`/artikelen/${article.slug}/`} class="card-tile">
              <div class:list={['card-media', !article.heroImage && 'is-empty']}>
                {article.heroImage ? (
                  <img src={article.heroImage} alt={article.title} width="600" height="450" loading="lazy" decoding="async" />
                ) : (
                  <div class="card-placeholder" aria-hidden="true"></div>
                )}
              </div>
              <div class="card-body">
                {article.category && <span class="card-eyebrow">{article.category.replace(/-/g, ' ')}</span>}
                <h3 class="card-title">{article.title}</h3>
                {article.description && <p class="card-desc">{article.description}</p>}
                <span class="card-meta">{authorName(article.author)} · {formatDate(article.pubDate)}</span>
              </div>
            </a>
          ))}
        </div>
        <p class="section-cta"><a href="/artikelen/" class="btn btn-outline">Alle artikelen →</a></p>
      </div>
    </section>
  )}

  <section class="proof" aria-label="Bewijs en gezicht">
    <div class="container proof-inner">
      <div class="proof-portrait">
        <img
          src="/over-ons-hero.jpg"
          alt="Marijn proeft een glas wijn met wijngaarden op de achtergrond"
          width="800"
          height="1000"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="proof-body">
        <span class="kicker proof-kicker">Bewijs en gezicht</span>
        {/* LAT-2008: cijfers gestaafd tegen de canon. "11" spiegelt de Tier 1-lijst
            `visited` op /over-ons/ (elf zelf-gereisde streken); "2019" is dezelfde bronclaim als
            "streken sinds 2019" daar. Het "60+ wijnhuizen"-cijfer is geschrapt tot
            er telbewijs uit Directus is (Marijn, 2026-07-03). */}
        <ul class="proof-stats">
          <li><span class="proof-num">11</span><span class="proof-label">streken zelf bereisd</span></li>
          <li><span class="proof-num">2019</span><span class="proof-label">sinds we op pad zijn</span></li>
        </ul>
        <p class="proof-manifest">
          Waar we zelf waren, zie je dat: het label <em>Zelf gereisd</em>.
        </p>
        <a href="/over-ons/" class="btn btn-outline">Ons verhaal →</a>
      </div>
    </div>
  </section>

  <section class="brief">
    <div class="container">
      <Briefkaart dateline="De Brief · elke twee weken" align="center">
        <h2 class="brief-kaart-h">Elke twee weken een brief. Geen lijstjes.</h2>
        <p>
          Een persoonlijke brief van Marijn: wat we recent dronken, waar we waren,
          en welke fles ons opviel. Geen affiliate-deals, geen nieuwsbriefformule.
        </p>
        <form
          class="brief-signup"
          action={BRIEF_FORM_ACTION}
          method="post"
          target="_blank"
          data-newsletter-signup
        >
          <div class="brief-signup__row">
            <label for="brief-email" class="visually-hidden">E-mailadres</label>
            <input
              id="brief-email"
              type="email"
              name="fields[email]"
              autocomplete="email"
              placeholder="je@adres.nl"
              required
            />
            <button type="submit" class="btn btn-primary" data-plausible-cta="newsletter_signup">Stuur me de brief</button>
          </div>
          <NewsletterRegionField id="brief-region" />
        </form>
      </Briefkaart>
    </div>
  </section>
</SiteLayout>

<style>
  /* ── Hero ─────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: clamp(560px, 88vh, 860px);
    color: var(--fixed-cream);
    overflow: hidden;
    isolation: isolate;
    display: flex;
    align-items: flex-end;
  }
  .hero-media {
    position: absolute;
    inset: 0;
    z-index: -2;
    display: block;
    overflow: hidden;
  }
  .hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 38%;
    transform: scale(1.04);
    animation: hero-zoom 28s ease-out forwards;
  }
  @keyframes hero-zoom {
    from { transform: scale(1.02); }
    to { transform: scale(1.10); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-media img { animation: none; transform: scale(1.02); }
  }
  .hero-veil {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(180deg, rgba(13, 10, 7, 0.65) 0%, rgba(13, 10, 7, 0.15) 28%, rgba(13, 10, 7, 0.15) 55%, rgba(13, 10, 7, 0.78) 100%),
      linear-gradient(90deg, rgba(13, 10, 7, 0.45) 0%, rgba(13, 10, 7, 0) 55%);
  }
  .hero-inner {
    position: relative;
    width: 100%;
    padding-top: var(--space-32);
    padding-bottom: var(--space-20);
    max-width: var(--max-width);
  }
  .hero-eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid color-mix(in srgb, var(--gold) 60%, transparent);
  }
  .hero-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(3rem, 7vw + 0.5rem, 6.5rem);
    line-height: 0.98;
    letter-spacing: -0.02em;
    color: var(--fixed-cream);
    margin: var(--space-6) 0 var(--space-5);
    max-width: 22ch;
  }
  .hero-title em {
    font-style: italic;
    color: var(--gold);
    display: inline-block;
  }
  .hero-lede {
    font-family: var(--font-body);
    font-size: clamp(1.0625rem, 0.4vw + 1rem, 1.25rem);
    line-height: 1.6;
    color: color-mix(in srgb, var(--fixed-cream) 92%, transparent);
    max-width: 38rem;
    margin-bottom: var(--space-8);
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }
  .hero-scroll {
    position: absolute;
    right: var(--gutter);
    bottom: var(--space-6);
    display: none;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    color: color-mix(in srgb, var(--fixed-cream) 80%, transparent);
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    text-decoration: none;
    z-index: 1;
  }
  .hero-scroll-line {
    width: 1px;
    height: 3rem;
    background: currentColor;
    opacity: 0.5;
    animation: scroll-line 2.4s ease-in-out infinite;
    transform-origin: top;
  }
  @keyframes scroll-line {
    0%, 100% { transform: scaleY(0.4); }
    50% { transform: scaleY(1); }
  }
  @media (min-width: 1024px) {
    .hero-scroll { display: flex; }
  }

  /* ── Buttons ──────────────────────────────────────────── */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.95rem 1.85rem;
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-decoration: none;
    border: 1px solid transparent;
    transition: background var(--duration-fast) var(--ease-out), color var(--duration-fast) var(--ease-out), border-color var(--duration-fast) var(--ease-out);
    cursor: pointer;
  }
  .btn-primary {
    background: var(--burgundy);
    color: var(--fixed-cream);
  }
  .btn-primary:hover { background: var(--burgundyDeep); color: var(--fixed-cream); }
  .btn-ghost {
    background: transparent;
    color: var(--fixed-cream);
    border-color: color-mix(in srgb, var(--fixed-cream) 60%, transparent);
  }
  .btn-ghost:hover {
    background: color-mix(in srgb, var(--fixed-cream) 10%, transparent);
    color: var(--fixed-cream);
    border-color: var(--fixed-cream);
  }
  .btn-outline {
    background: transparent;
    color: var(--burgundy);
