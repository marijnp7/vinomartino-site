---
import SiteLayout from '../layouts/SiteLayout.astro';
import { loadArticles } from '../lib/articles';
import { loadWijnhuizen } from '../lib/wijnhuizen';
import { loadRoutes } from '../lib/routes';
import { loadStreken } from '../lib/streken';
import { organizationSchema } from '../lib/seo';

const articles = await loadArticles();
const [spotlight, ...rest] = articles;
const moreArticles = rest.slice(0, 3);
const wijnhuizen = (await loadWijnhuizen()).slice(0, 3);
const routes = (await loadRoutes()).slice(0, 3);
const streken = (await loadStreken()).slice(0, 3);

const schema = organizationSchema();

const HERO_IMAGE = '/images/landschap-piemonte-barolo-001.jpg';

const editorialStreken = [
  {
    name: 'Piemonte',
    eyebrow: 'Italië',
    blurb: 'Nebbiolo, mist en truffels, de Langhe is het Piemonte dat zijn beloftes waarmaakt.',
    href: '/streken/langhe-piemonte/',
    image: '/images/landschap-langhe-001.jpg',
  },
  {
    name: 'Douro',
    eyebrow: 'Portugal',
    blurb: 'Schist-terrassen langs de rivier, Port én droge Douro, beide vakwerk.',
    href: '/streken/douro-portugal/',
    image: '/images/landschap-douro-001.jpg',
  },
  {
    name: 'Etna',
    eyebrow: 'Sicilië',
    blurb: 'Nerello Mascalese op basalt, op hoogte, vulkanische wijn die niet om aandacht vraagt.',
    href: '/wijnroutes/etna-noord-randazzo-solicchiata/',
    image: '/images/landschap-etna-noord-001.jpg',
  },
  {
    name: 'Wachau',
    eyebrow: 'Oostenrijk',
    blurb: 'Grüner Veltliner van terraswijngaarden boven de Donau, plus Blaufränkisch uit het Burgenland.',
    href: '/artikelen/oostenrijk-gruner-veltliner-in-de-wachau-en-blaufrankisch-in-het-burgenland/',
    image: '/images/landschap-wachau-001.jpg',
  },
];

function formatDate(value?: string | null) {
  if (!value) return '';
  try {
    return new Date(value).toLocaleDateString('nl-NL', { day: 'numeric', month: 'long', year: 'numeric' });
  } catch {
    return '';
  }
}
---

<SiteLayout
  title="VinoMartino: Wijnreizen met karakter"
  description="Image-led wijnreis-verhalen, routes en proefnotities uit Piemonte, de Douro, de Kaap en wijnstreken wereldwijd, geschreven door wijnliefhebbers die zelf op pad gaan."
  ogImage={HERO_IMAGE}
  schema={schema}
>
  <section class="hero" aria-label="Wijnreizen met karakter">
    <div class="hero-media">
      <img
        src={HERO_IMAGE}
        alt="Golden-hour wijngaardlandschap in de Langhe, pad door de vines richting Barolo, Piemonte"
        width="1600"
        height="1067"
        fetchpriority="high"
        decoding="async"
      />
    </div>
    <div class="hero-veil" aria-hidden="true"></div>
    <div class="hero-inner container">
      <span class="hero-eyebrow">VinoMartino, sinds de oogst van 2024</span>
      <h1 class="hero-title">
        Wijnreizen<br />
        <em>met karakter</em>
      </h1>
      <p class="hero-lede">
        Persoonlijke verhalen, routes en proefnotities uit Piemonte, de Douro, de Kaap en wijnstreken wereldwijd, geen toeristische lijstjes, wel het hele verhaal.
      </p>
      <div class="hero-ctas">
        <a href="/artikelen/" class="btn btn-primary">Lees de verhalen</a>
        <a href="/wijnroutes/" class="btn btn-ghost">Bekijk de routes</a>
      </div>
    </div>
    <a href="#streken-editorial" class="hero-scroll" aria-label="Scroll verder">
      <span class="hero-scroll-line" aria-hidden="true"></span>
      <span class="hero-scroll-label">Verder</span>
    </a>
  </section>

  <section id="streken-editorial" class="strip">
    <div class="container">
      <header class="strip-header">
        <span class="kicker">Vier streken, één obsessie</span>
        <h2 class="strip-title">Waar de fles begint</h2>
        <p class="strip-lede">
          Vier regio's die telkens terugkomen in ons werk, omdat de wijnen, het landschap en de mensen er onlosmakelijk zijn.
        </p>
      </header>
      <div class="streken-grid">
        {editorialStreken.map((streek, idx) => (
          <a href={streek.href} class={`streek-tile streek-tile--${idx}`}>
            <div class="streek-media">
              <img
                src={streek.image}
                alt={`${streek.name}, wijngaardlandschap`}
                width="800"
                height="1000"
                loading={idx === 0 ? 'eager' : 'lazy'}
                decoding="async"
              />
            </div>
            <div class="streek-body">
              <span class="streek-eyebrow">{streek.eyebrow}</span>
              <h3 class="streek-name">{streek.name}</h3>
              <p class="streek-blurb">{streek.blurb}</p>
              <span class="streek-link" aria-hidden="true">Ontdek de streek →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {spotlight && (
    <section class="spotlight">
      <div class="container spotlight-inner">
        <a href={`/artikelen/${spotlight.slug}/`} class="spotlight-media-link" aria-label={spotlight.title}>
          {spotlight.heroImage ? (
            <img
              src={spotlight.heroImage}
              alt={spotlight.title}
              width="1200"
              height="900"
              loading="lazy"
              decoding="async"
              class="spotlight-img"
            />
          ) : (
            <div class="spotlight-img spotlight-placeholder" aria-hidden="true"></div>
          )}
        </a>
        <div class="spotlight-body">
          <span class="kicker">Verhaal van de week</span>
          {spotlight.category && <span class="spotlight-cat">{spotlight.category.replace(/-/g, ' ')}</span>}
          <h2 class="spotlight-title">
            <a href={`/artikelen/${spotlight.slug}/`}>{spotlight.title}</a>
          </h2>
          {spotlight.description && <p class="spotlight-desc">{spotlight.description}</p>}
          <p class="spotlight-meta">
            <span>{spotlight.author}</span>
            <span class="dot" aria-hidden="true">·</span>
            <span>{formatDate(spotlight.pubDate)}</span>
          </p>
          <a href={`/artikelen/${spotlight.slug}/`} class="quiet-cta">Lees het hele verhaal →</a>
        </div>
      </div>
    </section>
  )}

  <section class="cards-section">
    <div class="container">
      <header class="section-head">
        <span class="kicker">Ontdek</span>
        <h2 class="section-h">Wijnhuizen die het verschil maken</h2>
        <p class="section-sub">
          Geen merknamen, wijnmakers met een handschrift. Geportretteerd door iemand die er zelf gestaan heeft.
        </p>
      </header>
      <div class="cards-grid">
        {wijnhuizen.map(w => (
          <a href={`/wijnhuizen/${w.slug}/`} class="card-tile">
            <div class="card-media">
              {w.heroImage ? (
                <img src={w.heroImage} alt={`${w.name}, ${w.region ?? ''}`.replace(/, $/, '')} width="600" height="450" loading="lazy" decoding="async" />
              ) : (
                <div class="card-placeholder" aria-hidden="true"></div>
              )}
            </div>
            <div class="card-body">
              {w.region && <span class="card-eyebrow">{w.region}</span>}
              <h3 class="card-title">{w.name}</h3>
              {w.description && <p class="card-desc">{w.description}</p>}
            </div>
          </a>
        ))}
      </div>
      <p class="section-cta"><a href="/wijnhuizen/" class="btn btn-outline">Alle wijnhuizen →</a></p>
    </div>
  </section>

  <section class="cards-section cards-section--alt">
    <div class="container">
      <header class="section-head">
        <span class="kicker">Op pad</span>
        <h2 class="section-h">Wijnroutes met karakter</h2>
        <p class="section-sub">
          Geen Google-maps-grids, maar reizen, twee tot vijf dagen, met kelders, eetadressen en de weg ertussen.
        </p>
      </header>
      <div class="cards-grid">
        {routes.map(r => (
          <a href={`/wijnroutes/${r.slug}/`} class="card-tile">
            <div class="card-media">
              {r.heroImage ? (
                <img src={r.heroImage} alt={r.title} width="600" height="450" loading="lazy" decoding="async" />
              ) : (
                <div class="card-placeholder" aria-hidden="true"></div>
              )}
            </div>
            <div class="card-body">
              {r.duration && <span class="card-eyebrow">{r.duration}</span>}
              <h3 class="card-title">{r.title}</h3>
              {r.description && <p class="card-desc">{r.description}</p>}
            </div>
          </a>
        ))}
      </div>
      <p class="section-cta"><a href="/wijnroutes/" class="btn btn-outline">Alle routes →</a></p>
    </div>
  </section>

  <section class="cards-section">
    <div class="container">
      <header class="section-head">
        <span class="kicker">Terroir</span>
        <h2 class="section-h">Streken in beeld</h2>
        <p class="section-sub">
          Diepere achtergrond bij de regio's die ons werk vormen, geologie, druiven, eet- en drinkadressen.
        </p>
      </header>
      <div class="cards-grid">
        {streken.map(s => (
          <a href={`/streken/${s.slug}/`} class="card-tile">
            <div class="card-media">
              {s.heroImage ? (
                <img src={s.heroImage} alt={`${s.name}, ${s.country ?? ''}`.replace(/, $/, '')} width="600" height="450" loading="lazy" decoding="async" />
              ) : (
                <div class="card-placeholder" aria-hidden="true"></div>
              )}
            </div>
            <div class="card-body">
              {s.country && <span class="card-eyebrow">{s.country}</span>}
              <h3 class="card-title">{s.name}</h3>
              {s.description && <p class="card-desc">{s.description}</p>}
            </div>
          </a>
        ))}
      </div>
      <p class="section-cta"><a href="/streken/" class="btn btn-outline">Alle streken →</a></p>
    </div>
  </section>

  {moreArticles.length > 0 && (
    <section class="cards-section cards-section--alt">
      <div class="container">
        <header class="section-head">
          <span class="kicker">Laatste verhalen</span>
          <h2 class="section-h">Vers van de pers</h2>
          <p class="section-sub">
            Reisverslagen, proefnotities en achtergronden, geen reclame, geen affiliate-onzin verkleed als advies.
          </p>
        </header>
        <div class="cards-grid">
          {moreArticles.map(article => (
            <a href={`/artikelen/${article.slug}/`} class="card-tile">
              <div class="card-media">
                {article.heroImage ? (
                  <img src={article.heroImage} alt={article.title} width="600" height="450" loading="lazy" decoding="async" />
                ) : (
                  <div class="card-placeholder" aria-hidden="true"></div>
                )}
              </div>
              <div class="card-body">
                {article.category && <span class="card-eyebrow">{article.category.replace(/-/g, ' ')}</span>}
                <h3 class="card-title">{article.title}</h3>
                {article.description && <p class="card-desc">{article.description}</p>}
                <span class="card-meta">{article.author} · {formatDate(article.pubDate)}</span>
              </div>
            </a>
          ))}
        </div>
        <p class="section-cta"><a href="/artikelen/" class="btn btn-outline">Alle artikelen →</a></p>
      </div>
    </section>
  )}

  <section class="brief">
    <div class="container brief-inner">
      <div class="brief-copy">
        <span class="kicker brief-kicker">De Brief</span>
        <h2 class="brief-h">Eén keer per maand. Geen lijstjes.</h2>
        <p class="brief-lede">
          Een persoonlijke brief van Martin, wat we recent dronken, waar we waren, en welke fles ons opviel. Géén affiliate-deals, géén nieuwsbriefformule.
        </p>
      </div>
      <a href="/de-brief/" class="btn btn-gold">Schrijf me in</a>
    </div>
  </section>
</SiteLayout>

<style>
  /* ── Hero ─────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: clamp(560px, 88vh, 860px);
    color: var(--paper);
    overflow: hidden;
    isolation: isolate;
    display: flex;
    align-items: flex-end;
  }
  .hero-media {
    position: absolute;
    inset: 0;
    z-index: -2;
    display: block;
    overflow: hidden;
  }
  .hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 38%;
    transform: scale(1.04);
    animation: hero-zoom 28s ease-out forwards;
  }
  @keyframes hero-zoom {
    from { transform: scale(1.02); }
    to { transform: scale(1.10); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-media img { animation: none; transform: scale(1.02); }
  }
  .hero-veil {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(180deg, rgba(13, 10, 7, 0.65) 0%, rgba(13, 10, 7, 0.15) 28%, rgba(13, 10, 7, 0.15) 55%, rgba(13, 10, 7, 0.78) 100%),
      linear-gradient(90deg, rgba(13, 10, 7, 0.45) 0%, rgba(13, 10, 7, 0) 55%);
  }
  .hero-inner {
    position: relative;
    width: 100%;
    padding-top: var(--space-32);
    padding-bottom: var(--space-20);
    max-width: var(--max-width);
  }
  .hero-eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid color-mix(in srgb, var(--gold) 60%, transparent);
  }
  .hero-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(3rem, 7vw + 0.5rem, 6.5rem);
    line-height: 0.98;
    letter-spacing: -0.02em;
    color: var(--paper);
    margin: var(--space-6) 0 var(--space-5);
    max-width: 22ch;
  }
  .hero-title em {
    font-style: italic;
    color: var(--gold);
    display: inline-block;
  }
  .hero-lede {
    font-family: var(--font-body);
    font-size: clamp(1.0625rem, 0.4vw + 1rem, 1.25rem);
    line-height: 1.6;
    color: color-mix(in srgb, var(--paper) 92%, transparent);
    max-width: 38rem;
    margin-bottom: var(--space-8);
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }
  .hero-scroll {
    position: absolute;
    right: var(--gutter);
    bottom: var(--space-6);
    display: none;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    color: color-mix(in srgb, var(--paper) 80%, transparent);
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    text-decoration: none;
    z-index: 1;
  }
  .hero-scroll-line {
    width: 1px;
    height: 3rem;
    background: currentColor;
    opacity: 0.5;
    animation: scroll-line 2.4s ease-in-out infinite;
    transform-origin: top;
  }
  @keyframes scroll-line {
    0%, 100% { transform: scaleY(0.4); }
    50% { transform: scaleY(1); }
  }
  @media (min-width: 1024px) {
    .hero-scroll { display: flex; }
  }

  /* ── Buttons ──────────────────────────────────────────── */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.95rem 1.85rem;
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-decoration: none;
    border: 1px solid transparent;
    transition: background var(--duration-fast) var(--ease-out), color var(--duration-fast) var(--ease-out), border-color var(--duration-fast) var(--ease-out);
    cursor: pointer;
  }
  .btn-primary {
    background: var(--burgundy);
    color: var(--paper);
  }
  .btn-primary:hover { background: var(--burgundyDeep); color: var(--paper); }
  .btn-ghost {
    background: transparent;
    color: var(--paper);
    border-color: color-mix(in srgb, var(--paper) 60%, transparent);
  }
  .btn-ghost:hover {
    background: color-mix(in srgb, var(--paper) 10%, transparent);
    color: var(--paper);
    border-color: var(--paper);
  }
  .btn-outline {
    background: transparent;
    color: var(--burgundy);
    border-color: var(--burgundy);
  }
  .btn-outline:hover { background: var(--burgundy); color: var(--paper); }
  .btn-gold {
    background: var(--gold);
    color: var(--ink);
  }
  .btn-gold:hover { background: var(--paper); color: var(--ink); }

  /* ── Shared typographic helpers ───────────────────────── */
  .kicker {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--rust);
  }

  /* ── Editorial streken-grid ───────────────────────────── */
  .strip {
    padding: var(--space-24) 0 var(--space-20);
    background: var(--paper);
  }
  .strip-header {
    max-width: 44rem;
    margin: 0 0 var(--space-12);
  }
  .strip-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2.25rem, 2vw + 1.5rem, 3.5rem);
    line-height: 1.05;
    color: var(--ink);
    margin: var(--space-4) 0 var(--space-3);
  }
  .strip-lede {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--inkSoft);
  }
  .streken-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-5);
  }
  .streek-tile {
    position: relative;
    display: block;
    color: var(--paper);
    text-decoration: none;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    isolation: isolate;
  }
  .streek-tile::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(180deg, rgba(13, 10, 7, 0.05) 0%, rgba(13, 10, 7, 0.15) 45%, rgba(13, 10, 7, 0.85) 100%);
    transition: background var(--duration-base) var(--ease-out);
  }
  .streek-tile:hover::after {
    background: linear-gradient(180deg, rgba(90, 26, 31, 0.05) 0%, rgba(90, 26, 31, 0.25) 45%, rgba(61, 17, 21, 0.9) 100%);
  }
  .streek-media {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }
  .streek-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-image) var(--ease-out);
  }
  .streek-tile:hover .streek-media img {
    transform: scale(1.05);
  }
  .streek-body {
    position: absolute;
    inset: auto 0 0 0;
    z-index: 2;
    padding: var(--space-6) var(--space-6) var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .streek-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
  }
  .streek-name {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.75rem, 1vw + 1.5rem, 2.5rem);
    line-height: 1;
    color: var(--paper);
  }
  .streek-blurb {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    line-height: 1.5;
    color: color-mix(in srgb, var(--paper) 88%, transparent);
    margin-top: var(--space-2);
  }
  .streek-link {
    margin-top: var(--space-3);
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    letter-spacing: 0.05em;
    color: var(--gold);
    opacity: 0;
    transform: translateY(4px);
    transition: opacity var(--duration-base) var(--ease-out), transform var(--duration-base) var(--ease-out);
  }
  .streek-tile:hover .streek-link {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Spotlight ───────────────────────────────────────── */
  .spotlight {
    padding: var(--space-20) 0;
    background: var(--paperDeep);
  }
  .spotlight-inner {
    display: grid;
    grid-template-columns: minmax(0, 6fr) minmax(0, 5fr);
    gap: var(--space-12);
    align-items: center;
  }
  .spotlight-media-link {
    display: block;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--paperShade);
  }
  .spotlight-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-image) var(--ease-out);
  }
  .spotlight-placeholder {
    background: linear-gradient(135deg, var(--paperShade), var(--paperDeep));
  }
  .spotlight-media-link:hover .spotlight-img { transform: scale(1.03); }
  .spotlight-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .spotlight-cat {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--burgundy);
  }
  .spotlight-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.875rem, 1.5vw + 1.5rem, 3rem);
    line-height: 1.08;
    color: var(--ink);
    margin: var(--space-2) 0 var(--space-3);
  }
  .spotlight-title a {
    color: inherit;
    text-decoration: none;
    background-image: linear-gradient(var(--rust), var(--rust));
    background-size: 0% 1px;
    background-repeat: no-repeat;
    background-position: 0 100%;
    transition: background-size var(--duration-base) var(--ease-out);
  }
  .spotlight-title a:hover { background-size: 100% 1px; }
  .spotlight-desc {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--inkSoft);
    margin-bottom: var(--space-4);
  }
  .spotlight-meta {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
