---
// LAT-2575 (LAT-2570): NL-homepage = dunne wrapper om HomeContent. De volledige
// opmaak/data leeft in HomeContent.astro zodat /en/ dezelfde render deelt met een
// locale-overlay. alternates voedt hreflang (EN-tegenhanger bestaat altijd).
import HomeContent from '../components/HomeContent.astro';
import { DEFAULT_LOCALE } from '../lib/i18n';
---

<HomeContent locale={DEFAULT_LOCALE} alternates={{ nl: '/', en: '/en/' }} />
