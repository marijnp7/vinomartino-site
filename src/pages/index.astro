---
import SiteLayout from '../layouts/SiteLayout.astro';
import ZelfGereisdBadge from '../components/ZelfGereisdBadge.astro';
import Briefkaart from '../components/Briefkaart.astro';
import HomeRoutesMap from '../components/HomeRoutesMap.astro';
import NewsletterRegionField from '../components/NewsletterRegionField.astro';
import { loadArticles } from '../lib/articles';
import { loadRoutes } from '../lib/routes';
import { loadStreken } from '../lib/streken';
import { organizationSchema } from '../lib/seo';
import { getAuthorByByline } from '../lib/authors';

// LAT-2008 (VIS-BL-09) — De Brief inline op de homepage. Zelfde MailerLite-
// capture als /de-brief/ (LAT-1631, form-ID door Marijn bevestigd), override via
// PUBLIC_MAILERLITE_FORM_ACTION zodat homepage en briefpagina niet divergeren.
const BRIEF_FORM_ACTION =
  import.meta.env.PUBLIC_MAILERLITE_FORM_ACTION ||
  'https://assets.mailerlite.com/jsonp/2415940/forms/189828746131277541/subscribe';

// LAT-1848: render altijd de gecanoniseerde auteursnaam uit het auteur-record
// (bv. "Marijn") i.p.v. het ruwe Directus author-veld (dat nog "Martin" kan zijn).
const authorName = (byline: string | null | undefined): string =>
  getAuthorByByline(byline)?.name ?? byline ?? 'VinoMartino';

const articles = await loadArticles();
// LAT-1611: het "verhaal van de week" is instelbaar via het `featured`-veld in
// Directus. Board zet de toggle aan op het gewenste artikel; bij meerdere wint
// het nieuwste. Geen featured-artikel → val terug op het nieuwste artikel.
const spotlight = articles.find((a) => a.featured) ?? articles[0];
const moreArticles = articles.filter((a) => a.slug !== spotlight?.slug).slice(0, 3);
// LAT-2267 — de routekaart + kaartjes tonen ALLE routes (geen hardcoded/laatste-3
// subset meer). HomeRoutesMap fit de bounds naar de volledige set, zodat het aantal
// markers gelijk is aan het werkelijke aantal routes. De kaartjes eronder shuffelen
// client-side (data-shuffle) naar drie willekeurige per load i.p.v. steeds dezelfde.
const routes = await loadRoutes();

// LAT-2008 — dagen/kelders-teller per routekaart. Kelders = aantal wijnhuis-stops
// uit stopsGeo (LAT-2000 kind='wijnhuis'); ontbreekt die data, dan tonen we alleen
// de duur zodat de kaart deploy-safe degradeert (geen "0 kelders").
const cellarsCount = (r: (typeof routes)[number]): number =>
  r.stopsGeo.filter((s) => s.kind === 'wijnhuis').length;

const schema = organizationSchema();

const HERO_IMAGE = '/images/landschap-piemonte-barolo-001.jpg';

// LAT-2267 — het bestemmingenblok toonde altijd dezelfde vier hardcoded streken.
// Nu bouwen we de tegels uit ÁLLE streken in Directus en shuffelen client-side naar
// vier willekeurige per load (data-shuffle). Foto-guard: alleen streken mét een
// geldige hero-foto komen in de set, zodat er nooit een lege/placeholder-tegel
// verschijnt (onderliggende beeld-gaten vult de Lead Editor-audit, LAT-2268).
// LAT-2356 — tekst-guard: naast de hero moet ook het blurb-veld (description)
// gevuld zijn, anders rendert de tegel een lege <p class="streek-blurb">.
// Zelfde data-completeness-patroon als de foto-guard; blurb-gaten backfilt
// de Lead Editor (LAT-2355).
const STREKEN_VISIBLE = 4;
const editorialStreken = (await loadStreken())
  .filter((s) => Boolean(s.heroImage) && Boolean(s.name) && Boolean(s.description?.trim()))
  .map((s) => ({
    name: s.name,
    eyebrow: s.country,
    blurb: s.description,
    href: `/streken/${s.slug}/`,
    image: s.heroImage as string,
    visited: s.zelfGereisd,
  }));

function formatDate(value?: string | null) {
  if (!value) return '';
  try {
    return new Date(value).toLocaleDateString('nl-NL', { day: 'numeric', month: 'long', year: 'numeric' });
  } catch {
    return '';
  }
}
---

<SiteLayout
  title="VinoMartino: Wijnreizen met karakter"
  description="Image-led wijnreis-verhalen, routes en proefnotities uit Piemonte, de Douro, de Kaap en wijnstreken wereldwijd, geschreven door wijnliefhebbers die zelf op pad gaan."
  ogImage={HERO_IMAGE}
  schema={schema}
>
  <section class="hero" aria-label="Wijnreizen met karakter">
    <div class="hero-media">
      <img
        src={HERO_IMAGE}
        alt="Golden-hour wijngaardlandschap in de Langhe, pad door de vines richting Barolo, Piemonte"
        width="1600"
        height="1067"
        fetchpriority="high"
        decoding="async"
      />
    </div>
    <div class="hero-veil" aria-hidden="true"></div>
    <div class="hero-inner container">
      <span class="hero-eyebrow">Zelf gereisd sinds 2019</span>
      <h1 class="hero-title">
        De wijnreizen die wij zelf maakten,
        <em>klaar om na te reizen.</em>
      </h1>
      <p class="hero-lede">
        Routes, wijnhuizen en adressen uit elf streken. Geen lijstjes, wel de weg ernaartoe.
      </p>
      <div class="hero-ctas">
        <a href="#bestemmingen" class="btn btn-primary">Kies je bestemming</a>
        <a href="#routes" class="btn btn-ghost">Bekijk de routes</a>
      </div>
    </div>
    <a href="#bestemmingen" class="hero-scroll" aria-label="Scroll verder">
      <span class="hero-scroll-line" aria-hidden="true"></span>
      <span class="hero-scroll-label">Verder</span>
    </a>
  </section>

  <section id="bestemmingen" class="strip">
    <div class="container">
      <header class="strip-header">
        <span class="kicker">Kies je bestemming</span>
        <h2 class="strip-title">Waar begint jouw wijnreis?</h2>
        <p class="strip-lede">
          Streken die telkens terugkomen in ons werk. Kies waar je heen wilt, en het verhaal, de routes en de adressen volgen.
        </p>
      </header>
      <div class="streken-grid" data-shuffle data-shuffle-visible={STREKEN_VISIBLE}>
        {editorialStreken.map((streek, idx) => (
          <a
            href={streek.href}
            class={`streek-tile${idx >= STREKEN_VISIBLE ? ' is-extra' : ''}`}
            data-shuffle-item
          >
            <div class="streek-media">
              <img
                src={streek.image}
                alt={`${streek.name}, wijngaardlandschap`}
                width="800"
                height="1000"
                loading={idx === 0 ? 'eager' : 'lazy'}
                decoding="async"
              />
            </div>
            {streek.visited && (
              <div class="streek-tile-badge">
                <ZelfGereisdBadge visited={true} />
              </div>
            )}
            <div class="streek-body">
              <span class="streek-eyebrow">{streek.eyebrow}</span>
              <h3 class="streek-name">{streek.name}</h3>
              <p class="streek-blurb">{streek.blurb}</p>
              <span class="streek-link" aria-hidden="true">Ontdek de streek →</span>
            </div>
          </a>
        ))}
      </div>
      <p class="section-cta"><a href="/streken/" class="btn btn-outline">Alle 20+ streken →</a></p>
    </div>
  </section>

  <section id="routes" class="cards-section">
    <div class="container">
      <header class="section-head">
        <span class="kicker">Op pad</span>
        <h2 class="section-h">Wijnroutes met karakter</h2>
        <p class="section-sub">
          Geen Google-maps-grids, maar reizen, twee tot vijf dagen, met kelders, eetadressen en de weg ertussen.
        </p>
      </header>
      <HomeRoutesMap routes={routes} />
      <div class="cards-grid" data-shuffle data-shuffle-visible="3">
        {routes.map((r, idx) => {
          const kelders = cellarsCount(r);
          return (
            <a
              href={`/wijnroutes/${r.slug}/`}
              class={`card-tile${idx >= 3 ? ' is-extra' : ''}`}
              data-shuffle-item
            >
              <div class="card-media">
                {r.heroImage ? (
                  <img src={r.heroImage} alt={r.title} width="600" height="450" loading="lazy" decoding="async" />
                ) : (
                  <div class="card-placeholder" aria-hidden="true"></div>
                )}
              </div>
              <div class="card-body">
                {(r.duration || kelders > 0) && (
                  <span class="card-eyebrow card-meter">
                    {r.duration}
                    {r.duration && kelders > 0 && <span class="card-meter-dot" aria-hidden="true"> · </span>}
                    {kelders > 0 && <span>{kelders} {kelders === 1 ? 'kelder' : 'kelders'}</span>}
                  </span>
                )}
                <h3 class="card-title">{r.title}</h3>
                {r.description && <p class="card-desc">{r.description}</p>}
              </div>
            </a>
          );
        })}
      </div>
      <p class="section-cta"><a href="/wijnroutes/" class="btn btn-outline">Alle routes →</a></p>
    </div>
  </section>

  {spotlight && (
    <section class="spotlight">
      <div class="container spotlight-inner">
        <a href={`/artikelen/${spotlight.slug}/`} class="spotlight-media-link" aria-label={spotlight.title}>
          {spotlight.heroImage ? (
            <img
              src={spotlight.heroImage}
              alt={spotlight.title}
              width="1200"
              height="900"
              loading="lazy"
              decoding="async"
              class="spotlight-img"
            />
          ) : (
            <div class="spotlight-img spotlight-placeholder" aria-hidden="true"></div>
          )}
        </a>
        <div class="spotlight-body">
          <span class="kicker">Verhaal van de week</span>
          {spotlight.category && <span class="spotlight-cat">{spotlight.category.replace(/-/g, ' ')}</span>}
          <h2 class="spotlight-title">
            <a href={`/artikelen/${spotlight.slug}/`}>{spotlight.title}</a>
          </h2>
          {spotlight.description && <p class="spotlight-desc">{spotlight.description}</p>}
          <p class="spotlight-meta">
            <span>{authorName(spotlight.author)}</span>
            <span class="dot" aria-hidden="true">·</span>
            <span>{formatDate(spotlight.pubDate)}</span>
          </p>
          <a href={`/artikelen/${spotlight.slug}/`} class="quiet-cta">Lees het hele verhaal →</a>
        </div>
      </div>
    </section>
  )}

  {moreArticles.length > 0 && (
    <section class="cards-section cards-section--alt">
      <div class="container">
        <header class="section-head">
          <span class="kicker">Laatste verhalen</span>
          <h2 class="section-h">Vers van de pers</h2>
          <p class="section-sub">
            Reisverslagen, proefnotities en achtergronden. Onze tips komen uit eigen bezoek en geteste adressen; boek je via onze links, dan steun je de site zonder dat jij meer betaalt.
          </p>
        </header>
        <div class="cards-grid">
          {moreArticles.map(article => (
            <a href={`/artikelen/${article.slug}/`} class="card-tile">
              <div class="card-media">
                {article.heroImage ? (
                  <img src={article.heroImage} alt={article.title} width="600" height="450" loading="lazy" decoding="async" />
                ) : (
                  <div class="card-placeholder" aria-hidden="true"></div>
                )}
              </div>
              <div class="card-body">
                {article.category && <span class="card-eyebrow">{article.category.replace(/-/g, ' ')}</span>}
                <h3 class="card-title">{article.title}</h3>
                {article.description && <p class="card-desc">{article.description}</p>}
                <span class="card-meta">{authorName(article.author)} · {formatDate(article.pubDate)}</span>
              </div>
            </a>
          ))}
        </div>
        <p class="section-cta"><a href="/artikelen/" class="btn btn-outline">Alle artikelen →</a></p>
      </div>
    </section>
  )}

  <section class="proof" aria-label="Bewijs en gezicht">
    <div class="container proof-inner">
      <div class="proof-portrait">
        <img
          src="/over-ons-hero.jpg"
          alt="Marijn proeft een glas wijn met wijngaarden op de achtergrond"
          width="800"
          height="1000"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="proof-body">
        <span class="kicker proof-kicker">Bewijs en gezicht</span>
        {/* LAT-2008: cijfers gestaafd tegen de canon. "11" spiegelt de Tier 1-lijst
            `visited` op /over-ons/ (elf streken); "2019" is dezelfde bronclaim als
            "streken sinds 2019" daar. Het "60+ wijnhuizen"-cijfer is geschrapt tot
            er telbewijs uit Directus is (Marijn, 2026-07-03). */}
        <ul class="proof-stats">
          <li><span class="proof-num">11</span><span class="proof-label">streken zelf bereisd</span></li>
          <li><span class="proof-num">2019</span><span class="proof-label">sinds we op pad zijn</span></li>
        </ul>
        <p class="proof-manifest">
          Waar we zelf waren, zie je dat: het label <em>Zelf gereisd</em>.
        </p>
        <a href="/over-ons/" class="btn btn-outline">Ons verhaal →</a>
      </div>
    </div>
  </section>

  <section class="brief">
    <div class="container">
      <Briefkaart dateline="De Brief · elke twee weken" align="center">
        <h2 class="brief-kaart-h">Elke twee weken een brief. Geen lijstjes.</h2>
        <p>
          Een persoonlijke brief van Marijn: wat we recent dronken, waar we waren,
          en welke fles ons opviel. Geen affiliate-deals, geen nieuwsbriefformule.
        </p>
        <form
          class="brief-signup"
          action={BRIEF_FORM_ACTION}
          method="post"
          target="_blank"
          data-newsletter-signup
        >
          <div class="brief-signup__row">
            <label for="brief-email" class="visually-hidden">E-mailadres</label>
            <input
              id="brief-email"
              type="email"
              name="fields[email]"
              autocomplete="email"
              placeholder="je@adres.nl"
              required
            />
            <button type="submit" class="btn btn-primary" data-plausible-cta="newsletter_signup">Stuur me de brief</button>
          </div>
          <NewsletterRegionField id="brief-region" />
        </form>
      </Briefkaart>
    </div>
  </section>
</SiteLayout>

<script>
  // LAT-2267 — client-side randomisatie voor de bestemmingen-tegels en de
  // routekaartjes. De pagina is statisch (SSG), dus zonder JS zou elke reload
  // dezelfde subset tonen. Per [data-shuffle]-container husselen we de
  // [data-shuffle-item]-kinderen (Fisher-Yates) en tonen we er data-shuffle-visible
  // van; de rest krijgt is-hidden. No-JS valt terug op de eerste N (is-extra in CSS).
  function shuffleInPlace<T>(arr: T[]): T[] {
    for (let i = arr.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [arr[i], arr[j]] = [arr[j], arr[i]];
    }
    return arr;
  }

  function applyShuffle(): void {
    const containers = document.querySelectorAll<HTMLElement>('[data-shuffle]');
    containers.forEach((container) => {
      const visible = parseInt(container.dataset.shuffleVisible || '0', 10);
      const items = Array.from(
        container.querySelectorAll<HTMLElement>('[data-shuffle-item]'),
      );
      if (!Number.isFinite(visible) || visible <= 0 || items.length <= visible) {
        items.forEach((el) => el.classList.remove('is-extra', 'is-hidden'));
        return;
      }
      shuffleInPlace(items);
      items.forEach((el, idx) => {
        container.appendChild(el);
        el.classList.remove('is-extra');
        el.classList.toggle('is-hidden', idx >= visible);
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', applyShuffle);
  } else {
    applyShuffle();
  }
</script>

<style>
  /* ── Hero ─────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: clamp(560px, 88vh, 860px);
    color: var(--fixed-cream);
    overflow: hidden;
    isolation: isolate;
    display: flex;
    align-items: flex-end;
  }
  .hero-media {
    position: absolute;
    inset: 0;
    z-index: -2;
    display: block;
    overflow: hidden;
  }
  .hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 38%;
    transform: scale(1.04);
    animation: hero-zoom 28s ease-out forwards;
  }
  @keyframes hero-zoom {
    from { transform: scale(1.02); }
    to { transform: scale(1.10); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-media img { animation: none; transform: scale(1.02); }
  }
  .hero-veil {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(180deg, rgba(13, 10, 7, 0.65) 0%, rgba(13, 10, 7, 0.15) 28%, rgba(13, 10, 7, 0.15) 55%, rgba(13, 10, 7, 0.78) 100%),
      linear-gradient(90deg, rgba(13, 10, 7, 0.45) 0%, rgba(13, 10, 7, 0) 55%);
  }
  .hero-inner {
    position: relative;
    width: 100%;
    padding-top: var(--space-32);
    padding-bottom: var(--space-20);
    max-width: var(--max-width);
  }
  .hero-eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid color-mix(in srgb, var(--gold) 60%, transparent);
  }
  .hero-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(3rem, 7vw + 0.5rem, 6.5rem);
    line-height: 0.98;
    letter-spacing: -0.02em;
    color: var(--fixed-cream);
    margin: var(--space-6) 0 var(--space-5);
    max-width: 22ch;
  }
  .hero-title em {
    font-style: italic;
    color: var(--gold);
    display: inline-block;
  }
  .hero-lede {
    font-family: var(--font-body);
    font-size: clamp(1.0625rem, 0.4vw + 1rem, 1.25rem);
    line-height: 1.6;
    color: color-mix(in srgb, var(--fixed-cream) 92%, transparent);
    max-width: 38rem;
    margin-bottom: var(--space-8);
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }
  .hero-scroll {
    position: absolute;
    right: var(--gutter);
    bottom: var(--space-6);
    display: none;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    color: color-mix(in srgb, var(--fixed-cream) 80%, transparent);
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    text-decoration: none;
    z-index: 1;
  }
  .hero-scroll-line {
    width: 1px;
    height: 3rem;
    background: currentColor;
    opacity: 0.5;
    animation: scroll-line 2.4s ease-in-out infinite;
    transform-origin: top;
  }
  @keyframes scroll-line {
    0%, 100% { transform: scaleY(0.4); }
    50% { transform: scaleY(1); }
  }
  @media (min-width: 1024px) {
    .hero-scroll { display: flex; }
  }

  /* ── Buttons ──────────────────────────────────────────── */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.95rem 1.85rem;
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    text-decoration: none;
    border: 1px solid transparent;
    transition: background var(--duration-fast) var(--ease-out), color var(--duration-fast) var(--ease-out), border-color var(--duration-fast) var(--ease-out);
    cursor: pointer;
  }
  .btn-primary {
    background: var(--burgundy);
    color: var(--fixed-cream);
  }
  .btn-primary:hover { background: var(--burgundyDeep); color: var(--fixed-cream); }
  .btn-ghost {
    background: transparent;
    color: var(--fixed-cream);
    border-color: color-mix(in srgb, var(--fixed-cream) 60%, transparent);
  }
  .btn-ghost:hover {
    background: color-mix(in srgb, var(--fixed-cream) 10%, transparent);
    color: var(--fixed-cream);
    border-color: var(--fixed-cream);
  }
  .btn-outline {
    background: transparent;
    color: var(--burgundy);
    border-color: var(--burgundy);
  }
  .btn-outline:hover { background: var(--burgundy); color: var(--fixed-cream); }
  .btn-gold {
    background: var(--gold);
    color: var(--fixed-ink);
  }
  .btn-gold:hover { background: var(--fixed-cream); color: var(--fixed-ink); }

  /* ── Shared typographic helpers ───────────────────────── */
  .kicker {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--rust);
  }

  /* ── Editorial streken-grid ───────────────────────────── */
  .strip {
    padding: var(--space-24) 0 var(--space-20);
    background: var(--paper);
  }
  .strip-header {
    max-width: 44rem;
    margin: 0 0 var(--space-12);
  }
  .strip-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2.25rem, 2vw + 1.5rem, 3.5rem);
    line-height: 1.05;
    color: var(--ink);
    margin: var(--space-4) 0 var(--space-3);
  }
  .strip-lede {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--inkSoft);
  }
  .streken-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-5);
  }
  .streek-tile {
    position: relative;
    display: block;
    color: var(--fixed-cream);
    text-decoration: none;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    isolation: isolate;
  }
  /* LAT-2267: no-JS fallback toont de eerste vier streken; JS shuffelt naar vier
     willekeurige per load. */
  .streek-tile.is-extra,
  .streek-tile.is-hidden {
    display: none;
  }
  .streek-tile::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(180deg, rgba(13, 10, 7, 0.05) 0%, rgba(13, 10, 7, 0.15) 45%, rgba(13, 10, 7, 0.85) 100%);
    transition: background var(--duration-base) var(--ease-out);
  }
  .streek-tile:hover::after {
    background: linear-gradient(180deg, rgba(90, 26, 31, 0.05) 0%, rgba(90, 26, 31, 0.25) 45%, rgba(61, 17, 21, 0.9) 100%);
  }
  .streek-media {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }
  .streek-media img {
    width: 100%;
    height: 100%;
