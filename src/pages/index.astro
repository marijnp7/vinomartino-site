---
import SiteLayout from '../layouts/SiteLayout.astro';
import { loadArticles } from '../lib/articles';
import { loadWijnhuizen } from '../lib/wijnhuizen';
import { loadRoutes } from '../lib/routes';
import { loadStreken } from '../lib/streken';
import { organizationSchema } from '../lib/seo';

const articles = await loadArticles();
const recentArticles = articles.slice(0, 3);
const wijnhuizen = (await loadWijnhuizen()).slice(0, 3);
const routes = (await loadRoutes()).slice(0, 3);
const streken = (await loadStreken()).slice(0, 3);

const COUNTRY_NL: Record<string, string> = { Italia: 'Italië' };
const toDutch = (c: string) => COUNTRY_NL[c] ?? c;

const schema = organizationSchema();
---

<SiteLayout
  title="VinoMartino — Wijnreizen met karakter"
  description="Persoonlijke wijnreis-verhalen, proefnotities en routes door de mooiste wijnstreken ter wereld — geschreven door wijnliefhebbers die zelf op pad gaan."
  ogImage={recentArticles[0]?.heroImage || undefined}
  schema={schema}
>
  <section class="hero">
    <div class="container">
      <span class="eyebrow">Wijnreizen met karakter</span>
      <h1>De wereld ontdekken,<br />glas voor glas</h1>
      <p class="lede">Persoonlijke verhalen, proefnotities en routes door de mooiste wijnstreken ter wereld — geschreven door wijnliefhebbers die zelf op pad gaan.</p>
      <a href="/artikelen/" class="cta">Lees alle artikelen →</a>
    </div>
  </section>

  <section class="feature">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Ontdek</span>
        <h2>Wijnhuizen</h2>
      </div>
      <div class="grid">
        {wijnhuizen.map(w => (
          <a href={`/wijnhuizen/${w.slug}/`} class="card card-link">
            {w.heroImage && (
              <img src={w.heroImage} alt={w.region ? `${w.name} — ${w.region}` : w.name} loading="lazy" width="400" height="220" class="card-img" />
            )}
            <div class="card-body">
              <span class="card-region">{w.region}</span>
              <h3 class="card-title">{w.name}</h3>
              {w.description && <p class="card-desc">{w.description}</p>}
            </div>
          </a>
        ))}
      </div>
      <p class="section-link"><a href="/wijnhuizen/" class="cta">Alle wijnhuizen →</a></p>
    </div>
  </section>

  <section class="feature feature--alt">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Op pad</span>
        <h2>Wijnroutes</h2>
      </div>
      <div class="grid">
        {routes.map(r => (
          <a href={`/wijnroutes/${r.slug}/`} class="card card-link">
            {r.heroImage && (
              <img src={r.heroImage} alt={r.title} loading="lazy" width="400" height="220" class="card-img" />
            )}
            <div class="card-body">
              <span class="card-region">{r.duration}</span>
              <h3 class="card-title">{r.title}</h3>
              {r.description && <p class="card-desc">{r.description}</p>}
            </div>
          </a>
        ))}
      </div>
      <p class="section-link"><a href="/wijnroutes/" class="cta">Alle routes →</a></p>
    </div>
  </section>

  <section class="feature">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Terroir</span>
        <h2>Streken</h2>
      </div>
      <div class="grid">
        {streken.map(s => (
          <a href={`/streken/${s.slug}/`} class="card card-link">
            {s.heroImage && (
              <img src={s.heroImage} alt={s.country ? `${s.name}, ${toDutch(s.country)}` : s.name} loading="lazy" width="400" height="220" class="card-img" />
            )}
            <div class="card-body">
              <span class="card-region">{s.country}</span>
              <h3 class="card-title">{s.name}</h3>
              {s.description && <p class="card-desc">{s.description}</p>}
            </div>
          </a>
        ))}
      </div>
      <p class="section-link"><a href="/streken/" class="cta">Alle streken →</a></p>
    </div>
  </section>

  <section class="feature feature--alt">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Vers van de pers</span>
        <h2>Laatste verhalen</h2>
      </div>
      <div class="grid">
        {recentArticles.map(article => (
          <a href={`/artikelen/${article.slug}/`} class="card card-link">
            {article.heroImage && (
              <img src={article.heroImage} alt={article.title} loading="lazy" width="400" height="220" class="card-img" />
            )}
            <div class="card-body">
              {article.category && <span class="card-region">{article.category}</span>}
              <h3 class="card-title">{article.title}</h3>
              {article.description && <p class="card-desc">{article.description}</p>}
              <span class="card-meta">{article.author} · {new Date(article.pubDate).toLocaleDateString('nl-NL', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
            </div>
          </a>
        ))}
      </div>
      <p class="section-link"><a href="/artikelen/" class="cta">Alle artikelen →</a></p>
    </div>
  </section>
</SiteLayout>

<style>
  .hero {
    padding: var(--space-24) 0 var(--space-20);
    text-align: center;
  }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--rust);
    font-weight: 500;
  }
  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw + 1rem, 5rem);
    font-style: italic;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: var(--space-6) 0;
  }
  .lede {
    font-family: var(--font-body);
    font-size: 1.125rem;
    color: var(--inkSoft);
    max-width: 38rem;
    margin: 0 auto var(--space-8);
    line-height: 1.6;
  }
  .cta {
    display: inline-block;
    padding: 0.875rem 2rem;
    background: var(--burgundy);
    color: var(--paper);
    font-family: var(--font-ui);
    font-weight: 500;
    font-size: 0.9375rem;
    text-decoration: none;
    transition: background var(--duration-fast) var(--ease-out);
  }
  .cta:hover { background: var(--burgundyDeep); color: var(--paper); }

  .feature {
    padding: var(--space-20) 0;
  }
  .feature--alt {
    background: var(--paperDeep);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-6);
  }
  .card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .card-img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 400 / 220;
    object-fit: cover;
  }
  .card-body {
    padding: 1.5rem;
  }
  .card-region {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--rust);
    display: block;
    margin-bottom: var(--space-2);
  }
  .card-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-style: italic;
    font-weight: 400;
    color: var(--ink);
    margin-bottom: var(--space-3);
    line-height: 1.2;
  }
  .card-desc {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--inkSoft);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: var(--space-3);
  }
  .card-meta {
    display: block;
    margin-top: var(--space-3);
    padding-top: var(--space-3);
    border-top: 1px solid var(--ruleSoft);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--inkFaint);
  }
  .section-link {
    text-align: center;
    margin-top: var(--space-10);
  }
</style>
