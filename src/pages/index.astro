---
import SiteLayout from '../layouts/SiteLayout.astro';
import { loadArticles } from '../lib/articles';
import { loadWijnhuizen } from '../lib/wijnhuizen';
import { loadRoutes } from '../lib/routes';
import { loadStreken } from '../lib/streken';
import { organizationSchema, breadcrumbSchema } from '../lib/seo';

const articles = await loadArticles();
const recentArticles = articles.slice(0, 3);
const wijnhuizen = (await loadWijnhuizen()).slice(0, 3);
const routes = (await loadRoutes()).slice(0, 3);
const streken = (await loadStreken()).slice(0, 3);

const schema = [
  organizationSchema(),
  breadcrumbSchema([{ name: 'Home', url: '/' }]),
];
---

<SiteLayout
  title="VinoMartino — Wijnreizen met karakter"
  description="Persoonlijke wijnreis-verhalen, proefnotities en routes door de mooiste wijnstreken ter wereld — geschreven door wijnliefhebbers die zelf op pad gaan."
  schema={schema}
>
  <section class="home-hero">
    <div class="container">
      <span class="section-label">Wijnreizen met karakter</span>
      <h1>De wereld ontdekken,<br />glas voor glas</h1>
      <p class="home-hero-lede">
        Persoonlijke verhalen, proefnotities en routes door de mooiste wijnstreken ter wereld —
        geschreven door wijnliefhebbers die zelf op pad gaan.
      </p>
      <a href="/artikelen/" class="cta">Lees alle artikelen →</a>
    </div>
  </section>

  <section class="home-section home-section--alt">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Ontdek</span>
        <h2>Wijnhuizen</h2>
      </div>
      <div class="home-grid">
        {wijnhuizen.map(w => (
          <a href={`/wijnhuizen/${w.slug}/`} class="card home-card">
            {w.heroImage && (
              <img src={w.heroImage} alt={w.name} loading="lazy" width="400" height="200" class="home-card-img" />
            )}
            <div class="home-card-body">
              <span class="home-card-cat">{w.region}</span>
              <h3 class="home-card-title">{w.name}</h3>
              <p class="home-card-desc">{w.description}</p>
            </div>
          </a>
        ))}
      </div>
      <p class="home-section-link"><a href="/wijnhuizen/" class="cta">Alle wijnhuizen →</a></p>
    </div>
  </section>

  <section class="home-section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Op pad</span>
        <h2>Wijnroutes</h2>
      </div>
      <div class="home-grid">
        {routes.map(r => (
          <a href={`/wijnroutes/${r.slug}/`} class="card home-card">
            {r.heroImage && (
              <img src={r.heroImage} alt={r.title} loading="lazy" width="400" height="200" class="home-card-img" />
            )}
            <div class="home-card-body">
              <span class="home-card-cat">{r.duration}</span>
              <h3 class="home-card-title">{r.title}</h3>
              <p class="home-card-desc">{r.description}</p>
            </div>
          </a>
        ))}
      </div>
      <p class="home-section-link"><a href="/wijnroutes/" class="cta">Alle routes →</a></p>
    </div>
  </section>

  <section class="home-section home-section--alt">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Terroir</span>
        <h2>Streken</h2>
      </div>
      <div class="home-grid">
        {streken.map(s => (
          <a href={`/streken/${s.slug}/`} class="card home-card">
            {s.heroImage && (
              <img src={s.heroImage} alt={s.name} loading="lazy" width="400" height="200" class="home-card-img" />
            )}
            <div class="home-card-body">
              <span class="home-card-cat">{s.country}</span>
              <h3 class="home-card-title">{s.name}</h3>
              <p class="home-card-desc">{s.description}</p>
            </div>
          </a>
        ))}
      </div>
      <p class="home-section-link"><a href="/streken/" class="cta">Alle streken →</a></p>
    </div>
  </section>

  <section class="home-section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Vers van de pers</span>
        <h2>Laatste verhalen</h2>
      </div>
      <div class="home-grid">
        {recentArticles.map(article => (
          <a href={`/artikelen/${article.slug}/`} class="card home-card">
            {article.heroImage && (
              <img src={article.heroImage} alt={article.title} loading="lazy" width="400" height="200" class="home-card-img" />
            )}
            <div class="home-card-body">
              {article.category && <span class="home-card-cat">{article.category}</span>}
              <h3 class="home-card-title">{article.title}</h3>
              {article.description && <p class="home-card-desc">{article.description}</p>}
              <span class="home-card-meta">
                {article.author} · {new Date(article.pubDate).toLocaleDateString('nl-NL', { day: 'numeric', month: 'long', year: 'numeric' })}
              </span>
            </div>
          </a>
        ))}
      </div>
      <p class="home-section-link"><a href="/artikelen/" class="cta">Alle artikelen →</a></p>
    </div>
  </section>
</SiteLayout>

<style>
  .home-hero {
    padding: var(--space-24) 0 var(--space-20);
    text-align: center;
    background: var(--paper);
  }
  .home-hero .container { max-width: 48rem; }
  .home-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 1.8rem + 3vw, 5rem);
    font-style: italic;
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: var(--space-6) 0;
  }
  .home-hero-lede {
    font-family: var(--font-body);
    font-size: clamp(1rem, 0.9rem + 0.4vw, 1.25rem);
    color: var(--inkSoft);
    max-width: 38rem;
    margin: 0 auto var(--space-8);
    line-height: 1.6;
  }

  .cta {
    display: inline-block;
    padding: 0.875rem 2rem;
    background: var(--burgundy);
    color: var(--paper);
    font-family: var(--font-ui);
    font-weight: 500;
    font-size: 0.9375rem;
    border-radius: var(--radius-sm);
    transition: background var(--duration-fast) var(--ease-out);
  }
  .cta:hover {
    background: var(--burgundyDeep);
    color: var(--paper);
  }

  .home-section { padding: var(--space-20) 0; }
  .home-section--alt { background: var(--paperDeep); }

  .home-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-6);
  }
  .home-card {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .home-card-img {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }
  .home-card-body { padding: 1.5rem; }
  .home-card-cat {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--rust);
    display: block;
    margin-bottom: var(--space-2);
  }
  .home-card-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-style: italic;
    font-weight: 400;
    color: var(--ink);
    margin-bottom: var(--space-3);
    line-height: 1.2;
  }
  .home-card-desc {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--inkSoft);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: var(--space-3);
  }
  .home-card-meta {
    display: block;
    margin-top: var(--space-3);
    padding-top: var(--space-3);
    border-top: 1px solid var(--ruleSoft);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--inkFaint);
  }
  .home-section-link {
    text-align: center;
    margin-top: var(--space-10);
  }

  @media (max-width: 768px) {
    .home-hero { padding: var(--space-16) 0 var(--space-12); }
    .home-section { padding: var(--space-16) 0; }
    .home-grid { grid-template-columns: 1fr; }
  }
</style>
