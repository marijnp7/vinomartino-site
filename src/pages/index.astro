---
import SiteLayout from '../layouts/SiteLayout.astro';
import { loadArticles } from '../lib/articles';
import { loadWijnhuizen } from '../lib/wijnhuizen';
import { loadRoutes } from '../lib/routes';
import { loadStreken } from '../lib/streken';
import { organizationSchema } from '../lib/seo';

const articles = await loadArticles();
const recentArticles = articles.slice(0, 3);
const wijnhuizen = (await loadWijnhuizen()).slice(0, 3);
const routes = (await loadRoutes()).slice(0, 3);
const streken = (await loadStreken()).slice(0, 3);
---

<SiteLayout
  title="VinoMartino — Wijnreizen met karakter"
  description="Persoonlijke wijnreis-verhalen, proefnotities en routes door de mooiste wijnstreken ter wereld — geschreven door wijnliefhebbers die zelf op pad gaan."
  schema={organizationSchema()}
>
  <section class="hero">
    <span class="eyebrow">Wijnreizen met karakter</span>
    <h1>De wereld ontdekken,<br/>glas voor glas</h1>
    <p class="lede">Persoonlijke verhalen, proefnotities en routes door de mooiste wijnstreken ter wereld — geschreven door wijnliefhebbers die zelf op pad gaan.</p>
    <a href="/artikelen/" class="cta">Lees alle artikelen →</a>
  </section>

  <section class="articles">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Ontdek</span>
        <h2>Wijnhuizen</h2>
      </div>
      <div class="grid">
        {wijnhuizen.map(w => (
          <a href={`/wijnhuizen/${w.slug}/`} class="card">
            <div class="card-body">
              <span class="cat">{w.region}</span>
              <h3>{w.name}</h3>
              <p>{w.description}</p>
            </div>
          </a>
        ))}
      </div>
      <p class="section-link"><a href="/wijnhuizen/" class="cta">Alle wijnhuizen →</a></p>
    </div>
  </section>

  <section class="articles">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Op pad</span>
        <h2>Wijnroutes</h2>
      </div>
      <div class="grid">
        {routes.map(r => (
          <a href={`/wijnroutes/${r.slug}/`} class="card">
            <div class="card-body">
              <span class="cat">{r.duration}</span>
              <h3>{r.title}</h3>
              <p>{r.description}</p>
            </div>
          </a>
        ))}
      </div>
      <p class="section-link"><a href="/wijnroutes/" class="cta">Alle routes →</a></p>
    </div>
  </section>

  <section class="articles">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Terroir</span>
        <h2>Streken</h2>
      </div>
      <div class="grid">
        {streken.map(s => (
          <a href={`/streken/${s.slug}/`} class="card">
            <div class="card-body">
              <span class="cat">{s.country}</span>
              <h3>{s.name}</h3>
              <p>{s.description}</p>
            </div>
          </a>
        ))}
      </div>
      <p class="section-link"><a href="/streken/" class="cta">Alle streken →</a></p>
    </div>
  </section>

  <section class="articles">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Vers van de pers</span>
        <h2>Laatste verhalen</h2>
      </div>
      <div class="grid">
        {recentArticles.map(article => (
          <a href={`/artikelen/${article.slug}/`} class="card">
            {article.heroImage && <img src={article.heroImage} alt={article.title} loading="lazy" />}
            <div class="card-body">
              {article.category && <span class="cat">{article.category}</span>}
              <h3>{article.title}</h3>
              {article.description && <p>{article.description}</p>}
              <span class="meta">{article.author} · {new Date(article.pubDate).toLocaleDateString('nl-NL', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
            </div>
          </a>
        ))}
      </div>
      <p class="section-link"><a href="/artikelen/" class="cta">Alle artikelen →</a></p>
    </div>
  </section>
</SiteLayout>

<style>
  .hero {
    padding: 6rem 1.5rem 5rem;
    text-align: center;
    max-width: 72rem;
    margin: 0 auto;
  }
  .eyebrow {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--rust);
    font-weight: 600;
  }
  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw + 1rem, 5rem);
    font-style: italic;
    font-weight: 400;
    line-height: 1.1;
    margin: 1.5rem 0;
    letter-spacing: -0.02em;
  }
  .lede {
    font-size: 1.25rem;
    max-width: 38rem;
    margin: 0 auto 2rem;
    color: var(--inkSoft);
  }
  .cta {
    display: inline-block;
    padding: 0.875rem 2rem;
    background: var(--burgundy);
    color: var(--paper);
    font-weight: 500;
    font-size: 0.9375rem;
    transition: background 0.2s;
  }
  .cta:hover {
    background: var(--burgundyDeep);
    color: var(--paper);
  }
  .articles {
    padding: 5rem 0;
    background: var(--paperDeep);
  }
  .section-head {
    text-align: center;
    margin-bottom: 3rem;
  }
  .section-head h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3vw + 1rem, 3rem);
    font-style: italic;
    font-weight: 400;
    margin-top: 0.5rem;
  }
  .grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }
  .card {
    background: var(--paper);
    transition: transform 0.2s, box-shadow 0.2s;
    display: block;
    color: inherit;
    text-decoration: none;
  }
  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(31, 26, 22, 0.12);
  }
  .card img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
  }
  .card-body {
    padding: 1.5rem;
  }
  .cat {
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--rust);
    font-weight: 600;
  }
  .card h3 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-style: italic;
    font-weight: 400;
    margin: 0.5rem 0 0.75rem;
    line-height: 1.2;
  }
  .card p {
    font-size: 0.9375rem;
    color: var(--inkSoft);
    margin-bottom: 1rem;
  }
  .meta {
    font-size: 0.75rem;
    color: var(--inkFaint);
    display: block;
    padding-top: 1rem;
    border-top: 1px solid var(--rule);
  }
  .section-link {
    text-align: center;
    margin-top: 2.5rem;
  }
</style>
