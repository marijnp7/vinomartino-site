---
import SampleArticleContent from '../../components/pages/SampleArticleContent.astro';
import { getActiveBrand } from '../../lib/brands';

export function getStaticPaths() {
  const brand = getActiveBrand();
  if (!brand) return [];
  return brand.locales.map((locale) => ({
    params: { locale },
    props: { brand },
  }));
}

const { brand } = Astro.props;
const { locale } = Astro.params;
---

<SampleArticleContent brand={brand} locale={locale!} />
