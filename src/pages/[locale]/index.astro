---
import { loadArticles } from '../../lib/articles';
import BrandHomeContent from '../../components/pages/BrandHomeContent.astro';
import { getActiveBrand } from '../../lib/brands';
import type { Article } from '../../lib/articles';

export async function getStaticPaths() {
  const brand = getActiveBrand();
  if (!brand) return [];
  const articles = await loadArticles();

  return brand.locales.map((locale) => ({
    params: { locale },
    props: { brand, articles },
  }));
}

interface Props {
  brand: ReturnType<typeof getActiveBrand>;
  articles: Article[];
}

const { brand, articles } = Astro.props;
const { locale } = Astro.params;
---

<BrandHomeContent brand={brand!} locale={locale!} articles={articles} />
