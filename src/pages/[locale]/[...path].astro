---
import BrandLayout from '../../layouts/BrandLayout.astro';
import { getActiveBrand, type Brand } from '../../lib/brands';
import { loadArticles, type Article } from '../../lib/articles';

export async function getStaticPaths() {
  const brand = getActiveBrand();
  if (!brand) return [];

  const articles = await loadArticles();

  const sectionPaths = [
    'verhalen',
    'artikelen',
    'over-ons',
    'reisroutes',
    'proefnotities',
    'streken/piemonte',
    'streken/bourgogne',
    'streken/priorat',
    'streken/mosel',
    'streken/wachau',
    'streken/etna',
    'streken/toscane',
    'streken/champagne',
    'streken/douro',
    'routes/langhe-4-dagen',
    'routes/bourgogne-trein',
    'routes/etna-noord',
    'routes/mosel-fietsvakantie',
    'themas/weekends',
    'themas/per-trein',
    'themas/druiven',
    'themas/wijnhuizen',
    'themas/natuur',
    'themas/bubbels',
    'themas/spijs-wijn',
    'themas/opkomend',
  ];

  return brand.locales.flatMap((locale) =>
    sectionPaths.map((p) => ({
      params: { locale, path: p },
      props: {
        brand,
        section: p.split('/')[0],
        slug: p.split('/')[1] || null,
        articles,
      },
    }))
  );
}

interface Props {
  brand: Brand;
  section: string;
  slug: string | null;
  articles: Article[];
}

const { brand, section, slug, articles } = Astro.props;
const { locale } = Astro.params;
const base = `/${locale}`;

const CATEGORY_LABELS: Record<string, string> = {
  'culture-history': 'Cultuur & Geschiedenis',
  'wine-regions': "Wijnregio's",
  'travel-tips': 'Reistips',
  'food-pairing': 'Spijs & Wijn',
  'tasting-notes': 'Proefnotities',
  'winery-portraits': 'Wijnhuizen',
  'sustainable-travel': 'Duurzaam Reizen',
  'digital-nomads': 'Digital Nomads',
};

const SECTION_TITLES: Record<string, string> = {
  verhalen: 'Alle verhalen',
  artikelen: 'Alle artikelen',
  streken: 'Wijnstreken',
  routes: 'Reisroutes',
  reisroutes: 'Reisroutes',
  themas: "Thema's",
  proefnotities: 'Proefnotities',
  'over-ons': 'Over Martin & Sophie',
};

const isArticleListSection = section === 'verhalen' || section === 'artikelen';
const sectionArticles = isArticleListSection ? articles : [];

const title = slug
  ? `${slug.charAt(0).toUpperCase()}${slug.slice(1).replace(/-/g, ' ')} — ${SECTION_TITLES[section] || section}`
  : SECTION_TITLES[section] || section;
---

<BrandLayout brand={brand} locale={locale!} title={`${title} — ${brand.name}`} description={title}>
  <section class="section-page">
    <div class="container">
      <nav class="breadcrumb">
        <a href={`${base}/`}>Home</a> ›
        {slug ? (
          <>
            <a href={`${base}/${section}/`}>{SECTION_TITLES[section]}</a> ›
            <span>{slug.replace(/-/g, ' ')}</span>
          </>
        ) : (
          <span>{SECTION_TITLES[section]}</span>
        )}
      </nav>
      <h1>{title}</h1>

      {isArticleListSection && sectionArticles.length > 0 ? (
        <div class="article-list">
          {sectionArticles.map((article) => {
            const catLabel = CATEGORY_LABELS[article.category] || article.category;
            const dateStr = new Date(article.pubDate).toLocaleDateString('nl-NL', {
              day: 'numeric', month: 'long', year: 'numeric',
            });
            return (
              <a href={`${base}/${article.slug}/`} class="article-list-item">
                <div class="article-list-content">
                  {catLabel && <span class="article-list-kicker">{catLabel}</span>}
                  <h2>{article.title}</h2>
                  {article.description && <p>{article.description.slice(0, 200)}</p>}
                  <div class="article-list-meta">
                    <time datetime={article.pubDate}>{dateStr}</time>
                    <span>·</span>
                    <span>{article.author}</span>
                  </div>
                </div>
                <span class="article-list-arrow" aria-hidden="true">→</span>
              </a>
            );
          })}
        </div>
      ) : (
        <p class="coming-soon">
          {section === 'over-ons'
            ? 'Martin en Sophie — wijnliefhebbers, reizigers, schrijvers. Al meer dan tien jaar onderweg door de mooiste wijnstreken van Europa. Meer over ons volgt binnenkort.'
            : 'Inhoud voor deze sectie wordt binnenkort toegevoegd.'}
        </p>
      )}

      <a href={`${base}/`} class="btn btn-secondary back-link">← Terug naar home</a>
    </div>
  </section>
</BrandLayout>

<style>
  .section-page {
    padding: var(--space-20, 5rem) 0 var(--space-32, 8rem);
    min-height: 60vh;
  }

  .breadcrumb {
    font-family: var(--font-ui, 'Inter', sans-serif);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--inkSoft, #666);
    margin-bottom: var(--space-8, 2rem);
  }

  .breadcrumb a {
    color: var(--rust, #A14F2A);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    text-decoration: underline;
  }

  h1 {
    font-family: var(--font-display, 'Cormorant Garamond', serif);
    font-size: clamp(2.5rem, 2rem + 2vw, 4rem);
    font-style: italic;
    font-weight: 400;
    color: var(--ink, #1F1A16);
    margin-bottom: var(--space-10, 2.5rem);
    letter-spacing: -0.02em;
  }

  .coming-soon {
    font-family: var(--font-body, 'Source Serif 4', serif);
    font-size: 1.125rem;
    color: var(--inkSoft, #666);
    margin-bottom: var(--space-8, 2rem);
    line-height: 1.7;
    max-width: 42rem;
  }

  .article-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-1, 0.25rem);
    margin-bottom: var(--space-10, 2.5rem);
  }

  .article-list-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6, 1.5rem);
    padding: var(--space-6, 1.5rem) 0;
    border-bottom: 1px solid var(--rule-20, rgba(201, 185, 143, 0.2));
    text-decoration: none;
    color: inherit;
    transition: background var(--duration-fast, 150ms) ease;
  }

  .article-list-item:first-child {
    border-top: 1px solid var(--rule-20, rgba(201, 185, 143, 0.2));
  }

  .article-list-item:hover {
    background: var(--burgundy-10, rgba(90, 26, 31, 0.04));
    padding-left: var(--space-4, 1rem);
    padding-right: var(--space-4, 1rem);
  }

  .article-list-kicker {
    font-family: var(--font-ui, 'Inter', sans-serif);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--rust, #A14F2A);
    display: block;
    margin-bottom: var(--space-2, 0.5rem);
  }

  .article-list-content h2 {
    font-family: var(--font-display, 'Cormorant Garamond', serif);
    font-size: 1.375rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--ink, #1F1A16);
    margin-bottom: var(--space-2, 0.5rem);
  }

  .article-list-content p {
    font-family: var(--font-body, 'Source Serif 4', serif);
    color: var(--inkSoft, #666);
    font-size: 0.9375rem;
    line-height: 1.6;
    margin-bottom: var(--space-2, 0.5rem);
  }

  .article-list-meta {
    font-family: var(--font-ui, 'Inter', sans-serif);
    font-size: 0.75rem;
    color: var(--inkSoft, #666);
    display: flex;
    gap: var(--space-2, 0.5rem);
  }

  .article-list-arrow {
    font-size: 1.25rem;
    color: var(--rust, #A14F2A);
    flex-shrink: 0;
    transition: transform var(--duration-fast, 150ms) ease;
  }

  .article-list-item:hover .article-list-arrow {
    transform: translateX(4px);
  }

  .back-link {
    margin-top: var(--space-6, 1.5rem);
  }

  @media (max-width: 640px) {
    .article-list-content p {
      display: none;
    }
  }
</style>
