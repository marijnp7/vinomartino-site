---
import SiteLayout from '../../layouts/SiteLayout.astro';
import AffiliatePlaceholder from '../../components/AffiliatePlaceholder.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import { loadStreken, type Streek } from '../../lib/streken';
import { streekSchema, streekMetaTitle, streekMetaDescription, breadcrumbSchema } from '../../lib/seo';

export async function getStaticPaths() {
  const entries = await loadStreken();
  return entries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: Streek };
const pageUrl = new URL(`/streken/${entry.slug}/`, Astro.site ?? 'https://vinomartino.com').href;

const schema = [
  streekSchema({
    name: entry.name,
    description: entry.description,
    image: entry.heroImage,
    country: entry.country,
    subregions: entry.subRegions,
    grapeVarieties: entry.mainGrapes,
    pageUrl,
  }),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Streken', url: '/streken/' },
    { name: entry.name, url: pageUrl },
  ]),
];

const hasStats = Boolean(
  entry.mainGrapes.length ||
  entry.climate ||
  entry.soil ||
  entry.vineyardArea ||
  entry.altitude,
);
---

<SiteLayout
  title={streekMetaTitle(entry.name, entry.country)}
  description={streekMetaDescription({ name: entry.name, country: entry.country, grapeVarieties: entry.mainGrapes, description: entry.description })}
  ogImage={entry.ogImage || entry.heroImage || undefined}
  schema={schema}
  activeNav="streken"
>
  <article class="streek-page">
    <section class="streek-hero">
      <div class="container">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a> / <a href="/streken/">Streken</a> / <span>{entry.name}</span>
        </nav>
        <div class:list={['streek-hero__grid', !hasStats && 'streek-hero__grid--no-stats']}>
          <div>
            <span class="section-label">Wijnstreek</span>
            <h1>{entry.name}</h1>
            {entry.country && <p class="streek-country">{entry.country}</p>}
            {entry.description && <p class="streek-subtitle">{entry.description}</p>}
          </div>
          {hasStats && (
            <div class="streek-stats">
              {entry.mainGrapes.length > 0 && (
                <div class="stat">
                  <span class="stat-label">Druivenrassen</span>
                  <span class="stat-value">{entry.mainGrapes.join(', ')}</span>
                </div>
              )}
              {entry.climate && (
                <div class="stat">
                  <span class="stat-label">Klimaat</span>
                  <span class="stat-value">{entry.climate}</span>
                </div>
              )}
              {entry.soil && (
                <div class="stat">
                  <span class="stat-label">Bodem</span>
                  <span class="stat-value">{entry.soil}</span>
                </div>
              )}
              {entry.vineyardArea && (
                <div class="stat">
                  <span class="stat-label">Oppervlakte</span>
                  <span class="stat-value">{entry.vineyardArea}</span>
                </div>
              )}
              {entry.altitude && (
                <div class="stat">
                  <span class="stat-label">Hoogte</span>
                  <span class="stat-value">{entry.altitude}</span>
                </div>
              )}
            </div>
          )}
        </div>
      </div>
      {entry.heroImage && (
        <div class="streek-hero-img-wrap">
          <img src={entry.heroImage} alt={entry.name} class="streek-hero-img" loading="eager" />
        </div>
      )}
    </section>

    <section class="streek-accommodation">
      <div class="container">
        <AffiliatePlaceholder type="accommodation" partner="booking.com" region={entry.name} placement="sidebar" context="streek-accommodation" />
      </div>
    </section>

    {entry.bodyHtml && (
      <section class="streek-body">
        <div class="streek-body__inner">
          <div class="streek-prose" set:html={entry.bodyHtml} />
          <AffiliatePlaceholder type="activity" partner="getyourguide" region={entry.name} placement="inline-end" context="streek-activity" />
        </div>
      </section>
    )}

    {entry.subRegions.length > 0 && (
      <section class="streek-subregions">
        <div class="container">
          <span class="section-label">Deelregio's</span>
          <div class="subregion-grid">
            {entry.subRegions.map(sub => (
              <div class="subregion-chip">{sub}</div>
            ))}
          </div>
        </div>
      </section>
    )}

    {entry.appellations.length > 0 && (
      <section class="streek-appellations">
        <div class="container">
          <span class="section-label">Appellations</span>
          <div class="appellation-grid">
            {entry.appellations.map(app => (
              <div class="appellation-chip">{app}</div>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="streek-insurance">
      <div class="container">
        <AffiliatePlaceholder type="insurance" partner="reisverzekering" region={entry.name} placement="footer" context="streek-insurance" />
      </div>
    </section>

    <RelatedArticles items={entry.relatedArticles} />

    <AffiliateDisclosure />
  </article>
</SiteLayout>

<style>
  .streek-hero {
    background: var(--paper);
    padding-top: 3rem;
  }
  .breadcrumb {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--inkFaint);
    margin-bottom: var(--space-4);
  }
  .breadcrumb a {
    color: var(--inkSoft);
    text-decoration: none;
  }
  .breadcrumb a:hover { text-decoration: underline; }
  .streek-hero__grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 3rem;
    align-items: end;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--rule);
  }
  .streek-hero__grid--no-stats {
    grid-template-columns: 1fr;
  }
  .streek-hero__grid h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 1.5rem + 5vw, 5rem);
    font-weight: 500;
    line-height: 0.95;
    color: var(--ink);
    margin: 0;
  }
  .streek-country {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--rust);
    margin-top: var(--space-3);
  }
  .streek-subtitle {
    font-family: var(--font-body);
    font-size: 1.125rem;
    line-height: 1.5;
    font-style: italic;
    color: var(--inkSoft);
    margin-top: var(--space-3);
    max-width: 46ch;
  }
  .streek-stats {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    border-left: 1px solid var(--rule);
    padding-left: 1.5rem;
  }
  .stat-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--burgundy);
    margin-bottom: 0.25rem;
  }
  .stat-value {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--inkSoft);
  }
  .streek-hero-img-wrap {
    aspect-ratio: 21 / 9;
    margin-top: 2.5rem;
    overflow: hidden;
  }
  .streek-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .streek-body {
    padding: 4.5rem 0;
    border-bottom: 1px solid var(--rule);
  }
  .streek-body__inner {
    max-width: var(--max-width-narrow);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }
  .streek-prose {
    font-family: var(--font-body);
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--ink);
  }
  .streek-prose :global(p) { margin-bottom: 1.25rem; }
  .streek-prose :global(h2) {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 500;
    margin: 2.5rem 0 1rem;
  }
  .streek-prose :global(h3) {
    font-family: var(--font-ui);
    font-size: 1.125rem;
    font-weight: 600;
    margin: 2rem 0 0.75rem;
  }
  .streek-subregions, .streek-appellations, .streek-accommodation, .streek-insurance {
    padding: 3rem 0;
    border-bottom: 1px solid var(--rule);
  }
  .subregion-grid, .appellation-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: var(--space-3);
  }
  .subregion-chip, .appellation-chip {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    background: var(--paperDeep);
    color: var(--inkSoft);
    padding: 0.375rem 0.75rem;
    border-radius: 1px;
  }
  @media (max-width: 900px) {
    .streek-hero__grid { grid-template-columns: 1fr; }
    .streek-stats { border-left: none; padding-left: 0; border-top: 1px solid var(--rule); padding-top: 1rem; }
  }
</style>
