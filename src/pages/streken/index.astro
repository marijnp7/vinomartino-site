---
import SiteLayout from '../../layouts/SiteLayout.astro';
import SmartImg from '../../components/SmartImg.astro';
import { loadStreken } from '../../lib/streken';
import { organizationSchema, breadcrumbSchema } from '../../lib/seo';

const entries = await loadStreken();

const schema = [
  organizationSchema(),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Streken', url: '/streken/' },
  ]),
];
---

<SiteLayout
  title="Wijnstreken, Van Piemonte tot de Mosel | VinoMartino"
  description="Ontdek de grote wijnstreken van Europa, terroir, druivenrassen, klimaat en de beste producenten. Diepgaande gidsen voor wijnliefhebbers."
  schema={schema}
  activeNav="streken"
>
  <section class="hero-sm">
    <div class="container">
      <span class="section-label">Wijnstreken</span>
      <h1>Terroir, druiven & traditie</h1>
      <p class="hero-desc">Piemonte, Etna, Bourgogne, Mosel, elke streek heeft een eigen logica van bodem, klimaat en druif. Hier leg ik ze uit zoals ik ze heb leren kennen: door er naartoe te rijden.</p>
    </div>
  </section>

  <section class="section container">
    {entries.length > 0 ? (
      <div class="grid">
        {entries.map(entry => (
          <a href={`/streken/${entry.slug}/`} class="card card-link">
            <div class="card-img-wrap">
              <SmartImg src={entry.heroImage || undefined} alt={entry.name} theme="vineyard" class="card-img" />
            </div>
            <div class="card-body">
              {entry.country && <span class="card-country">{entry.country}</span>}
              <h2 class="card-title">{entry.name}</h2>
              {entry.description && <p class="card-desc">{entry.description}</p>}
              {entry.mainGrapes && entry.mainGrapes.length > 0 && (
                <div class="card-tags">
                  {entry.mainGrapes.slice(0, 3).map(g => <span class="tag">{g}</span>)}
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <h2>De gidsen zijn onderweg</h2>
        <p>Piemonte, Etna, Bourgogne, Mosel en Priorat staan bovenaan de lijst. Ik schrijf ze liever goed dan snel, begin ondertussen bij de <a href="/artikelen/">artikelen</a>.</p>
      </div>
    )}
  </section>
</SiteLayout>

<style>
  .hero-sm {
    background: var(--paperDeep);
    padding: var(--space-12) 0 var(--space-8);
    text-align: center;
  }
  .hero-sm h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.6rem + 1.5vw, 3rem);
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin-top: var(--space-3);
  }
  .hero-desc {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--inkSoft);
    margin-top: var(--space-3);
    max-width: 36rem;
    margin-inline: auto;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-6);
  }
  /* LAT-1118 (M5-hardening): voorkom horizontale overflow op smalle telefoons
     (<=360px Android / 320px iPhone SE) waar de track de viewport overschrijdt. */
  @media (max-width: 420px) {
    .grid { grid-template-columns: 1fr; }
  }
  .card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .card-img-wrap {
    aspect-ratio: 16 / 11;
    overflow: hidden;
    background: var(--paperShade);
  }
  .card-img-wrap :global(img),
  .card-img-wrap :global(.smart-img-placeholder) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-image) var(--ease-out);
  }
  .card-link:hover .card-img-wrap :global(img) { transform: scale(1.03); }
  .card-body { padding: 1.25rem; }
  .card-country {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--rust);
    display: block;
    margin-bottom: var(--space-2);
  }
  .card-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: var(--space-2);
    line-height: 1.25;
  }
  .card-desc {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--inkSoft);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: var(--space-3);
  }
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: var(--paperDeep);
    color: var(--inkSoft);
    padding: 0.25rem 0.625rem;
    border-radius: 1px;
  }
  .empty-state {
    text-align: center;
    padding: var(--space-16) var(--space-4);
  }
  .empty-state h2 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin-bottom: var(--space-3);
  }
  .empty-state p {
    font-size: 1rem;
    color: var(--inkSoft);
  }
</style>
