---
import SiteLayout from '../../layouts/SiteLayout.astro';
import StreekCard from '../../components/StreekCard.astro';
import { loadStreken, type Streek } from '../../lib/streken';
import { organizationSchema, breadcrumbSchema } from '../../lib/seo';

const entries = await loadStreken();

// LAT-2006 (VIS-BL-07) - twee-tier ordening van het streken-overzicht:
//   Tier 1 = "Zelf gereisd" (zelfGereisd=true) bovenaan, met badge.
//   Tier 2 = "Redactiegidsen" (zelfGereisd=false), per land gegroepeerd.
// Beide tiers degraderen gracieus: is een tier leeg dan verdwijnt de sectie.
const tier1 = entries.filter(e => e.zelfGereisd);
const tier2 = entries.filter(e => !e.zelfGereisd);

// "Begin hier"-hint op de sterkste zelf-gereisde streken. Sterkte = compleetheid
// (heldenbeeld + omschrijving + druiven) zodat de hint data-driven blijft en niet
// op een fragiele slug-lijst leunt.
function strength(e: Streek): number {
  return (e.heroImage ? 2 : 0) + (e.description ? 1 : 0) + Math.min(e.mainGrapes?.length ?? 0, 3);
}
const beginHier = new Set(
  [...tier1]
    .sort((a, b) => strength(b) - strength(a))
    .slice(0, 4)
    .map(e => e.slug),
);

// Tier 2 per land: landen alfabetisch (Nederlands), streken op naam. Streken
// zonder land vallen onder "Overig" en komen achteraan.
const OVERIG = 'Overig';
const tier2Groups = (() => {
  const map = new Map<string, Streek[]>();
  for (const e of tier2) {
    const key = e.country || OVERIG;
    if (!map.has(key)) map.set(key, []);
    map.get(key)!.push(e);
  }
  return [...map.entries()]
    .sort(([a], [b]) => {
      if (a === OVERIG) return 1;
      if (b === OVERIG) return -1;
      return a.localeCompare(b, 'nl');
    })
    .map(([country, items]) => ({
      country,
      items: items.sort((x, y) => x.name.localeCompare(y.name, 'nl')),
    }));
})();

const schema = [
  organizationSchema(),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Streken', url: '/streken/' },
  ]),
];
---

<SiteLayout
  title="Wijnstreken, Van Piemonte tot de Mosel | VinoMartino"
  description="Ontdek de grote wijnstreken van Europa, terroir, druivenrassen, klimaat en de beste producenten. Diepgaande gidsen voor wijnliefhebbers."
  schema={schema}
  activeNav="streken"
>
  <section class="hero-sm">
    <div class="container">
      <span class="section-label">Wijnstreken</span>
      <h1>Terroir, druiven & traditie</h1>
      <p class="hero-desc">Piemonte, Etna, Bourgogne, Mosel, elke streek heeft een eigen logica van bodem, klimaat en druif. Hier leg ik ze uit zoals ik ze heb leren kennen: door er naartoe te rijden.</p>
    </div>
  </section>

  <section class="section container">
    {entries.length > 0 ? (
      <>
        {tier1.length > 0 && (
          <div class="tier">
            <div class="tier-head">
              <span class="section-label">Zelf gereisd</span>
              <h2 class="tier-title">Streken waar ik zelf reed</h2>
              <p class="tier-desc">Deze gidsen schreef ik na eigen bezoek. Weet je niet waar te beginnen? Start bij de vier met een "Begin hier"-label.</p>
            </div>
            <div class="grid">
              {tier1.map(entry => (
                <StreekCard entry={entry} beginHier={beginHier.has(entry.slug)} />
              ))}
            </div>
          </div>
        )}

        {tier2Groups.length > 0 && (
          <div class="tier">
            <div class="tier-head">
              <span class="section-label">Redactiegidsen</span>
              <h2 class="tier-title">Gidsen per land</h2>
              <p class="tier-desc">Zorgvuldig samengesteld op basis van primaire bronnen en lokale kennis, gegroepeerd per land.</p>
            </div>
            {tier2Groups.map(group => (
              <div class="country-group">
                <h3 class="country-title">{group.country}</h3>
                <div class="grid">
                  {group.items.map(entry => (
                    <StreekCard entry={entry} />
                  ))}
                </div>
              </div>
            ))}
          </div>
        )}
      </>
    ) : (
      <div class="empty-state">
        <h2>De gidsen zijn onderweg</h2>
        <p>Piemonte, Etna, Bourgogne, Mosel en Priorat staan bovenaan de lijst. Ik schrijf ze liever goed dan snel, begin ondertussen bij de <a href="/artikelen/">artikelen</a>.</p>
      </div>
    )}
  </section>
</SiteLayout>

<style>
  .hero-sm {
    background: var(--paperDeep);
    padding: var(--space-12) 0 var(--space-8);
    text-align: center;
  }
  .hero-sm h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.6rem + 1.5vw, 3rem);
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin-top: var(--space-3);
  }
  .hero-desc {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--inkSoft);
    margin-top: var(--space-3);
    max-width: 36rem;
    margin-inline: auto;
  }
  .tier { margin-bottom: var(--space-12); }
  .tier:last-child { margin-bottom: 0; }
  .tier-head { margin-bottom: var(--space-6); }
  .tier-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 1.3rem + 1vw, 2rem);
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin-top: var(--space-2);
  }
  .tier-desc {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--inkSoft);
    margin-top: var(--space-2);
    max-width: 40rem;
  }
  .country-group { margin-bottom: var(--space-8); }
  .country-group:last-child { margin-bottom: 0; }
  .country-title {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--rust);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--paperShade, #e6ddca);
    margin-bottom: var(--space-5);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-6);
  }
  /* LAT-1118 (M5-hardening): voorkom horizontale overflow op smalle telefoons
     (<=360px Android / 320px iPhone SE) waar de track de viewport overschrijdt. */
  @media (max-width: 420px) {
    .grid { grid-template-columns: 1fr; }
  }
  .empty-state {
    text-align: center;
    padding: var(--space-16) var(--space-4);
  }
  .empty-state h2 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin-bottom: var(--space-3);
  }
  .empty-state p {
    font-size: 1rem;
    color: var(--inkSoft);
  }
</style>
