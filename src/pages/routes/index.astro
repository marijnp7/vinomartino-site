---
import SiteLayout from '../../layouts/SiteLayout.astro';
import RoutesIndexContent from '../../components/pages/RoutesIndexContent.astro';
import { loadRoutes } from '../../lib/routes';
import { breadcrumbSchema } from '../../lib/seo';

const entries = await loadRoutes();

const routes = entries.map(entry => ({
  title: entry.title,
  country: '',
  region: entry.stops[0] || '',
  days: entry.duration ? parseInt(entry.duration) || 0 : 0,
  transport: entry.transport || '',
  style: entry.style || '',
  href: `/routes/${entry.slug}/`,
  image: entry.heroImage || undefined,
}));

const schema = breadcrumbSchema([
  { name: 'Home', url: '/' },
  { name: 'Routes', url: '/routes/' },
]);
---

<SiteLayout
  title="Wijnroutes — Kant-en-klare reisroutes door wijnstreken | VinoMartino"
  description="Zelf gereden routes door de mooiste wijnstreken. Met dagindeling, slaapadressen en de wijnhuizen die je écht moet bezoeken."
  schema={schema}
  activeNav="Routes"
>
  <RoutesIndexContent routes={routes.length > 0 ? routes : undefined} />
</SiteLayout>
