---
import { loadRoutes } from '../../lib/routes';

// LAT-859 + LAT-989: Redirect /routes/* to /wijnroutes/* (canonical URL structure)
export async function getStaticPaths() {
  const entries = await loadRoutes();
  return entries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { slug } = Astro.params;
return Astro.redirect(`/wijnroutes/${slug}/`, 301);
---
