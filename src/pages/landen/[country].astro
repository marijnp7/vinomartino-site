---
import SiteLayout from '../../layouts/SiteLayout.astro';
import AffiliatePlaceholder from '../../components/AffiliatePlaceholder.astro';
import { loadCountries, type Country } from '../../lib/countries';
import { loadDestinations, getDestinationsByCountry } from '../../lib/destinations';
import { loadItineraries, getItinerariesByCountry } from '../../lib/itineraries';
import { loadArticles } from '../../lib/articles';

export async function getStaticPaths() {
  const countries = await loadCountries();
  return countries.map((c) => ({ params: { country: c.slug }, props: { country: c } }));
}

const { country } = Astro.props as { country: Country };

await loadDestinations();
await loadItineraries();

const destinations = getDestinationsByCountry(country.slug);
const itineraries = getItinerariesByCountry(country.slug);
const articles = await loadArticles();

const months = ['jan', 'feb', 'mrt', 'apr', 'mei', 'jun', 'jul', 'aug', 'sep', 'okt', 'nov', 'dec'];
const monthLabels = ['Jan', 'Feb', 'Mrt', 'Apr', 'Mei', 'Jun', 'Jul', 'Aug', 'Sep', 'Okt', 'Nov', 'Dec'];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Country',
  name: country.name,
  description: country.description,
  url: new URL(`/landen/${country.slug}/`, Astro.site ?? 'https://reisplatform.nl').href,
};
---

<SiteLayout
  title={country.metaTitle || `${country.name} Reisgids`}
  description={country.metaDescription || country.description}
  ogImage={country.heroImage}
  schema={schema}
  activeNav="landen"
>
  <!-- Hero -->
  <section class="country-hero">
    <img src={country.heroImage} alt={country.name} class="country-hero-img" />
    <div class="country-hero-overlay"></div>
    <div class="country-hero-content">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a> / <a href="/landen/">Landen</a> / <span>{country.name}</span>
      </nav>
      <h1>{country.name}</h1>
      <p class="country-hero-sub">{country.continent} · {country.capital}</p>
    </div>
  </section>

  <div class="container country-body">
    <!-- Intro -->
    <section class="country-intro">
      <p class="country-desc">{country.description}</p>
    </section>

    <!-- Praktische info -->
    <section class="practical-info">
      <h2 class="section-title">Praktische informatie</h2>
      <div class="info-grid">
        <div class="info-item">
          <span class="info-label">Hoofdstad</span>
          <span class="info-value">{country.capital}</span>
        </div>
        <div class="info-item">
          <span class="info-label">Valuta</span>
          <span class="info-value">{country.currency}</span>
        </div>
        <div class="info-item">
          <span class="info-label">Taal</span>
          <span class="info-value">{country.language}</span>
        </div>
        <div class="info-item">
          <span class="info-label">Tijdzone</span>
          <span class="info-value">{country.timezone}</span>
        </div>
        <div class="info-item">
          <span class="info-label">Veiligheid</span>
          <span class="info-value">{country.safetyLevel}</span>
        </div>
      </div>
    </section>

    <!-- Visum -->
    <section class="visa-section">
      <h2 class="section-title">Visum & inentingen</h2>
      <div class="visa-grid">
        <div class="visa-card">
          <h3>Visum</h3>
          <p>{country.visaRules}</p>
        </div>
        <div class="visa-card">
          <h3>Inentingen</h3>
          <p>{country.vaccinations}</p>
        </div>
      </div>
    </section>

    <!-- Beste reistijd -->
    {Object.keys(country.bestTravelTime).length > 0 && (
      <section class="travel-time-section">
        <h2 class="section-title">Beste reistijd</h2>
        <div class="travel-chart">
          {months.map((m, i) => {
            const score = country.bestTravelTime[m] || 5;
            const pct = (score / 10) * 100;
            return (
              <div class="chart-bar-wrap">
                <div class="chart-bar" style={`height: ${pct}%`} title={`${monthLabels[i]}: ${score}/10`}>
                  <span class="chart-score">{score}</span>
                </div>
                <span class="chart-month">{monthLabels[i]}</span>
              </div>
            );
          })}
        </div>
      </section>
    )}

    <!-- Bestemmingen -->
    {destinations.length > 0 && (
      <section class="destinations-section">
        <h2 class="section-title">Bestemmingen in {country.name}</h2>
        <div class="dest-grid">
          {destinations.map(d => (
            <a href={`/bestemmingen/${d.slug}/`} class="dest-card card">
              {d.heroImage && <img src={d.heroImage} alt={d.name} loading="lazy" width="300" height="180" />}
              <div class="dest-info">
                <h3>{d.name}</h3>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Reisroutes -->
    {itineraries.length > 0 && (
      <section class="itineraries-section">
        <h2 class="section-title">Reisroutes voor {country.name}</h2>
        <div class="itin-list">
          {itineraries.map(it => (
            <a href={`/reisroutes/${it.slug}/`} class="itin-card card">
              <div class="itin-info">
                <h3>{it.title}</h3>
                <div class="itin-meta">
                  {it.duration && <span>{it.duration}</span>}
                  {it.budget && <span>{it.budget}</span>}
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <AffiliatePlaceholder type="accommodation" context={country.slug} />
    <AffiliatePlaceholder type="flight" context={country.slug} />
    <AffiliatePlaceholder type="insurance" context={country.slug} />
  </div>
</SiteLayout>

<style>
  .country-hero {
    position: relative;
    height: 50vh;
    min-height: 360px;
    overflow: hidden;
  }
  .country-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .country-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(31,26,22,0.3) 0%, rgba(31,26,22,0.7) 100%);
  }
  .country-hero-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-8) var(--gutter);
    max-width: var(--max-width);
    margin: 0 auto;
    color: var(--paper);
  }
  .breadcrumb {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-3);
    opacity: 0.8;
  }
  .breadcrumb a {
    color: var(--paper);
    text-decoration: none;
  }
  .breadcrumb a:hover { text-decoration: underline; }
  .country-hero-content h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 2rem + 2vw, 4rem);
    font-weight: 400;
    font-style: italic;
  }
  .country-hero-sub {
    font-family: var(--font-ui);
    font-size: 1rem;
    opacity: 0.85;
    margin-top: var(--space-2);
  }

  .country-body {
    padding-top: var(--space-12);
    padding-bottom: var(--space-12);
  }
  .country-intro {
    margin-bottom: var(--space-12);
  }
  .country-desc {
    font-family: var(--font-body);
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--ink);
    max-width: var(--article-body-max);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--rule);
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--space-4);
    margin-bottom: var(--space-12);
  }
  .info-item {
    background: var(--paperDeep);
    padding: 1rem 1.25rem;
    border-radius: var(--radius-sm);
  }
  .info-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--inkFaint);
    margin-bottom: 0.25rem;
  }
  .info-value {
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--ink);
  }

  .practical-info, .visa-section, .travel-time-section,
  .destinations-section, .itineraries-section {
    margin-bottom: var(--space-12);
  }

  .visa-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
  }
  .visa-card {
    background: var(--paperDeep);
    padding: 1.5rem;
    border-radius: var(--radius-sm);
  }
  .visa-card h3 {
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .visa-card p {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--inkSoft);
  }

  .travel-chart {
    display: flex;
    align-items: flex-end;
    gap: var(--space-2);
    height: 180px;
    padding-bottom: 2rem;
    position: relative;
  }
  .chart-bar-wrap {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
    justify-content: flex-end;
  }
  .chart-bar {
    width: 100%;
    max-width: 48px;
    background: var(--burgundy);
    border-radius: 2px 2px 0 0;
    position: relative;
    min-height: 8px;
    transition: height var(--duration-base);
  }
  .chart-score {
    position: absolute;
    top: -1.25rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--ink);
    font-weight: 500;
  }
  .chart-month {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--inkSoft);
    margin-top: 0.5rem;
  }

  .dest-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: var(--space-4);
  }
  .dest-card {
    text-decoration: none;
    color: inherit;
  }
  .dest-card img {
    width: 100%;
    height: 180px;
    object-fit: cover;
  }
  .dest-info {
    padding: 0.875rem 1rem;
  }
  .dest-info h3 {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--ink);
  }

  .itin-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .itin-card {
    text-decoration: none;
    color: inherit;
    padding: 1.25rem 1.5rem;
    display: block;
  }
  .itin-info h3 {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--ink);
  }
  .itin-meta {
    display: flex;
    gap: 1rem;
    margin-top: 0.375rem;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--inkSoft);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  @media (max-width: 640px) {
    .visa-grid { grid-template-columns: 1fr; }
    .info-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
