---
// LAT-2638 — NL land-detailroute (prefixloos). Dunne wrapper rond het gedeelde
// LandDetail-component; de EN-tegenhanger leeft onder /en/landen/. hreflang-
// alternates worden alleen gezet wanneer er een EN-vertaling bestaat (launch-
// gate: geen en-hreflang zonder tegenhanger).
import LandDetail from '../../components/LandDetail.astro';
import { loadLanden, type Land } from '../../lib/landen';
import { loadStreken } from '../../lib/streken';
import { loadWijnhuizen } from '../../lib/wijnhuizen';
import { loadRoutes } from '../../lib/routes';
import { loadAtlasForLand, type AtlasData } from '../../lib/atlas-data';
import { strekenForLand, streekToCard, wijnhuisToCard, routeToCard, type StreekCard, type WijnhuisCard, type RouteCard } from '../../lib/landen-cards';
import { DEFAULT_LOCALE } from '../../lib/i18n';

export async function getStaticPaths() {
  const [entries, allStreken, allWijnhuizen, allRoutes, enEntries] = await Promise.all([
    loadLanden(),
    loadStreken(),
    loadWijnhuizen(),
    loadRoutes(),
    loadLanden('en'),
  ]);
  const enSlugs = new Set(enEntries.map(e => e.slug));
  if (entries.length > 0) {
    return Promise.all(entries.map(async entry => {
      const landStreken = strekenForLand(entry, allStreken);
      const streekSlugs = new Set(landStreken.map(s => s.slug));
      const landWijnhuizen = allWijnhuizen.filter(w => w.streekSlug && streekSlugs.has(w.streekSlug));
      // LAT-1199: routes van dit land via routes.streek_id→streek→land-keten
      // (streekSlug uit M2O of M2M-fallback in loadRoutes).
      const landRoutes = allRoutes.filter(r => r.streekSlug && streekSlugs.has(r.streekSlug));
      // LAT-1122: interactieve atlas (alléén landen met map_config-geometrie).
      // Geïsoleerde loader; faalt zacht naar null → pagina rendert zonder atlas.
      const atlas = await loadAtlasForLand(entry.slug).catch(() => null);
      return {
        params: { slug: entry.slug },
        props: {
          entry,
          atlas,
          strekenCards: landStreken.map(streekToCard),
          wijnhuisCards: landWijnhuizen.slice(0, 6).map(wijnhuisToCard),
          routeCards: landRoutes.map(routeToCard),
          alternates: enSlugs.has(entry.slug)
            ? { nl: `/landen/${entry.slug}/`, en: `/en/landen/${entry.slug}/` }
            : undefined,
        },
      };
    }));
  }
  // Showcase fallback slugs when no CMS data
  const empty = { entry: null, atlas: null, strekenCards: [], wijnhuisCards: [], routeCards: [], alternates: undefined };
  return [
    { params: { slug: 'italie' }, props: { ...empty } },
    { params: { slug: 'duitsland' }, props: { ...empty } },
    { params: { slug: 'frankrijk' }, props: { ...empty } },
    { params: { slug: 'spanje' }, props: { ...empty } },
    { params: { slug: 'portugal' }, props: { ...empty } },
    { params: { slug: 'oostenrijk' }, props: { ...empty } },
  ];
}

const { slug } = Astro.params;
const { entry, atlas, strekenCards, wijnhuisCards, routeCards, alternates } = Astro.props as {
  entry: Land | null;
  atlas: AtlasData | null;
  strekenCards: StreekCard[];
  wijnhuisCards: WijnhuisCard[];
  routeCards: RouteCard[];
  alternates?: Record<string, string>;
};
---

<LandDetail
  slug={slug!}
  entry={entry}
  atlas={atlas}
  strekenCards={strekenCards}
  wijnhuisCards={wijnhuisCards}
  routeCards={routeCards}
  locale={DEFAULT_LOCALE}
  alternates={alternates}
/>
