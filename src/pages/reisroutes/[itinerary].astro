---
import SiteLayout from '../../layouts/SiteLayout.astro';
import AffiliatePlaceholder from '../../components/AffiliatePlaceholder.astro';
import { loadItineraries, type Itinerary } from '../../lib/itineraries';
import { loadCountries, getCountryBySlug } from '../../lib/countries';

export async function getStaticPaths() {
  const itineraries = await loadItineraries();
  return itineraries.map((i) => ({ params: { itinerary: i.slug }, props: { itinerary: i } }));
}

const { itinerary } = Astro.props as { itinerary: Itinerary };
await loadCountries();
const country = getCountryBySlug(itinerary.countrySlug);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'TouristTrip',
  name: itinerary.title,
  description: itinerary.description,
};
---

<SiteLayout
  title={itinerary.metaTitle || itinerary.title}
  description={itinerary.metaDescription || itinerary.description}
  ogImage={itinerary.heroImage}
  schema={schema}
  activeNav="reisroutes"
>
  <section class="itin-hero">
    {itinerary.heroImage && (
      <img src={itinerary.heroImage} alt={itinerary.title} class="itin-hero-img" />
    )}
    <div class="itin-hero-overlay"></div>
    <div class="itin-hero-content container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a> /
        <a href="/reisroutes/">Reisroutes</a> /
        <span>{itinerary.title}</span>
      </nav>
      <h1>{itinerary.title}</h1>
      <div class="itin-hero-meta">
        {itinerary.duration && <span>{itinerary.duration}</span>}
        {itinerary.budget && <span>{itinerary.budget}</span>}
        {itinerary.difficulty && <span>{itinerary.difficulty}</span>}
        {country && <span>{country.name}</span>}
      </div>
    </div>
  </section>

  <div class="container itin-body">
    <div class="itin-content">
      <p class="itin-desc">{itinerary.description}</p>

      {itinerary.bodyHtml && (
        <div class="itin-prose" set:html={itinerary.bodyHtml} />
      )}

      <AffiliatePlaceholder type="accommodation" context={itinerary.slug} />
      <AffiliatePlaceholder type="activity" context={itinerary.slug} />
      <AffiliatePlaceholder type="flight" context={itinerary.slug} />
    </div>

    <aside class="itin-sidebar">
      <AffiliatePlaceholder type="sidebar" context={itinerary.slug} />
    </aside>
  </div>
</SiteLayout>

<style>
  .itin-hero {
    position: relative;
    height: 45vh;
    min-height: 320px;
    overflow: hidden;
    background: var(--paperDeep);
  }
  .itin-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .itin-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(31,26,22,0.2) 0%, rgba(31,26,22,0.65) 100%);
  }
  .itin-hero-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding-bottom: var(--space-8);
    color: var(--paper);
  }
  .breadcrumb {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-3);
    opacity: 0.8;
  }
  .breadcrumb a { color: var(--paper); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }
  .itin-hero-content h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.6rem + 2vw, 3.5rem);
    font-weight: 400;
    font-style: italic;
  }
  .itin-hero-meta {
    display: flex;
    gap: 1.5rem;
    margin-top: var(--space-3);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.85;
  }

  .itin-body {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: var(--space-10);
    padding-top: var(--space-10);
    padding-bottom: var(--space-12);
  }
  .itin-desc {
    font-family: var(--font-body);
    font-size: 1.125rem;
    line-height: 1.7;
    margin-bottom: var(--space-8);
  }
  .itin-prose {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--ink);
  }
  .itin-prose :global(h2) {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 500;
    margin: var(--space-8) 0 var(--space-4);
  }
  .itin-prose :global(h3) {
    font-family: var(--font-ui);
    font-size: 1.125rem;
    font-weight: 600;
    margin: var(--space-6) 0 var(--space-3);
  }
  .itin-prose :global(p) {
    margin-bottom: var(--space-4);
  }
  .itin-prose :global(ul), .itin-prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: var(--space-4);
  }

  @media (max-width: 900px) {
    .itin-body { grid-template-columns: 1fr; }
  }
</style>
