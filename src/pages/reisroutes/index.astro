---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { loadItineraries } from '../../lib/itineraries';

const itineraries = await loadItineraries();
---

<SiteLayout
  title="Reisroutes — Kant-en-klare routes"
  description="Ontdek kant-en-klare reisroutes met dagprogramma's, budgetten en praktische tips."
  activeNav="reisroutes"
>
  <section class="hero-sm">
    <div class="container">
      <span class="section-label">Reisroutes</span>
      <h1>Kant-en-klare reisroutes</h1>
      <p class="hero-desc">Complete routes met dagprogramma's, budgetindicaties en praktische tips — klaar om na te reizen.</p>
    </div>
  </section>

  <section class="section container">
    {itineraries.length > 0 ? (
      <div class="itin-grid">
        {itineraries.map(it => (
          <a href={`/reisroutes/${it.slug}/`} class="itin-card card">
            {it.heroImage && (
              <img src={it.heroImage} alt={it.title} loading="lazy" width="400" height="220" class="itin-img" />
            )}
            <div class="itin-body">
              <h2 class="itin-title">{it.title}</h2>
              <div class="itin-meta">
                {it.duration && <span>{it.duration}</span>}
                {it.budget && <span>{it.budget}</span>}
                {it.difficulty && <span>{it.difficulty}</span>}
              </div>
              <p class="itin-desc">{it.description}</p>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <span class="empty-icon" aria-hidden="true">🗺️</span>
        <h2>Reisroutes komen eraan</h2>
        <p>We werken aan kant-en-klare routes voor onze toplanden. Binnenkort beschikbaar!</p>
        <a href="/landen/" class="btn-text">Bekijk onze landengidsen &rarr;</a>
      </div>
    )}
  </section>
</SiteLayout>

<style>
  .hero-sm {
    background: var(--paperDeep);
    padding: var(--space-12) 0 var(--space-8);
    text-align: center;
  }
  .hero-sm h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.6rem + 1.5vw, 3rem);
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin-top: var(--space-3);
  }
  .hero-desc {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--inkSoft);
    margin-top: var(--space-3);
    max-width: 36rem;
    margin-inline: auto;
  }
  .itin-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: var(--space-6);
  }
  .itin-card {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .itin-img {
    width: 100%;
    height: 220px;
    object-fit: cover;
  }
  .itin-body {
    padding: 1.25rem 1.5rem;
  }
  .itin-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--ink);
  }
  .itin-meta {
    display: flex;
    gap: 1rem;
    margin-top: 0.375rem;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--inkSoft);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .itin-desc {
    margin-top: 0.75rem;
    font-size: 0.875rem;
    color: var(--inkSoft);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .empty-state {
    text-align: center;
    padding: var(--space-16) var(--space-4);
  }
  .empty-icon {
    font-size: 3rem;
    display: block;
    margin-bottom: var(--space-4);
  }
  .empty-state h2 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin-bottom: var(--space-3);
  }
  .empty-state p {
    font-size: 1rem;
    color: var(--inkSoft);
    margin-bottom: var(--space-6);
  }
  .btn-text {
    font-family: var(--font-ui);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--burgundy);
    text-decoration: none;
  }
  .btn-text:hover { text-decoration: underline; }
</style>
