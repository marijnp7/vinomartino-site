---
import SiteLayout from '../../layouts/SiteLayout.astro';
import DiscoverMapEurope from '../../components/DiscoverMapEurope.astro';
import { loadLanden } from '../../lib/landen';
import { loadStreken } from '../../lib/streken';
import { organizationSchema, breadcrumbSchema } from '../../lib/seo';

const [landen, streken] = await Promise.all([loadLanden(), loadStreken()]);

// Groepeer gepubliceerde streken onder hun land. loadStreken levert alleen
// publiceerbare rijen, dus elke streek hier heeft een echte /streken/{slug}/.
const strekenByLand = new Map<string, { slug: string; name: string }[]>();
for (const s of streken) {
  if (!s.landSlug) continue;
  const list = strekenByLand.get(s.landSlug) ?? [];
  list.push({ slug: s.slug, name: s.name });
  strekenByLand.set(s.landSlug, list);
}
for (const list of strekenByLand.values()) {
  list.sort((a, b) => a.name.localeCompare(b.name, 'nl'));
}

// Bubbel per land. Kleur is data-gedreven (vaste merk-agnostische palet,
// deterministisch per land) — nieuw land = bubbel erbij, geen nav-item erbij.
const PALETTE = ['#5A1A1F', '#A14F2A', '#5C6B3F', '#B86030', '#6B3A4A', '#7A6A2C'];

interface Bubble {
  slug: string;
  name: string;
  continent: string;
  color: string;
  regions: { slug: string; name: string }[];
}

const bubbles: Bubble[] = landen.map((land, i) => ({
  slug: land.slug,
  name: land.name,
  continent: land.continent,
  color: PALETTE[i % PALETTE.length] as string,
  regions: strekenByLand.get(land.slug) ?? [],
}));

const totaalStreken = streken.length;

const schema = [
  organizationSchema(),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Ontdek', url: '/ontdek/' },
  ]),
];
---

<SiteLayout
  title="Ontdek de wijnatlas, landen & streken | VinoMartino"
  description="De wijnatlas van VinoMartino: blader van wijnland naar wijnstreek. Per land de streken die ertoe doen, elk met een eigen gids over terroir, druiven en reizen."
  schema={schema}
  activeNav="ontdek"
>
  <section class="hero-sm">
    <div class="container">
      <span class="section-label">Wijnatlas</span>
      <h1>Ontdek per land en streek</h1>
      <p class="hero-desc">Blader door de wijnlanden van Europa. Kies een land, duik in de streken eronder en lees de gids van de regio die je trekt. Hoe meer we toevoegen, hoe rijker de atlas, zonder dat het menu meegroeit.</p>
    </div>
  </section>

  <section class="section container">
    {bubbles.length > 0 && (
      <DiscoverMapEurope
        countries={bubbles.map(b => ({ slug: b.slug, name: b.name, color: b.color, regionCount: b.regions.length }))}
      />
    )}
    {bubbles.length > 0 ? (
      <div class="atlas-grid">
        {bubbles.map(b => (
          <article class="bubble" style={`--bubble: ${b.color};`}>
            <a href={`/landen/${b.slug}/`} class="bubble-head">
              {b.continent && <span class="bubble-continent">{b.continent}</span>}
              <h2 class="bubble-title">{b.name}</h2>
            </a>
            {b.regions.length > 0 ? (
              <ul class="region-list">
                {b.regions.map(r => (
                  <li>
                    <a href={`/streken/${r.slug}/`} class="region-link">{r.name}</a>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="region-empty">
                <a href={`/landen/${b.slug}/`}>Bekijk het land &rsaquo;</a>
              </p>
            )}
          </article>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <h2>De atlas vult zich</h2>
        <p>We werken aan de eerste wijnlandgidsen. Begin ondertussen bij de <a href="/artikelen/">artikelen</a>.</p>
      </div>
    )}
  </section>

  {bubbles.length > 0 && (
    <section class="section container atlas-foot">
      <p>{bubbles.length} {bubbles.length === 1 ? 'wijnland' : 'wijnlanden'} &middot; {totaalStreken} {totaalStreken === 1 ? 'streek' : 'streken'} in de atlas. Elke streek is een eigen gids over terroir, druiven en reizen.</p>
    </section>
  )}
</SiteLayout>

<style>
  .hero-sm {
    background: var(--paperDeep);
    padding: var(--space-12) 0 var(--space-8);
    text-align: center;
  }
  .hero-sm h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.6rem + 1.5vw, 3rem);
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin-top: var(--space-3);
  }
  .hero-desc {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--inkSoft);
    margin-top: var(--space-3);
    max-width: 40rem;
    margin-inline: auto;
  }
  .atlas-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-6);
  }
  @media (max-width: 420px) {
    .atlas-grid { grid-template-columns: 1fr; }
  }
  .bubble {
    border: 1px solid var(--ruleSoft);
    border-top: 4px solid var(--bubble);
    background: var(--paper);
    display: flex;
    flex-direction: column;
  }
  .bubble-head {
    display: block;
    text-decoration: none;
    padding: 1.25rem 1.25rem 1rem;
    background: color-mix(in srgb, var(--bubble) 8%, var(--paper));
    border-bottom: 1px solid var(--ruleSoft);
    transition: background var(--duration-fast) var(--ease-out);
  }
  .bubble-head:hover {
    background: color-mix(in srgb, var(--bubble) 16%, var(--paper));
  }
  .bubble-continent {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--bubble);
    display: block;
    margin-bottom: var(--space-2);
  }
  .bubble-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.2;
  }
  .region-list {
    list-style: none;
    margin: 0;
    padding: 0.75rem 1.25rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  .region-link {
    display: block;
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    color: var(--ink);
    text-decoration: none;
    padding: 0.4375rem 0;
    border-bottom: 1px solid var(--ruleSoft);
    transition: color var(--duration-fast) var(--ease-out),
                padding-left var(--duration-fast) var(--ease-out);
  }
  .region-list li:last-child .region-link { border-bottom: none; }
  .region-link:hover {
    color: var(--bubble);
    padding-left: 0.375rem;
  }
  .region-empty {
    padding: 0.75rem 1.25rem 1.25rem;
    font-family: var(--font-ui);
    font-size: 0.9375rem;
  }
  .region-empty a {
    color: var(--bubble);
    text-decoration: none;
  }
  .region-empty a:hover { text-decoration: underline; }
  .atlas-foot {
    text-align: center;
    padding-top: 0;
  }
  .atlas-foot p {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--inkFaint);
  }
  .empty-state {
    text-align: center;
    padding: var(--space-16) var(--space-4);
  }
  .empty-state h2 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin-bottom: var(--space-3);
  }
  .empty-state p { font-size: 1rem; color: var(--inkSoft); }
</style>
