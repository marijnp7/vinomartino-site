---
import SiteLayout from '../../layouts/SiteLayout.astro';
import SmartImg from '../../components/SmartImg.astro';
import DiscoverMapEurope from '../../components/DiscoverMapEurope.astro';
import { loadLanden } from '../../lib/landen';
import { loadStreken } from '../../lib/streken';
import { organizationSchema, breadcrumbSchema } from '../../lib/seo';

const [landen, streken] = await Promise.all([loadLanden(), loadStreken()]);

// Groepeer gepubliceerde streken onder hun land. loadStreken levert alleen
// publiceerbare rijen, dus elke streek hier heeft een echte /streken/{slug}/.
const strekenByLand = new Map<string, { slug: string; name: string }[]>();
for (const s of streken) {
  if (!s.landSlug) continue;
  const list = strekenByLand.get(s.landSlug) ?? [];
  list.push({ slug: s.slug, name: s.name });
  strekenByLand.set(s.landSlug, list);
}
for (const list of strekenByLand.values()) {
  list.sort((a, b) => a.name.localeCompare(b.name, 'nl'));
}

// Foto-rijke land-tegel. Kleur is data-gedreven (vaste merk-agnostische palet,
// deterministisch per land) — nieuw land = tegel erbij, geen nav-item erbij.
const PALETTE = ['#5A1A1F', '#A14F2A', '#5C6B3F', '#B86030', '#6B3A4A', '#7A6A2C'];

interface Tile {
  slug: string;
  name: string;
  continent: string;
  color: string;
  heroImage: string | null;
  regions: { slug: string; name: string }[];
}

const tiles: Tile[] = landen.map((land, i) => ({
  slug: land.slug,
  name: land.name,
  continent: land.continent || 'Overig',
  color: PALETTE[i % PALETTE.length] as string,
  heroImage: land.heroImage,
  regions: strekenByLand.get(land.slug) ?? [],
}));

// Groepeer per continent (reisjunk-patroon: continent-sectiekop + foto-tegels).
// Europa eerst — dat is de wijnkern — daarna de overige continenten alfabetisch.
const CONTINENT_ORDER = ['Europa'];
const continentGroups = [...new Set(tiles.map(t => t.continent))]
  .sort((a, b) => {
    const ia = CONTINENT_ORDER.indexOf(a);
    const ib = CONTINENT_ORDER.indexOf(b);
    if (ia !== -1 || ib !== -1) return (ia === -1 ? 99 : ia) - (ib === -1 ? 99 : ib);
    return a.localeCompare(b, 'nl');
  })
  .map(continent => ({
    continent,
    landen: tiles
      .filter(t => t.continent === continent)
      .sort((a, b) => a.name.localeCompare(b.name, 'nl')),
  }));

const totaalStreken = streken.length;

const schema = [
  organizationSchema(),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Ontdek', url: '/ontdek/' },
  ]),
];
---

<SiteLayout
  title="Ontdek de wijnatlas, landen & streken | VinoMartino"
  description="De wijnatlas van VinoMartino: blader van wijnland naar wijnstreek. Per land de streken die ertoe doen, elk met een eigen gids over terroir, druiven en reizen."
  schema={schema}
  activeNav="ontdek"
>
  <section class="hero-sm">
    <div class="container">
      <span class="section-label">Wijnatlas</span>
      <h1>Ontdek per land en streek</h1>
      <p class="hero-desc">Blader door de wijnlanden van Europa. Kies een land, duik in de streken eronder en lees de gids van de regio die je trekt. Hoe meer we toevoegen, hoe rijker de atlas, zonder dat het menu meegroeit.</p>
    </div>
  </section>

  {tiles.length > 0 && (
    <section class="section container map-hero">
      <DiscoverMapEurope
        countries={tiles.map(t => ({ slug: t.slug, name: t.name, color: t.color, regionCount: t.regions.length }))}
      />
    </section>
  )}

  {tiles.length > 0 ? (
    continentGroups.map(group => (
      <section class="section container continent-block">
        <header class="continent-head">
          <span class="continent-label">{group.continent}</span>
          <span class="continent-count">{group.landen.length} {group.landen.length === 1 ? 'land' : 'landen'}</span>
        </header>
        <div class="tile-grid">
          {group.landen.map(t => (
            <article class="tile" style={`--accent: ${t.color};`}>
              <a href={`/landen/${t.slug}/`} class="tile-img-link" aria-label={`Ontdek ${t.name}`}>
                <div class="tile-img-wrap">
                  <SmartImg src={t.heroImage || undefined} alt={t.name} theme="region" class="tile-img" />
                  <span class="tile-name">{t.name}</span>
                </div>
              </a>
              {t.regions.length > 0 ? (
                <ul class="region-list">
                  {t.regions.map(r => (
                    <li>
                      <a href={`/streken/${r.slug}/`} class="region-link">{r.name}</a>
                    </li>
                  ))}
                </ul>
              ) : (
                <p class="region-empty">
                  <a href={`/landen/${t.slug}/`}>Bekijk het land &rsaquo;</a>
                </p>
              )}
            </article>
          ))}
        </div>
      </section>
    ))
  ) : (
    <section class="section container">
      <div class="empty-state">
        <h2>De atlas vult zich</h2>
        <p>We werken aan de eerste wijnlandgidsen. Begin ondertussen bij de <a href="/artikelen/">artikelen</a>.</p>
      </div>
    </section>
  )}

  {tiles.length > 0 && (
    <section class="section container atlas-foot">
      <p>{tiles.length} {tiles.length === 1 ? 'wijnland' : 'wijnlanden'} &middot; {totaalStreken} {totaalStreken === 1 ? 'streek' : 'streken'} in de atlas. Elke streek is een eigen gids over terroir, druiven en reizen.</p>
    </section>
  )}
</SiteLayout>

<style>
  .hero-sm {
    background: var(--paperDeep);
    padding: var(--space-12) 0 var(--space-8);
    text-align: center;
  }
  .hero-sm h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.6rem + 1.5vw, 3rem);
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin-top: var(--space-3);
  }
  .hero-desc {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--inkSoft);
    margin-top: var(--space-3);
    max-width: 40rem;
    margin-inline: auto;
  }
  .map-hero {
    padding-bottom: var(--space-6);
  }
  .continent-block {
    padding-top: var(--space-6);
    padding-bottom: var(--space-6);
  }
  .continent-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-3);
    padding-bottom: var(--space-4);
    margin-bottom: var(--space-6);
    border-bottom: 1px solid var(--ruleSoft);
  }
  .continent-label {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 1.2rem + 1vw, 2rem);
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
  }
  .continent-count {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--inkFaint);
    white-space: nowrap;
  }
  .tile-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-6);
  }
  @media (max-width: 420px) {
    .tile-grid { grid-template-columns: 1fr; }
  }
  .tile {
    border: 1px solid var(--ruleSoft);
    border-top: 4px solid var(--accent);
    background: var(--paper);
    display: flex;
    flex-direction: column;
  }
  .tile-img-link {
    display: block;
    text-decoration: none;
  }
  .tile-img-wrap {
    position: relative;
    aspect-ratio: 16 / 11;
    overflow: hidden;
    background: var(--paperShade);
  }
  .tile-img-wrap :global(img),
  .tile-img-wrap :global(.smart-img-placeholder) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-image) var(--ease-out);
  }
  .tile-img-link:hover .tile-img-wrap :global(img),
  .tile-img-link:hover .tile-img-wrap :global(.smart-img-placeholder) {
    transform: scale(1.03);
  }
  .tile-img-wrap::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top,
      color-mix(in srgb, var(--accent) 78%, #1a1208) 0%,
      color-mix(in srgb, var(--accent) 30%, transparent) 42%,
      transparent 72%);
    pointer-events: none;
  }
  .tile-name {
    position: absolute;
    left: 1.125rem;
    right: 1.125rem;
    bottom: 0.875rem;
    z-index: 1;
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 500;
    line-height: 1.15;
    color: #FBF6EC;
    text-shadow: 0 1px 6px rgba(20, 12, 6, 0.45);
  }
  .region-list {
    list-style: none;
    margin: 0;
    padding: 0.75rem 1.25rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  .region-link {
    display: block;
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    color: var(--ink);
    text-decoration: none;
    padding: 0.4375rem 0;
    border-bottom: 1px solid var(--ruleSoft);
    transition: color var(--duration-fast) var(--ease-out),
                padding-left var(--duration-fast) var(--ease-out);
  }
  .region-list li:last-child .region-link { border-bottom: none; }
  .region-link:hover {
    color: var(--accent);
    padding-left: 0.375rem;
  }
  .region-empty {
    padding: 0.75rem 1.25rem 1.25rem;
    font-family: var(--font-ui);
    font-size: 0.9375rem;
  }
  .region-empty a {
    color: var(--accent);
    text-decoration: none;
  }
  .region-empty a:hover { text-decoration: underline; }
  .atlas-foot {
    text-align: center;
    padding-top: 0;
  }
  .atlas-foot p {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--inkFaint);
  }
  .empty-state {
    text-align: center;
    padding: var(--space-16) var(--space-4);
  }
  .empty-state h2 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin-bottom: var(--space-3);
  }
  .empty-state p { font-size: 1rem; color: var(--inkSoft); }
</style>
