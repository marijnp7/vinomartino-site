---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { loadArticles } from '../../lib/articles';

const articles = await loadArticles();
---

<SiteLayout
  title="Artikelen — Reisverhalen en gidsen"
  description="Lees onze reisverhalen, praktische gidsen en tips — geschreven door reizigers met verschillende perspectieven."
  activeNav="artikelen"
>
  <section class="hero-sm">
    <div class="container">
      <span class="section-label">Artikelen</span>
      <h1>Reisverhalen & gidsen</h1>
      <p class="hero-desc">Eerlijke verhalen, praktische tips en diepgaande gidsen — geschreven door ons redactieteam.</p>
    </div>
  </section>

  <section class="section container">
    {articles.length > 0 ? (
      <div class="article-grid">
        {articles.map(article => (
          <a href={`/artikelen/${article.slug}/`} class="article-card card">
            {article.heroImage && (
              <img src={article.heroImage} alt={article.title} loading="lazy" width="400" height="200" class="article-img" />
            )}
            <div class="article-body">
              {article.category && <span class="article-cat">{article.category}</span>}
              <h2 class="article-title">{article.title}</h2>
              <p class="article-desc">{article.description}</p>
              <span class="article-meta">
                {article.author} · {new Date(article.pubDate).toLocaleDateString('nl-NL', { day: 'numeric', month: 'long', year: 'numeric' })}
              </span>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <h2>Artikelen komen eraan</h2>
        <p>We werken aan reisverhalen en gidsen. Binnenkort beschikbaar!</p>
      </div>
    )}
  </section>
</SiteLayout>

<style>
  .hero-sm {
    background: var(--paperDeep);
    padding: var(--space-12) 0 var(--space-8);
    text-align: center;
  }
  .hero-sm h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.6rem + 1.5vw, 3rem);
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin-top: var(--space-3);
  }
  .hero-desc {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--inkSoft);
    margin-top: var(--space-3);
    max-width: 36rem;
    margin-inline: auto;
  }
  .article-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-6);
  }
  .article-card {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .article-img {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }
  .article-body {
    padding: 1.25rem;
  }
  .article-cat {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--rust);
  }
  .article-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--ink);
    margin: 0.375rem 0 0.5rem;
    line-height: 1.25;
  }
  .article-desc {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--inkSoft);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .article-meta {
    display: block;
    margin-top: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--inkFaint);
  }
  .empty-state {
    text-align: center;
    padding: var(--space-16) var(--space-4);
  }
  .empty-state h2 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin-bottom: var(--space-3);
  }
  .empty-state p {
    font-size: 1rem;
    color: var(--inkSoft);
  }
</style>
