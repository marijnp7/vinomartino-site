<script>
  // LAT-1118: highlight de actieve sectie in de desktop-TOC. Progressive
  // enhancement — zonder JS blijft het een werkende anchor-lijst.
  const links = Array.from(
    document.querySelectorAll<HTMLAnchorElement>('.toc-desktop a[data-toc-link]'),
  );
  if (links.length > 0 && 'IntersectionObserver' in window) {
    const byId = new Map(links.map((a) => [a.dataset.tocLink ?? '', a]));
    const headings = links
      .map((a) => document.getElementById(a.dataset.tocLink ?? ''))
      .filter((el): el is HTMLElement => el !== null);
    const visible = new Set<string>();
    const setActive = (id: string | null) => {
      for (const a of links) a.classList.remove('toc-active');
      if (id) byId.get(id)?.classList.add('toc-active');
    };
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) visible.add(entry.target.id);
          else visible.delete(entry.target.id);
        }
        const firstVisible = headings.find((h) => visible.has(h.id));
        if (firstVisible) setActive(firstVisible.id);
      },
      { rootMargin: '0px 0px -70% 0px', threshold: 0 },
    );
    for (const h of headings) observer.observe(h);
  }
</script>
