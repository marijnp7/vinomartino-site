---
import SiteLayout from '../../layouts/SiteLayout.astro';
import AffiliatePlaceholder from '../../components/AffiliatePlaceholder.astro';
import { loadArticles, type Article } from '../../lib/articles';
import { articleSchema, breadcrumbSchema } from '../../lib/seo';
import { getAffiliateBlock } from '../../lib/affiliates';

export async function getStaticPaths() {
  const articles = await loadArticles();
  return articles.map((a) => ({ params: { slug: a.slug }, props: { article: a } }));
}

const { article } = Astro.props as { article: Article };
const accommodation = getAffiliateBlock(article.slug, 'accommodation');
const activity = getAffiliateBlock(article.slug, 'activity');
const sidebar = getAffiliateBlock(article.slug, 'sidebar');

const pageUrl = new URL(`/artikelen/${article.slug}/`, Astro.site ?? 'https://vinomartino.com').href;

const modifiedTime = article.updatedAt || article.pubDate;

const schema = [
  articleSchema({
    title: article.title,
    description: article.description,
    author: article.author,
    datePublished: article.pubDate,
    dateModified: modifiedTime,
    image: article.heroImage,
    url: pageUrl,
  }),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Artikelen', url: '/artikelen/' },
    { name: article.title, url: pageUrl },
  ]),
];
---

<SiteLayout
  title={article.metaTitle || article.title}
  description={article.metaDescription || article.description}
  ogImage={article.heroImage || undefined}
  ogType="article"
  article={{
    publishedTime: article.pubDate,
    modifiedTime,
    author: article.author,
    section: article.category,
    tags: article.tags,
  }}
  schema={schema}
  activeNav="artikelen"
>
  <article class="article-page">
    {article.heroImage && (
      <div class="article-hero">
        <img src={article.heroImage} alt={article.title} class="article-hero-img" />
      </div>
    )}

    <div class="container article-layout">
      <div class="article-main">
        <header class="article-header">
          <nav class="breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a> / <a href="/artikelen/">Artikelen</a> / <span>{article.title}</span>
          </nav>
          {article.category && <span class="article-cat">{article.category}</span>}
          <h1>{article.title}</h1>
          <div class="article-meta">
            <span class="article-author">{article.author}</span>
            <span class="article-date">{new Date(article.pubDate).toLocaleDateString('nl-NL', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
          </div>
          {article.tags && article.tags.length > 0 && (
            <div class="article-tags">
              {article.tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
          )}
        </header>

        <div class="article-prose" set:html={article.bodyHtml} />

        {accommodation && (
          <AffiliatePlaceholder
            type="accommodation"
            context={article.slug}
            partner={accommodation.linkBron === 'Booking.com' ? 'booking.com' : accommodation.linkBron === 'GetYourGuide' ? 'getyourguide' : undefined}
            placement="inline-mid"
            href={accommodation.href}
            producent={accommodation.producent}
            bezoekMaand={accommodation.bezoekMaand}
            bezoekJaar={accommodation.bezoekJaar}
            linkBron={accommodation.linkBron}
            ctaLabel={accommodation.ctaLabel}
            description={accommodation.description}
          />
        )}
        {activity && (
          <AffiliatePlaceholder
            type="activity"
            context={article.slug}
            partner={activity.linkBron === 'Booking.com' ? 'booking.com' : activity.linkBron === 'GetYourGuide' ? 'getyourguide' : undefined}
            placement="inline-end"
            href={activity.href}
            producent={activity.producent}
            bezoekMaand={activity.bezoekMaand}
            bezoekJaar={activity.bezoekJaar}
            linkBron={activity.linkBron}
            ctaLabel={activity.ctaLabel}
            description={activity.description}
          />
        )}
      </div>

      <aside class="article-sidebar">
        {sidebar && (
          <AffiliatePlaceholder
            type="sidebar"
            context={article.slug}
            partner={sidebar.linkBron === 'Booking.com' ? 'booking.com' : sidebar.linkBron === 'GetYourGuide' ? 'getyourguide' : undefined}
            placement="sidebar"
            href={sidebar.href}
            producent={sidebar.producent}
            bezoekMaand={sidebar.bezoekMaand}
            bezoekJaar={sidebar.bezoekJaar}
            linkBron={sidebar.linkBron}
            ctaLabel={sidebar.ctaLabel}
            description={sidebar.description}
          />
        )}
      </aside>
    </div>
  </article>
</SiteLayout>

<style>
  .article-hero {
    height: 45vh;
    min-height: 300px;
    overflow: hidden;
  }
  .article-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .article-layout {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: var(--space-10);
    padding-top: var(--space-10);
    padding-bottom: var(--space-12);
  }
  .breadcrumb {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--inkFaint);
    margin-bottom: var(--space-4);
  }
  .breadcrumb a {
    color: var(--inkSoft);
    text-decoration: none;
  }
  .breadcrumb a:hover { text-decoration: underline; }
  .article-cat {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--rust);
    display: block;
    margin-bottom: var(--space-2);
  }
  .article-header h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.6rem + 1.5vw, 3rem);
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    line-height: 1.15;
    margin-bottom: var(--space-4);
  }
  .article-meta {
    display: flex;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--inkSoft);
    margin-bottom: var(--space-3);
  }
  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-bottom: var(--space-8);
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: var(--paperDeep);
    color: var(--inkSoft);
    padding: 0.25rem 0.625rem;
    border-radius: 1px;
  }

  .article-prose {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--ink);
    max-width: var(--article-body-max);
  }
  .article-prose :global(h2) {
    font-family: var(--font-display);
    font-size: 1.625rem;
    font-weight: 500;
    margin: var(--space-10) 0 var(--space-4);
  }
  .article-prose :global(h3) {
    font-family: var(--font-ui);
    font-size: 1.125rem;
    font-weight: 600;
    margin: var(--space-8) 0 var(--space-3);
  }
  .article-prose :global(p) {
    margin-bottom: var(--space-5);
  }
  .article-prose :global(ul), .article-prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: var(--space-5);
  }
  .article-prose :global(li) {
    margin-bottom: 0.375rem;
  }
  .article-prose :global(blockquote) {
    border-left: 3px solid var(--burgundy);
    padding-left: 1.5rem;
    margin: var(--space-6) 0;
    font-style: italic;
    color: var(--inkSoft);
  }
  .article-prose :global(img) {
    border-radius: var(--radius-sm);
    margin: var(--space-6) 0;
  }

  @media (max-width: 900px) {
    .article-layout { grid-template-columns: 1fr; }
  }
</style>
