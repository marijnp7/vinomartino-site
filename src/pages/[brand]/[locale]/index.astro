---
import BrandHomeContent from '../../../components/pages/BrandHomeContent.astro';
import { getLiveBrands, isSingleBrandMode, type Brand } from '../../../lib/brands';

export function getStaticPaths() {
  if (isSingleBrandMode()) return [];
  const brands = getLiveBrands();
  return brands.flatMap((brand) =>
    brand.locales.map((locale) => ({
      params: { brand: brand.slug, locale },
      props: { brand },
    }))
  );
}

const { brand } = Astro.props;
const { locale } = Astro.params;
---

<BrandHomeContent brand={brand} locale={locale!} />
