---
import { getLiveBrands, isSingleBrandMode, type Brand } from '../../../../lib/brands';
import { loadArticles, type Article } from '../../../../lib/articles';
import BrandLayout from '../../../../layouts/BrandLayout.astro';

export async function getStaticPaths() {
  if (isSingleBrandMode()) return [];
  const brands = getLiveBrands();
  const articles = await loadArticles();

  return brands.flatMap((brand) =>
    brand.locales.flatMap((locale) =>
      articles.map((article) => ({
        params: { brand: brand.slug, locale, slug: article.slug },
        props: { article, brand },
      })),
    ),
  );
}

interface Props {
  article: Article;
  brand: Brand;
}

const { article, brand } = Astro.props;
const { locale } = Astro.params;

const CATEGORY_LABELS: Record<string, string> = {
  'culture-history': 'Cultuur & Geschiedenis',
  'wine-regions': "Wijnregio's",
  'travel-tips': 'Reistips',
  'food-pairing': 'Spijs & Wijn',
  'tasting-notes': 'Proefnotities',
  'winery-portraits': 'Wijnhuizen',
  'sustainable-travel': 'Duurzaam Reizen',
  'digital-nomads': 'Digital Nomads',
};

const categoryLabel = CATEGORY_LABELS[article.category] || article.category;

const pubDateFormatted = new Date(article.pubDate).toLocaleDateString('nl-NL', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.title,
  description: article.metaDescription || article.description || '',
  author: { '@type': 'Person', name: article.author },
  datePublished: new Date(article.pubDate).toISOString(),
  publisher: {
    '@type': 'Organization',
    name: brand.name,
    url: `https://vinomartino.com`,
  },
  ...(article.heroImage ? { image: article.heroImage } : {}),
};
---

<BrandLayout
  brand={brand}
  locale={locale!}
  title={article.metaTitle}
  description={article.metaDescription}
  ogImage={article.heroImage || undefined}
  schema={articleSchema}
>
  <article class="article-page">
    <header class="article-header container">
      <nav class="article-breadcrumb">
        <a href={`/${brand.slug}/${locale}/`}>Home</a>
        <span class="sep">›</span>
        <a href={`/${brand.slug}/${locale}/artikelen/`}>Artikelen</a>
        <span class="sep">›</span>
        <span>{article.title}</span>
      </nav>
      <div class="article-meta">
        {categoryLabel && <span class="article-category">{categoryLabel}</span>}
        {categoryLabel && <span class="article-sep">&middot;</span>}
        <time datetime={article.pubDate}>{pubDateFormatted}</time>
      </div>
      <h1 class="article-title">{article.title}</h1>
      {article.description && (
        <p class="article-description">{article.description}</p>
      )}
      <div class="article-byline">Door <strong>{article.author}</strong></div>
    </header>

    {article.heroImage && (
      <div class="article-hero">
        <img src={article.heroImage} alt={article.title} loading="eager" />
      </div>
    )}

    <div class="article-body container prose" set:html={article.bodyHtml} />
  </article>
</BrandLayout>

<style>
  .article-page { padding-bottom: var(--space-24); }

  .article-header {
    max-width: 48rem;
    margin: 0 auto;
    padding-top: var(--space-8);
    padding-bottom: var(--space-8);
  }

  .article-breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--inkSoft);
    margin-bottom: var(--space-6);
    padding-top: var(--space-6);
    flex-wrap: wrap;
  }

  .article-breadcrumb a { color: var(--rust); text-decoration: none; }
  .article-breadcrumb a:hover { text-decoration: underline; }
  .sep { opacity: 0.5; }

  .article-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--inkFaint);
    margin-bottom: var(--space-4);
  }

  .article-category { color: var(--rust); }
  .article-sep { opacity: 0.4; }

  .article-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.5rem + 2vw, 3.25rem);
    font-style: italic;
    font-weight: 400;
    line-height: 1.15;
    color: var(--ink);
    margin-bottom: var(--space-6);
    letter-spacing: -0.02em;
  }

  .article-description {
    font-family: var(--font-body);
    font-size: 1.25rem;
    font-style: italic;
    line-height: 1.6;
    color: var(--inkSoft);
    margin-bottom: var(--space-6);
    max-width: 40rem;
  }

  .article-byline {
    font-family: var(--font-ui);
    font-size: 0.875rem;
    color: var(--inkFaint);
    padding-top: var(--space-4);
    border-top: 1px solid var(--rule);
  }

  .article-hero {
    max-width: 56rem;
    margin: 0 auto var(--space-12);
    padding: 0 var(--space-6);
  }

  .article-hero img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: var(--radius-sm);
  }

  .article-body { max-width: 48rem; margin: 0 auto; }

  .prose :global(h1) { display: none; }
  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 1.2rem + 1vw, 2rem);
    font-style: italic;
    font-weight: 400;
    margin-top: var(--space-12);
    margin-bottom: var(--space-4);
    color: var(--ink);
    line-height: 1.3;
  }
  .prose :global(h3) {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
    color: var(--ink);
  }
  .prose :global(p) {
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--inkSoft);
    margin-bottom: var(--space-5);
  }
  .prose :global(blockquote) {
    border-left: 3px solid var(--burgundy);
    padding-left: var(--space-6);
    margin: var(--space-8) 0;
    font-style: italic;
    color: var(--inkSoft);
  }
  .prose :global(ul), .prose :global(ol) {
    margin: var(--space-5) 0;
    padding-left: var(--space-6);
    color: var(--inkSoft);
    line-height: 1.8;
  }
  .prose :global(li) { margin-bottom: var(--space-2); }
  .prose :global(strong) { color: var(--ink); font-weight: 600; }
  .prose :global(a) { color: var(--rust); }
  .prose :global(a:hover) { text-decoration: underline; }
  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--rule);
    margin: var(--space-12) 0;
  }
</style>
