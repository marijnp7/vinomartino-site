---
import BrandLayout from '../../../layouts/BrandLayout.astro';
import { getLiveBrands, isSingleBrandMode, type Brand } from '../../../lib/brands';

export function getStaticPaths() {
  if (isSingleBrandMode()) return [];
  const brands = getLiveBrands();

  const sectionPaths = [
    'verhalen',
    'over-ons',
    'routes/langhe-4-dagen',
    'routes/bourgogne-trein',
    'routes/etna-noord',
    'routes/mosel-fietsvakantie',
    'themas/weekends',
    'themas/per-trein',
    'themas/druiven',
    'themas/wijnhuizen',
    'themas/natuur',
    'themas/bubbels',
    'themas/spijs-wijn',
    'themas/opkomend',
  ];

  return brands.flatMap((brand) =>
    brand.locales.flatMap((locale) =>
      sectionPaths.map((p) => ({
        params: { brand: brand.slug, locale, path: p },
        props: { brand, section: p.split('/')[0], slug: p.split('/')[1] || null },
      }))
    )
  );
}

interface Props {
  brand: Brand;
  section: string;
  slug: string | null;
}

const { brand, section, slug } = Astro.props;
const { locale } = Astro.params;

const SECTION_TITLES: Record<string, string> = {
  verhalen: 'Alle verhalen',
  streken: 'Wijnstreken',
  routes: 'Reisroutes',
  themas: "Thema's",
  'over-ons': 'Over Martin & Sophie',
};

const title = slug
  ? `${slug.charAt(0).toUpperCase()}${slug.slice(1)} — ${SECTION_TITLES[section] || section}`
  : SECTION_TITLES[section] || section;
---

<BrandLayout brand={brand} locale={locale!} title={`${title} — ${brand.name}`} description={title}>
  <section class="placeholder-page">
    <div class="container">
      <nav class="breadcrumb">
        <a href={`/${brand.slug}/${locale}/`}>Home</a> ›
        {slug ? (
          <>
            <a href={`/${brand.slug}/${locale}/${section}/`}>{SECTION_TITLES[section]}</a> ›
            <span>{slug}</span>
          </>
        ) : (
          <span>{SECTION_TITLES[section]}</span>
        )}
      </nav>
      <h1>{title}</h1>
      <p class="coming-soon">Deze pagina wordt binnenkort gepubliceerd.</p>
      <a href={`/${brand.slug}/${locale}/`} class="btn btn-secondary">← Terug naar home</a>
    </div>
  </section>
</BrandLayout>

<style>
  .placeholder-page {
    padding: var(--space-20) 0 var(--space-32);
    min-height: 60vh;
    display: flex;
    align-items: center;
  }

  .breadcrumb {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--inkSoft);
    margin-bottom: var(--space-8);
  }

  .breadcrumb a {
    color: var(--rust);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    text-decoration: underline;
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 2rem + 2vw, 4rem);
    font-style: italic;
    font-weight: 400;
    color: var(--ink);
    margin-bottom: var(--space-6);
    letter-spacing: -0.02em;
  }

  .coming-soon {
    font-family: var(--font-body);
    font-size: 1.125rem;
    color: var(--inkSoft);
    margin-bottom: var(--space-8);
    line-height: 1.7;
  }
</style>
