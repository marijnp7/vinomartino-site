---
import BrandLayout from '../../../layouts/BrandLayout.astro';
import { getLiveBrands, isSingleBrandMode, type Brand } from '../../../lib/brands';
import { loadArticles, type Article } from '../../../lib/articles';

export async function getStaticPaths() {
  if (isSingleBrandMode()) return [];
  const brands = getLiveBrands();
  const articles = await loadArticles();

  const sectionPaths = [
    'artikelen',
    'verhalen',
    'over-ons',
    'streken/piemonte',
    'streken/bourgogne',
    'streken/priorat',
    'streken/mosel',
    'streken/wachau',
    'streken/etna',
    'streken/toscane',
    'streken/champagne',
    'streken/douro',
    'streken/georgië',
    'streken/slovenië',
    'streken/engeland',
    'routes/langhe-4-dagen',
    'routes/bourgogne-trein',
    'routes/etna-noord',
    'routes/mosel-fietsvakantie',
    'themas/weekends',
    'themas/per-trein',
    'themas/druiven',
    'themas/wijnhuizen',
    'themas/natuur',
    'themas/bubbels',
    'themas/spijs-wijn',
    'themas/opkomend',
  ];

  return brands.flatMap((brand) =>
    brand.locales.flatMap((locale) =>
      sectionPaths.map((p) => ({
        params: { brand: brand.slug, locale, path: p },
        props: { brand, section: p.split('/')[0], slug: p.split('/')[1] || null, articles },
      }))
    )
  );
}

interface Props {
  brand: Brand;
  section: string;
  slug: string | null;
  articles: Article[];
}

const { brand, section, slug, articles } = Astro.props;
const { locale } = Astro.params;

const SECTION_TITLES: Record<string, string> = {
  artikelen: 'Alle artikelen',
  verhalen: 'Alle verhalen',
  streken: 'Wijnstreken',
  routes: 'Reisroutes',
  themas: "Thema's",
  'over-ons': 'Over Martin & Sophie',
};

const title = slug
  ? `${slug.charAt(0).toUpperCase()}${slug.slice(1)} — ${SECTION_TITLES[section] || section}`
  : SECTION_TITLES[section] || section;
---

<BrandLayout brand={brand} locale={locale!} title={`${title} — ${brand.name}`} description={title}>
  <section class="placeholder-page">
    <div class="container">
      <nav class="breadcrumb">
        <a href={`/${brand.slug}/${locale}/`}>Home</a> ›
        {slug ? (
          <>
            <a href={`/${brand.slug}/${locale}/${section}/`}>{SECTION_TITLES[section]}</a> ›
            <span>{slug}</span>
          </>
        ) : (
          <span>{SECTION_TITLES[section]}</span>
        )}
      </nav>
      <h1>{title}</h1>

      {section === 'artikelen' && articles.length > 0 ? (
        <ul class="article-list">
          {articles.map(a => (
            <li>
              <a href={`/${brand.slug}/${locale}/artikelen/${a.slug}/`} class="article-list-link">
                <span class="article-list-title">{a.title}</span>
                <time class="article-list-date">{new Date(a.pubDate).toLocaleDateString('nl-NL', { day: 'numeric', month: 'long', year: 'numeric' })}</time>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="coming-soon">Deze pagina wordt binnenkort gepubliceerd.</p>
      )}

      <a href={`/${brand.slug}/${locale}/`} class="btn btn-secondary">← Terug naar home</a>
    </div>
  </section>
</BrandLayout>

<style>
  .placeholder-page {
    padding: var(--space-20) 0 var(--space-32);
    min-height: 60vh;
    display: flex;
    align-items: center;
  }

  .breadcrumb {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--inkSoft);
    margin-bottom: var(--space-8);
  }

  .breadcrumb a {
    color: var(--rust);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    text-decoration: underline;
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 2rem + 2vw, 4rem);
    font-style: italic;
    font-weight: 400;
    color: var(--ink);
    margin-bottom: var(--space-6);
    letter-spacing: -0.02em;
  }

  .coming-soon {
    font-family: var(--font-body);
    font-size: 1.125rem;
    color: var(--inkSoft);
    margin-bottom: var(--space-8);
    line-height: 1.7;
  }

  .article-list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-8);
    border-top: 1px solid var(--rule);
  }

  .article-list li {
    border-bottom: 1px solid var(--ruleSoft);
  }

  .article-list-link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
    padding: var(--space-4) 0;
    text-decoration: none;
    color: var(--ink);
    transition: color var(--duration-fast);
  }

  .article-list-link:hover { color: var(--burgundy); }

  .article-list-title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-style: italic;
    flex: 1;
  }

  .article-list-date {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--inkFaint);
    white-space: nowrap;
  }
</style>
