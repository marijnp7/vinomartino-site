---
// LAT-2638 — NL wijnhuis-detailroute (prefixloos). Dunne wrapper rond het
// gedeelde WijnhuisDetail-component; de EN-tegenhanger leeft onder
// /en/wijnhuizen/. hreflang-alternates worden alleen gezet wanneer er een
// EN-vertaling bestaat (launch-gate: geen en-hreflang zonder tegenhanger).
import WijnhuisDetail from '../../components/WijnhuisDetail.astro';
import { loadWijnhuizen, type Wijnhuis } from '../../lib/wijnhuizen';
import { loadStreken } from '../../lib/streken';
import { loadRoutes } from '../../lib/routes';
import { DEFAULT_LOCALE } from '../../lib/i18n';

export async function getStaticPaths() {
  const [entries, streken, routes, enEntries] = await Promise.all([loadWijnhuizen(), loadStreken(), loadRoutes(), loadWijnhuizen('en')]);
  const enSlugs = new Set(enEntries.map(e => e.slug));
  const streekBySlug = new Map(streken.map(s => [s.slug, s]));
  // LAT-2010 [VIS-BL-11]: koppel elk wijnhuis aan een wijnroute. Voorkeur: de route
  // die dit huis expliciet als stop noemt (stops_geo kind=wijnhuis + slug, na
  // datafix LAT-1994). Anders val terug op de eerste route van de streek, zodat
  // interne doorstroom ook vóór de datafix werkt. Geen route → meta-regel weg.
  const routesByStreek = new Map<string, typeof routes>();
  for (const r of routes) {
    if (!r.streekSlug) continue;
    const list = routesByStreek.get(r.streekSlug) ?? [];
    list.push(r);
    routesByStreek.set(r.streekSlug, list);
  }
  const routeByWijnhuisSlug = new Map<string, typeof routes[number]>();
  for (const r of routes) {
    for (const stop of r.stopsGeo) {
      if (stop.kind === 'wijnhuis' && stop.slug && !routeByWijnhuisSlug.has(stop.slug)) {
        routeByWijnhuisSlug.set(stop.slug, r);
      }
    }
  }
  return entries.map(entry => {
    // LAT-1199: leid de parent-Land af via de streek→land relatie voor de
    // verticale kruimel (wijnhuis kent zelf geen land).
    const streek = entry.streekSlug ? streekBySlug.get(entry.streekSlug) : undefined;
    const route = routeByWijnhuisSlug.get(entry.slug)
      ?? (entry.streekSlug ? routesByStreek.get(entry.streekSlug)?.[0] : undefined);
    return {
      params: { slug: entry.slug },
      props: {
        entry,
        landSlug: streek?.landSlug ?? '',
        landName: streek?.country ?? '',
        routeHref: route ? `/wijnroutes/${route.slug}/` : '',
        routeLabel: route?.title ?? '',
        alternates: enSlugs.has(entry.slug)
          ? { nl: `/wijnhuizen/${entry.slug}/`, en: `/en/wijnhuizen/${entry.slug}/` }
          : undefined,
      },
    };
  });
}

const { entry, landSlug, landName, routeHref, routeLabel, alternates } = Astro.props as { entry: Wijnhuis; landSlug: string; landName: string; routeHref: string; routeLabel: string; alternates?: Record<string, string> };
---

<WijnhuisDetail entry={entry} landSlug={landSlug} landName={landName} routeHref={routeHref} routeLabel={routeLabel} locale={DEFAULT_LOCALE} alternates={alternates} />
