---
import SiteLayout from '../../layouts/SiteLayout.astro';
import SmartImg from '../../components/SmartImg.astro';
import { loadWijnhuizen } from '../../lib/wijnhuizen';
import { organizationSchema, breadcrumbSchema } from '../../lib/seo';

const entries = await loadWijnhuizen();

const schema = [
  organizationSchema(),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Wijnhuizen', url: '/wijnhuizen/' },
  ]),
];
---

<SiteLayout
  title="Wijnhuizen — Producenten & wijnmakerijen | VinoMartino"
  description="Ontdek de wijnhuizen achter de fles — van eigenzinnige Barolo-producenten tot vulkanische pioniers op de Etna. Persoonlijke portretten van wijnmakers die er echt toe doen."
  schema={schema}
  activeNav="wijnhuizen"
>
  <section class="hero-sm">
    <div class="container">
      <span class="section-label">Wijnhuizen</span>
      <h1>Producenten & wijnmakerijen</h1>
      <p class="hero-desc">Niet de fles, maar de mensen erachter. Wijnmakers die ik heb bezocht, met wie ik heb gesproken — van oude Piëmontese families tot radicale nieuwe-golf producenten op de Etna.</p>
    </div>
  </section>

  <section class="section container">
    {entries.length > 0 ? (
      <div class="grid">
        {entries.map(entry => (
          <a href={`/wijnhuizen/${entry.slug}/`} class="card card-link">
            <div class="card-img-wrap">
              <SmartImg src={entry.heroImage || undefined} alt={entry.name} theme="winery" class="card-img" />
            </div>
            <div class="card-body">
              <span class="card-region">{[entry.region, entry.country].filter(Boolean).join(' — ')}</span>
              <h2 class="card-title">{entry.name}</h2>
              {entry.description && <p class="card-desc">{entry.description}</p>}
              {entry.grapes && entry.grapes.length > 0 && (
                <div class="card-tags">
                  {entry.grapes.slice(0, 3).map(g => <span class="tag">{g}</span>)}
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <h2>De portretten zijn onderweg</h2>
        <p>Elk wijnhuis krijgt één verhaal — geen scorekaart. De eerste portretten verschijnen zodra ik de bezoeken achter me heb. Begin ondertussen bij de <a href="/artikelen/">reisartikelen</a>.</p>
      </div>
    )}
  </section>
</SiteLayout>

<style>
  .hero-sm {
    background: var(--paperDeep);
    padding: var(--space-12) 0 var(--space-8);
    text-align: center;
  }
  .hero-sm h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.6rem + 1.5vw, 3rem);
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin-top: var(--space-3);
  }
  .hero-desc {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--inkSoft);
    margin-top: var(--space-3);
    max-width: 36rem;
    margin-inline: auto;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-6);
  }
  .card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .card-img-wrap {
    aspect-ratio: 16 / 11;
    overflow: hidden;
    background: var(--paperShade);
  }
  .card-img-wrap :global(img),
  .card-img-wrap :global(.smart-img-placeholder) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-image) var(--ease-out);
  }
  .card-link:hover .card-img-wrap :global(img) { transform: scale(1.03); }
  .card-body {
    padding: 1.25rem;
  }
  .card-region {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--rust);
    display: block;
    margin-bottom: var(--space-2);
  }
  .card-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: var(--space-2);
    line-height: 1.25;
  }
  .card-desc {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--inkSoft);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: var(--space-3);
  }
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: var(--paperDeep);
    color: var(--inkSoft);
    padding: 0.25rem 0.625rem;
    border-radius: 1px;
  }
  .empty-state {
    text-align: center;
    padding: var(--space-16) var(--space-4);
  }
  .empty-state h2 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin-bottom: var(--space-3);
  }
  .empty-state p {
    font-size: 1rem;
    color: var(--inkSoft);
  }
</style>
