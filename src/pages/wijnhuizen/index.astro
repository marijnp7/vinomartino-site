---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getCollection } from 'astro:content';
import { organizationSchema, breadcrumbSchema } from '../../lib/seo';

const entries = await getCollection('wijnhuizen');
entries.sort((a, b) => (a.data.title > b.data.title ? 1 : -1));

const schema = [
  organizationSchema(),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Wijnhuizen', url: '/wijnhuizen/' },
  ]),
];
---

<SiteLayout
  title="Wijnhuizen — Producenten & wijnmakerijen | VinoMartino"
  description="Ontdek de wijnhuizen achter de fles — van eigenzinnige Barolo-producenten tot vulkanische pioniers op de Etna. Persoonlijke portretten van wijnmakers die er echt toe doen."
  schema={schema}
  activeNav="wijnhuizen"
>
  <section class="hero-sm">
    <div class="container">
      <span class="section-label">Wijnhuizen</span>
      <h1>Producenten & wijnmakerijen</h1>
      <p class="hero-desc">De mensen en plekken achter de fles — van oude Piëmontese families tot radicale nieuwe-golf producenten.</p>
    </div>
  </section>

  <section class="section container">
    {entries.length > 0 ? (
      <div class="grid">
        {entries.map(entry => {
          const slug = entry.data.slug || entry.id.replace(/\.md$/, '');
          return (
            <a href={`/wijnhuizen/${slug}/`} class="card card-link">
              {entry.data.heroImage && (
                <img src={entry.data.heroImage} alt={entry.data.name || entry.data.title} loading="lazy" width="400" height="220" class="card-img" />
              )}
              <div class="card-body">
                <span class="card-region">{[entry.data.region, entry.data.country].filter(Boolean).join(' — ')}</span>
                <h2 class="card-title">{entry.data.name || entry.data.title}</h2>
                {entry.data.description && <p class="card-desc">{entry.data.description}</p>}
                {entry.data.grapes && entry.data.grapes.length > 0 && (
                  <div class="card-tags">
                    {entry.data.grapes.slice(0, 3).map(g => <span class="tag">{g}</span>)}
                  </div>
                )}
              </div>
            </a>
          );
        })}
      </div>
    ) : (
      <div class="empty-state">
        <h2>Wijnhuis-portretten komen eraan</h2>
        <p>We werken aan diepgaande portretten van bijzondere producenten. Binnenkort beschikbaar.</p>
      </div>
    )}
  </section>
</SiteLayout>

<style>
  .hero-sm {
    background: var(--paperDeep);
    padding: var(--space-12) 0 var(--space-8);
    text-align: center;
  }
  .hero-sm h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.6rem + 1.5vw, 3rem);
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin-top: var(--space-3);
  }
  .hero-desc {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--inkSoft);
    margin-top: var(--space-3);
    max-width: 36rem;
    margin-inline: auto;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-6);
  }
  .card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .card-img {
    width: 100%;
    height: 220px;
    object-fit: cover;
  }
  .card-body {
    padding: 1.25rem;
  }
  .card-region {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--rust);
    display: block;
    margin-bottom: var(--space-2);
  }
  .card-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: var(--space-2);
    line-height: 1.25;
  }
  .card-desc {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--inkSoft);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: var(--space-3);
  }
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: var(--paperDeep);
    color: var(--inkSoft);
    padding: 0.25rem 0.625rem;
    border-radius: 1px;
  }
  .empty-state {
    text-align: center;
    padding: var(--space-16) var(--space-4);
  }
  .empty-state h2 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin-bottom: var(--space-3);
  }
  .empty-state p {
    font-size: 1rem;
    color: var(--inkSoft);
  }
</style>
