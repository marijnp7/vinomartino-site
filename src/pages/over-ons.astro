---
import SiteLayout from '../layouts/SiteLayout.astro';
import { organizationSchema, breadcrumbSchema } from '../lib/seo';
import { readDirectusEnv, directusSignal } from '../lib/directus-config';

const schema = [
  organizationSchema(),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Over ons', url: '/over-ons/' },
  ]),
];

const rules = [
  {
    n: '01',
    h: 'Waar we zelf waren, zie je dat',
    d: 'Gidsen gebaseerd op eigen bezoek dragen het label Zelf gereisd. In die stukken schrijf ik in eerste persoon over wat ik proefde en zag. Redactiegidsen zijn zorgvuldig samengesteld op basis van primaire bronnen en lokale kennis, maar bevatten geen ooggetuigeclaims. Het onderscheid staat bij elk artikel vermeld.',
  },
  {
    n: '02',
    h: 'Affiliate alleen voor wat ik zelf heb getest',
    d: 'Als een artikel een boekingslink bevat, heb ik die plek bezocht. We ontvangen commissie bij een boeking, de prijs blijft gelijk. Welke wijnhuizen en accommodaties in aanmerking komen voor een link, bepaal ik op basis van bezoekdocumentatie, niet op basis van wie er om vraagt.',
  },
  {
    n: '03',
    h: 'Geen advertorials, geen betaalde stukken',
    d: 'Aanbevelingen zijn onafhankelijk van externe financiering. Affiliate-inkomsten financieren nieuwe bezoeken en het voortbestaan van VinoMartino. Ze bepalen niet wat ik schrijf.',
  },
];

const visited = [
  'Loire',
  'Bourgogne',
  'Champagne',
  'Provence',
  'Mosel',
  'Piemonte',
  'Toscane',
  'Kaapregio',
  'Veneto',
  'Alto Adige',
  'Slowakije',
];

// LAT-1987: twee eigen foto's van Marijn uit de DAM, gekoppeld via Directus-bestanden.
// 694f2a29… = DAM ref 1240 (Calmont, Ediger); dfaff3d0… = DAM ref 816 (uitkijkpunt over het dal).
// At-buildtijd uit Directus /assets/{uuid} gehaald — geen beeldbytes in de repo (HARDE REGEL 2).
async function fetchOverOnsFoto(uuid: string): Promise<string | null> {
  const env = readDirectusEnv();
  if (!env.configured) return null; // lokaal/dev zonder Directus: beeld overslaan
  const { writeFileSync, mkdirSync, existsSync } = await import('node:fs');
  const { join } = await import('node:path');
  const outDir = join(process.cwd(), 'public', 'images', 'over-ons');
  const outPath = join(outDir, `${uuid}.jpg`);
  const rel = `/images/over-ons/${uuid}.jpg`;
  if (existsSync(outPath)) return rel;
  const res = await fetch(`${env.url}/assets/${uuid}`, {
    headers: { Authorization: `Bearer ${env.token}` },
    signal: directusSignal(),
  });
  if (!res.ok) {
    throw new Error(`[over-ons] Directus-asset ${uuid} niet op te halen: HTTP ${res.status}`);
  }
  mkdirSync(outDir, { recursive: true });
  writeFileSync(outPath, Buffer.from(await res.arrayBuffer()));
  return rel;
}

const fotoCalmont = await fetchOverOnsFoto('694f2a29-122b-479c-a2b0-1cd895a493de');
const fotoUitkijk = await fetchOverOnsFoto('dfaff3d0-675b-48db-acc8-893263eaf06d');
---

<SiteLayout
  title="Over VinoMartino: Marijn & Sophie"
  description="Marijn (internationaal Martino) schrijft over wijnreizen vanuit eigen bezoek. Affiliate alleen voor plekken die we zelf hebben getest. Geen advertorials."
  schema={schema}
  activeNav="over-ons"
  alternates={{ nl: '/over-ons/', en: '/en/over-ons/' }}
>
  <section class="hero">
    <div class="hero-grid container">
      <div class="hero-text">
        <span class="kicker kicker-vine">Over VinoMartino</span>
        <h1>Hi, ik ben <em>Marijn</em></h1>
        <p class="lede">
          Bij wijnboeren van Piemonte tot de Kaap werd ik al snel "Martino" genoemd, en die naam bleef hangen. Hij werd zelfs de naam van deze site: VinoMartino. Dus internationaal ben ik Martino, thuis gewoon Marijn.
        </p>
        <p class="lede">
          Ik heb een wijnkoelkast die altijd gevuld is en eigenlijk veel te weinig plek heeft.
          Meerdere keren per jaar rij ik een smalle Fiat door Piemontese wijngaardpaden, of Siciliaanse, of Portugese, afhankelijk van het seizoen.
          Ik probeer steeds nieuwe wijngebieden te ontdekken en schrijf op wat ik daar vond.
        </p>
        <p class="lede">
          We zijn geen pure wijnkenners of professionals. We zijn wijnfanaten met een enorme passie die we graag delen, zodat ook jij dezelfde reizen en gebieden kunt ontdekken.
        </p>
      </div>
      <div class="hero-image">
        <img src="/over-ons-hero.jpg" alt="Marijn proeft een glas wijn met de wijngaarden van Stellenbosch op de achtergrond" width="800" height="1000" loading="eager" decoding="async" />
      </div>
    </div>
  </section>

  <section class="intro">
    <div class="container container-narrow">
      <p>
        VinoMartino begon als een notitieboekje. Na elke reis verzamelde ik aantekeningen: de wijnmaker die ons op woensdagmiddag zijn kelderrand
        liet proeven, het agriturismo met drie streepjes mobiel bereik waar ik toch uitstekend sliep, de Carricante die ik pas thuis begreep.
        Op een gegeven moment was het notitieboekje zo vol dat het nuttig begon te worden voor anderen die dezelfde reizen plannen. Dat is dit.
      </p>
      <p>
        Sophie reist soms mee en leest dit alles pas als het online staat.
      </p>
      <p>
        Sommige stukken gaan wat dieper dan andere, dat hangt af van de reis en wat me opviel. Ik deel vooral ervaringen en probeer mensen genoeg informatie te geven om zelf mooie reizen te plannen. Heb je zelf iets te delen dat anderen daarbij helpt? Dan bied ik de mogelijkheid om een bijdrage op de site te plaatsen.
      </p>
      <p>
        En al draait het hier om wijn: de meeste van deze streken zijn ook zonder een enkel wijnhuis al prachtig om te bezoeken. De wijn is de aanleiding, niet de enige reden.
      </p>
      <p>
        Op den duur willen we het breder trekken: restaurants en andere plekken die een reis compleet maken, krijgen straks ook een plek op de site.
      </p>
      {fotoCalmont && (
        <figure class="over-figure">
          <img
            src={fotoCalmont}
            alt="Marijn bij het Calmont-bord boven de Moezel, met groene heuvels en het rivierdal op de achtergrond"
            width="1500"
            height="2000"
            loading="lazy"
            decoding="async"
          />
          <figcaption>Op de Calmont in Ediger, de steilste wijngaard van Duitsland.</figcaption>
        </figure>
      )}
    </div>
  </section>

  <section class="rules">
    <div class="container container-narrow">
      <span class="kicker kicker-burgundy">§ Hoe dit werkt</span>
      <h2>Drie regels</h2>
      <ol class="rules-list">
        {rules.map((r) => (
          <li>
            <span class="rule-num">{r.n}</span>
            <div>
              <h3>{r.h}</h3>
              <p>{r.d}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="visited">
    <div class="container">
      <span class="kicker kicker-rust">Bezochte streken</span>
      <h2>{visited.length}+ streken sinds 2019</h2>
      <div class="visited-list">
        {visited.map((v) => (
          <span class="visited-item">{v}</span>
        ))}
        <span class="visited-more">… en meer</span>
      </div>
      {fotoUitkijk && (
        <figure class="over-figure">
          <img
            src={fotoUitkijk}
            alt="Marijn bij een uitkijkpunt kijkt uit over een weids dal"
            width="2000"
            height="1500"
            loading="lazy"
            decoding="async"
          />
          <figcaption>Even uitkijken over het dal, onderweg naar het volgende wijngebied.</figcaption>
        </figure>
      )}
    </div>
  </section>

  <section class="contact">
    <div class="container container-narrow">
      <h2>Contact</h2>
      <p>
        Vragen, tips, of een wijnhuis dat we écht moeten bezoeken?<br />
        <a href="mailto:contact@vinomartino.com">contact@vinomartino.com</a>
      </p>
    </div>
  </section>
</SiteLayout>

<style>
  .container { max-width: 1280px; margin: 0 auto; padding-inline: var(--gutter); }
  .container-narrow { max-width: 880px; }

  .kicker {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    display: inline-block;
    margin-bottom: 1rem;
  }
  .kicker-vine { color: var(--color-vine, #5C6B3F); }
  .kicker-burgundy { color: var(--color-primary); }
  .kicker-rust { color: var(--color-rust, #A14F2A); }

  .hero {
    padding: clamp(48px, 8vw, 80px) 0;
    border-bottom: 1px solid var(--color-rule, #C9B98F);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .hero-text h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw + 1rem, 5rem);
    font-weight: 500;
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin: 0;
  }
  .hero-text h1 em {
    color: var(--color-primary);
    font-style: italic;
  }
  .lede {
    font-family: var(--font-serif, var(--font-body));
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--color-text-soft, var(--color-text));
    margin-top: 1.5rem;
    font-style: italic;
    text-wrap: pretty;
  }
  .hero-image {
    aspect-ratio: 4 / 5;
    background: var(--color-paper-shade, #E8DCC0);
    background-image: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 12px,
      rgba(0, 0, 0, 0.04) 12px,
      rgba(0, 0, 0, 0.04) 13px
    );
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .placeholder-tag {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-soft, var(--color-text));
    background: var(--color-bg);
    padding: 0.5rem 1rem;
  }

  .intro {
    padding: clamp(40px, 6vw, 64px) 0;
    border-bottom: 1px solid var(--color-rule, #C9B98F);
  }
  .intro p {
    font-family: var(--font-serif, var(--font-body));
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-text);
    margin: 0 0 1.5rem;
  }
  .intro p:last-child { margin-bottom: 0; }

  .over-figure {
    margin: 2.5rem 0 0;
  }
  .over-figure img {
    width: 100%;
    height: auto;
    display: block;
    border: 1px solid var(--color-rule, #C9B98F);
  }
  .over-figure figcaption {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: var(--color-text-soft, var(--color-text));
    margin-top: 0.6rem;
    font-style: italic;
  }
  .intro .over-figure {
    max-width: 460px;
    margin-inline: auto;
  }
  .visited .over-figure {
    margin-top: 2rem;
  }

  .rules {
    padding: clamp(48px, 8vw, 80px) 0;
    border-bottom: 1px solid var(--color-rule, #C9B98F);
  }
  .rules h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3vw + 1rem, 2.75rem);
    font-weight: 500;
    color: var(--color-text);
    margin: 0 0 2rem;
  }
  .rules-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .rules-list li {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-top: 1px solid var(--color-rule-soft, #E0D2B0);
  }
  .rule-num {
    font-family: var(--font-display);
    font-size: 3rem;
    font-style: italic;
    color: var(--color-primary);
    line-height: 1;
  }
  .rules-list h3 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 500;
    color: var(--color-text);
    margin: 0 0 0.5rem;
  }
  .rules-list p {
    font-family: var(--font-serif, var(--font-body));
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--color-text-soft, var(--color-text));
    margin: 0;
  }

  .visited {
    padding: clamp(48px, 7vw, 72px) 0;
    background: var(--color-paper-deep, #F0E6D0);
  }
  .visited h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3vw + 1rem, 2.75rem);
    font-weight: 500;
    color: var(--color-text);
    margin: 0 0 2rem;
  }
  .visited-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
  }
  .visited-item,
  .visited-more {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 500;
    color: var(--color-text);
  }
  .visited-more {
    font-style: italic;
    opacity: 0.6;
  }

  .contact {
    padding: clamp(48px, 8vw, 80px) 0;
  }
  .contact h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3vw + 1rem, 2.75rem);
    font-weight: 500;
    color: var(--color-text);
    margin: 0 0 1rem;
  }
  .contact p {
    font-family: var(--font-serif, var(--font-body));
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--color-text-soft, var(--color-text));
  }
  .contact a { color: var(--color-primary); }

  @media (max-width: 768px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .rules-list li {
      grid-template-columns: 60px 1fr;
      gap: 1rem;
    }
    .rule-num { font-size: 2.25rem; }
  }
</style>
