---
import SiteLayout from '../../layouts/SiteLayout.astro';
import AffiliatePlaceholder from '../../components/AffiliatePlaceholder.astro';
import { loadDestinations, type Destination } from '../../lib/destinations';
import { loadCountries, getCountryBySlug } from '../../lib/countries';

export async function getStaticPaths() {
  const destinations = await loadDestinations();
  return destinations.map((d) => ({ params: { destination: d.slug }, props: { destination: d } }));
}

const { destination } = Astro.props as { destination: Destination };
await loadCountries();
const country = getCountryBySlug(destination.countrySlug);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'TouristDestination',
  name: destination.name,
  description: destination.description,
};
---

<SiteLayout
  title={destination.metaTitle || `${destination.name} — Reisgids`}
  description={destination.metaDescription || destination.description}
  ogImage={destination.heroImage}
  schema={schema}
  activeNav="bestemmingen"
>
  <section class="dest-hero">
    {destination.heroImage && (
      <img src={destination.heroImage} alt={destination.name} class="dest-hero-img" />
    )}
    <div class="dest-hero-overlay"></div>
    <div class="dest-hero-content container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a> /
        {country && <><a href={`/landen/${country.slug}/`}>{country.name}</a> / </>}
        <span>{destination.name}</span>
      </nav>
      <h1>{destination.name}</h1>
    </div>
  </section>

  <div class="container dest-body">
    <div class="dest-content">
      <p class="dest-desc">{destination.description}</p>

      {destination.highlights.length > 0 && (
        <section class="highlights">
          <h2>Hoogtepunten</h2>
          <ul>
            {destination.highlights.map(h => <li>{h}</li>)}
          </ul>
        </section>
      )}

      <AffiliatePlaceholder type="accommodation" context={destination.slug} />
      <AffiliatePlaceholder type="activity" context={destination.slug} />
    </div>

    <aside class="dest-sidebar">
      <AffiliatePlaceholder type="sidebar" context={destination.slug} />
    </aside>
  </div>
</SiteLayout>

<style>
  .dest-hero {
    position: relative;
    height: 45vh;
    min-height: 320px;
    overflow: hidden;
    background: var(--paperDeep);
  }
  .dest-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .dest-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(31,26,22,0.2) 0%, rgba(31,26,22,0.65) 100%);
  }
  .dest-hero-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding-bottom: var(--space-8);
    color: var(--paper);
  }
  .breadcrumb {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-3);
    opacity: 0.8;
  }
  .breadcrumb a { color: var(--paper); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }
  .dest-hero-content h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.6rem + 2vw, 3.5rem);
    font-weight: 400;
    font-style: italic;
  }

  .dest-body {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: var(--space-10);
    padding-top: var(--space-10);
    padding-bottom: var(--space-12);
  }
  .dest-desc {
    font-family: var(--font-body);
    font-size: 1.125rem;
    line-height: 1.7;
    margin-bottom: var(--space-8);
  }
  .highlights h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
    font-style: italic;
    margin-bottom: var(--space-4);
  }
  .highlights ul {
    padding-left: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .highlights li {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--inkSoft);
  }

  @media (max-width: 900px) {
    .dest-body {
      grid-template-columns: 1fr;
    }
  }
</style>
