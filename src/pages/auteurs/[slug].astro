---
// LAT-2693 — NL auteur-detailpagina (prefixloos). getStaticPaths blijft hier;
// markup + logica leven in het gedeelde AuteurDetail-component. De /en/-tegenhanger
// rendert hetzelfde met locale="en".
import AuteurDetail from '../../components/AuteurDetail.astro';
import { AUTHORS, type Author } from '../../lib/authors';

export async function getStaticPaths() {
  return AUTHORS.map((author) => ({ params: { slug: author.slug }, props: { author } }));
}

const { author } = Astro.props as { author: Author };
---

<AuteurDetail
  author={author}
  alternates={{ nl: `/auteurs/${author.slug}/`, en: `/en/auteurs/${author.slug}/` }}
/>
