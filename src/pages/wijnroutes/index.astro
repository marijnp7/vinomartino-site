---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { loadRoutes } from '../../lib/routes';
import { organizationSchema, breadcrumbSchema } from '../../lib/seo';

const entries = await loadRoutes();

const schema = [
  organizationSchema(),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Wijnroutes', url: '/wijnroutes/' },
  ]),
];
---

<SiteLayout
  title="Wijnroutes — Gids voor wijnreizen | VinoMartino"
  description="Doorloop de mooiste wijnroutes ter wereld — van de steile Etna-noordflank tot de kronkelende Mosel. Praktische routes voor wijnliefhebbers die zelf op pad gaan."
  schema={schema}
  activeNav="wijnroutes"
>
  <section class="hero-sm">
    <div class="container">
      <span class="section-label">Wijnroutes</span>
      <h1>Gids voor wijnreizen</h1>
      <p class="hero-desc">Praktische routes langs de mooiste wijnstreken — van dagtrips tot meerdaagse tochten langs producenten en proeflokalen.</p>
    </div>
  </section>

  <section class="section container">
    {entries.length > 0 ? (
      <div class="grid">
        {entries.map(entry => (
          <a href={`/wijnroutes/${entry.slug}/`} class="card card-link">
            {entry.heroImage && (
              <img src={entry.heroImage} alt={entry.title} loading="lazy" width="400" height="220" class="card-img" />
            )}
            <div class="card-body">
              <div class="card-meta-row">
                {entry.duration && <span class="card-duration">{entry.duration}</span>}
                {entry.transport && <span class="card-transport">{entry.transport}</span>}
                {entry.style && <span class="card-style">{entry.style}</span>}
              </div>
              <h2 class="card-title">{entry.title}</h2>
              {entry.description && <p class="card-desc">{entry.description}</p>}
              {entry.highlights && entry.highlights.length > 0 && (
                <ul class="card-highlights">
                  {entry.highlights.slice(0, 3).map(h => <li>{h}</li>)}
                </ul>
              )}
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <h2>Wijnroutes komen eraan</h2>
        <p>We werken aan uitgebreide routegidsen. Binnenkort beschikbaar.</p>
      </div>
    )}
  </section>
</SiteLayout>

<style>
  .hero-sm {
    background: var(--paperDeep);
    padding: var(--space-12) 0 var(--space-8);
    text-align: center;
  }
  .hero-sm h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.6rem + 1.5vw, 3rem);
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin-top: var(--space-3);
  }
  .hero-desc {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--inkSoft);
    margin-top: var(--space-3);
    max-width: 36rem;
    margin-inline: auto;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: var(--space-6);
  }
  .card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .card-img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 400 / 220;
    object-fit: cover;
  }
  .card-body { padding: 1.25rem; }
  .card-meta-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: var(--space-2);
    flex-wrap: wrap;
  }
  .card-duration, .card-transport, .card-style {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: var(--paperDeep);
    color: var(--inkSoft);
    padding: 0.2rem 0.5rem;
    border-radius: 1px;
  }
  .card-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: var(--space-2);
    line-height: 1.25;
  }
  .card-desc {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--inkSoft);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: var(--space-3);
  }
  .card-highlights {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .card-highlights li {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--inkFaint);
  }
  .card-highlights li::before {
    content: '— ';
  }
  .empty-state {
    text-align: center;
    padding: var(--space-16) var(--space-4);
  }
  .empty-state h2 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin-bottom: var(--space-3);
  }
  .empty-state p {
    font-size: 1rem;
    color: var(--inkSoft);
  }
</style>
