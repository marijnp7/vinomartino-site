---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getCollection, render } from 'astro:content';
import { wijnrouteSchema, wijnrouteMetaTitle, wijnrouteMetaDescription, breadcrumbSchema } from '../../lib/seo';

export async function getStaticPaths() {
  const entries = await getCollection('wijnroutes');
  return entries.map(entry => ({
    params: { slug: entry.data.slug || entry.id.replace(/\.md$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { data } = entry;

const slug = data.slug || entry.id.replace(/\.md$/, '');
const pageUrl = new URL(`/wijnroutes/${slug}/`, Astro.site ?? 'https://vinomartino.com').href;

const schema = [
  wijnrouteSchema({
    name: data.title,
    description: data.description,
    image: data.heroImage,
    duration: data.duration,
    region: data.region,
    country: data.country,
    stops: data.highlights || data.stops,
    pageUrl,
  }),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Wijnroutes', url: '/wijnroutes/' },
    { name: data.title, url: pageUrl },
  ]),
];
---

<SiteLayout
  title={wijnrouteMetaTitle(data.title, data.region)}
  description={wijnrouteMetaDescription({ name: data.title, region: data.region, duration: data.duration, description: data.description })}
  ogImage={data.heroImage}
  schema={schema}
  activeNav="wijnroutes"
>
  <article class="route-page">
    {data.heroImage && (
      <div class="page-hero">
        <img src={data.heroImage} alt={data.title} class="page-hero-img" />
      </div>
    )}

    <div class="container page-layout">
      <div class="page-main">
        <header class="page-header">
          <nav class="breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a> / <a href="/wijnroutes/">Wijnroutes</a> / <span>{data.title}</span>
          </nav>
          <div class="page-meta-row">
            {data.region && <span class="page-region">{data.region}</span>}
            {data.duration && <span class="page-badge">{data.duration}</span>}
            {data.difficulty && <span class="page-badge">{data.difficulty}</span>}
          </div>
          <h1>{data.title}</h1>
          {data.author && (
            <div class="page-author">Door {data.author}</div>
          )}
        </header>

        <div class="page-prose">
          <Content />
        </div>
      </div>

      <aside class="page-sidebar">
        <div class="sidebar-card">
          <h3>Route info</h3>
          {data.duration && <p><strong>Duur:</strong> {data.duration}</p>}
          {data.difficulty && <p><strong>Niveau:</strong> {data.difficulty}</p>}
          {data.region && <p><strong>Regio:</strong> {data.region}</p>}
          {data.country && <p><strong>Land:</strong> {data.country}</p>}
        </div>

        {data.highlights && data.highlights.length > 0 && (
          <div class="sidebar-card sidebar-highlights">
            <h3>Highlights</h3>
            <ul>
              {data.highlights.map(h => <li>{h}</li>)}
            </ul>
          </div>
        )}
      </aside>
    </div>
  </article>
</SiteLayout>

<style>
  .page-hero {
    height: 45vh;
    min-height: 300px;
    overflow: hidden;
  }
  .page-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .page-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: var(--space-10);
    padding-top: var(--space-10);
    padding-bottom: var(--space-12);
  }
  .breadcrumb {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--inkFaint);
    margin-bottom: var(--space-4);
  }
  .breadcrumb a {
    color: var(--inkSoft);
    text-decoration: none;
  }
  .breadcrumb a:hover { text-decoration: underline; }
  .page-meta-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: var(--space-3);
    flex-wrap: wrap;
  }
  .page-region {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--rust);
  }
  .page-badge {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: var(--paperDeep);
    color: var(--inkSoft);
    padding: 0.2rem 0.625rem;
    border-radius: 1px;
  }
  .page-header h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.6rem + 1.5vw, 3rem);
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    line-height: 1.15;
    margin-bottom: var(--space-3);
  }
  .page-author {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--inkSoft);
    margin-bottom: var(--space-8);
  }
  .page-prose {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--ink);
    max-width: var(--article-body-max);
  }
  .page-prose :global(h2) {
    font-family: var(--font-display);
    font-size: 1.625rem;
    font-weight: 500;
    margin: var(--space-10) 0 var(--space-4);
  }
  .page-prose :global(h3) {
    font-family: var(--font-ui);
    font-size: 1.125rem;
    font-weight: 600;
    margin: var(--space-8) 0 var(--space-3);
  }
  .page-prose :global(p) { margin-bottom: var(--space-5); }
  .page-prose :global(ul), .page-prose :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: var(--space-5);
  }
  .page-prose :global(li) { margin-bottom: 0.375rem; }
  .page-prose :global(blockquote) {
    border-left: 3px solid var(--burgundy);
    padding-left: 1.5rem;
    margin: var(--space-6) 0;
    font-style: italic;
    color: var(--inkSoft);
  }
  .sidebar-card {
    background: var(--paperDeep);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-sm);
    padding: 1.25rem;
    font-family: var(--font-ui);
    font-size: 0.875rem;
    line-height: 1.6;
    margin-bottom: var(--space-4);
  }
  .sidebar-card h3 {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 500;
    font-style: italic;
    margin-bottom: var(--space-4);
    color: var(--ink);
  }
  .sidebar-card p {
    margin-bottom: var(--space-2);
    color: var(--inkSoft);
  }
  .sidebar-highlights ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .sidebar-highlights li {
    font-size: 0.8125rem;
    color: var(--inkSoft);
    padding: 0.25rem 0;
    border-bottom: 1px solid var(--color-border-light);
  }
  .sidebar-highlights li:last-child { border-bottom: none; }
  @media (max-width: 900px) {
    .page-layout { grid-template-columns: 1fr; }
  }
</style>
