---
// LAT-2638 — NL wijnroute-detailroute (prefixloos). Dunne wrapper rond het
// gedeelde RouteDetail-component; de EN-tegenhanger leeft onder /en/wijnroutes/.
// hreflang-alternates worden alleen gezet wanneer er een EN-vertaling bestaat
// (launch-gate: geen en-hreflang zonder tegenhanger).
import RouteDetail from '../../components/RouteDetail.astro';
import { loadRoutes, type WijnRoute } from '../../lib/routes';
import { loadStreken } from '../../lib/streken';
import { loadWijnhuizen, type Wijnhuis } from '../../lib/wijnhuizen';
import { loadAccommodatieRoundupsByStreek } from '../../lib/accommodaties-loader';
import { filterRoundupOpFotos, roundupKaartAantal, type AccommodatieRoundup as AccommodatieRoundupData } from '../../lib/accommodaties';
import { DEFAULT_LOCALE } from '../../lib/i18n';

export async function getStaticPaths() {
  const [entries, streken, wijnhuizen, accRoundupsByStreek, enEntries] = await Promise.all([loadRoutes(), loadStreken(), loadWijnhuizen(), loadAccommodatieRoundupsByStreek(), loadRoutes('en')]);
  const enSlugs = new Set(enEntries.map(e => e.slug));
  const streekBySlug = new Map(streken.map(s => [s.slug, s]));
  // LAT-1201: wijnhuizen per streek zodat een route → wijnhuizen-selectie afgeleid
  // wordt uit routes.streek_id (route kent zelf geen wijnhuis-relatie). Zelfde
  // transition-safe keten als de streek-pagina's "Wijnhuizen in <streek>".
  const wijnhuizenByStreek = new Map<string, Wijnhuis[]>();
  for (const wh of wijnhuizen) {
    if (!wh.streekSlug) continue;
    const list = wijnhuizenByStreek.get(wh.streekSlug) ?? [];
    list.push(wh);
    wijnhuizenByStreek.set(wh.streekSlug, list);
  }
  const wijnhuisBySlug = new Map(wijnhuizen.map(wh => [wh.slug, wh]));
  return entries.map(entry => {
    // LAT-1199: leid de keten Land → Streek af via routes.streek_id → streek→land
    // voor de verticale kruimel (route kent zelf geen land).
    const streek = entry.streekSlug ? streekBySlug.get(entry.streekSlug) : undefined;
    // LAT-2010 [VIS-BL-11] / LAT-1994: als de route expliciet wijnhuis-stops noemt
    // (stops_geo kind=wijnhuis + slug), toon alléén die huizen — in route-volgorde —
    // zodat de route enkel naar huizen linkt die er écht op liggen. Zonder die data
    // (vóór de datafix) val terug op de streek-brede selectie (bestaand gedrag).
    const routeWijnhuisSlugs = entry.stopsGeo
      .filter(s => s.kind === 'wijnhuis' && s.slug)
      .map(s => s.slug as string);
    const routeWijnhuizen = routeWijnhuisSlugs
      .map(slug => wijnhuisBySlug.get(slug))
      .filter((wh): wh is Wijnhuis => Boolean(wh));
    // LAT-1609: curated verblijven voor de streek van deze route. Alleen kaarten
    // met echte DAM-foto tellen — gelijk aan de regel die bepaalt of
    // /accommodaties/<streek>/ bestaat (LAT-1371). Geen foto's → geen teaser.
    const rawRoundup = entry.streekSlug ? accRoundupsByStreek.get(entry.streekSlug) : undefined;
    const staysRoundup = rawRoundup && roundupKaartAantal(filterRoundupOpFotos(rawRoundup)) > 0
      ? filterRoundupOpFotos(rawRoundup)
      : null;
    return {
      params: { slug: entry.slug },
      props: {
        entry,
        streekName: streek?.name ?? '',
        landSlug: streek?.landSlug ?? '',
        landName: streek?.country ?? '',
        wijnhuizen: routeWijnhuizen.length > 0
          ? routeWijnhuizen
          : (entry.streekSlug ? (wijnhuizenByStreek.get(entry.streekSlug) ?? []) : []),
        staysRoundup,
        alternates: enSlugs.has(entry.slug)
          ? { nl: `/wijnroutes/${entry.slug}/`, en: `/en/wijnroutes/${entry.slug}/` }
          : undefined,
      },
    };
  });
}

const { entry, streekName, landSlug, landName, wijnhuizen, staysRoundup, alternates } = Astro.props as {
  entry: WijnRoute; streekName: string; landSlug: string; landName: string; wijnhuizen: Wijnhuis[];
  staysRoundup: AccommodatieRoundupData | null; alternates?: Record<string, string>;
};
---

<RouteDetail entry={entry} streekName={streekName} landSlug={landSlug} landName={landName} wijnhuizen={wijnhuizen} staysRoundup={staysRoundup} locale={DEFAULT_LOCALE} alternates={alternates} />
