---
import SiteLayout from '../../../layouts/SiteLayout.astro';
import InfographicCardMinimal from '../../../components/InfographicCardMinimal.astro';

/**
 * LAT-1110 — Stijl 1 ("Minimaal & Wit") als echte webpagina.
 * Pilot voor de Nebbiolo Cellar Card herzien op feedback van Marijn:
 * grotere typo, dikkere lijnen, hogere contrast, web-native UX (hover-waardes,
 * scroll-reveal), responsive zonder vaste social-crop canvas.
 *
 * Geen Directus afhankelijkheid — pure preview / mockup-vervanger.
 * Route is noindex via SiteLayout default; pagina is gericht op redactie-review.
 */

const barolo = {
  label: 'Barolo',
  contextLine: 'DOCG · 1980 · 11 gemeenten',
  axes: [
    { label: 'Zuur',    value: 7 },
    { label: 'Tannine', value: 9 },
    { label: 'Alc',     value: 7 },
    { label: 'Body',    value: 8 },
    { label: 'Rijping', value: 9 },
  ] as const,
  meta: [
    { label: 'Hoogte',    value: '170 – 540 m' },
    { label: 'Bodem',     value: 'Kalkmergel (Tortonian / Helvetian)' },
    { label: 'Rijping',   value: '38 maanden, waarvan 18 in eikenhout' },
    { label: 'Drinkraam', value: '2030 – 2055' },
  ],
  tasting: 'Rozen, teer en kers met een lange, mineraal-spannende afdronk.',
  accent: 'burgundy' as const,
};

const barbaresco = {
  label: 'Barbaresco',
  contextLine: 'DOCG · 1980 · 3 gemeenten',
  axes: [
    { label: 'Zuur',    value: 8 },
    { label: 'Tannine', value: 7 },
    { label: 'Alc',     value: 6 },
    { label: 'Body',    value: 7 },
    { label: 'Rijping', value: 7 },
  ] as const,
  meta: [
    { label: 'Hoogte',    value: '170 – 400 m' },
    { label: 'Bodem',     value: 'Mergel met zandlagen' },
    { label: 'Rijping',   value: '26 maanden, waarvan 9 in eikenhout' },
    { label: 'Drinkraam', value: '2028 – 2045' },
  ],
  tasting: 'Eleganter en frisser dan Barolo: viooltje, framboos en lichte kruiding.',
  accent: 'burgundy' as const,
};

// ─── Topografie / altitude curve ──────────────────────
// Twee gestileerde altitude-profielen. SVG-paden, geen library nodig.
// Y-as: 100 = zeeniveau, 0 = topografisch hoog. X-as: west → oost over de zone.
const topoBarolo  = 'M 0 80 L 20 70 L 35 55 L 55 28 L 78 14 L 100 25 L 122 18 L 145 35 L 168 50 L 190 65 L 210 78 L 240 88 L 270 80 L 300 92';
const topoBarbar  = 'M 0 92 L 25 85 L 50 72 L 75 58 L 100 48 L 125 38 L 150 35 L 175 42 L 200 55 L 225 70 L 250 80 L 275 88 L 300 90';
---

<SiteLayout
  title="Nebbiolo — de druif van plek en geduld | Stijl 1 mockup"
  description="Web-implementatie van de Nebbiolo Cellar Card (Stijl 1, minimaal & wit). Pilot voor LAT-1110."
  activeNav=""
  schema={[]}
  noindex={true}
>
  <main class="stijl1">
    <article class="article">
      <header class="article-head">
        <p class="eyebrow">DRUIVEN &amp; VARIËTEITEN · NO. 002</p>
        <h1 class="display">Nebbiolo<span class="display-em">: de druif van plek en geduld</span></h1>
        <p class="byline">
          <span>Door <em>Marijn</em></span>
          <span class="sep">·</span>
          <time datetime="2026-05-19">19 mei 2026</time>
          <span class="sep">·</span>
          <span>Leestijd 6 min</span>
        </p>
        <p class="standfirst">
          Uit de mistige heuvels van Piemonte komt Nebbiolo met twee onmiskenbaar
          verschillende gezichten. Hier ligt Barolo's gewicht naast Barbaresco's
          finesse — dezelfde druif, twee terroirs, twee leeftijden om op te
          wachten.
        </p>
      </header>

      <section class="lede">
        <p>
          Weinige druiven dragen hun plek zo letterlijk op de tong als Nebbiolo.
          Op kalkrijke heuvels rond Alba ontvouwt hij subtiele verschillen die
          twee namen rechtvaardigen: Barolo en Barbaresco. De vergelijking
          hieronder is geen ranglijst — het is een ijkpunt om in te lezen
          waaróm dezelfde druif twee verhalen vertelt.
        </p>
      </section>

      <InfographicCardMinimal
        kicker="DRUIVENPROFIEL · NO. 002"
        title="Nebbiolo"
        subtitle="Barolo &amp; Barbaresco vergeleken"
        intro="Vijf assen, twee terroirs. Hover op een punt voor de exacte waarde; de cijfers volgen WSET-L4 conventie (0–10)."
        profiles={[barolo, barbaresco]}
        source="Consorzio Tutela Barolo Barbaresco · WSET Level 4"
        alt="Vergelijking van Barolo en Barbaresco op vijf radarassen (zuur, tannine, alcohol, body, rijping) met bodem, hoogte en drinkraam per regio."
      />

      <section class="topo">
        <header class="topo-head">
          <p class="kicker">HOOGTE &amp; TOPOGRAFIE</p>
          <h2 class="topo-title">Tortonian en Helvetian — twee oevers, twee lichamen</h2>
          <p class="topo-intro">
            Hetzelfde rivierdal, ander gesteente. Barolo's wijngaarden bouwen
            zich op tot rond de 540 meter; Barbaresco blijft lager en dichter
            bij de Tanaro. De curves hieronder geven de typische hoogteband per
            zone — geen exact reliëf, maar leesbaar genoeg om te zien waarom de
            wijnen anders ademen.
          </p>
        </header>

        <div class="topo-grid">
          <figure class="topo-card">
            <figcaption class="topo-cap">
              <h3>Barolo</h3>
              <p>170 – 540 m · westoever Tanaro · kalkmergel</p>
            </figcaption>
            <svg viewBox="0 0 300 100" preserveAspectRatio="none" class="topo-svg" role="img" aria-label="Hoogteprofiel Barolo: licht heuvelig met pieken rond 540 meter">
              <title>Barolo — typisch hoogteprofiel</title>
              <line x1="0" y1="100" x2="300" y2="100" class="topo-base" />
              <path d={`${topoBarolo} L 300 100 L 0 100 Z`} class="topo-fill" />
              <path d={topoBarolo} class="topo-line" />
              <circle cx="78" cy="14" r="3" class="topo-peak" />
              <text x="78" y="6" class="topo-peak-label" text-anchor="middle">540 m</text>
            </svg>
            <p class="topo-foot">
              Tortonian-mergel — koeler, langer rijpend, structurele tannine.
            </p>
          </figure>

          <figure class="topo-card">
            <figcaption class="topo-cap">
              <h3>Barbaresco</h3>
              <p>170 – 400 m · oostoever Tanaro · mergel met zand</p>
            </figcaption>
            <svg viewBox="0 0 300 100" preserveAspectRatio="none" class="topo-svg" role="img" aria-label="Hoogteprofiel Barbaresco: gelijkmatiger en lager dan Barolo, top rond 400 meter">
              <title>Barbaresco — typisch hoogteprofiel</title>
              <line x1="0" y1="100" x2="300" y2="100" class="topo-base" />
              <path d={`${topoBarbar} L 300 100 L 0 100 Z`} class="topo-fill" />
              <path d={topoBarbar} class="topo-line" />
              <circle cx="150" cy="35" r="3" class="topo-peak" />
              <text x="150" y="27" class="topo-peak-label" text-anchor="middle">400 m</text>
            </svg>
            <p class="topo-foot">
              Helvetian — zandiger, vroeger rijp, ronder en sneller benaderbaar.
            </p>
          </figure>
        </div>
      </section>

      <section class="closer">
        <p class="closer-rule" aria-hidden="true"></p>
        <p>
          Nebbiolo, ook wel "de koning van Piemonte", is een wijn voor wie
          lange-baan-spel waardeert. Barbaresco komt eerder op gang, gracieuzer
          en sneller benaderbaar; Barolo vraagt geduld en geeft het meervoud
          ervan terug. Beide zijn Nebbiolo — alleen het terroir zegt hoe.
        </p>
        <p class="closer-foot">
          <a href="/infographics/">← Terug naar alle infographics</a>
        </p>
      </section>
    </article>
  </main>
</SiteLayout>

<style>
  .stijl1 {
    background: #FFFFFF;
    color: #1A1A1A;
    padding: clamp(2rem, 5vw, 5rem) clamp(1rem, 3vw, 2rem) clamp(4rem, 8vw, 8rem);
  }
  .article {
    max-width: 56rem;
    margin: 0 auto;
    font-family: 'Source Serif 4', Georgia, serif;
  }

  .article-head {
    text-align: center;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
    padding-bottom: clamp(1.5rem, 3vw, 2.5rem);
    border-bottom: 1px solid #E5E5E5;
  }
  .eyebrow {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.75rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #5A1A1F;
    margin: 0 0 1.25rem;
  }
  .display {
    font-family: 'Cormorant Garamond', 'EB Garamond', Georgia, serif;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1.02;
    font-weight: 500;
    color: #1A1A1A;
    margin: 0 0 0.5rem;
  }
  .display-em {
    font-style: italic;
    font-weight: 400;
    color: #2E2E2E;
  }
  .byline {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #6E6E6E;
    margin: 1.5rem 0 1.25rem;
    display: flex;
    justify-content: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  .byline .sep { color: #BFBFBF; }
  .byline em { font-style: normal; color: #1A1A1A; }
  .standfirst {
    max-width: 36rem;
    margin: 1.5rem auto 0;
    font-size: clamp(1.05rem, 1.6vw, 1.2rem);
    line-height: 1.55;
    color: #3A3A3A;
    font-style: italic;
  }

  .lede {
    max-width: 36rem;
    margin: 0 auto clamp(2rem, 4vw, 3rem);
  }
  .lede p {
    font-size: clamp(1.05rem, 1.5vw, 1.15rem);
    line-height: 1.7;
    margin: 0;
    color: #2A2A2A;
  }
  .lede p::first-line {
    font-variant-caps: small-caps;
    letter-spacing: 0.05em;
  }

  /* Topografie sectie ------------------------------------ */
  .topo {
    margin: clamp(2.5rem, 5vw, 4rem) 0;
  }
  .topo-head {
    max-width: 38rem;
    margin: 0 auto clamp(1.5rem, 3vw, 2.5rem);
    text-align: center;
  }
  .topo .kicker {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #5A1A1F;
    margin: 0 0 0.75rem;
  }
  .topo-title {
    font-family: 'Cormorant Garamond', 'EB Garamond', Georgia, serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-style: italic;
    font-weight: 500;
    line-height: 1.15;
    margin: 0 0 0.75rem;
  }
  .topo-intro {
    font-size: clamp(0.98rem, 1.4vw, 1.05rem);
    line-height: 1.6;
    color: #4A4A4A;
    margin: 0;
  }

  .topo-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }
  @media (min-width: 720px) {
    .topo-grid { grid-template-columns: 1fr 1fr; }
  }

  .topo-card {
    margin: 0;
  }
  .topo-cap {
    border-top: 1px solid #1A1A1A;
    padding-top: 1rem;
    margin-bottom: 0.75rem;
  }
  .topo-cap h3 {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin: 0 0 0.25rem;
  }
  .topo-cap p {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #8A8A8A;
    margin: 0;
  }
  .topo-svg {
    width: 100%;
    height: 120px;
    display: block;
  }
  .topo-base { stroke: #1A1A1A; stroke-width: 1; }
  .topo-fill { fill: #5A1A1F; fill-opacity: 0.08; }
  .topo-line { fill: none; stroke: #5A1A1F; stroke-width: 2; stroke-linejoin: round; }
  .topo-peak { fill: #5A1A1F; }
  .topo-peak-label {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 9px;
    letter-spacing: 0.1em;
    fill: #1A1A1A;
  }
  .topo-foot {
    margin: 0.75rem 0 0;
    font-size: 0.95rem;
    line-height: 1.5;
    color: #4A4A4A;
    font-style: italic;
  }

  /* Closer ----------------------------------------------- */
  .closer {
    max-width: 36rem;
    margin: clamp(2.5rem, 5vw, 4rem) auto 0;
    text-align: center;
  }
  .closer-rule {
    width: 2.5rem;
    height: 1px;
    background: #1A1A1A;
    margin: 0 auto 1.5rem;
  }
  .closer p {
    font-size: clamp(1.05rem, 1.5vw, 1.15rem);
    line-height: 1.7;
    color: #2A2A2A;
    margin: 0 0 1.5rem;
  }
  .closer-foot a {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #5A1A1F;
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 0.15rem;
  }
  .closer-foot a:hover { color: #1A1A1A; }
</style>
