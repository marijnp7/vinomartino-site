---
// LAT-1383 (Track B, EPIC LAT-1330) — accommodaties-landing. Linkt naar de
// reisjunk-stijl regio-overzichten. Toont alleen regio's met ≥1 echte DAM-foto
// (LAT-1371).
import SiteLayout from '../../layouts/SiteLayout.astro';
import SmartImg from '../../components/SmartImg.astro';
import { loadAccommodatieRoundupsByStreek } from '../../lib/accommodaties-loader';
import { filterRoundupOpFotos, roundupKaartAantal } from '../../lib/accommodaties';
import { loadStreken } from '../../lib/streken';
import { organizationSchema, breadcrumbSchema } from '../../lib/seo';

const [roundups, streken] = await Promise.all([loadAccommodatieRoundupsByStreek(), loadStreken()]);
const streekBySlug = new Map(streken.map((s) => [s.slug, s]));

const regios = [];
for (const [streekSlug, raw] of roundups) {
  const roundup = filterRoundupOpFotos(raw);
  const aantal = roundupKaartAantal(roundup);
  if (aantal === 0) continue;
  const streek = streekBySlug.get(streekSlug);
  regios.push({
    slug: streekSlug,
    naam: roundup.regio || streek?.name || streekSlug,
    land: streek?.country ?? null,
    heroImage: streek?.heroImage ?? null,
    aantal,
  });
}
regios.sort((a, b) => a.naam.localeCompare(b.naam, 'nl'));

const schema = [
  organizationSchema(),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Accommodaties', url: '/accommodaties/' },
  ]),
];
---

<SiteLayout
  title="Accommodaties in wijnregio's, handgekozen verblijven | VinoMartino"
  description="Per wijnregio een persoonlijke selectie verblijven met echte foto's, locatie en prijsindicatie. Geen willekeurig hotelaanbod, maar adressen die we zelf zouden boeken."
  schema={schema}
  activeNav="accommodaties"
>
  <section class="hero-sm">
    <div class="container">
      <span class="section-label">Accommodaties</span>
      <h1>Waar te slapen in de wijnstreek</h1>
      <p class="hero-desc">Voor elke regio een handgekozen selectie verblijven, geen willekeurig hotelaanbod. Kies een streek en vind adressen die we zelf zouden boeken.</p>
    </div>
  </section>

  <section class="section container">
    {regios.length > 0 ? (
      <div class="grid">
        {regios.map((r) => (
          <a href={`/accommodaties/${r.slug}/`} class="card card-link">
            <div class="card-img-wrap">
              <SmartImg src={r.heroImage || undefined} alt={r.naam} theme="vineyard" class="card-img" />
            </div>
            <div class="card-body">
              {r.land && <span class="card-country">{r.land}</span>}
              <h2 class="card-title">{r.naam}</h2>
              <p class="card-desc">{r.aantal} {r.aantal === 1 ? 'verblijf' : 'verblijven'} geselecteerd</p>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <h2>De selecties zijn onderweg</h2>
        <p>We curateren per regio een handvol verblijven met echte foto's. Begin ondertussen bij de <a href="/streken/">wijnstreken</a>.</p>
      </div>
    )}
  </section>
</SiteLayout>

<style>
  .hero-sm {
    background: var(--paperDeep);
    padding: var(--space-12) 0 var(--space-8);
    text-align: center;
  }
  .hero-sm h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.6rem + 1.5vw, 3rem);
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin-top: var(--space-3);
  }
  .hero-desc {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--inkSoft);
    margin-top: var(--space-3);
    max-width: 36rem;
    margin-inline: auto;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-6);
  }
  @media (max-width: 420px) {
    .grid { grid-template-columns: 1fr; }
  }
  .card-link { text-decoration: none; color: inherit; display: block; }
  .card-img-wrap {
    aspect-ratio: 16 / 11;
    overflow: hidden;
    background: var(--paperShade);
  }
  .card-img-wrap :global(img),
  .card-img-wrap :global(.smart-img-placeholder) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-image) var(--ease-out);
  }
  .card-link:hover .card-img-wrap :global(img) { transform: scale(1.03); }
  .card-body { padding: 1.25rem; }
  .card-country {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--rust);
    display: block;
    margin-bottom: var(--space-2);
  }
  .card-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: var(--space-2);
    line-height: 1.25;
  }
  .card-desc {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    color: var(--inkSoft);
  }
  .empty-state { text-align: center; padding: var(--space-16) var(--space-4); }
  .empty-state h2 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin-bottom: var(--space-3);
  }
  .empty-state p { font-size: 1rem; color: var(--inkSoft); }
</style>
