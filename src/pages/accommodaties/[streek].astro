---
// LAT-1383 (Track B, EPIC LAT-1330) — reisjunk-stijl accommodatie-overzicht per
// regio. Hergebruikt AccommodatieRoundup (LAT-1332) + de Directus-loader
// (LAT-1331). Route-conventie: top-level /accommodaties/<streek-slug>/.
import SiteLayout from '../../layouts/SiteLayout.astro';
import AccommodatieRoundup from '../../components/AccommodatieRoundup.astro';
import CtaPrimary from '../../components/CtaPrimary.astro';
import CtaComparison from '../../components/CtaComparison.astro';
import CtaClosing from '../../components/CtaClosing.astro';
import HubBacklink from '../../components/HubBacklink.astro';
import { loadAccommodatieRoundupsByStreek } from '../../lib/accommodaties-loader';
import { filterRoundupOpFotos, roundupKaartAantal, type AccommodatieRoundup as Roundup } from '../../lib/accommodaties';
import { loadStreken, type Streek } from '../../lib/streken';
import { roundupFromCuratedStays } from '../../lib/curated-stays';
import { currencyForLand } from '../../lib/currency';
import { organizationSchema, breadcrumbSchema } from '../../lib/seo';

export async function getStaticPaths() {
  const [collectionRoundups, streken] = await Promise.all([loadAccommodatieRoundupsByStreek(), loadStreken()]);
  const streekBySlug = new Map(streken.map((s) => [s.slug, s]));
  const paths = [];
  const seen = new Set<string>();

  // LAT-1644: de gecureerde streek-set (LAT-1133) is de enige bron die compleet
  // is (3+3+3) én lat/lng draagt, dus die voedt /accommodaties via dezelfde
  // 40-min-clustering als /streken. Zo is de cluster-layout identiek op beide
  // surfaces i.p.v. de oude, incomplete per-plaats-rijen uit de losse collectie.
  for (const streek of streken) {
    // LAT-1644: gelijk aan /streken/<slug>/ — de gecureerde set is de canonieke,
    // complete (3+3+3) bron en wordt hier NIET op foto's gefilterd. De curated
    // stays dragen nog geen DAM-foto (fotoRef leeg); zou de foto-gate hier wél
    // gelden, dan viel de surface terug op de oude, incomplete per-plaats-
    // collectie en faalde de DoD (beide surfaces moeten alle 9 in cluster-layout
    // tonen). De kaart rendert netjes zonder afbeelding, identiek aan /streken.
    const roundup = roundupFromCuratedStays(streek);
    const aantal = roundup.clusters.reduce((n, c) => n + c.kaarten.length, 0);
    if (aantal === 0) continue;
    paths.push({ params: { streek: streek.slug }, props: { roundup, streek, streekSlug: streek.slug } });
    seen.add(streek.slug);
  }

  // Fallback: streken zónder gecureerde set vallen terug op de reisjunk-collectie.
  for (const [streekSlug, raw] of collectionRoundups) {
    if (seen.has(streekSlug)) continue;
    const roundup = filterRoundupOpFotos(raw);
    if (roundupKaartAantal(roundup) === 0) continue;
    paths.push({ params: { streek: streekSlug }, props: { roundup, streek: streekBySlug.get(streekSlug) ?? null, streekSlug } });
  }
  return paths;
}

const { roundup, streek, streekSlug } = Astro.props as { roundup: Roundup; streek: Streek | null; streekSlug: string };
const regio = roundup.regio || streek?.name || streekSlug;
// LAT-1664: bron-valuta volgt het land van de streek (Zuid-Afrika → ZAR); de
// roundup converteert naar EUR voor weergave. Display blijft EUR (board-besluit).
const bronValuta = currencyForLand(streek?.landSlug);

// LAT-1821: aparte 3-CTA-structuur voor de accommodatie-surface (eigen veld
// streken.accom_cta_blocks, pre-geparsed in de loader als accomCta). Andere copy
// dan de streek-CTA. Leeg/ontbrekend → componenten renderen niets.
const accomCta = streek?.accomCta ?? {};

// LAT-1898 — Piemonte-funnel: redactioneel intro-blok 'Slapen in de Langhe'
// (markdown→HTML) VÓÓR de lijst + beknopte planningspassage(s) NÁ de lijst. Beide
// uit de loader (streken.waar_slapen_intro / streken.accom_cta_blocks.planning).
const waarSlapenIntroHtml = streek?.waarSlapenIntroHtml ?? '';
const accomPlanning = streek?.accomPlanning ?? [];

const schema = [
  organizationSchema(),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Accommodaties', url: '/accommodaties/' },
    { name: regio, url: `/accommodaties/${streekSlug}/` },
  ]),
];
---

<SiteLayout
  title={`Waar slapen in ${regio}? Handgekozen verblijven | VinoMartino`}
  description={`Een persoonlijke selectie verblijven in ${regio}, met echte foto's, locatie en prijsindicatie. Geen willekeurig hotelaanbod, maar adressen die we zelf zouden boeken.`}
  ogImage={streek?.ogImage || streek?.heroImage || undefined}
  schema={schema}
  activeNav="accommodaties"
>
  <section class="hero-sm">
    <div class="container">
      <nav class="crumbs" aria-label="Kruimelpad">
        <a href="/accommodaties/">Accommodaties</a>
        <span aria-hidden="true">/</span>
        <span>{regio}</span>
      </nav>
      <span class="section-label">Waar slapen</span>
      <h1>Verblijven in {regio}</h1>
      <p class="hero-desc">Handgekozen adressen per bestemming, geen willekeurig hotelaanbod. Plekken die we zelf zouden boeken, met echte foto's en een eerlijke prijsindicatie.</p>
      {streek && (
        <p class="hero-link"><a href={`/streken/${streek.slug}/`}>Lees de wijngids over {regio} →</a></p>
      )}
    </div>
  </section>

  <div class="container">
    <CtaPrimary data={accomCta.primary} sid={streekSlug} />
  </div>

  {waarSlapenIntroHtml && (
    <div class="container">
      <section class="waar-slapen-intro">
        <div class="waar-slapen-intro__prose" set:html={waarSlapenIntroHtml} />
      </section>
    </div>
  )}

  <div class="container">
    <AccommodatieRoundup roundup={roundup} context={streekSlug} bronValuta={bronValuta} hideHead />
  </div>

  {accomPlanning.length > 0 && (
    <div class="container">
      <section class="accom-planning" aria-label="Je reis plannen">
        {accomPlanning.map((block) => (
          <div class="accom-planning__block">
            {block.heading && <h2>{block.heading}</h2>}
            {block.text && <p>{block.text}</p>}
          </div>
        ))}
      </section>
    </div>
  )}

  <div class="container">
    <CtaComparison data={accomCta.comparison} sid={streekSlug} />
    <CtaClosing data={accomCta.closing} sid={streekSlug} />
    <HubBacklink type="accommodatie" slug={streekSlug} />
  </div>
</SiteLayout>

<style>
  .hero-sm {
    background: var(--paperDeep);
    padding: var(--space-12) 0 var(--space-8);
    text-align: center;
  }
  .crumbs {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--inkSoft);
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    margin-bottom: var(--space-3);
  }
  .crumbs a { color: var(--rust); text-decoration: none; }
  .hero-sm h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.6rem + 1.5vw, 3rem);
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    margin-top: var(--space-3);
  }
  .hero-desc {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--inkSoft);
    margin-top: var(--space-3);
    max-width: 36rem;
    margin-inline: auto;
  }
  .hero-link {
    margin-top: var(--space-4);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
  }
  .hero-link a { color: var(--rust); text-decoration: none; }

  /* LAT-1898 — intro-blok 'Slapen in de Langhe', vóór de accommodatielijst. */
  .waar-slapen-intro {
    max-width: var(--max-width-narrow);
    margin: var(--space-8) auto var(--space-4);
  }
  .waar-slapen-intro__prose {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--ink);
  }
  .waar-slapen-intro__prose :global(p) { margin-bottom: 1.1rem; }
  .waar-slapen-intro__prose :global(h2) {
    font-family: var(--font-display);
    font-size: 1.625rem;
    font-weight: 500;
    margin: 0 0 1rem;
  }
  .waar-slapen-intro__prose :global(h3) {
    font-family: var(--font-ui);
    font-size: 1.0625rem;
    font-weight: 600;
    margin: 1.75rem 0 0.5rem;
  }
  .waar-slapen-intro__prose :global(a) { color: var(--rust); }

  /* LAT-1898 — beknopte planningspassage ná de accommodatielijst. */
  .accom-planning {
    max-width: var(--max-width-narrow);
    margin: var(--space-8) auto;
    padding: var(--space-6);
    background: var(--paperDeep);
    border: 1px solid var(--rule);
  }
  .accom-planning__block + .accom-planning__block { margin-top: var(--space-5); }
  .accom-planning__block h2 {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 500;
    color: var(--ink);
    margin: 0 0 0.5rem;
  }
  .accom-planning__block p {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--inkSoft);
    margin: 0;
  }
</style>
