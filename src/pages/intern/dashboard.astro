---
// LAT-1019 — Tractie-mini-dashboard
// Static page, client-side fetch. Protected by nginx basic-auth at location /intern/.
// Goal: Strategy meet 50 daily organic / 5 affiliate clicks / 2 fotograaf-yes vóór 2026-06-15.

import SiteLayout from '../../layouts/SiteLayout.astro';

// SEO-baseline gets baked in from LAT-1025 (SEO Specialist). Updated weekly until live.
// TODO(2026-05-31): replace placeholder met getal van SEO Specialist.
const ORGANIC_BASELINE_VISITS_PER_DAY: number | null = null;
const ORGANIC_BASELINE_SOURCE = 'Google Search Console — vinomartino.com (7-day avg)';
const ORGANIC_BASELINE_AS_OF: string | null = null;

const FOTOGRAAF_YES = 0;
const FOTOGRAAF_TARGET = 2;
const FOTOGRAAF_AS_OF = '2026-05-29';

const TRACTIE_DEADLINE = '2026-06-15';
const ORGANIC_TARGET = 50;
const CLICKS_TARGET = 5;
---

<SiteLayout title="Tractie-dashboard — intern" noindex>
  <section class="dashboard">
    <header class="dashboard-header">
      <p class="kicker">VinoMartino · intern · niet voor publicatie</p>
      <h1>Tractie-dashboard</h1>
      <p class="lead">
        Hard-tractie-criterium: <strong>{ORGANIC_TARGET} daily organic visits</strong> · <strong>{CLICKS_TARGET} affiliate clicks/dag</strong> · <strong>{FOTOGRAAF_TARGET} fotograaf-yes'en</strong>
        op <strong>{TRACTIE_DEADLINE}</strong>. Bron: <a href="/LAT/issues/LAT-1018#comment-43de9092-741e-48dc-ab12-c1a9efe34593">Strategy review</a>.
      </p>
    </header>

    <div class="kpi-grid">
      <!-- KPI 1: Organic visits -->
      <article class="kpi">
        <p class="kpi-label">Organic visits / dag (7d avg)</p>
        <p class="kpi-value" id="kpi-organic">
          {ORGANIC_BASELINE_VISITS_PER_DAY !== null ? ORGANIC_BASELINE_VISITS_PER_DAY : '—'}
        </p>
        <p class="kpi-target">Target: {ORGANIC_TARGET}/dag op {TRACTIE_DEADLINE}</p>
        <p class="kpi-meta">
          {ORGANIC_BASELINE_AS_OF ? `As of ${ORGANIC_BASELINE_AS_OF}` : 'Wacht op SEO Specialist (LAT-1025)'}
          <br /><span class="kpi-source">{ORGANIC_BASELINE_SOURCE}</span>
        </p>
      </article>

      <!-- KPI 2: Affiliate clicks -->
      <article class="kpi">
        <p class="kpi-label">Affiliate clicks (laatste 7d)</p>
        <p class="kpi-value" id="kpi-clicks" data-loading>—</p>
        <p class="kpi-target">Target: {CLICKS_TARGET}/dag = {CLICKS_TARGET * 7}/week op {TRACTIE_DEADLINE}</p>
        <p class="kpi-meta">
          Live uit Directus <code>affiliate_clicks</code>
          <br /><span class="kpi-source" id="kpi-clicks-asof"></span>
        </p>
      </article>

      <!-- KPI 3: Fotograaf-yes -->
      <article class="kpi">
        <p class="kpi-label">Fotograaf-yes'en</p>
        <p class="kpi-value">{FOTOGRAAF_YES}<span class="kpi-value-suffix">/{FOTOGRAAF_TARGET}</span></p>
        <p class="kpi-target">Target: {FOTOGRAAF_TARGET} op {TRACTIE_DEADLINE}</p>
        <p class="kpi-meta">As of {FOTOGRAAF_AS_OF} · handmatige update door Marketing &amp; Growth (LAT-1018)</p>
      </article>
    </div>

    <section class="detail">
      <h2>Affiliate clicks — breakdown laatste 7 dagen</h2>
      <div id="clicks-breakdown" data-loading><p class="muted">Laden…</p></div>
    </section>

    <section class="detail">
      <h2>Affiliate clicks — per partner (7d)</h2>
      <div id="clicks-per-partner" data-loading><p class="muted">Laden…</p></div>
    </section>

    <footer class="dashboard-footer">
      <p class="muted">
        Dashboard build: <span id="build-ts"></span> · bron: <a href="/LAT/issues/LAT-1019">LAT-1019</a> · counter:
        in-house (geen Plausible/Google Analytics) · DNT-aware.
      </p>
    </footer>
  </section>
</SiteLayout>

<script>
  // Client-side fetch into Directus aggregate. Endpoint set via build-time env or hardcoded.
  // DevOps levert read-only API token via secret_ref (LAT-1026). In tussentijd:
  // - Als window.__VM_DIRECTUS_READ_TOKEN globaal beschikbaar is, gebruik die.
  // - Anders: probeer /api/clicks/summary (zou nginx-proxy zijn naar geprefilterde Directus query).

  const SEVEN_DAYS_MS = 7 * 24 * 60 * 60 * 1000;
  const since = new Date(Date.now() - SEVEN_DAYS_MS).toISOString();

  type ClickRow = {
    partner?: string | null;
    placement?: string | null;
    clicked_at?: string | null;
  };

  function fmtDate(d: Date): string {
    return d.toISOString().slice(0, 10);
  }

  function bucketByDay(rows: ClickRow[]): Map<string, number> {
    const map = new Map<string, number>();
    for (let i = 6; i >= 0; i--) {
      const d = new Date(Date.now() - i * 24 * 60 * 60 * 1000);
      map.set(fmtDate(d), 0);
    }
    for (const r of rows) {
      if (!r.clicked_at) continue;
      const day = r.clicked_at.slice(0, 10);
      if (map.has(day)) map.set(day, (map.get(day) || 0) + 1);
    }
    return map;
  }

  function bucketByPartner(rows: ClickRow[]): Map<string, number> {
    const map = new Map<string, number>();
    for (const r of rows) {
      const key = r.partner || '(onbekend)';
      map.set(key, (map.get(key) || 0) + 1);
    }
    return map;
  }

  function renderError(targetId: string, msg: string): void {
    const el = document.getElementById(targetId);
    if (!el) return;
    el.removeAttribute('data-loading');
    el.innerHTML = `<p class="error">${msg}</p>`;
  }

  async function fetchClicks(): Promise<ClickRow[] | null> {
    // Endpoint contract (LAT-1026): nginx proxies /api/clicks/summary → Directus
    // `/items/affiliate_clicks?filter[clicked_at][_gte]=<since>&fields=partner,placement,clicked_at&limit=-1`
    const url = `/api/clicks/summary?since=${encodeURIComponent(since)}`;
    try {
      const res = await fetch(url, { headers: { Accept: 'application/json' } });
      if (!res.ok) {
        renderError('clicks-breakdown', `Dashboard kon clicks niet ophalen (HTTP ${res.status}). Endpoint nog niet live? Zie LAT-1026.`);
        renderError('clicks-per-partner', '');
        const k = document.getElementById('kpi-clicks');
        if (k) { k.textContent = '—'; k.removeAttribute('data-loading'); }
        return null;
      }
      const body = await res.json();
      // Directus returns { data: [...] }, our proxy may forward directly.
      const data = Array.isArray(body) ? body : Array.isArray(body?.data) ? body.data : [];
      return data as ClickRow[];
    } catch (e) {
      renderError('clicks-breakdown', `Network error: ${(e as Error).message}`);
      return null;
    }
  }

  async function render(): Promise<void> {
    const buildTs = document.getElementById('build-ts');
    if (buildTs) buildTs.textContent = new Date().toLocaleString('nl-NL');

    const rows = await fetchClicks();
    if (!rows) return;

    const totalClicks = rows.length;
    const kpi = document.getElementById('kpi-clicks');
    if (kpi) { kpi.textContent = String(totalClicks); kpi.removeAttribute('data-loading'); }
    const asof = document.getElementById('kpi-clicks-asof');
    if (asof) asof.textContent = `Last fetch ${new Date().toLocaleString('nl-NL')}`;

    // Per-day breakdown
    const byDay = bucketByDay(rows);
    const max = Math.max(1, ...Array.from(byDay.values()));
    const days = Array.from(byDay.entries()).map(([day, count]) => {
      const pct = Math.round((count / max) * 100);
      return `<li><span class="day-label">${day}</span><span class="day-bar"><span class="day-bar-fill" style="width:${pct}%"></span></span><span class="day-count">${count}</span></li>`;
    }).join('');
    const dayEl = document.getElementById('clicks-breakdown');
    if (dayEl) {
      dayEl.removeAttribute('data-loading');
      dayEl.innerHTML = `<ul class="day-list">${days}</ul>`;
    }

    // Per-partner breakdown
    const byPartner = Array.from(bucketByPartner(rows).entries()).sort((a, b) => b[1] - a[1]);
    const partnerEl = document.getElementById('clicks-per-partner');
    if (partnerEl) {
      partnerEl.removeAttribute('data-loading');
      if (byPartner.length === 0) {
        partnerEl.innerHTML = `<p class="muted">Nog geen clicks geregistreerd in de laatste 7 dagen.</p>`;
      } else {
        partnerEl.innerHTML = `<ul class="partner-list">${byPartner.map(([p, c]) => `<li><strong>${p}</strong><span>${c}</span></li>`).join('')}</ul>`;
      }
    }
  }

  render();
</script>

<style>
  .dashboard {
    max-width: 64rem;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
    font-family: var(--font-body);
    color: var(--ink);
  }
  .dashboard-header { margin-bottom: 2.5rem; }
  .kicker {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--burgundy);
    margin-bottom: 0.5rem;
  }
  .dashboard h1 {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2rem, 1.6rem + 1.5vw, 2.875rem);
    line-height: 1.1;
    margin-bottom: 1rem;
  }
  .lead {
    color: var(--inkSoft);
    font-size: 1rem;
    line-height: 1.6;
    max-width: 50rem;
  }
  .lead a { color: var(--burgundy); }

  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: 1.25rem;
    margin-bottom: 3rem;
  }
  .kpi {
    background: var(--paperDeep, #F0E6D0);
    border: 1px solid var(--ruleSoft, #E0D2B0);
    border-radius: 4px;
    padding: 1.5rem;
  }
  .kpi-label {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--inkFaint);
    margin-bottom: 0.5rem;
  }
  .kpi-value {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 3rem;
    line-height: 1;
    color: var(--ink);
    margin-bottom: 0.5rem;
  }
  .kpi-value[data-loading] { opacity: 0.4; }
  .kpi-value-suffix {
    font-size: 1.5rem;
    color: var(--inkFaint);
  }
  .kpi-target {
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--burgundy);
    margin-bottom: 0.75rem;
  }
  .kpi-meta {
    font-size: 0.75rem;
    color: var(--inkFaint);
    line-height: 1.5;
  }
  .kpi-source { color: var(--inkFaint); }

  .detail { margin-bottom: 2.5rem; }
  .detail h2 {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--ink);
    margin-bottom: 1rem;
  }

  .day-list, .partner-list { list-style: none; padding: 0; margin: 0; }
  .day-list li {
    display: grid;
    grid-template-columns: 6rem 1fr 3rem;
    gap: 0.75rem;
    align-items: center;
    padding: 0.375rem 0;
    border-bottom: 1px solid var(--ruleSoft, #E0D2B0);
    font-size: 0.875rem;
  }
  .day-label { font-family: var(--font-mono); color: var(--inkSoft); }
  .day-bar { background: var(--ruleSoft, #E0D2B0); height: 8px; border-radius: 2px; overflow: hidden; }
  .day-bar-fill { display: block; height: 100%; background: var(--burgundy); }
  .day-count { text-align: right; font-variant-numeric: tabular-nums; }

  .partner-list li {
    display: flex;
    justify-content: space-between;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--ruleSoft, #E0D2B0);
    font-size: 0.9375rem;
  }

  .muted { color: var(--inkFaint); font-size: 0.875rem; }
  .error { color: var(--burgundy); font-size: 0.875rem; }

  .dashboard-footer {
    margin-top: 4rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--ruleSoft, #E0D2B0);
  }
</style>
