---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { organizationSchema, breadcrumbSchema } from '../../lib/seo';

const schema = [
  organizationSchema(),
  breadcrumbSchema([
    { name: 'Home', url: '/en/' },
    { name: 'Working together', url: '/en/voor-accommodaties/' },
  ]),
];

const krijgt = [
  'An editorial mention in an article or regional guide, with photographs and terroir context',
  'A pin on our interactive regional maps',
  'Organic reach among an audience actively searching for this type of address',
];

const vragen = [
  'Accommodation for one or two nights, sometimes more depending on the trip',
  'The freedom to write honestly, even if something disappoints',
];

const nietDoen = [
  {
    h: 'No paid placements',
    d: 'Buying an article is not possible, not through any route.',
  },
  {
    h: 'No guaranteed positive reviews',
    d: 'We write what we experience.',
  },
  {
    h: 'No vague collaboration without transparency',
    d: 'Hosted visits are always disclosed as such.',
  },
];

const past = [
  'Boutique hotels and agriturismi in wine regions we actively cover',
  'Addresses with a direct connection to wine: their own vineyard, a partnership with local producers, a wine cellar that is part of the stay',
  'Places where the owner is the story',
];
---

<SiteLayout
  title="Working together — for accommodations, agriturismi and wine estates"
  description="VinoMartino is open to press stays and hosted visits. Editorial coverage for an audience actively looking for boutique accommodation in wine regions. No paid placements."
  schema={schema}
  locale="en"
  alternates={{ nl: '/voor-accommodaties/', en: '/en/voor-accommodaties/' }}
>
  <section class="hero">
    <div class="container container-narrow">
      <span class="kicker kicker-vine">Working together</span>
      <h1>For accommodations, agriturismi and <em>wine estates</em></h1>
      <p class="lede">
        VinoMartino is a travel blog for people who plan their travel calendar around wine. Our readers are 28 to 45 years
        old, have above-average incomes and actively seek out the right addresses in the wine regions we cover. They book
        boutique hotels and agriturismi, not chains. They buy wine from specialist shops. They plan their tastings
        weeks in advance.
      </p>
      <p class="lede lede-accent">We don't reach the largest numbers. We reach the right people.</p>
    </div>
  </section>

  <section class="intro">
    <div class="container container-narrow">
      <span class="kicker kicker-burgundy">§ Who we are</span>
      <p>
        Marijn travels 6 to 8 times a year to European wine regions: Piedmont, Tuscany, Etna, Priorat, Mosel, Wachau, and
        increasingly Georgia, Slovenia and Croatia. Always with a concrete agenda: visiting winemakers, getting to know
        regions, writing honest reports. The accommodations he describes, he describes because he genuinely stayed there —
        not because there was a payment involved.
      </p>
    </div>
  </section>

  <section class="offer">
    <div class="container container-narrow">
      <span class="kicker kicker-rust">Press stays and hosted visits</span>
      <h2>We are open to press stays and hosted visits</h2>
      <p>
        When we visit a region that fits our editorial calendar, we sometimes reach out to accommodations that match who
        we are.
      </p>
      <div class="offer-grid">
        <div class="offer-card">
          <h3>What you receive</h3>
          <ul>
            {krijgt.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <div class="offer-card">
          <h3>What we ask</h3>
          <ul>
            {vragen.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </div>
      <p>
        That last point is non-negotiable. Our readers trust us because we don't write for those who pay us. If we cannot
        describe your accommodation honestly, we won't write about you. That may sound strict, but it is also why a mention
        with us carries real weight.
      </p>
      <p>
        All hosted-visit content receives an explicit disclosure that it was a press stay. Transparency is not a footnote
        for us.
      </p>
    </div>
  </section>

  <section class="niet">
    <div class="container container-narrow">
      <span class="kicker kicker-burgundy">What we don't do</span>
      <ul class="niet-list">
        {nietDoen.map((n) => (
          <li>
            <h3>{n.h}</h3>
            <p>{n.d}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="past">
    <div class="container container-narrow">
      <span class="kicker kicker-vine">Is your accommodation a good fit?</span>
      <h2>We look for</h2>
      <ul class="past-list">
        {past.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <section class="contact">
    <div class="container container-narrow">
      <h2>Contact</h2>
      <p>
        Do you think your accommodation fits what Marijn describes? Send a brief email — location, season, and why you
        think it's a good match — to:
      </p>
      <p class="contact-mail"><a href="mailto:info@vinomartino.com">info@vinomartino.com</a></p>
      <p class="contact-sla">We aim to respond within five working days.</p>
    </div>
  </section>
</SiteLayout>

<style>
  .container { max-width: 1280px; margin: 0 auto; padding-inline: var(--gutter); }
  .container-narrow { max-width: 880px; }

  .kicker {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    display: inline-block;
    margin-bottom: 1rem;
  }
  .kicker-vine { color: var(--color-vine, #5C6B3F); }
  .kicker-burgundy { color: var(--color-primary); }
  .kicker-rust { color: var(--color-rust, #A14F2A); }

  .hero {
    padding: clamp(48px, 8vw, 80px) 0;
    border-bottom: 1px solid var(--color-rule, #C9B98F);
  }
  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4vw + 1rem, 4rem);
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin: 0;
  }
  .hero h1 em {
    color: var(--color-primary);
    font-style: italic;
  }
  .lede {
    font-family: var(--font-serif, var(--font-body));
    font-size: 1.1875rem;
    line-height: 1.6;
    color: var(--color-text-soft, var(--color-text));
    margin-top: 1.5rem;
    text-wrap: pretty;
  }
  .lede-accent {
    font-style: italic;
    color: var(--color-primary);
  }

  .intro,
  .offer,
  .niet,
  .past {
    padding: clamp(40px, 6vw, 64px) 0;
    border-bottom: 1px solid var(--color-rule, #C9B98F);
  }

  .intro p,
  .offer p,
  .past p {
    font-family: var(--font-serif, var(--font-body));
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-text);
    margin: 0 0 1.5rem;
  }
  .intro p:last-child,
  .offer p:last-child { margin-bottom: 0; }

  .offer h2,
  .past h2,
  .contact h2 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw + 1rem, 2.5rem);
    font-weight: 500;
    color: var(--color-text);
    margin: 0 0 1.5rem;
  }

  .offer-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin: 2rem 0;
  }
  .offer-card {
    background: var(--color-paper-deep, #F0E6D0);
    padding: 1.75rem;
    border: 1px solid var(--color-rule-soft, #E0D2B0);
  }
  .offer-card h3 {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 500;
    color: var(--color-primary);
    margin: 0 0 1rem;
  }
  .offer-card ul,
  .past-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .offer-card li,
  .past-list li {
    font-family: var(--font-serif, var(--font-body));
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text);
    padding-left: 1.25rem;
    position: relative;
    margin-bottom: 0.75rem;
  }
  .offer-card li:last-child,
  .past-list li:last-child { margin-bottom: 0; }
  .offer-card li::before,
  .past-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-primary);
  }

  .niet-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .niet-list li {
    padding: 1.25rem 0;
    border-top: 1px solid var(--color-rule-soft, #E0D2B0);
  }
  .niet-list h3 {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 500;
    color: var(--color-text);
    margin: 0 0 0.375rem;
  }
  .niet-list p {
    font-family: var(--font-serif, var(--font-body));
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--color-text-soft, var(--color-text));
    margin: 0;
  }

  .contact {
    padding: clamp(48px, 8vw, 80px) 0;
  }
  .contact p {
    font-family: var(--font-serif, var(--font-body));
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--color-text-soft, var(--color-text));
    margin: 0 0 1rem;
  }
  .contact-mail a {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-primary);
  }
  .contact-sla {
    font-size: 0.9375rem !important;
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .offer-grid { grid-template-columns: 1fr; }
  }
</style>
