---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { organizationSchema, breadcrumbSchema } from '../../lib/seo';
import { readDirectusEnv } from '../../lib/directus-config';

const schema = [
  organizationSchema(),
  breadcrumbSchema([
    { name: 'Home', url: '/en/' },
    { name: 'About us', url: '/en/over-ons/' },
  ]),
];

const rules = [
  {
    n: '01',
    h: 'What we visited, you\'ll see that',
    d: 'Guides based on first-hand visits carry the Been there label. In those pieces I write in the first person about what I tasted and saw. Editorial guides are carefully compiled using primary sources and local knowledge, but contain no eyewitness claims. The distinction is noted for every article.',
  },
  {
    n: '02',
    h: 'Affiliate links only for places I\'ve tested myself',
    d: 'If an article contains a booking link, I\'ve visited that place. We receive a commission on a booking; the price stays the same. Which wineries and accommodations qualify for a link is based on visit documentation, not on who asks for it.',
  },
  {
    n: '03',
    h: 'No advertorials, no paid content',
    d: 'Recommendations are independent of external funding. Affiliate income funds new visits and keeps VinoMartino going. It does not determine what I write.',
  },
];

const visited = [
  'Loire',
  'Burgundy',
  'Champagne',
  'Provence',
  'Mosel',
  'Piedmont',
  'Tuscany',
  'Cape Winelands',
  'Veneto',
  'Alto Adige',
  'Slovakia',
];

// LAT-1987: twee eigen foto's van Marijn uit de DAM, gekoppeld via Directus-bestanden.
// 694f2a29… = DAM ref 1240 (Calmont, Ediger); dfaff3d0… = DAM ref 816 (uitkijkpunt over het dal).
// At-buildtijd uit Directus /assets/{uuid} gehaald — geen beeldbytes in de repo (HARDE REGEL 2).
async function fetchOverOnsFoto(uuid: string): Promise<string | null> {
  const env = readDirectusEnv();
  if (!env.configured) return null; // lokaal/dev zonder Directus: beeld overslaan
  const { writeFileSync, mkdirSync, existsSync } = await import('node:fs');
  const { join } = await import('node:path');
  const outDir = join(process.cwd(), 'public', 'images', 'over-ons');
  const outPath = join(outDir, `${uuid}.jpg`);
  const rel = `/images/over-ons/${uuid}.jpg`;
  if (existsSync(outPath)) return rel;
  const res = await fetch(`${env.url}/assets/${uuid}`, {
    headers: { Authorization: `Bearer ${env.token}` },
    signal: AbortSignal.timeout(15000),
  });
  if (!res.ok) {
    throw new Error(`[over-ons] Directus-asset ${uuid} niet op te halen: HTTP ${res.status}`);
  }
  mkdirSync(outDir, { recursive: true });
  writeFileSync(outPath, Buffer.from(await res.arrayBuffer()));
  return rel;
}

const fotoCalmont = await fetchOverOnsFoto('694f2a29-122b-479c-a2b0-1cd895a493de');
const fotoUitkijk = await fetchOverOnsFoto('dfaff3d0-675b-48db-acc8-893263eaf06d');
---

<SiteLayout
  title="About VinoMartino: Marijn & Sophie"
  description="Marijn (internationally known as Martino) writes about wine travel based on first-hand visits. Affiliate links only for places we've actually been. No advertorials."
  schema={schema}
  activeNav="over-ons"
  locale="en"
  alternates={{ nl: '/over-ons/', en: '/en/over-ons/' }}
>
  <section class="hero">
    <div class="hero-grid container">
      <div class="hero-text">
        <span class="kicker kicker-vine">About VinoMartino</span>
        <h1>Hi, I'm <em>Marijn</em></h1>
        <p class="lede">
          Among winemakers from Piedmont to the Cape, people quickly started calling me "Martino" — that nickname stuck. It even became the name of this site: VinoMartino. So internationally I'm Martino, at home just Marijn.
        </p>
        <p class="lede">
          I have a wine fridge that's always full and honestly never quite big enough.
          Several times a year I drive a compact Fiat through Piedmontese vineyard lanes — or Sicilian, or Portuguese, depending on the season.
          I keep discovering new wine regions and write down what I find.
        </p>
        <p class="lede">
          We're not pure wine experts or professionals. We're wine enthusiasts with a passion we love sharing, so you can discover the same journeys and regions yourself.
        </p>
      </div>
      <div class="hero-image">
        <img src="/over-ons-hero.jpg" alt="Marijn tasting a glass of wine with the vineyards of Stellenbosch in the background" width="800" height="1000" loading="eager" decoding="async" />
      </div>
    </div>
  </section>

  <section class="intro">
    <div class="container container-narrow">
      <p>
        VinoMartino started as a notebook. After every trip I collected notes: the winemaker who let us taste through his cellar on a Wednesday afternoon, the agriturismo with three bars of mobile signal where I still slept brilliantly, the Carricante I only understood once I was home. At some point the notebook was full enough to be useful to others planning the same journeys. That's this.
      </p>
      <p>
        Sophie sometimes comes along and only reads all of this once it's online.
      </p>
      <p>
        Some pieces go deeper than others — that depends on the trip and what caught my attention. I share experiences and try to give people enough information to plan their own great journeys. If you have something to share that helps others, there is an option to publish a contribution on the site.
      </p>
      <p>
        And even though wine is at the centre: most of these regions are worth visiting even without a single winery. The wine is the reason to go, not the only one.
      </p>
      <p>
        In time we want to broaden this: restaurants and other places that complete a journey will have a home here too.
      </p>
      {fotoCalmont && (
        <figure class="over-figure">
          <img
            src={fotoCalmont}
            alt="Marijn at the Calmont sign above the Mosel, with green hills and the river valley in the background"
            width="1500"
            height="2000"
            loading="lazy"
            decoding="async"
          />
          <figcaption>On the Calmont in Ediger, the steepest vineyard in Germany.</figcaption>
        </figure>
      )}
    </div>
  </section>

  <section class="rules">
    <div class="container container-narrow">
      <span class="kicker kicker-burgundy">§ How this works</span>
      <h2>Three rules</h2>
      <ol class="rules-list">
        {rules.map((r) => (
          <li>
            <span class="rule-num">{r.n}</span>
            <div>
              <h3>{r.h}</h3>
              <p>{r.d}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="visited">
    <div class="container">
      <span class="kicker kicker-rust">Visited regions</span>
      <h2>{visited.length}+ regions since 2019</h2>
      <div class="visited-list">
        {visited.map((v) => (
          <span class="visited-item">{v}</span>
        ))}
        <span class="visited-more">… and more</span>
      </div>
      {fotoUitkijk && (
        <figure class="over-figure">
          <img
            src={fotoUitkijk}
            alt="Marijn at a viewpoint looking out over a broad valley"
            width="2000"
            height="1500"
            loading="lazy"
            decoding="async"
          />
          <figcaption>Taking in the view across the valley, on the way to the next wine region.</figcaption>
        </figure>
      )}
    </div>
  </section>

  <section class="contact">
    <div class="container container-narrow">
      <h2>Contact</h2>
      <p>
        Questions, tips, or a winery we really should visit?<br />
        <a href="mailto:contact@vinomartino.com">contact@vinomartino.com</a>
      </p>
    </div>
  </section>
</SiteLayout>

<style>
  .container { max-width: 1280px; margin: 0 auto; padding-inline: var(--gutter); }
  .container-narrow { max-width: 880px; }

  .kicker {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    display: inline-block;
    margin-bottom: 1rem;
  }
  .kicker-vine { color: var(--color-vine, #5C6B3F); }
  .kicker-burgundy { color: var(--color-primary); }
  .kicker-rust { color: var(--color-rust, #A14F2A); }

  .hero {
    padding: clamp(48px, 8vw, 80px) 0;
    border-bottom: 1px solid var(--color-rule, #C9B98F);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .hero-text h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw + 1rem, 5rem);
    font-weight: 500;
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin: 0;
  }
  .hero-text h1 em {
    color: var(--color-primary);
    font-style: italic;
  }
  .lede {
    font-family: var(--font-serif, var(--font-body));
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--color-text-soft, var(--color-text));
    margin-top: 1.5rem;
    font-style: italic;
    text-wrap: pretty;
  }
  .hero-image {
    aspect-ratio: 4 / 5;
    background: var(--color-paper-shade, #E8DCC0);
    background-image: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 12px,
      rgba(0, 0, 0, 0.04) 12px,
      rgba(0, 0, 0, 0.04) 13px
    );
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .placeholder-tag {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-soft, var(--color-text));
    background: var(--color-bg);
    padding: 0.5rem 1rem;
  }

  .intro {
    padding: clamp(40px, 6vw, 64px) 0;
    border-bottom: 1px solid var(--color-rule, #C9B98F);
  }
  .intro p {
    font-family: var(--font-serif, var(--font-body));
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-text);
    margin: 0 0 1.5rem;
  }
  .intro p:last-child { margin-bottom: 0; }

  .over-figure {
    margin: 2.5rem 0 0;
  }
  .over-figure img {
    width: 100%;
    height: auto;
    display: block;
    border: 1px solid var(--color-rule, #C9B98F);
  }
  .over-figure figcaption {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: var(--color-text-soft, var(--color-text));
    margin-top: 0.6rem;
    font-style: italic;
  }
  .intro .over-figure {
    max-width: 460px;
    margin-inline: auto;
  }
  .visited .over-figure {
    margin-top: 2rem;
  }

  .rules {
    padding: clamp(48px, 8vw, 80px) 0;
    border-bottom: 1px solid var(--color-rule, #C9B98F);
  }
  .rules h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3vw + 1rem, 2.75rem);
    font-weight: 500;
    color: var(--color-text);
    margin: 0 0 2rem;
  }
  .rules-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .rules-list li {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-top: 1px solid var(--color-rule-soft, #E0D2B0);
  }
  .rule-num {
    font-family: var(--font-display);
    font-size: 3rem;
    font-style: italic;
    color: var(--color-primary);
    line-height: 1;
  }
  .rules-list h3 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 500;
    color: var(--color-text);
    margin: 0 0 0.5rem;
  }
  .rules-list p {
    font-family: var(--font-serif, var(--font-body));
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--color-text-soft, var(--color-text));
    margin: 0;
  }

  .visited {
    padding: clamp(48px, 7vw, 72px) 0;
    background: var(--color-paper-deep, #F0E6D0);
  }
  .visited h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3vw + 1rem, 2.75rem);
    font-weight: 500;
    color: var(--color-text);
    margin: 0 0 2rem;
  }
  .visited-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
  }
  .visited-item,
  .visited-more {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 500;
    color: var(--color-text);
  }
  .visited-more {
    font-style: italic;
    opacity: 0.6;
  }

  .contact {
    padding: clamp(48px, 8vw, 80px) 0;
  }
  .contact h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3vw + 1rem, 2.75rem);
    font-weight: 500;
    color: var(--color-text);
    margin: 0 0 1rem;
  }
  .contact p {
    font-family: var(--font-serif, var(--font-body));
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--color-text-soft, var(--color-text));
  }
  .contact a { color: var(--color-primary); }

  @media (max-width: 768px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .rules-list li {
      grid-template-columns: 60px 1fr;
      gap: 1rem;
    }
    .rule-num { font-size: 2.25rem; }
  }
</style>
