---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { breadcrumbSchema } from '../../lib/seo';

const datum = "5 June 2026";

const schema = [
  breadcrumbSchema([
    { name: 'Home', url: '/en/' },
    { name: 'Imprint', url: '/en/colofon/' },
  ]),
];
---

<SiteLayout
  locale="en"
  title="Imprint — VinoMartino"
  description="Publisher, editorial team and contact details for VinoMartino."
  schema={schema}
  alternates={{ nl: '/colofon/', en: '/en/colofon/' }}
>
  <section class="legal container">
    <article class="legal-body">
      <h1>Imprint</h1>
      <p class="update-datum"><em>Last updated: {datum}</em></p>

      <p>VinoMartino is an independent travel and wine platform writing about wine travel in Europe. This page provides the legal and editorial details of the publisher, intended for press, partners and readers who want to know who is behind the site.</p>

      <h2>Publisher</h2>
      <dl class="colofon-dl">
        <dt>Trade name</dt>
        <dd>VinoMartino</dd>

        <dt>Legal form</dt>
        <dd>Trade name registered in the Netherlands, registered as a sole trader in the Trade Register of the Netherlands Chamber of Commerce.</dd>

        <dt>Chamber of Commerce number</dt>
        <dd>50186213</dd>

        <dt>VAT identification number</dt>
        <dd>NL001551010B59</dd>

        <dt>Registered address</dt>
        <dd>Narva-eiland 176<br />1014 ZJ Amsterdam<br />The Netherlands</dd>

        <dt>Email</dt>
        <dd><a href="mailto:info@vinomartino.com">info@vinomartino.com</a></dd>

        <dt>Website</dt>
        <dd><a href="https://vinomartino.com">vinomartino.com</a></dd>

        <dt>Instagram</dt>
        <dd><a href="https://www.instagram.com/vinomartino.travel/" target="_blank" rel="me noopener" aria-label="VinoMartino on Instagram (@vinomartino.travel)">@vinomartino.travel</a></dd>
      </dl>

      <h2>Editorial</h2>
      <p>Marijn writes and travels for VinoMartino. VinoMartino publishes under editorial names. Every guide bearing the <em>Been there</em> label is based on an actual visit by our editorial team. More about who we are and how we work can be found on the <a href="/en/over-ons/">About us</a> page.</p>

      <h2>Press and partner enquiries</h2>
      <p>Press enquiries, partnership proposals or corrections: <a href="mailto:info@vinomartino.com">info@vinomartino.com</a>. We aim to respond within five working days.</p>

      <h2>Legal statements</h2>
      <ul>
        <li><a href="/en/privacy/">Privacy policy</a>: how we handle personal data.</li>
        <li><a href="/en/cookies/">Cookie statement</a>: which cookies we set and why.</li>
        <li><a href="/en/affiliate-verklaring/">Affiliate disclosure</a>: how we label partner links and who we work with.</li>
      </ul>

      <h2>Copyright</h2>
      <p>All texts, photographs and tasting notes on vinomartino.com are protected by copyright held by VinoMartino, unless otherwise stated. Reproduction of longer passages is permitted with attribution and a link to the original article. For commercial reuse, contact <a href="mailto:info@vinomartino.com">info@vinomartino.com</a>.</p>
    </article>
  </section>
</SiteLayout>

<style>
  .legal {
    padding: var(--space-16) 0;
  }
  .legal-body {
    max-width: 44rem;
    margin: 0 auto;
    font-family: var(--font-body);
    color: var(--ink);
  }
  .legal-body h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.6rem + 1.5vw, 2.875rem);
    font-style: italic;
    font-weight: 400;
    color: var(--ink);
    margin-bottom: var(--space-2);
    line-height: 1.15;
  }
  .legal-body h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-style: italic;
    font-weight: 400;
    color: var(--ink);
    margin: var(--space-10) 0 var(--space-3);
  }
  .legal-body p,
  .legal-body ul {
    font-size: 1rem;
    color: var(--inkSoft);
    line-height: 1.7;
    margin-bottom: var(--space-5);
  }
  .legal-body ul {
    padding-left: 1.5rem;
  }
  .legal-body li {
    margin-bottom: var(--space-2);
  }
  .legal-body a {
    color: var(--burgundy);
  }
  .legal-body a:hover {
    color: var(--burgundyDeep);
  }
  .legal-body strong {
    color: var(--ink);
  }
  .update-datum {
    color: var(--inkFaint);
    font-size: 0.875rem;
    margin-bottom: var(--space-6);
  }
  .colofon-dl {
    display: grid;
    grid-template-columns: 12rem 1fr;
    gap: var(--space-3) var(--space-6);
    margin: var(--space-6) 0 var(--space-8);
    font-size: 1rem;
    color: var(--inkSoft);
  }
  .colofon-dl dt {
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink);
    font-weight: 600;
  }
  .colofon-dl dd {
    margin: 0;
    line-height: 1.6;
  }
  .colofon-dl dd em {
    color: var(--inkFaint);
    font-style: italic;
  }
  @media (max-width: 640px) {
    .colofon-dl {
      grid-template-columns: 1fr;
      gap: var(--space-1) var(--space-3);
    }
    .colofon-dl dd {
      margin-bottom: var(--space-3);
    }
  }
</style>
