---
import BrandLayout from './BrandLayout.astro';
import type { Brand } from '../lib/brands';

interface TocEntry {
  id: string;
  label: string;
  level?: 2 | 3;
}

interface Props {
  brand: Brand;
  locale: string;
  title: string;
  description?: string;
  pillar?: string;
  author?: string;
  pubDate?: string;
  heroImage?: string;
  readTime?: number;
  toc?: TocEntry[];
  canonicalUrl?: string;
  ogImage?: string;
}

const {
  brand,
  locale,
  title,
  description,
  pillar,
  author = 'Martin',
  pubDate,
  heroImage,
  readTime,
  toc = [],
  canonicalUrl,
  ogImage,
} = Astro.props;

const dateStr = pubDate
  ? new Date(pubDate).toLocaleDateString('nl-NL', { day: 'numeric', month: 'long', year: 'numeric' })
  : null;
---

<BrandLayout
  brand={brand}
  locale={locale}
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage || heroImage}
>
  <!-- Reading progress bar -->
  <div class="reading-progress" id="reading-progress" aria-hidden="true">
    <div class="reading-progress-bar" id="reading-progress-bar"></div>
  </div>

  <!-- Article header — centered, editorial -->
  <section class="article-header-section">
    <div class="article-header-inner">
      {/* Kicker / meta strip */}
      <div class="article-meta-strip">
        {pillar && <span class="article-pillar">{pillar}</span>}
        {dateStr && <><span class="meta-sep" aria-hidden="true">·</span><time datetime={pubDate}>{dateStr}</time></>}
        {readTime && <><span class="meta-sep" aria-hidden="true">·</span><span>{readTime}&thinsp;min lezen</span></>}
      </div>

      <h1 id="article-title">{title}</h1>

      {description && (
        <p class="article-lede">{description}</p>
      )}

      <div class="article-byline">
        <div class="byline-avatar" aria-hidden="true">{author[0]}</div>
        <div>
          <div class="byline-name">Door {author}</div>
          {dateStr && <div class="byline-date"><time datetime={pubDate}>{dateStr}</time></div>}
        </div>
      </div>
    </div>
  </section>

  <!-- Hero image — full-width 21/9 -->
  {heroImage && (
    <div class="article-hero">
      <img src={heroImage} alt={title} loading="eager" fetchpriority="high" />
    </div>
  )}

  <!-- 3-col grid -->
  <div class="article-grid container">
    <!-- Left: Sticky TOC -->
    <aside class="article-toc" aria-label="Inhoudsopgave">
      {toc.length > 0 && (
        <div class="toc-inner" id="toc-inner">
          <button class="toc-label" aria-expanded="true">
            In dit artikel
            <svg class="toc-chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
              <path d="M2 3.5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </button>
          <nav aria-label="Inhoudsopgave">
            <ol class="toc-list" role="list">
              {toc.map((entry, i) => (
                <li class={`toc-item ${entry.level === 3 ? 'toc-item--sub' : ''}`}>
                  <a href={`#${entry.id}`} class="toc-link">
                    <span class="toc-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
                    {entry.label}
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        </div>
      )}
    </aside>

    <!-- Center: Article body -->
    <article class="article-body" aria-labelledby="article-title">
      <div class="article-content">
        <slot />
      </div>
    </article>

    <!-- Right: Margin notes slot -->
    <aside class="article-aside" aria-label="Marge-noten">
      <slot name="aside" />
    </aside>
  </div>
</BrandLayout>

<style>
  /* ── Reading progress ────────────────────────────── */
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    z-index: 200;
    background: transparent;
  }

  .reading-progress-bar {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--burgundy), var(--rule));
    transition: width 100ms linear;
  }

  /* ── Article header section ──────────────────────── */
  .article-header-section {
    background: var(--paper);
    border-bottom: 1px solid var(--rule);
    padding: 56px 0 40px;
  }

  .article-header-inner {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 var(--gutter);
    text-align: center;
  }

  .article-meta-strip {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--inkSoft);
    margin-bottom: 20px;
  }

  .article-pillar {
    color: var(--rust);
  }

  .meta-sep { opacity: 0.4; }

  .article-header-section h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 2rem + 2.5vw, 4.5rem);
    font-weight: 500;
    line-height: 0.98;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0 0 24px;
    text-wrap: balance;
  }

  .article-lede {
    font-family: var(--font-body);
    font-size: 1.375rem;
    line-height: 1.45;
    font-style: italic;
    color: var(--inkSoft);
    margin: 0 0 28px;
    text-wrap: pretty;
  }

  .article-byline {
    display: inline-flex;
    align-items: center;
    gap: 16px;
    padding-top: 20px;
    border-top: 1px solid var(--rule);
  }

  .byline-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--paperShade);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--burgundy);
    font-weight: 600;
    flex-shrink: 0;
  }

  .byline-name {
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--ink);
    text-align: left;
  }

  .byline-date {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--inkFaint);
    margin-top: 2px;
    text-align: left;
  }

  /* ── Hero image ──────────────────────────────────── */
  .article-hero {
    width: 100%;
    aspect-ratio: 21/9;
    overflow: hidden;
  }

  .article-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── 3-col grid ──────────────────────────────────── */
  .article-grid {
    display: grid;
    grid-template-columns: 220px 1fr 220px;
    grid-template-areas: 'toc body aside';
    gap: var(--space-12);
    align-items: start;
    padding-top: var(--space-12);
    padding-bottom: var(--space-24);
  }

  /* ── TOC ─────────────────────────────────────────── */
  .article-toc {
    grid-area: toc;
    position: sticky;
    top: 24px;
  }

  .toc-inner {
    border: 1px solid var(--ruleSoft);
    background: var(--paperDeep);
    overflow: hidden;
  }

  .toc-label {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--burgundy);
    background: none;
    border: none;
    border-bottom: 1px solid var(--ruleSoft);
    cursor: pointer;
    transition: color var(--duration-fast) var(--ease-out);
  }
  .toc-label:hover { color: var(--burgundyDeep); }

  .toc-chevron {
    transition: transform var(--duration-fast) var(--ease-out);
    flex-shrink: 0;
  }
  .toc-inner[data-collapsed] .toc-chevron { transform: rotate(-90deg); }

  .toc-list {
    list-style: none;
    padding: var(--space-3) var(--space-2) var(--space-3);
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    counter-reset: toc;
  }

  .toc-inner[data-collapsed] .toc-list { display: none; }

  .toc-item { padding: 0; }
  .toc-item--sub .toc-link { padding-left: var(--space-8); font-size: 0.75rem; }

  .toc-link {
    display: flex;
    align-items: baseline;
    gap: 8px;
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    color: var(--inkSoft);
    text-decoration: none;
    padding: var(--space-2) var(--space-3);
    line-height: 1.4;
    transition:
      color var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out);
    border-left: 2px solid transparent;
  }
  .toc-link:hover { color: var(--burgundy); background: var(--burgundy-10); }
  .toc-link.active {
    color: var(--burgundy);
    border-left-color: var(--burgundy);
    background: var(--burgundy-10);
    font-weight: 600;
  }
  .toc-link.active .toc-num { color: var(--burgundy); }

  .toc-num {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--inkFaint);
    flex-shrink: 0;
    padding-top: 1px;
  }

  /* ── Article body ────────────────────────────────── */
  .article-body {
    grid-area: body;
    min-width: 0;
    max-width: 640px;
    margin: 0 auto;
    width: 100%;
  }

  /* ── Article prose ───────────────────────────────── */
  .article-content :global(p) {
    font-family: var(--font-body);
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--ink);
    margin-bottom: var(--space-5);
    font-weight: 300;
    text-wrap: pretty;
  }

  .article-content :global(.drop-cap::first-letter),
  .article-content :global(p:first-of-type.lead::first-letter) {
    float: left;
    font-family: var(--font-display);
    font-size: 5.25rem;
    line-height: 0.85;
    font-weight: 500;
    color: var(--burgundy);
    margin-right: 12px;
    margin-top: 6px;
    margin-bottom: -6px;
  }

  /* Section label before h2 */
  .article-content :global(.section-label) {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--burgundy);
    margin-top: var(--space-12);
    margin-bottom: 12px;
  }

  .article-content :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(1.625rem, 1.3rem + 1vw, 2.375rem);
    font-style: normal;
    font-weight: 500;
    color: var(--ink);
    margin-top: var(--space-10);
    margin-bottom: var(--space-5);
    line-height: 1.05;
    letter-spacing: -0.015em;
  }

  .article-content :global(h3) {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-style: normal;
    font-weight: 500;
    color: var(--ink);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
    line-height: 1.2;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--inkSoft);
    padding-left: var(--space-6);
    margin-bottom: var(--space-5);
    font-weight: 300;
  }

  .article-content :global(li) { margin-bottom: var(--space-2); }

  .article-content :global(blockquote) {
    border-left: 3px solid var(--burgundy);
    padding: var(--space-5) var(--space-8);
    margin: var(--space-10) 0;
    background: var(--paperDeep);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }

  .article-content :global(blockquote p) {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-style: italic;
    color: var(--ink);
    margin-bottom: 0;
    line-height: 1.3;
    font-weight: 400;
  }

  .article-content :global(blockquote footer) {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--inkSoft);
    margin-top: 16px;
    font-style: normal;
    letter-spacing: 0.05em;
  }

  .article-content :global(figure) {
    margin: 32px -64px;
  }

  .article-content :global(figure img) {
    width: 100%;
    height: auto;
  }

  .article-content :global(figcaption) {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--inkFaint);
    margin-top: 10px;
    padding-left: 64px;
  }

  .article-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--paperDeep);
    padding: 0.15em 0.45em;
    border-radius: var(--radius-sm);
    color: var(--rust);
    border: 1px solid var(--ruleSoft);
  }

  .article-content :global(strong) {
    font-weight: 600;
    color: var(--ink);
  }

  .article-content :global(a) {
    color: var(--burgundy);
    text-decoration: underline;
    text-decoration-color: var(--burgundy-20);
    text-underline-offset: 3px;
    transition: text-decoration-color var(--duration-fast);
  }
  .article-content :global(a:hover) {
    text-decoration-color: var(--burgundy);
  }

  /* Section divider (· · ·) */
  .article-content :global(.section-sep) {
    text-align: center;
    margin: 48px 0;
    font-family: var(--font-display);
    font-size: 2rem;
    font-style: italic;
    color: var(--rule);
    letter-spacing: 0.4em;
  }

  /* Tasting note card */
  .article-content :global(.tasting-note) {
    border: 1px solid var(--rule);
    background: var(--paper);
    margin: 40px 0;
  }

  .article-content :global(.tasting-note-header) {
    padding: 14px 20px;
    background: var(--burgundy);
    color: var(--paper);
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    display: flex;
    justify-content: space-between;
  }

  .article-content :global(.tasting-note-body) {
    padding: 24px;
  }

  /* Practical info box */
  .article-content :global(.practical-info) {
    background: var(--paperDeep);
    border: 1px solid var(--ruleSoft);
    border-left: 3px solid var(--vine);
    padding: var(--space-6) 1.75rem;
    margin: var(--space-8) 0;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }

  .article-content :global(.practical-info h3) {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--vine);
    margin-top: 0;
    margin-bottom: var(--space-4);
    font-style: normal;
  }

  /* ── Aside (margin notes) ────────────────────────── */
  .article-aside {
    grid-area: aside;
    position: sticky;
    top: 24px;
    min-width: 0;
  }

  .article-aside :global(.margin-note) {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    line-height: 1.55;
    color: var(--inkSoft);
    font-style: italic;
    padding-left: var(--space-4);
    border-left: 1px solid var(--ruleSoft);
    margin-bottom: var(--space-6);
    font-weight: 300;
  }

  .article-aside :global(.margin-note .mn-label) {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--burgundy);
    display: block;
    margin-bottom: 6px;
    border-left: none;
    padding-left: 0;
  }

  /* ── Responsive ──────────────────────────────────── */
  @media (max-width: 1200px) {
    .article-grid {
      grid-template-columns: 220px 1fr;
      grid-template-areas:
        'toc body'
        '. body';
    }
    .article-aside { display: none; }
  }

  @media (max-width: 768px) {
    .article-grid {
      grid-template-columns: 1fr;
      grid-template-areas:
        'toc'
        'body';
      gap: var(--space-8);
      padding-top: var(--space-6);
    }

    .article-toc {
      position: static;
      border-bottom: 1px solid var(--ruleSoft);
      padding-bottom: var(--space-6);
    }

    .article-header-section { padding: 40px 0 32px; }
    .article-hero { aspect-ratio: 16/9; }
    .article-content :global(figure) { margin: 24px 0; }
    .article-content :global(figcaption) { padding-left: 0; }
  }

  @media (max-width: 540px) {
    .article-header-section h1 { font-size: clamp(2rem, 1.6rem + 2.5vw, 3rem); }
    .article-lede { font-size: 1.125rem; }
    .article-content :global(blockquote p) { font-size: 1.375rem; }
  }
</style>

<script>
  // Reading progress bar
  const bar = document.getElementById('reading-progress-bar');
  const article = document.querySelector('.article-body');
  if (bar && article) {
    window.addEventListener('scroll', () => {
      const rect = article.getBoundingClientRect();
      const articleHeight = (article as HTMLElement).offsetHeight;
      const scrolled = Math.max(0, -rect.top);
      const pct = Math.min(100, (scrolled / articleHeight) * 100);
      bar.style.width = `${pct}%`;
    }, { passive: true });
  }

  // TOC active-link highlight via Intersection Observer
  const headings = document.querySelectorAll<HTMLElement>('.article-content h2[id], .article-content h3[id]');
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-link');

  if (headings.length && tocLinks.length) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            tocLinks.forEach((link) => link.classList.remove('active'));
            const active = document.querySelector<HTMLAnchorElement>(`.toc-link[href="#${entry.target.id}"]`);
            active?.classList.add('active');
          }
        });
      },
      { rootMargin: '0px 0px -65% 0px', threshold: 0 }
    );
    headings.forEach((h) => observer.observe(h));
  }

  // TOC collapse toggle
  const tocInner = document.getElementById('toc-inner');
  const tocLabel = tocInner?.querySelector('.toc-label');
  tocLabel?.addEventListener('click', () => {
    const collapsed = tocInner?.hasAttribute('data-collapsed');
    collapsed ? tocInner?.removeAttribute('data-collapsed') : tocInner?.setAttribute('data-collapsed', '');
    tocLabel.setAttribute('aria-expanded', collapsed ? 'true' : 'false');
  });
</script>
