---
interface Props {
  title: string;
}

const { title } = Astro.props;

const personas = [
  { name: 'Backpacker', slug: 'backpacker', emoji: '\u{1F392}' },
  { name: 'Flashpacker', slug: 'flashpacker', emoji: '\u{1F9F3}' },
  { name: 'Family Traveler', slug: 'family', emoji: '\u{1F46A}' },
  { name: 'Luxury & Slow Travel', slug: 'luxury', emoji: '\u{2728}' },
  { name: 'Digital Nomad', slug: 'digital-nomad', emoji: '\u{1F4BB}' },
  { name: 'Culture & Food', slug: 'culture-food', emoji: '\u{1F37D}\u{FE0F}' },
];
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        color: #1a1a2e;
        background: #fafafa;
        line-height: 1.6;
      }
      header {
        background: #1a1a2e;
        color: #fff;
        padding: 1rem 2rem;
      }
      .header-inner {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
      }
      .brand {
        font-size: 1.5rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        text-decoration: none;
        color: #fff;
      }
      nav { display: flex; gap: 0.25rem; flex-wrap: wrap; }
      nav a {
        color: #ccc;
        text-decoration: none;
        padding: 0.35rem 0.75rem;
        border-radius: 4px;
        font-size: 0.85rem;
        transition: background 0.15s, color 0.15s;
      }
      nav a:hover { background: #2d2d4e; color: #fff; }
      main {
        max-width: 1200px;
        margin: 2rem auto;
        padding: 0 2rem;
      }
      footer {
        text-align: center;
        padding: 2rem;
        color: #888;
        font-size: 0.85rem;
        border-top: 1px solid #eee;
        margin-top: 4rem;
      }
    </style>
  </head>
  <body>
    <header>
      <div class="header-inner">
        <a href="/" class="brand">Reisplatform</a>
        <nav>
          {personas.map((p) => (
            <a href={`#${p.slug}`}>{p.emoji} {p.name}</a>
          ))}
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>Dev Preview &mdash; Reisplatform &copy; 2026</p>
    </footer>
  </body>
</html>
