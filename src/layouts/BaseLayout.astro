---
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        color: #2A2622;
        background: #fafafa;
        line-height: 1.6;
      }
      header {
        background: #5E1A1D;
        color: #fff;
        padding: 1rem 2rem;
      }
      .header-inner {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
      }
      .brand {
        font-size: 1.5rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        text-decoration: none;
        color: #fff;
      }
      nav { display: flex; gap: 0.25rem; flex-wrap: wrap; }
      nav a {
        color: #E8DCC4;
        text-decoration: none;
        padding: 0.35rem 0.75rem;
        border-radius: 4px;
        font-size: 0.85rem;
        transition: background 0.15s, color 0.15s;
      }
      nav a:hover { background: rgba(255,255,255,0.15); color: #fff; }
      main {
        max-width: 1200px;
        margin: 2rem auto;
        padding: 0 2rem;
      }
      footer {
        text-align: center;
        padding: 2rem;
        color: #888;
        font-size: 0.85rem;
        border-top: 1px solid #eee;
        margin-top: 4rem;
      }
    </style>
  </head>
  <body>
    <header>
      <div class="header-inner">
        <a href="/" class="brand">VinoMartino</a>
        <nav>
          <a href="/artikelen/">Artikelen</a>
          <a href="/over-ons/">Over ons</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>&copy; {year} VinoMartino. Alle rechten voorbehouden.</p>
    </footer>
  </body>
</html>
