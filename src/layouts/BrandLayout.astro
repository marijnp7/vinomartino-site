---
import type { Brand } from '../lib/brands';
import BrandHeader from '../components/BrandHeader.astro';
import BrandFooter from '../components/BrandFooter.astro';

interface Props {
  brand: Brand;
  locale: string;
  title: string;
  description?: string;
  canonicalUrl?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const { brand, locale, title, description, canonicalUrl, schema } = Astro.props;
const pageTitle = title.includes(brand.name) ? title : `${title} — ${brand.name}`;
const canonical = canonicalUrl ?? new URL(Astro.url.pathname, Astro.site ?? 'https://vinomartino.com').href;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    {description && <meta name="description" content={description} />}
    <meta property="og:title" content={pageTitle} />
    <meta property="og:site_name" content={brand.name} />
    {description && <meta property="og:description" content={description} />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" />
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(Array.isArray(schema) ? schema : [schema])} />
    )}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Inter:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <BrandHeader brand={brand} locale={locale} />
    <main>
      <slot />
    </main>
    <BrandFooter brand={brand} />
  </body>
</html>

<style is:global>
  :root {
    --burgundy: #5E1A1D;
    --burgundy-80: #7A2B2F;
    --burgundy-10: #F2E8E9;
    --ivory: #E8DCC4;
    --charcoal: #2A2622;
    --terracotta: #6E7F5E;
    --terracotta-80: #7E9070;
    --terracotta-10: #EBF1ED;
    --aged-gold: #8A7E74;
    --aged-gold-20: #D8CEB8;
    --warm-cream: #F0E6D2;
    --stone: #8A7E74;
    --stone-light: #A89E94;
    --deep-night: #1A1410;

    --color-bg: var(--ivory);
    --color-text: var(--charcoal);
    --color-text-secondary: var(--stone);
    --color-text-muted: var(--stone-light);
    --color-primary: var(--burgundy);
    --color-primary-hover: var(--burgundy-80);
    --color-accent: var(--terracotta);
    --color-border: var(--aged-gold-20);

    --font-display: 'Cormorant Garamond', 'EB Garamond', Georgia, serif;
    --font-heading: 'Cormorant Garamond', 'EB Garamond', Georgia, serif;
    --font-body: 'Inter', 'Helvetica Neue', Arial, sans-serif;
    --font-ui: 'Inter', system-ui, sans-serif;

    --max-width: 80rem;
    --gutter: 1.5rem;
    --space-2: 0.5rem;
    --space-3: 0.75rem;
    --space-4: 1rem;
    --space-5: 1.25rem;
    --space-6: 1.5rem;
    --space-8: 2rem;
    --space-10: 2.5rem;
    --space-12: 3rem;
    --space-16: 4rem;
    --space-24: 6rem;

    --radius-sm: 0.125rem;
    --shadow-md: 0 4px 12px rgba(44, 40, 37, 0.08);
    --shadow-card-hover: 0 8px 32px rgba(44, 40, 37, 0.12);
    --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
    --duration-fast: 150ms;
    --duration-image: 600ms;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: var(--font-body);
    color: var(--color-text);
    background: var(--color-bg);
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
  }

  img { max-width: 100%; height: auto; display: block; }

  a {
    color: var(--color-primary);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }
  a:hover { color: var(--color-primary-hover); }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding-inline: var(--gutter);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 0.9375rem;
    padding: 0.75rem 1.75rem;
    border-radius: var(--radius-sm);
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: all var(--duration-fast) var(--ease-out);
  }

  .btn-primary {
    background: var(--color-primary);
    color: var(--ivory);
  }
  .btn-primary:hover {
    background: var(--color-primary-hover);
    color: var(--ivory);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-primary);
    border: 1.5px solid var(--color-primary);
  }
  .btn-secondary:hover {
    background: var(--color-primary);
    color: var(--ivory);
  }

  .btn-ghost-light {
    background: rgba(255,255,255,0.15);
    color: var(--ivory);
    border: 1px solid rgba(255,255,255,0.3);
    backdrop-filter: blur(4px);
  }
  .btn-ghost-light:hover {
    background: rgba(255,255,255,0.25);
    color: white;
  }

  .section { padding: var(--space-16) 0; }
  .section-lg { padding: var(--space-24) 0; }

  .section-header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .section-label {
    display: block;
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: var(--space-3);
  }

  .section-header h2 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 1.6rem + 1.5vw, 2.5rem);
    font-weight: 700;
    color: var(--color-text);
  }

  .section-desc {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    max-width: 36rem;
    margin: var(--space-4) auto 0;
  }

  .card {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    overflow: hidden;
    transition: box-shadow var(--duration-fast) var(--ease-out), transform var(--duration-fast) var(--ease-out);
  }
  .card:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    :root { --gutter: 1rem; }
  }
</style>
