---
import type { Brand } from '../lib/brands';
import BrandHeader from '../components/BrandHeader.astro';
import BrandFooter from '../components/BrandFooter.astro';
import '../styles/tokens.css';

interface Props {
  brand: Brand;
  locale: string;
  title: string;
  description?: string;
  canonicalUrl?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const { brand, locale, title, description, canonicalUrl, schema } = Astro.props;
const pageTitle = title.includes(brand.name) ? title : `${title} — ${brand.name}`;
const canonical = canonicalUrl ?? new URL(Astro.url.pathname, Astro.site ?? 'https://vinomartino.com').href;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    {description && <meta name="description" content={description} />}
    <meta property="og:title" content={pageTitle} />
    <meta property="og:site_name" content={brand.name} />
    {description && <meta property="og:description" content={description} />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" />
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(Array.isArray(schema) ? schema : [schema])} />
    )}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <BrandHeader brand={brand} locale={locale} />
    <main>
      <slot />
    </main>
    <BrandFooter brand={brand} />
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: var(--font-body);
    color: var(--color-text);
    background: var(--color-bg);
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
  }

  img { max-width: 100%; height: auto; display: block; }

  a {
    color: var(--color-primary);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }
  a:hover { color: var(--color-primary-hover); }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding-inline: var(--gutter);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 0.9375rem;
    padding: 0.75rem 1.75rem;
    border-radius: var(--radius-sm);
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: all var(--duration-fast) var(--ease-out);
    letter-spacing: 0.01em;
  }

  .btn-primary {
    background: var(--color-primary);
    color: var(--paper);
  }
  .btn-primary:hover {
    background: var(--color-primary-hover);
    color: var(--paper);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-primary);
    border: 1.5px solid var(--color-primary);
  }
  .btn-secondary:hover {
    background: var(--color-primary);
    color: var(--paper);
  }

  .btn-ghost-light {
    background: rgba(250, 245, 233, 0.15);
    color: var(--paper);
    border: 1px solid rgba(250, 245, 233, 0.3);
    backdrop-filter: blur(4px);
  }
  .btn-ghost-light:hover {
    background: rgba(250, 245, 233, 0.25);
    color: white;
  }

  .section { padding: var(--space-16) 0; }
  .section-lg { padding: var(--space-24) 0; }

  .section-header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .section-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    margin-bottom: var(--space-3);
  }

  .section-header h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.6rem + 1.5vw, 2.75rem);
    font-weight: 400;
    font-style: italic;
    color: var(--color-text);
    line-height: 1.15;
  }

  .section-desc {
    font-family: var(--font-ui);
    font-size: 1rem;
    color: var(--color-text-secondary);
    max-width: 36rem;
    margin: var(--space-4) auto 0;
    line-height: 1.6;
  }

  .card {
    background: var(--paper);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-sm);
    overflow: hidden;
    transition: box-shadow var(--duration-fast) var(--ease-out), transform var(--duration-fast) var(--ease-out);
  }
  .card:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
  }
</style>
