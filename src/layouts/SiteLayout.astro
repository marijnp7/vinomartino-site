---
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SearchDialog from '../components/SearchDialog.astro';
import '../styles/tokens.css';

type OgType = 'website' | 'article' | 'profile' | 'place';

interface ArticleMeta {
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  section?: string;
  tags?: string[];
}

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  ogType?: OgType;
  article?: ArticleMeta;
  noindex?: boolean;
  schema?: Record<string, unknown> | Record<string, unknown>[];
  activeNav?: string;
}

const { title, description, canonicalUrl, ogImage, ogType, article, noindex, schema, activeNav } = Astro.props;

const SITE_ORIGIN = (Astro.site ?? new URL('https://vinomartino.com')).origin;
const pageTitle = title.includes('VinoMartino') ? title : `${title} | VinoMartino`;
const canonical = canonicalUrl ?? new URL(Astro.url.pathname, Astro.site ?? 'https://vinomartino.com').href;

function toAbsoluteUrl(value?: string | null): string | undefined {
  if (!value) return undefined;
  if (/^https?:\/\//i.test(value)) return value;
  if (value.startsWith('//')) return `https:${value}`;
  return new URL(value.startsWith('/') ? value : `/${value}`, Astro.site ?? 'https://vinomartino.com').href;
}

const ogImageUrl = toAbsoluteUrl(ogImage);
const resolvedOgType: OgType = ogType ?? (article ? 'article' : 'website');
const articleTags = article?.tags?.filter((tag): tag is string => Boolean(tag && tag.trim())) ?? [];
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    {description && <meta name="description" content={description} />}
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta property="og:title" content={pageTitle} />
    <meta property="og:site_name" content="VinoMartino" />
    <meta property="og:type" content={resolvedOgType} />
    <meta property="og:url" content={canonical} />
    {ogImageUrl && (
      <>
        <meta property="og:image" content={ogImageUrl} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:alt" content={pageTitle} />
      </>
    )}
    <meta property="og:locale" content="nl_NL" />
    {description && <meta property="og:description" content={description} />}
    {resolvedOgType === 'article' && article?.publishedTime && (
      <meta property="article:published_time" content={article.publishedTime} />
    )}
    {resolvedOgType === 'article' && article?.modifiedTime && (
      <meta property="article:modified_time" content={article.modifiedTime} />
    )}
    {resolvedOgType === 'article' && article?.author && (
      <meta property="article:author" content={article.author} />
    )}
    {resolvedOgType === 'article' && article?.section && (
      <meta property="article:section" content={article.section} />
    )}
    {resolvedOgType === 'article' && articleTags.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}
    <meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:site" content="@vinomartino" />
    <meta name="twitter:title" content={pageTitle} />
    {description && <meta name="twitter:description" content={description} />}
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
    {ogImageUrl && <meta name="twitter:image:alt" content={pageTitle} />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" type="image/png" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="mask-icon" href="/favicon.svg" color="#6b1f2b" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#6b1f2b" />
    <meta name="apple-mobile-web-app-title" content="VinoMartino" />
    <meta name="application-name" content="VinoMartino" />
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(Array.isArray(schema) ? schema : [schema])} />
    )}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600&family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,600;1,8..60,300;1,8..60,400&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('vm-theme');
          if (t === 'cellar') document.documentElement.setAttribute('data-theme', 'cellar');
        } catch (e) {}
      })();
    </script>
    <!-- Stay22 "Let Me Allez" affiliate loader (LAT-1126). LinkSwap auto-converteert
         bestaande hotel/activiteit-links naar Stay22-affiliate-links. AID: vinomartino. -->
    <script is:inline>
      (function (s, t, a, y, twenty, two) {
        s.Stay22 = s.Stay22 || {};
        s.Stay22.params = {
          lmaID: '6a22c22f543a519eadd2cd2e',
          nova: { ignoreElements: ['.affiliate-block__cta', '.acc-kaart__cta'] },
        };
        twenty = t.createElement(a);
        two = t.getElementsByTagName(a)[0];
        twenty.async = 1;
        twenty.src = y;
        two.parentNode.insertBefore(twenty, two);
      })(window, document, 'script', 'https://scripts.stay22.com/letmeallez.js');
    </script>
    <!-- Universele booking-guard (LAT-1369 → LAT-1400 → LAT-1729). LinkSwap herschrijft
         client-side de href van booking.com-links naar Stay22 (aid 818285 → 1607597) — dat
         kaapt onze directe CJ-conversie. De oude guard beschermde alléén a[data-cj-href]
         (gemarkeerde CTA's); elke andere booking.com-link (StreekKaart/CuratedStayMap-pins,
         controle-kaarten, losse links) lekte nog. LAT-1729 maakt de guard universeel: we
         stashen bij DOMContentLoaded de server-gerenderde href van ÉLKE a[href*="booking.com"]
         in data-vm-booking-href (vóór LinkSwap kan rewriten) en herstellen die met een
         MutationObserver + sweeps. data-cj-href blijft de canonieke bron waar aanwezig.
         LinkSwap kent geen per-element opt-out (nova.ignoreElements stuurt alleen de overlay,
         niet de rewrite); globale LinkSwap blijft aan voor niet-booking OTA-links elders. -->
    <script is:inline>
      (function () {
        function canonical(el) {
          return el.getAttribute('data-cj-href') || el.getAttribute('data-vm-booking-href');
        }
        function stash(el) {
          if (el.getAttribute('data-cj-href') || el.getAttribute('data-vm-booking-href')) return;
          var h = el.getAttribute('href') || '';
          if (h.indexOf('booking.com') !== -1) el.setAttribute('data-vm-booking-href', h);
        }
        function restore(el) {
          var cj = canonical(el);
          if (!cj) return;
          if (el.getAttribute('href') !== cj) el.setAttribute('href', cj);
          if (el.hasAttribute('onclick')) el.removeAttribute('onclick');
          if (el.hasAttribute('data-modified-href')) el.removeAttribute('data-modified-href');
          if (el.hasAttribute('data-s22url')) el.removeAttribute('data-s22url');
          if (el.getAttribute('target') !== '_blank') el.setAttribute('target', '_blank');
        }
        function sweep() {
          var bk = document.querySelectorAll('a[href*="booking.com"]');
          for (var i = 0; i < bk.length; i++) stash(bk[i]);
          var els = document.querySelectorAll('a[data-cj-href], a[data-vm-booking-href]');
          for (var j = 0; j < els.length; j++) restore(els[j]);
        }
        function start() {
          sweep();
          try {
            new MutationObserver(function (muts) {
              for (var i = 0; i < muts.length; i++) {
                var n = muts[i].target;
                if (n.nodeType !== 1 || !n.hasAttribute) continue;
                if (n.hasAttribute('data-cj-href') || n.hasAttribute('data-vm-booking-href')) {
                  restore(n);
                } else if (n.tagName === 'A') {
                  var h = n.getAttribute('href') || '';
                  if (h.indexOf('booking.com') !== -1) { stash(n); restore(n); }
                }
              }
            }).observe(document.body, { subtree: true, attributes: true, attributeFilter: ['href', 'onclick'] });
          } catch (e) {}
          window.addEventListener('load', sweep);
          setTimeout(sweep, 1500);
          setTimeout(sweep, 4000);
        }
        if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', start);
        else start();
      })();
    </script>
  </head>
  <body>
    <SiteHeader activeNav={activeNav} />
    <main>
      <slot />
    </main>
    <SiteFooter />
    <SearchDialog />
    <script>
      import { initAffiliateTracker } from '../lib/click-tracker';
      initAffiliateTracker();
    </script>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: var(--font-body);
    color: var(--color-text);
    background: var(--color-bg);
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
  img { max-width: 100%; height: auto; display: block; }
  a {
    color: var(--color-primary);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }
  a:hover { color: var(--color-primary-hover); }
  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding-inline: var(--gutter);
  }
  .section { padding: var(--space-16) 0; }
  .section-lg { padding: var(--space-24) 0; }
  .section-header {
    text-align: center;
    margin-bottom: var(--space-12);
  }
  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-accent);
    margin-bottom: var(--space-4);
  }
  .section-label::before, .section-label::after {
    content: '';
    display: block;
    width: 1.5rem;
    height: 1px;
    background: currentColor;
    opacity: 0.5;
  }
  .section-header h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.6rem + 1.5vw, 2.875rem);
    font-weight: 400;
    font-style: italic;
    color: var(--color-text);
    line-height: 1.12;
  }
  .section-desc {
    font-family: var(--font-ui);
    font-size: 1rem;
    color: var(--color-text-secondary);
    max-width: 36rem;
    margin: var(--space-4) auto 0;
    line-height: 1.65;
  }
  .card {
    background: var(--paper);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-sm);
    overflow: hidden;
    transition: box-shadow var(--duration-base) var(--ease-out),
                transform var(--duration-base) var(--ease-out);
  }
  .card:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
  }
  :focus-visible {
    outline: 2px solid var(--burgundy);
    outline-offset: 3px;
  }
</style>
